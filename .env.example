# Site
SITE_URL=https://skystates.us

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key

# Stripe webhook — required for reliable payment confirmation
# Dashboard: https://dashboard.stripe.com/webhooks
# Endpoint URL: https://skystates.us/api/payments/webhook
# Events: checkout.session.completed, checkout.session.async_payment_succeeded, checkout.session.async_payment_failed
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Admin session signing (change in production)
SESSION_SECRET=change_me_to_a_long_random_string

# Super admin account — synced on every container start
ADMIN_USERNAME=support@skystates.us
ADMIN_PASSWORD=your_secure_password

# Email — Hostinger (support@skystates.us)
# hPanel → Emails → Manage → Configuration settings
# DNS: hPanel → Emails → Manage → Domain settings → Connect Domain
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=support@skystates.us
SMTP_PASS=your_email_account_password
SMTP_FROM=Sky States <support@skystates.us>
SMTP_REPLY_TO=support@skystates.us
