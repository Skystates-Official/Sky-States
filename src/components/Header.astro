    <video id="trans-video-ds" src="/admin/Page_transition_Data_Science_AI_202606270237.mp4" preload="auto" muted playsinline></video>
    <video id="trans-video-cs" src="/admin/Cyber_Security_page_transition_1080p_202606270238.mp4" preload="auto" muted playsinline></video>
    <video id="trans-video-do" src="/admin/devops_loop_transi._202606270238.mp4" preload="auto" muted playsinline></video>
