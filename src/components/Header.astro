---
// src/components/Header.astro
---

<nav
  class="fixed inset-x-0 top-0 z-[1000000] border-b border-slate-200/80 bg-white/95 shadow-[0_4px_20px_rgba(0,0,0,0.02)] backdrop-blur-xl font-sans transition-colors"
  aria-label="Main"
  id="main-header"
>
  <!--
    KEY FIX: grid-cols-[auto,1fr,auto] instead of absolute-centered nav-links.
    Column 1 = logo (auto width), Column 2 = center links (1fr, takes only
    leftover space so it can NEVER overlap the CTAs), Column 3 = CTAs (auto).
    This is what removes the overlap bug from before, permanently.
  -->
  <div
    class="mx-auto grid h-16 max-w-7xl grid-cols-[auto_1fr_auto] items-center gap-1 pl-1 pr-4 sm:pl-2 sm:pr-6 lg:gap-3 lg:pl-3 lg:pr-10"
  >
    <!-- Brand / Logo: bigger, and hugging the left edge (minimal left padding above) -->
    <a
      class="flex flex-shrink-0 items-center"
      aria-label="Sky States home"
      href="/"
    >
      <div
        class="flex h-14 w-[210px] items-center justify-center overflow-hidden sm:h-16 sm:w-[250px] lg:h-16 lg:w-[340px]"
      >
        <img
          src="/assets/logo_main_skystates.svg"
          alt="Sky States Logo"
          class="h-14 w-auto max-h-14 object-contain"
        />
      </div>
    </a>

    <!-- Desktop Navigation Links (Centered inside its own grid column - can't overlap anything) -->
    <div
      class="hidden min-w-0 items-center justify-center gap-2 md:flex lg:gap-5"
      aria-label="Primary navigation"
    >
      <a href="/" class="nav-link">Home</a>
      <a href="/live-jobs" class="nav-link">Live Jobs</a>

      <!-- Programs Dropdown -->
      <div class="group relative">
        <button class="nav-link dropdown-trigger">
          Programs
          <span class="material-symbols-outlined dropdown-caret"
            >expand_more</span
          >
        </button>
        <div class="dropdown-menu left-[-1.5rem]">
          <div class="dropdown-header">
            <span>Explore Programs</span>
          </div>
          <div class="dropdown-content">
            <a
              href="/programs/data-science-ai"
              class="dropdown-item group/item"
            >
              <span class="item-title">Data Science &amp; AI</span>
              <span class="item-desc">Machine learning, NLP &amp; GenAI</span>
            </a>
            <a href="/programs/cyber-security" class="dropdown-item group/item">
              <span class="item-title"
                >Cyber Security &amp; Ethical Hacking</span
              >
              <span class="item-desc">Threat hunting &amp; network defense</span
              >
            </a>
            <a href="/programs/devops" class="dropdown-item group/item">
              <span class="item-title">DevOps &amp; Cloud</span>
              <span class="item-desc"
                >Infrastructure engineering &amp; CI/CD</span
              >
            </a>
          </div>
        </div>
      </div>

      <!-- Company -->
      <div class="group relative">
        <button class="nav-link dropdown-trigger">
          Company
          <span class="material-symbols-outlined dropdown-caret"
            >expand_more</span
          >
        </button>
        <div class="dropdown-menu left-[-1.5rem]">
          <div class="dropdown-content">
            <a href="/about" class="dropdown-item group/item">
              <span class="item-title">About Us</span>
            </a>
            <a href="/contact-us" class="dropdown-item group/item">
              <span class="item-title">Contact</span>
            </a>
            <a href="/stories" class="dropdown-item group/item">
              <span class="item-title">Testimonials</span>
            </a>
            <a href="/reviews" class="dropdown-item group/item">
              <span class="item-title">Reviews</span>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Right CTAs: ALL links always visible from md+, nothing hidden -->
    <div class="hidden min-w-0 items-center justify-end gap-1 md:flex lg:gap-2">
      <!-- Register Now Dropdown -->
      <div class="group relative">
        <button class="btn-cta btn-solid dropdown-trigger">
          Register Now
          <span class="material-symbols-outlined dropdown-caret"
            >expand_more</span
          >
        </button>
        <div class="dropdown-menu right-0">
          <div class="dropdown-header">
            <span>Scholar Tier - $99 Seat Deposit</span>
          </div>
          <div class="dropdown-content">
            <a
              href="/checkout?course=Data+Science+%26+AI&type=normal"
              class="dropdown-item group/item"
            >
              <span class="item-title">Data Science &amp; AI</span>
              <span class="item-desc">Enroll as Scholar - $99</span>
            </a>
            <a
              href="/checkout?course=Cyber+Security+%26+Ethical+Hacking&type=normal"
              class="dropdown-item group/item"
            >
              <span class="item-title"
                >Cyber Security &amp; Ethical Hacking</span
              >
              <span class="item-desc">Enroll as Scholar - $99</span>
            </a>
            <a
              href="/checkout?course=DevOps+%26+Cloud+Computing&type=normal"
              class="dropdown-item group/item"
            >
              <span class="item-title">DevOps &amp; Cloud Computing</span>
              <span class="item-desc">Enroll as Scholar - $99</span>
            </a>
          </div>
        </div>
      </div>

      <!-- Enroll Now Dropdown -->
      <div class="group relative">
        <button class="btn-cta btn-outline dropdown-trigger">
          Enroll Now
          <span class="material-symbols-outlined dropdown-caret"
            >expand_more</span
          >
        </button>
        <div class="dropdown-menu right-0">
          <div class="dropdown-header">
            <span>Full Tuition Enrollment</span>
          </div>
          <div class="dropdown-content">
            <a
              href="/checkout?course=Data+Science+%26+AI&type=normal&mode=full"
              class="dropdown-item group/item"
            >
              <span class="item-title">Data Science &amp; AI</span>
              <span class="item-desc">Full Tuition Enrollment</span>
            </a>
            <a
              href="/checkout?course=Cyber+Security+%26+Ethical+Hacking&type=normal&mode=full"
              class="dropdown-item group/item"
            >
              <span class="item-title"
                >Cyber Security &amp; Ethical Hacking</span
              >
              <span class="item-desc">Full Tuition Enrollment</span>
            </a>
            <a
              href="/checkout?course=DevOps+%26+Cloud+Computing&type=normal&mode=full"
              class="dropdown-item group/item"
            >
              <span class="item-title">DevOps &amp; Cloud Computing</span>
              <span class="item-desc">Full Tuition Enrollment</span>
            </a>
          </div>
        </div>
      </div>

      <!-- LMS Login: ALWAYS visible from md+, just shrinks its text/padding on tablet -->
      <a
        href="https://learnwithus.sbs/login"
        class="nav-link btn-cta btn-outline hidden md:inline-flex"
        target="_blank"
      >
        <span class="hidden lg:inline">LMS Login</span>
        <span class="lg:hidden">LMS</span>
        <span class="material-symbols-outlined text-[16px] lg:text-[18px]"
          >login</span
        >
      </a>
    </div>

    <!-- Mobile Hamburger -->
    <button
      class="justify-self-end p-2 text-slate-900 md:hidden"
      type="button"
      aria-label="Open navigation menu"
      aria-controls="mobile-nav-panel"
      aria-expanded="false"
      id="mobile-menu-toggle"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="23"
        height="23"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        id="hamburger-icon"
      >
        <path d="M4 5h16"></path><path d="M4 12h16"></path><path d="M4 19h16"
        ></path>
      </svg>
    </button>
  </div>
</nav>

<!-- Mobile Navigation Panel -->
<div
  class="fixed inset-0 z-[999999] flex invisible flex-col items-center overflow-y-auto bg-white pb-10 pt-20 opacity-0 transition-opacity duration-300 ease-out md:hidden"
  id="mobile-nav-panel"
  aria-hidden="true"
>
  <div
    class="mx-auto flex w-full max-w-[340px] flex-col items-center gap-3 px-6"
  >
    <a tabindex="-1" href="/" class="mobile-nav-link">Home</a>
    <a tabindex="-1" href="/live-jobs" class="mobile-nav-link">Live Jobs</a>

    <span class="mobile-section-label">Programs</span>
    <a
      tabindex="-1"
      href="/programs/data-science-ai"
      class="mobile-program-link">Data Science &amp; AI</a
    >
    <a tabindex="-1" href="/programs/cyber-security" class="mobile-program-link"
      >Cyber Security</a
    >
    <a tabindex="-1" href="/programs/devops" class="mobile-program-link"
      >DevOps &amp; Cloud</a
    >

    <span class="mobile-section-label">Company</span>
    <a tabindex="-1" href="/about" class="mobile-program-link">About</a>
    <a tabindex="-1" href="/contact-us" class="mobile-program-link">Contact</a>
    <a tabindex="-1" href="/stories" class="mobile-program-link">Testimonials</a
    >

    <div class="my-2 w-full border-t border-slate-200/50"></div>

    <!-- Register Now -->
    <div class="mt-2 flex w-full flex-col gap-2">
      <span
        class="text-center text-xs font-bold uppercase tracking-wide text-[#005d90]"
        >Register Now</span
      >
      <div class="flex w-full flex-col gap-2">
        <a
          tabindex="-1"
          href="/checkout?course=Data+Science+%26+AI&type=normal"
          class="mobile-cta-btn"
        >
          <span class="text-[0.85rem]">Data Science &amp; AI</span>
          <span class="text-xs font-medium opacity-90">$99</span>
        </a>
        <a
          tabindex="-1"
          href="/checkout?course=Cyber+Security+%26+Ethical+Hacking&type=normal"
          class="mobile-cta-btn"
        >
          <span class="text-[0.85rem]">Cyber Security</span>
          <span class="text-xs font-medium opacity-90">$99</span>
        </a>
        <a
          tabindex="-1"
          href="/checkout?course=DevOps+%26+Cloud+Computing&type=normal"
          class="mobile-cta-btn"
        >
          <span class="text-[0.85rem]">DevOps &amp; Cloud</span>
          <span class="text-xs font-medium opacity-90">$99</span>
        </a>
      </div>
    </div>

    <!-- Enroll Now -->
    <div class="mt-2 flex w-full flex-col gap-2">
      <span
        class="text-center text-xs font-bold uppercase tracking-wide text-[#005d90]"
        >Enroll Now</span
      >
      <div class="flex w-full flex-col gap-2">
        <a
          tabindex="-1"
          href="/checkout?course=Data+Science+%26+AI&type=normal&mode=full"
          class="mobile-cta-btn-outline"
        >
          <span class="text-[0.85rem]">Data Science &amp; AI</span>
          <span class="text-xs text-slate-500">$2999</span>
        </a>
        <a
          tabindex="-1"
          href="/checkout?course=Cyber+Security+%26+Ethical+Hacking&type=normal&mode=full"
          class="mobile-cta-btn-outline"
        >
          <span class="text-[0.85rem]">Cyber Security</span>
          <span class="text-xs text-slate-500">$2999</span>
        </a>
        <a
          tabindex="-1"
          href="/checkout?course=DevOps+%26+Cloud+Computing&type=normal&mode=full"
          class="mobile-cta-btn-outline"
        >
          <span class="text-[0.85rem]">DevOps &amp; Cloud</span>
          <span class="text-xs text-slate-500">$2999</span>
        </a>
      </div>
    </div>

    <a
      tabindex="-1"
      href="https://learnwithus.sbs/login"
      target="_blank"
      class="mobile-program-link btn-cta btn-outline mt-2 flex items-center justify-center gap-1.5 font-semibold text-[#1b4a9a]"
    >
      LMS Login
      <span class="material-symbols-outlined text-base">login</span>
    </a>
  </div>
</div>

<!-- Page Transition Overlay -->
<div
  id="page-transition-overlay"
  class="pointer-events-none fixed inset-0 z-[100000000] flex items-center justify-center bg-[#0c1013] opacity-0 transition-opacity duration-400 ease-out"
  style="display: none;"
>
  <div class="relative flex h-full w-full items-center justify-center">
    <video
      id="trans-video-ds"
      src="/admin/Page_transition_Data_Science_AI_202606270237.mp4"
      preload="none"
      muted
      playsinline
      class="absolute inset-0 hidden h-full w-full object-cover"></video>
    <video
      id="trans-video-cs"
      src="/admin/Cyber_Security_page_transition_1080p_202606270238.mp4"
      preload="none"
      muted
      playsinline
      class="absolute inset-0 hidden h-full w-full object-cover"></video>
    <video
      id="trans-video-do"
      src="/admin/devops_loop_transi._202606270238.mp4"
      preload="none"
      muted
      playsinline
      class="absolute inset-0 hidden h-full w-full object-cover"></video>
  </div>
</div>

<style>
  /* Small set of utility classes that combine several Tailwind-style tokens
     for elements repeated many times, plus the JS-driven state transitions
     that Tailwind's static class scanner can't safelist automatically. */

  .nav-link {
    @apply inline-flex h-9 cursor-pointer items-center gap-1 whitespace-nowrap border-none bg-none p-0 text-[0.72rem] font-medium text-slate-600 transition-colors hover:text-[#005d90] lg:h-10 lg:text-[0.95rem];
  }

  .dropdown-caret {
    @apply ml-0.5 inline-block text-base transition-transform duration-200 ease-out lg:text-lg;
  }
  .group:hover .dropdown-caret {
    @apply rotate-180;
  }

  .dropdown-menu {
    @apply invisible absolute top-full z-[999999] w-72 translate-y-2 overflow-hidden rounded-xl border border-slate-200/80 bg-[#e1f0f4] opacity-0 shadow-[0_20px_40px_rgba(15,23,42,0.08)] transition-all duration-200 ease-out lg:w-80;
  }
  .group:hover .dropdown-menu {
    @apply visible translate-y-0.5 opacity-100;
  }

  .dropdown-header {
    @apply border-b border-slate-200/60 bg-slate-900/[0.02] px-5 py-3.5 text-xs font-bold uppercase tracking-wide text-[#005d90];
  }
  .dropdown-content {
    @apply flex flex-col gap-1 p-2;
  }
  .dropdown-item {
    @apply flex flex-col rounded-lg px-4 py-3 no-underline transition-colors hover:bg-[#005d90]/[0.04];
  }
  .item-title {
    @apply text-sm font-semibold text-slate-800 transition-colors group-hover/item:text-[#005d90];
  }
  .item-desc {
    @apply mt-0.5 text-xs text-slate-500;
  }

  .btn-cta {
    @apply inline-flex h-8 cursor-pointer items-center justify-center gap-1 whitespace-nowrap rounded-lg px-2 text-[0.7rem] font-semibold transition-all duration-200 lg:h-10 lg:gap-1.5 lg:px-5 lg:text-[0.9rem];
  }
  .btn-solid {
    @apply border-none bg-gradient-to-br from-[#005d90] to-[#0077b6] text-white shadow-[0_2px_8px_rgba(0,93,144,0.15)] hover:-translate-y-px hover:shadow-[0_6px_20px_rgba(0,93,144,0.25)];
  }
  .btn-outline {
    @apply border-[1.5px] border-[#005d90]/25 bg-[#005d90]/[0.03] text-[#005d90] hover:-translate-y-px hover:border-[#005d90] hover:bg-[#005d90]/[0.08];
  }

  .mobile-nav-link {
    @apply w-full text-center text-lg font-semibold text-slate-800 no-underline transition-colors hover:text-[#005d90];
  }
  .mobile-section-label {
    @apply w-full pt-1 text-center text-[0.72rem] font-extrabold uppercase tracking-widest text-slate-500;
  }
  .mobile-program-link {
    @apply w-full py-1 text-center text-sm font-medium text-slate-600 no-underline transition-colors hover:text-[#005d90];
  }
  .mobile-cta-btn {
    @apply flex items-center justify-between rounded-lg bg-gradient-to-br from-[#005d90] to-[#0077b6] px-4 py-3 font-semibold text-white no-underline shadow-[0_2px_6px_rgba(0,93,144,0.15)] transition-transform hover:-translate-y-px;
  }
  .mobile-cta-btn-outline {
    @apply flex items-center justify-between rounded-lg border-[1.5px] border-[#005d90]/25 bg-[#005d90]/[0.03] px-4 py-3 font-semibold text-[#005d90] no-underline transition-colors hover:bg-[#005d90]/[0.08];
  }

  /* JS-driven open/close states for the mobile panel & solid-header state */
  #mobile-nav-panel.is-open {
    opacity: 1;
    visibility: visible;
  }
  #main-header.is-mobile-menu-open {
    background-color: #ffffff !important;
  }
</style>

<script is:inline>
  (() => {
    const nav = document.getElementById("main-header");
    const menuButton = document.getElementById("mobile-menu-toggle");
    const panel = document.getElementById("mobile-nav-panel");

    if (menuButton && panel) {
      const menuIcon =
        '<svg xmlns="http://www.w3.org/2000/svg" width="23" height="23" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 5h16"></path><path d="M4 12h16"></path><path d="M4 19h16"></path></svg>';
      const closeIcon =
        '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>';
      const links = Array.from(panel.querySelectorAll("a"));

      const setOpen = (open) => {
        nav?.classList.toggle("is-mobile-menu-open", open);
        panel.classList.toggle("is-open", open);
        panel.classList.toggle("invisible", !open);
        document.body.classList.toggle("overflow-hidden", open);
        menuButton.setAttribute("aria-expanded", String(open));
        menuButton.setAttribute(
          "aria-label",
          open ? "Close navigation menu" : "Open navigation menu",
        );
        menuButton.innerHTML = open ? closeIcon : menuIcon;
        panel.setAttribute("aria-hidden", String(!open));
        for (const link of links) {
          if (open) link.removeAttribute("tabindex");
          else link.setAttribute("tabindex", "-1");
        }
      };

      menuButton.addEventListener("click", () => {
        const isOpen = nav?.classList.contains("is-mobile-menu-open");
        setOpen(!isOpen);
      });

      for (const link of links) {
        link.addEventListener("click", () => setOpen(false));
      }

      window.addEventListener(
        "resize",
        () => {
          if (window.innerWidth >= 768) {
            const isOpen = nav?.classList.contains("is-mobile-menu-open");
            if (isOpen) setOpen(false);
          }
        },
        { passive: true },
      );
    }

    // Force light mode theme
    function initTheme() {
      document.documentElement.classList.remove("dark");
      document.documentElement.classList.add("light");
      localStorage.setItem("theme", "light");
    }
    initTheme();

    // Page Transition Manager
    const transitionOverlay = document.getElementById(
      "page-transition-overlay",
    );
    const transitionVideos = {
      "data-science": document.getElementById("trans-video-ds"),
      "cyber-security": document.getElementById("trans-video-cs"),
      devops: document.getElementById("trans-video-do"),
    };

    try {
      const pendingTransition = sessionStorage.getItem(
        "page-transition-target",
      );
      if (pendingTransition && transitionOverlay) {
        transitionOverlay.style.display = "flex";
        transitionOverlay.style.opacity = "1";
        transitionOverlay.style.pointerEvents = "all";
        sessionStorage.removeItem("page-transition-target");

        setTimeout(() => {
          transitionOverlay.style.transition =
            "opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1)";
          transitionOverlay.style.opacity = "0";
          setTimeout(() => {
            transitionOverlay.style.display = "none";
            transitionOverlay.style.pointerEvents = "none";
          }, 600);
        }, 400);
      }
    } catch (e) {
      console.warn("Failed to handle entrance transition:", e);
    }

    const programUrls = {
      "/programs/data-science-ai": "data-science",
      "/programs/cyber-security": "cyber-security",
      "/programs/devops": "devops",
    };

    document.addEventListener(
      "mouseenter",
      (e) => {
        const link = e.target.closest("a");
        if (!link) return;
        const href = link.getAttribute("href");
        if (href) {
          const matchedKey =
            programUrls[href] ||
            Object.keys(programUrls).find(
              (key) => href.endsWith(key) && !href.includes("checkout"),
            );
          if (matchedKey) {
            const programKey = programUrls[matchedKey];
            const video = transitionVideos[programKey];
            if (video && video.preload !== "auto") {
              video.preload = "auto";
              video.load();
            }
          }
        }
      },
      true,
    );

    document.addEventListener("click", (e) => {
      const link = e.target.closest("a");
      if (!link) return;
      const href = link.getAttribute("href");
      if (href) {
        const matchedKey =
          programUrls[href] ||
          Object.keys(programUrls).find(
            (key) => href.endsWith(key) && !href.includes("checkout"),
          );
        if (matchedKey) {
          const programKey = programUrls[matchedKey];
          const video = transitionVideos[programKey];

          if (video && transitionOverlay) {
            e.preventDefault();
            try {
              try {
                sessionStorage.setItem("page-transition-target", programKey);
              } catch (storageErr) {
                console.warn("sessionStorage is not available:", storageErr);
              }

              Object.values(transitionVideos).forEach((v) => {
                if (v) {
                  try {
                    v.style.display = "none";
                    v.pause();
                  } catch (e) {}
                }
              });

              video.style.display = "block";
              try {
                video.currentTime = 0;
              } catch (e) {}

              transitionOverlay.style.transition = "opacity 0.3s ease";
              transitionOverlay.style.display = "flex";
              transitionOverlay.style.opacity = "1";
              transitionOverlay.style.pointerEvents = "all";

              const playPromise = video.play();
              if (playPromise !== undefined) {
                playPromise.catch((err) => {
                  console.warn("Video play was prevented:", err);
                  setTimeout(() => {
                    window.location.href = href;
                  }, 400);
                });
              }

              setTimeout(() => {
                window.location.href = href;
              }, 1600);
            } catch (err) {
              console.error(
                "Transition failed, falling back to direct navigation:",
                err,
              );
              window.location.href = href;
            }
          }
        }
      }
    });
  })();
</script>
