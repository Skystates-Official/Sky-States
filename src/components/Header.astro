<style>
  /* Base Navigation Styling */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000000 !important; /* Raised z-index to be on top of mobile panel */
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 1.25rem;
    background-color: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(226, 232, 240, 0.8);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
    transition: padding 0.25s cubic-bezier(0.4, 0, 0.2, 1), background-color 0.25s, border-bottom 0.25s, box-shadow 0.25s;
    font-family: 'Outfit', 'Inter', sans-serif;
  }

  @media (min-width: 768px) {
    .nav {
      padding: 0.5rem 2.5rem;
    }
  }

  .brand {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  /* Logo cropping and scaling system (scaled up by an additional 30% on desktop, responsive on mobile) */
  .logo-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    height: 48px;
    width: 210px;
  }

  .brand-logo-img {
    height: 135px;
    width: auto;
    object-fit: contain;
    margin-top: -4px;
    transition: transform 0.3s ease;
  }

  @media (min-width: 768px) {
    .logo-wrapper {
      height: 78px; /* 30% larger than 60px */
      width: 338px; /* 30% larger than 260px */
    }
    .brand-logo-img {
      height: 234px; /* 30% larger than 180px */
      margin-top: -8px;
    }
  }

  /* Desktop Navigation Links Layout (Centered) */
  .nav-links {
    display: none;
  }

  @media (min-width: 768px) {
    .nav-links {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 2.25rem;
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
    }
  }

  /* Desktop CTA Buttons Layout (Right-aligned) */
  .cta-container {
    display: none;
    align-items: center;
    gap: 1rem;
    margin-left: auto;
  }

  @media (min-width: 768px) {
    .cta-container {
      display: flex;
    }
  }

  /* Standardized Trigger Alignments & Fonts */
  .nav-link-item {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--on-surface-variant, #404850);
    transition: color 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    height: 40px; /* Force same height bounding box */
  }

  .nav-link-item:hover {
    color: var(--primary, #005d90);
  }

  /* CTA Buttons styling - styled as buttons but perfectly aligned */
  .btn-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    height: 40px;
    padding: 0 1.25rem;
    font-size: 0.9rem;
    font-weight: 600;
    border-radius: 8px;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
    box-sizing: border-box;
  }

  .btn-solid {
    background: linear-gradient(135deg, var(--primary, #005d90), #0077b6);
    color: #ffffff;
    border: none;
    box-shadow: 0 2px 8px rgba(0, 93, 144, 0.15);
  }

  .btn-solid:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(0, 93, 144, 0.25);
  }

  .btn-outline {
    background: rgba(0, 93, 144, 0.03);
    border: 1.5px solid rgba(0, 93, 144, 0.25);
    color: var(--primary, #005d90);
  }

  .btn-outline:hover {
    background: rgba(0, 93, 144, 0.08);
    border-color: var(--primary, #005d90);
    transform: translateY(-1px);
  }

  /* Dropdown Alignment Caret */
  .dropdown-caret {
    font-size: 1.1rem !important;
    display: inline-block;
    transition: transform 0.25s ease;
    margin-top: 1px;
  }

  .dropdown-wrapper:hover .dropdown-caret {
    transform: rotate(180deg);
  }

  /* Standardized Dropdown Menu System */
  .dropdown-menu {
    position: absolute;
    top: 100%;
    width: 20rem; /* Exactly 320px for all dropdowns */
    background: #ffffff;
    border: 1px solid rgba(226, 232, 240, 0.8);
    border-radius: 12px;
    box-shadow: 0 20px 40px rgba(15, 23, 42, 0.08);
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
    z-index: 999999 !important;
  }

  /* Alignments of Dropdown Menus */
  .dropdown-menu:not(.dropdown-right) {
    left: -1.5rem;
  }

  .dropdown-right {
    right: 0;
  }

  .dropdown-wrapper:hover .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(2px);
  }

  /* Consistent Dropdown Headers */
  .dropdown-header {
    background: rgba(15, 23, 42, 0.015);
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid rgba(226, 232, 240, 0.6);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--primary, #005d90);
  }

  /* Consistent Dropdown Content */
  .dropdown-content {
    padding: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  /* Unified Dropdown Items */
  .dropdown-item {
    display: flex;
    flex-direction: column;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .dropdown-item:hover {
    background: rgba(0, 93, 144, 0.04);
  }

  .item-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: #1e293b;
    transition: color 0.2s ease;
  }

  .dropdown-item:hover .item-title {
    color: var(--primary, #005d90);
  }

  .item-desc {
    font-size: 0.75rem;
    color: #64748b;
    margin-top: 0.15rem;
  }

  /* Mobile menu button */
  .mobile-menu-button {
    display: block;
    background: none;
    border: none;
    color: var(--on-surface, #1a1c1c);
    cursor: pointer;
    padding: 0.5rem;
    z-index: 10000001 !important; /* Ensure toggler button is on top of nav & panel */
  }
  @media (min-width: 768px) {
    .mobile-menu-button {
      display: none;
    }
  }

  /* Mobile Nav Panel */
  .mobile-nav-panel {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(255, 255, 255, 0.99);
    backdrop-filter: blur(25px);
    z-index: 999999 !important;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1), visibility 0.3s ease;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
    overflow-y: auto;
    padding-top: 5.5rem; /* Adjusted to start beautifully below header bar */
    padding-bottom: 2.5rem;
  }

  .nav.is-mobile-menu-open {
    background-color: #ffffff !important;
  }

  .mobile-nav-panel.is-open {
    opacity: 1;
    visibility: visible;
  }

  .mobile-nav-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    width: 100%;
    max-width: 340px;
    padding: 1rem 1.5rem;
  }

  .mobile-nav-inner a {
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--on-surface, #1a1c1c);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .mobile-nav-inner a:hover {
    color: var(--primary, #005d90);
  }

  /* Mobile CTA Buttons styling */
  .mobile-cta-section {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .mobile-cta-section-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--primary, #005d90);
    text-align: center;
    margin-bottom: 0.25rem;
  }

  .mobile-cta-grid {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
  }

  .mobile-cta-sub-btn {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem !important;
    background: linear-gradient(135deg, var(--primary, #005d90), #0077b6);
    color: #ffffff !important;
    border-radius: 8px;
    font-size: 0.875rem !important;
    font-weight: 600 !important;
    text-decoration: none;
    box-shadow: 0 2px 6px rgba(0, 93, 144, 0.15);
    transition: all 0.2s ease;
  }

  .mobile-cta-sub-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(0, 93, 144, 0.25);
  }

  .mobile-cta-sub-btn.outline {
    background: rgba(0, 93, 144, 0.03) !important;
    border: 1.5px solid rgba(0, 93, 144, 0.25);
    color: var(--primary, #005d90) !important;
    box-shadow: none;
  }

  .mobile-cta-sub-btn.outline:hover {
    background: rgba(0, 93, 144, 0.08) !important;
    border-color: var(--primary, #005d90);
  }

  .cta-sub-title {
    font-size: 0.85rem;
  }

  .cta-sub-price {
    font-size: 0.75rem;
    opacity: 0.9;
    font-weight: 500;
  }

  .mobile-cta-sub-btn.outline .cta-sub-price {
    color: #64748b;
  }

  /* Page Transition Overlay Styles */
  .page-transition-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #0c1013;
    z-index: 100000000 !important; /* Ensure it is above everything else */
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .transition-video-container {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .transition-video-container video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: none;
  }
</style>

<script is:inline>
  (() => {
    const nav = document.getElementById('main-header');
    
    // Dynamic Scroll Progress Calculation
    if (nav) {
      let frame = 0;
      let lastProgress = -1;
      const updateNav = () => {
        frame = 0;
        const progress = Math.min(Math.max(window.scrollY / 190, 0), 1);
        const eased = progress * progress * (3 - 2 * progress);
        const rounded = Math.round(eased * 100) / 100;
        if (Math.abs(rounded - lastProgress) < 0.01) return;
        lastProgress = rounded;
        nav.style.setProperty('--nav-scroll', rounded.toFixed(2));
      };
      const requestUpdate = () => {
        if (!frame) frame = window.requestAnimationFrame(updateNav);
      };
      updateNav();
      window.addEventListener('scroll', requestUpdate, { passive: true });
    }

    // Mobile Hamburger Menu Interaction
    const menuButton = document.getElementById('mobile-menu-toggle');
    const panel = document.getElementById('mobile-nav-panel');
    if (menuButton && panel) {
      const menuIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="23" height="23" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-menu" aria-hidden="true"><path d="M4 5h16"></path><path d="M4 12h16"></path><path d="M4 19h16"></path></svg>';
      const closeIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-x" aria-hidden="true"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>';
      const links = Array.from(panel.querySelectorAll('a'));
      
      const setOpen = (open) => {
        nav?.classList.toggle('is-mobile-menu-open', open);
        panel?.classList.toggle('is-open', open);
        menuButton.setAttribute('aria-expanded', String(open));
        menuButton.setAttribute('aria-label', open ? 'Close navigation menu' : 'Open navigation menu');
        menuButton.innerHTML = open ? closeIcon : menuIcon;
        panel.setAttribute('aria-hidden', String(!open));
        for (const link of links) {
          if (open) link.removeAttribute('tabindex');
          else link.setAttribute('tabindex', '-1');
        }
      };

      menuButton.addEventListener('click', () => {
        const isOpen = nav?.classList.contains('is-mobile-menu-open');
        setOpen(!isOpen);
      });

      for (const link of links) {
        link.addEventListener('click', () => setOpen(false));
      }
    }

    // Force light mode theme
    function initTheme() {
      document.documentElement.classList.remove('dark');
      document.documentElement.classList.add('light');
      localStorage.setItem('theme', 'light');
    }
    initTheme();

    // Page Transition Manager
    const transitionOverlay = document.getElementById('page-transition-overlay');
    const transitionVideos = {
      'data-science': document.getElementById('trans-video-ds'),
      'cyber-security': document.getElementById('trans-video-cs'),
      'devops': document.getElementById('trans-video-do')
    };

    // Check if we just transitioned
    try {
      const pendingTransition = sessionStorage.getItem('page-transition-target');
      if (pendingTransition && transitionOverlay) {
        // Show the overlay in a solid state first, then fade it out
        transitionOverlay.style.display = 'flex';
        transitionOverlay.style.opacity = '1';
        transitionOverlay.style.pointerEvents = 'all';
        
        // Clear the session storage immediately
        sessionStorage.removeItem('page-transition-target');
        
        // Smoothly fade out after a brief moment so the page content is ready
        setTimeout(() => {
          transitionOverlay.style.transition = 'opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1)';
          transitionOverlay.style.opacity = '0';
          setTimeout(() => {
            transitionOverlay.style.display = 'none';
            transitionOverlay.style.pointerEvents = 'none';
          }, 600);
        }, 400);
      }
    } catch (e) {
      console.warn('Failed to handle entrance transition:', e);
    }

    // Intercept clicks on program links
    const programUrls = {
      '/programs/data-science-ai': 'data-science',
      '/programs/cyber-security': 'cyber-security',
      '/programs/devops': 'devops'
    };

    document.addEventListener('click', (e) => {
      const link = e.target.closest('a');
      if (!link) return;
      
      const href = link.getAttribute('href');
      if (href) {
        // Match both absolute path or relative path
        const matchedKey = programUrls[href] || Object.keys(programUrls).find(key => href.endsWith(key) && !href.includes('checkout'));
        if (matchedKey) {
          const programKey = programUrls[matchedKey];
          const video = transitionVideos[programKey];
          
          if (video && transitionOverlay) {
            e.preventDefault();
            
            try {
              // Set target in sessionStorage for the next page to fade out
              try {
                sessionStorage.setItem('page-transition-target', programKey);
              } catch (storageErr) {
                console.warn('sessionStorage is not available:', storageErr);
              }
              
              // Hide all videos first, then show the active one
              Object.values(transitionVideos).forEach(v => {
                if (v) {
                  try {
                    v.style.display = 'none';
                    v.pause();
                  } catch (e) {}
                }
              });
              
              video.style.display = 'block';
              try {
                video.currentTime = 0;
              } catch (e) {}
              
              // Show overlay and play video
              transitionOverlay.style.transition = 'opacity 0.3s ease';
              transitionOverlay.style.display = 'flex';
              transitionOverlay.style.opacity = '1';
              transitionOverlay.style.pointerEvents = 'all';
              
              const playPromise = video.play();
              if (playPromise !== undefined) {
                playPromise.catch(err => {
                  console.warn('Video play was prevented:', err);
                  // If video play is blocked (e.g. low power mode), navigate faster
                  setTimeout(() => {
                    window.location.href = href;
                  }, 400);
                });
              }
              
              // Navigate to the target page after the transition peak (1.6 seconds)
              setTimeout(() => {
                window.location.href = href;
              }, 1600);
            } catch (err) {
              console.error('Transition failed, falling back to direct navigation:', err);
              window.location.href = href;
            }
          }
        }
      }
    });
  })();
</script>
