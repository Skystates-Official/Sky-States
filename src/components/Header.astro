      </button>
      <div class="dropdown-menu dropdown-right">
        <div class="dropdown-header">
          <span>Scholar Tier - $99 Seat Deposit</span>
        </div>
        <div class="dropdown-content">
          <a href="/checkout?course=Data+Science+%26+AI&type=normal" class="dropdown-item">
            <span class="item-title">Data Science & AI</span>
            <span class="item-desc">Enroll as Scholar - $99</span>
          </a>
          <a href="/checkout?course=Cyber+Security+%26+Ethical+Hacking&type=normal" class="dropdown-item">
            <span class="item-title">Cyber Security & Ethical Hacking</span>
            <span class="item-desc">Enroll as Scholar - $99</span>
          </a>
          <a href="/checkout?course=DevOps+%26+Cloud+Computing&type=normal" class="dropdown-item">
            <span class="item-title">DevOps & Cloud Computing</span>
            <span class="item-desc">Enroll as Scholar - $99</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Enroll Now Dropdown -->
    <div class="relative group/drop dropdown-wrapper">
      <button class="btn-cta btn-outline dropdown-trigger">
        Enroll Now
        <span class="material-symbols-outlined dropdown-caret">expand_more</span>
      </button>
      <div class="dropdown-menu dropdown-right">
        <div class="dropdown-header">
          <span>Full Tuition Enrollment</span>
        </div>
        <div class="dropdown-content">
          <a href="/checkout?course=Data+Science+%26+AI&type=normal&mode=full" class="dropdown-item">
            <span class="item-title">Data Science & AI</span>
            <span class="item-desc">Full Tuition Enrollment</span>
          </a>
          <a href="/checkout?course=Cyber+Security+%26+Ethical+Hacking&type=normal&mode=full" class="dropdown-item">
            <span class="item-title">Cyber Security & Ethical Hacking</span>
            <span class="item-desc">Full Tuition Enrollment</span>
          </a>
          <a href="/checkout?course=DevOps+%26+Cloud+Computing&type=normal&mode=full" class="dropdown-item">
