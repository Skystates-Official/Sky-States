---
// src/components/Footer.astro
---
<footer class="bg-surface-container-lowest border-t border-outline-variant/30 py-20 mt-16">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12">
    <!-- Brand / Mission -->
    <div class="lg:col-span-2 space-y-6">
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-primary text-3xl">cloud</span>
        <span class="font-headline-md text-headline-md font-bold text-primary tracking-tight">Sky States</span>
      </div>
      <p class="text-secondary font-body-md max-w-sm leading-relaxed">
        Architecting the future of technical leadership. Elite immersive bootcamps designed for real-world engineering excellence.
      </p>
      <div class="flex gap-4">
        <span class="text-xs text-secondary font-label-sm uppercase tracking-widest bg-surface-container px-3 py-1.5 rounded-full border border-outline-variant/10">Est. 2024</span>
        <span class="text-xs text-secondary font-label-sm uppercase tracking-widest bg-surface-container px-3 py-1.5 rounded-full border border-outline-variant/10">Global Network</span>
      </div>
    </div>

    <!-- Programs Links -->
    <div class="space-y-4">
      <h6 class="font-label-md text-label-md uppercase tracking-wider text-on-surface font-bold">Programs</h6>
      <ul class="space-y-3 font-label-sm text-sm">
        <li><a class="text-secondary hover:text-primary transition-colors" href="/programs/data-science-ai">Data Science & AI</a></li>
        <li><a class="text-secondary hover:text-primary transition-colors" href="/programs/cyber-security">Cyber Security</a></li>
        <li><a class="text-secondary hover:text-primary transition-colors" href="/programs/devops">DevOps & Cloud</a></li>
      </ul>
    </div>

    <!-- Career Links -->
    <div class="space-y-4">
      <h6 class="font-label-md text-label-md uppercase tracking-wider text-on-surface font-bold">Career Hub</h6>
      <ul class="space-y-3 font-label-sm text-sm">
        <li><a class="text-secondary hover:text-primary transition-colors" href="/career-hub">Career Hub Central</a></li>
        <li><a class="text-secondary hover:text-primary transition-colors" href="/career-roi">Salary Guide & ROI</a></li>
        <li><a class="text-secondary hover:text-primary transition-colors" href="/resume-hub">Resume Engineering</a></li>
        <li><a class="text-secondary hover:text-primary transition-colors" href="/placements">Placement Process</a></li>
      </ul>
    </div>

    <!-- Resources Links -->
    <div class="space-y-4">
      <h6 class="font-label-md text-label-md uppercase tracking-wider text-on-surface font-bold">Resources</h6>
      <ul class="space-y-3 font-label-sm text-sm">
        <li><a class="text-secondary hover:text-primary transition-colors" href="/faq">FAQ & Transparency</a></li>
        <li><a class="text-secondary hover:text-primary transition-colors" href="/refund-policy">Refund & Pricing</a></li>
        <li><a class="text-secondary hover:text-primary transition-colors" href="/news">News & Insights</a></li>
      </ul>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 mt-16 pt-8 border-t border-outline-variant/10 flex flex-col md:flex-row justify-between items-center gap-4 text-center md:text-left">
    <p class="text-secondary font-label-sm text-xs">&copy; 2026 Sky States. Institutional Excellence in Technology. All rights reserved.</p>
    <div class="flex gap-6 font-label-sm text-xs">
      <a class="text-secondary hover:text-primary transition-colors" href="/about">About Us</a>
      <a class="text-secondary hover:text-primary transition-colors" href="/checkout">Checkout</a>
    </div>
  </div>
</footer>
