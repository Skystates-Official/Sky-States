---
// src/components/Footer.astro
import Logo from './Logo.astro';
---
<footer class="bg-surface-container-lowest border-t border-outline-variant/30 py-20 mt-16 font-body-md text-secondary">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
    
    <!-- Column 1: Brand / Description -->
    <div class="space-y-6">
      <div class="flex items-center">
        <Logo class="h-12 w-auto" />
      </div>
      <p class="text-secondary font-body-md leading-relaxed">
        Sky States offers a diverse range of professional courses designed to empower students across multiple domains, including software development, cybersecurity, data science, artificial intelligence, cloud computing, and various other emerging fields
      </p>
    </div>

    <!-- Column 2: Quick Links (Part 1) -->
    <div class="space-y-4">
      <h4 class="font-label-md text-label-md uppercase tracking-wider text-on-surface font-bold">Quick Links</h4>
      <ul class="space-y-3 font-label-sm text-sm">
        <li><a class="text-secondary hover:text-primary transition-colors" href="/">Home</a></li>
        <li><a class="text-secondary hover:text-primary transition-colors" href="/live-jobs">Live Jobs</a></li>
        <li><a class="text-secondary hover:text-primary transition-colors" href="/certifications">Alumni Certifications</a></li>
        <li><a class="text-secondary hover:text-primary transition-colors" href="/programs/data-science-ai">Program</a></li>
        <li><a class="text-secondary hover:text-primary transition-colors" href="/checkout?type=1on1">One to One</a></li>
        <li><a class="text-secondary hover:text-primary transition-colors" href="/checkout">Pay Now</a></li>
        <li><a class="text-secondary hover:text-primary transition-colors" href="/checkout">Register Now</a></li>
      </ul>
    </div>

    <!-- Column 3: Legal & Resources (Part 2) -->
    <div class="space-y-4">
      <h4 class="font-label-md text-label-md uppercase tracking-wider text-on-surface font-bold">Support & Policy</h4>
      <ul class="space-y-3 font-label-sm text-sm">
        <li><a class="text-secondary hover:text-primary transition-colors" href="/contact-us">Contact Us</a></li>
        <li><a class="text-secondary hover:text-primary transition-colors" href="/privacy-policy">Privacy Policy</a></li>
        <li><a class="text-secondary hover:text-primary transition-colors" href="/legal-disclosures">Legal Disclosures</a></li>
        <li><a class="text-secondary hover:text-primary transition-colors" href="/microsoft-partnership">Microsoft Partnership</a></li>
        <li><a class="text-secondary hover:text-primary transition-colors" href="/refund-policy">Refund and Returns Policy</a></li>
        <li><a class="text-secondary hover:text-primary transition-colors" href="/faq">Frequently Asked Questions</a></li>
        <li><a class="text-secondary hover:text-primary transition-colors" href="/about">About Sky States</a></li>
        <li><a class="text-secondary hover:text-primary transition-colors" href="/free-data-science-interview-questions">Free Data Science QnA</a></li>
      </ul>
    </div>

    <!-- Column 4: Contacts & Socials -->
    <div class="space-y-6">
      <h4 class="font-label-md text-label-md uppercase tracking-wider text-on-surface font-bold">Contacts</h4>
      <div class="space-y-3 text-sm leading-relaxed">
        <p>
          <span class="font-bold text-on-surface">Add:</span> 30 N Gould St, Sheridan,<br />
          WY, 82801, USA
        </p>
        <div class="space-y-1">
          <p>
            <span class="font-bold text-on-surface">Call:</span> <a href="tel:+18888102434" class="text-primary hover:underline font-semibold">(888) 810-2434</a>
          </p>
          <p>
            <span class="inline-block w-8"></span> <a href="tel:+18889277072" class="text-primary hover:underline font-semibold">(888) 927-7072</a>
          </p>
        </div>
        <p>
          <span class="font-bold text-on-surface">Email:</span> <a href="mailto:info@skystates.us" class="text-primary hover:underline font-semibold">Info@skystates.us</a>
        </p>
      </div>
      
      <!-- Social Icons -->
      <div class="flex items-center gap-4 pt-2">
        <a href="https://www.linkedin.com/company/skystate/" target="_blank" aria-label="LinkedIn" class="w-10 h-10 rounded-full bg-surface-container flex items-center justify-center hover:bg-primary hover:text-white transition-all text-secondary">
          <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
        </a>
        <a href="https://www.instagram.com/skystatess" target="_blank" aria-label="Instagram" class="w-10 h-10 rounded-full bg-surface-container flex items-center justify-center hover:bg-primary hover:text-white transition-all text-secondary">
          <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
        <a href="https://www.youtube.com/@Skystatess" target="_blank" aria-label="YouTube" class="w-10 h-10 rounded-full bg-surface-container flex items-center justify-center hover:bg-primary hover:text-white transition-all text-secondary">
          <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M23.498 6.163c-.272-1.016-1.071-1.815-2.087-2.087-1.84-.495-9.21-.495-9.21-.495s-7.371 0-9.21.495c-1.017.272-1.815 1.071-2.087 2.087-.495 1.84-.495 5.767-.495 5.767s0 3.927.495 5.767c.272 1.016 1.07 1.815 2.087 2.087 1.84.495 9.21.495 9.21.495s7.37 0 9.21-.495c1.016-.272 1.815-1.071 2.087-2.087.495-1.84.495-5.767.495-5.767s0-3.927-.495-5.767zm-13.998 9.337v-6.999l6.082 3.5z"/></svg>
        </a>
        <a href="https://www.facebook.com/people/Sky-States/" target="_blank" aria-label="Facebook" class="w-10 h-10 rounded-full bg-surface-container flex items-center justify-center hover:bg-primary hover:text-white transition-all text-secondary">
          <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg>
        </a>
      </div>
    </div>

  </div>

  <!-- Copyright / Secondary Links -->
  <div class="max-w-7xl mx-auto px-6 mt-16 pt-8 border-t border-outline-variant/10 flex flex-col md:flex-row justify-between items-center gap-4 text-center md:text-left text-xs">
    <p>&copy; 2026 Sky States. Institutional Excellence in Technology. All rights reserved.</p>
    <div class="flex gap-6">
      <a class="hover:text-primary transition-colors" href="/about">About Us</a>
      <a class="hover:text-primary transition-colors" href="/checkout">Checkout</a>
    </div>
  </div>
</footer>
