---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Geist:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Privacy Policy - Sky States</title>
    <meta
      name="description"
      content="Read the Sky States privacy policy. Learn how we secure your data, protect student privacy, and enforce strict zero-SSN collection policies."
    />
    <link rel="canonical" href="https://skystates.us/privacy-policy" />
    <style>
      body { overflow-x: hidden; }
      /* Push content below fixed navbar */
      main { padding-top: 4rem; }
      @media (min-width: 768px) { main { padding-top: 4.5rem; } }
      @media (min-width: 1024px) { main { padding-top: 5rem; } }
    </style>
  </head>
  <body class="bg-slate-50/50 text-slate-800 font-sans min-h-screen overflow-x-hidden">
    <Header />
    <main class="min-h-screen pb-24 px-4 sm:px-6 flex justify-center">
      <article
        class="w-full max-w-4xl bg-white rounded-2xl shadow-xl shadow-slate-200/50 border border-slate-200/60 p-8 sm:p-12 md:p-16 space-y-10"
      >
        <!-- Hero/Header Section -->
        <div class="text-center space-y-4 border-b border-slate-100 pb-8">
          <span
            class="inline-block bg-sky-50 border border-sky-100 text-sky-700 px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider"
            >Data Trust</span
          >
          <h1
            class="text-3xl sm:text-4xl font-bold text-[#0f3473] tracking-tight"
          >
            Privacy Policy
          </h1>
          <p class="text-slate-500 text-base max-w-2xl mx-auto">
            At Sky States, we hold student data security and privacy to
            institutional standards. Read our comprehensive policies below.
          </p>
        </div>

        <!-- Policy Content -->
        <div class="space-y-10 text-slate-700 leading-relaxed text-base">
          <!-- Section 1: Security Commitment -->
          <div class="space-y-3">
            <h2
              class="text-xl font-bold text-slate-900 flex items-center gap-3"
            >
              <span class="material-symbols-outlined text-[#1b4a9a]">lock</span>
              1. Security Commitment & Non-Collection of SSNs
            </h2>
            <p class="text-slate-600 text-justify leading-relaxed">
              Sky States is committed to protecting your personal information.
              We enforce a strict policy regarding sensitive personal
              identifiers: <strong
                >Sky States does NOT collect, store, or process Social Security
                Numbers (SSN)</strong
              > or equivalent national identification numbers from our students or
              applicants.
            </p>
          </div>

          <!-- Section 2: Data We Collect -->
          <div class="space-y-3">
            <h2
              class="text-xl font-bold text-slate-900 flex items-center gap-3"
            >
              <span class="material-symbols-outlined text-[#1b4a9a]"
                >database</span
              >
              2. Information We Collect
            </h2>
            <p class="text-slate-600 text-justify leading-relaxed">
              We collect minimal personal details necessary to facilitate your
              training, career services, and billing:
            </p>
            <ul class="list-disc pl-6 text-slate-600 space-y-2">
              <li>
                <strong>Contact Information:</strong> Name, professional email address,
                phone number, and physical address.
              </li>
              <li>
                <strong>Academic & Professional History:</strong> Resume, LinkedIn
                URL, and academic/STEM background to tailor career placement.
              </li>
              <li>
                <strong>Billing Information:</strong> Payments are securely processed
                via certified, PCI-compliant third-party gateways (e.g., Stripe).
                Sky States does not store your credit card credentials on our servers.
              </li>
            </ul>
          </div>

          <!-- Section 3: Screen Share and Live Labs -->
          <div class="space-y-3">
            <h2
              class="text-xl font-bold text-slate-900 flex items-center gap-3"
            >
              <span class="material-symbols-outlined text-[#1b4a9a]"
                >screen_share</span
              >
              3. Screen Share & Live Class Interaction
            </h2>
            <p class="text-slate-600 text-justify leading-relaxed">
              During our live weekend instruction, interactive labs, and
              capstone project evaluations, students may be requested to share
              their screens. This is conducted solely for real-time pedagogical
              support, code debugging, and skills assessment. Screen sharing
              sessions are never recorded without explicit, prior student
              consent.
            </p>
          </div>

          <!-- Section 4: Data Retention & Protection -->
          <div class="space-y-3">
            <h2
              class="text-xl font-bold text-slate-900 flex items-center gap-3"
            >
              <span class="material-symbols-outlined text-[#1b4a9a]"
                >shield</span
              >
              4. Data Protection Standards
            </h2>
            <p class="text-slate-600 text-justify leading-relaxed">
              All data transmitted to or from the Sky States platform is
              encrypted in transit using industry-standard SSL/TLS technology.
              Access to student records is strictly restricted to authorized
              educational mentors and career services coordinators.
            </p>
          </div>

          <!-- Section 5: Contact Our Privacy Team -->
          <div class="space-y-3">
            <h2
              class="text-xl font-bold text-slate-900 flex items-center gap-3"
            >
              <span class="material-symbols-outlined text-[#1b4a9a]"
                >contact_support</span
              >
              5. Privacy Inquiries
            </h2>
            <p class="text-slate-600 text-justify leading-relaxed">
              For any questions, modifications, or deletion requests regarding
              your personal data records, please reach out directly to our
              privacy officer at <a
                href="mailto:info@skystates.us"
                class="text-sky-600 font-semibold hover:underline"
                >info@skystates.us</a
              > or <a
                href="mailto:support@skystates.us"
                class="text-sky-600 font-semibold hover:underline"
                >support@skystates.us</a
              >.
            </p>
          </div>
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
