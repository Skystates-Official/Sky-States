---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

export const prerender = false;
---

<!doctype html>
<html class="light" lang="en">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Geist:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Microsoft License Services & Partnerships | Sky States</title>
    <meta
      name="description"
      content="Explore how Microsoft License Services play a pivotal role in building institutional partnerships, delivering official certifications, and empowering career readiness."
    />
    <link rel="canonical" href="https://skystates.us/microsoft-partnership" />

    <style>
      .material-symbols-outlined {
        font-variation-settings:
          "FILL" 0,
          "wght" 400,
          "GRAD" 0,
          "opsz" 24;
      }
      .mesh-gradient {
        background: radial-gradient(at top right, rgba(14, 165, 233, 0.15) 0%, transparent 50%),
                    radial-gradient(at bottom left, rgba(2, 132, 199, 0.08) 0%, transparent 50%),
                    linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
      }
      .glass-card {
        background: rgba(255, 255, 255, 0.75);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
      }
      .accent-card {
        border-left: 4px solid #005d90;
      }
    </style>
  </head>
  <body class="bg-slate-50 text-slate-900 font-sans overflow-x-hidden antialiased">
    <Header />

    <main class="w-full">
      <!-- Hero Section with Spacing for Fixed Navbar -->
      <section class="relative w-full pt-28 pb-16 md:pt-36 md:pb-24 overflow-hidden mesh-gradient">
        <div class="max-w-7xl mx-auto px-4 sm:px-8 md:px-12 relative z-10">
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
            
            <!-- Left Info Block -->
            <div class="lg:col-span-7 space-y-6 md:space-y-8">
              <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-sky-50 border border-sky-100/80 shadow-sm">
                <!-- Microsoft classic 4 color squares -->
                <div class="grid grid-cols-2 gap-0.5 shrink-0">
                  <div class="w-1.5 h-1.5 bg-[#f25f22]"></div>
                  <div class="w-1.5 h-1.5 bg-[#7fba00]"></div>
                  <div class="w-1.5 h-1.5 bg-[#00a4ef]"></div>
                  <div class="w-1.5 h-1.5 bg-[#ffb900]"></div>
                </div>
                <span class="text-[10px] font-extrabold uppercase tracking-widest text-sky-850">
                  Enterprise Licensing &amp; Cloud Partners
                </span>
              </div>
              
              <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-slate-900 leading-[1.1] max-w-2xl">
                The Role of Microsoft <span class="bg-clip-text text-transparent bg-gradient-to-r from-sky-600 to-blue-700">License Services</span>
              </h1>
              
              <p class="text-base md:text-lg text-slate-600 max-w-xl leading-relaxed">
                Empowering Sky States learners with official cloud tenant sandboxes, verifiable Microsoft exam vouchers, and career-readiness infrastructure.
              </p>

              <div class="flex flex-wrap gap-3">
                <span class="px-3.5 py-1.5 rounded-xl bg-white border border-slate-200 text-xs font-semibold text-slate-700 shadow-sm flex items-center gap-1.5">
                  <span class="w-1.5 h-1.5 rounded-full bg-sky-500"></span> AZ-900
                </span>
                <span class="px-3.5 py-1.5 rounded-xl bg-white border border-slate-200 text-xs font-semibold text-slate-700 shadow-sm flex items-center gap-1.5">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> DP-900
                </span>
                <span class="px-3.5 py-1.5 rounded-xl bg-white border border-slate-200 text-xs font-semibold text-slate-700 shadow-sm flex items-center gap-1.5">
                  <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span> SC-900
                </span>
              </div>
            </div>

            <!-- Right Simulation Card -->
            <div class="lg:col-span-5 relative">
              <div class="absolute inset-0 bg-gradient-to-tr from-sky-200 to-blue-300 rounded-3xl opacity-20 blur-2xl -z-10"></div>
              <div class="glass-card rounded-3xl p-6 border border-slate-200/60 shadow-xl space-y-4">
                
                <div class="flex items-center justify-between pb-3 border-b border-slate-100">
                  <div class="flex items-center gap-2">
                    <span class="w-2.5 h-2.5 rounded-full bg-[#f25f22]"></span>
                    <span class="w-2.5 h-2.5 rounded-full bg-[#7fba00]"></span>
                    <span class="w-2.5 h-2.5 rounded-full bg-[#00a4ef]"></span>
                    <span class="w-2.5 h-2.5 rounded-full bg-[#ffb900]"></span>
                    <span class="text-[10px] font-bold text-slate-750 font-mono ml-1.5">Microsoft Cloud Tenant</span>
                  </div>
                  <span class="px-2 py-0.5 rounded-full bg-emerald-50 text-[10px] font-bold text-emerald-700 uppercase tracking-wider">Connected</span>
                </div>

                <div class="bg-slate-950 rounded-2xl p-4 font-mono text-[10px] sm:text-[11px] text-slate-350 space-y-2 leading-relaxed overflow-x-auto shadow-inner">
                  <p class="text-slate-500">// Seeding sandboxed workspace...</p>
                  <p><span class="text-sky-400">GET</span> /api/licensing/provision-vouchers</p>
                  <p class="text-emerald-400">✔ AZ-900 Cloud Fundamentals [Seeded]</p>
                  <p class="text-emerald-400">✔ DP-900 Data Architecture [Seeded]</p>
                  <p class="text-emerald-400">✔ SC-900 Cloud Security [Seeded]</p>
                  <p class="text-slate-500">// Verifiable exam credentials active.</p>
                </div>

                <div class="flex items-center justify-between text-[11px] text-slate-500 pt-1.5 font-medium">
                  <span class="flex items-center gap-1">
                    <span class="material-symbols-outlined text-[13px] text-sky-600">dns</span>
                    Host: skystates-lab.org
                  </span>
                  <span class="flex items-center gap-1">
                    <span class="material-symbols-outlined text-[13px] text-emerald-600">verified</span>
                    Licensed Provider
                  </span>
                </div>

              </div>
            </div>

          </div>
        </div>
      </section>

      <!-- Main Contents -->
      <section class="max-w-7xl mx-auto px-4 sm:px-8 md:px-12 py-16 md:py-24 space-y-20 md:space-y-28">
        
        <!-- Intro & Partnership Focus -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-start">
          <div class="lg:col-span-5 accent-card bg-white p-6 sm:p-8 rounded-r-3xl shadow-sm border border-slate-200/80">
            <h2 class="text-2xl font-bold text-slate-900 mb-4">
              Building Bridges with Microsoft Licensing
            </h2>
            <p class="text-slate-600 text-sm sm:text-base leading-relaxed mb-4">
              In today's digital economy, cloud competencies are no longer optional. They are the bedrock of modern enterprise engineering. At Sky States, our mission is to deliver career-ready talents in Cloud Architecture, Cybersecurity, and Artificial Intelligence.
            </p>
            <p class="text-slate-600 text-sm sm:text-base leading-relaxed">
              To achieve this, we leverage official <strong>Microsoft License Services</strong> to provision sandboxed learning environments, distribute authorized exam vouchers (DP-900, SC-900, AZ-900), and build strong co-learning frameworks that connect academic training with industry standards.
            </p>
          </div>
          
          <div class="lg:col-span-7 space-y-6">
            <h3 class="text-lg font-bold text-slate-800 flex items-center gap-2">
              <span class="material-symbols-outlined text-sky-600">verified_user</span>
              Licensed Ecosystem Integration
            </h3>
            <p class="text-slate-500 text-sm leading-relaxed">
              Sky States uses official API integrations and organizational license allocations to host student cloud workspaces. This structural alignment with Microsoft standards provides learners with the most realistic hands-on scenarios possible, bridging the gap between local code edits and global production deployment.
            </p>
            <!-- Highlight grid -->
            <div class="grid grid-cols-2 gap-4 pt-2">
              <div class="p-4 rounded-2xl bg-white border border-slate-200/60 shadow-sm">
                <span class="block text-2xl font-extrabold text-sky-700">94%</span>
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Exam Pass Rate</span>
              </div>
              <div class="p-4 rounded-2xl bg-white border border-slate-200/60 shadow-sm">
                <span class="block text-2xl font-extrabold text-sky-700">100%</span>
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Verifiable Credentials</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Pillars of Integration -->
        <div class="space-y-8">
          <div class="text-center max-w-2xl mx-auto space-y-2">
            <h2 class="text-3xl font-extrabold text-slate-900">Key Licensing Operations</h2>
            <p class="text-slate-500 text-sm">How official partnerships empower students to build real systems</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
            
            <!-- Card 1 -->
            <div class="bg-white rounded-3xl p-6 border border-slate-200/80 shadow-sm space-y-5 hover:shadow-md hover:border-sky-350 hover:-translate-y-1 transition-all duration-300">
              <div class="w-10 h-10 rounded-2xl bg-sky-50 text-sky-600 flex items-center justify-center">
                <span class="material-symbols-outlined text-lg font-bold">vpn_key</span>
              </div>
              <div class="space-y-2">
                <div class="flex items-center justify-between">
                  <h3 class="text-base font-bold text-slate-900">Authorized Vouchers</h3>
                  <span class="px-2 py-0.5 rounded-full bg-slate-100 text-[8px] font-bold tracking-wider text-slate-500 uppercase">Verified</span>
                </div>
                <p class="text-xs sm:text-sm text-slate-500 leading-relaxed">
                  Direct provisioning of official Microsoft certification vouchers. Our licensed distribution ensures that every eligible student receives validated credentials upon completing coursework.
                </p>
              </div>
            </div>

            <!-- Card 2 -->
            <div class="bg-white rounded-3xl p-6 border border-slate-200/80 shadow-sm space-y-5 hover:shadow-md hover:border-sky-350 hover:-translate-y-1 transition-all duration-300">
              <div class="w-10 h-10 rounded-2xl bg-emerald-50 text-emerald-600 flex items-center justify-center">
                <span class="material-symbols-outlined text-lg font-bold">cloud_queue</span>
              </div>
              <div class="space-y-2">
                <div class="flex items-center justify-between">
                  <h3 class="text-base font-bold text-slate-900">Sandboxed Lab Tenants</h3>
                  <span class="px-2 py-0.5 rounded-full bg-emerald-50 text-[8px] font-bold tracking-wider text-emerald-600 uppercase">Active</span>
                </div>
                <p class="text-xs sm:text-sm text-slate-500 leading-relaxed">
                  By utilising enterprise-level Microsoft cloud licenses, we provide students with hands-on environments to configure Azure Active Directory, deploy Kubernetes, and run security audits safely.
                </p>
              </div>
            </div>

            <!-- Card 3 -->
            <div class="bg-white rounded-3xl p-6 border border-slate-200/80 shadow-sm space-y-5 hover:shadow-md hover:border-sky-350 hover:-translate-y-1 transition-all duration-300">
              <div class="w-10 h-10 rounded-2xl bg-amber-50 text-amber-600 flex items-center justify-center">
                <span class="material-symbols-outlined text-lg font-bold">handshake</span>
              </div>
              <div class="space-y-2">
                <div class="flex items-center justify-between">
                  <h3 class="text-base font-bold text-slate-900">Institutional Trust</h3>
                  <span class="px-2 py-0.5 rounded-full bg-slate-100 text-[8px] font-bold tracking-wider text-slate-500 uppercase">Registered</span>
                </div>
                <p class="text-xs sm:text-sm text-slate-500 leading-relaxed">
                  Licensing agreements establish a formal bridge between our curriculum and official Microsoft learning pathways, giving clients and corporate partners full trust in our graduates.
                </p>
              </div>
            </div>

          </div>
        </div>

        <!-- Detailed Operations Matrix -->
        <div class="space-y-8 bg-white border border-slate-200/80 rounded-3xl p-6 sm:p-8 md:p-10 shadow-sm">
          <div class="space-y-2">
            <h3 class="text-xl font-bold text-slate-900">Strategic Integration Matrix</h3>
            <p class="text-slate-500 text-sm">Review our structured license operations mapping curriculum to industry credentials.</p>
          </div>

          <div class="grid grid-cols-1 divide-y divide-slate-100 pt-4">
            
            <!-- Row 1 -->
            <div class="py-6 sm:py-8 flex flex-col md:flex-row gap-6 md:gap-8 items-start">
              <div class="md:w-1/3 space-y-1">
                <span class="text-[10px] font-bold uppercase tracking-wider text-sky-600 bg-sky-50 px-2.5 py-1 rounded-md inline-block">Curriculum Mapping</span>
                <h4 class="text-base font-bold text-slate-800 pt-1">
                  Curriculum Alignment
                </h4>
              </div>
              <div class="md:w-2/3">
                <p class="text-slate-600 text-sm leading-relaxed">
                  Our training materials are designed around official Microsoft Learn objectives. By integrating Microsoft License Services, we ensure that students are not just learning theoretical concepts, but are working with the actual software versions and Azure cloud portal experiences demanded by global employers.
                </p>
              </div>
            </div>

            <!-- Row 2 -->
            <div class="py-6 sm:py-8 flex flex-col md:flex-row gap-6 md:gap-8 items-start">
              <div class="md:w-1/3 space-y-1">
                <span class="text-[10px] font-bold uppercase tracking-wider text-emerald-600 bg-emerald-50 px-2.5 py-1 rounded-md inline-block">Corporate compliance</span>
                <h4 class="text-base font-bold text-slate-800 pt-1">
                  Enterprise Validation
                </h4>
              </div>
              <div class="md:w-2/3">
                <p class="text-slate-600 text-sm leading-relaxed">
                  For corporate clients seeking to upskill their engineering cohorts, our licensed delivery model guarantees that training meets compliance benchmarks. We handle the provisioning of software licenses, tracking student progress, and administering certifications under authorized guidelines.
                </p>
              </div>
            </div>

            <!-- Row 3 -->
            <div class="py-6 sm:py-8 flex flex-col md:flex-row gap-6 md:gap-8 items-start">
              <div class="md:w-1/3 space-y-1">
                <span class="text-[10px] font-bold uppercase tracking-wider text-amber-600 bg-amber-50 px-2.5 py-1 rounded-md inline-block">Infrastructure</span>
                <h4 class="text-base font-bold text-slate-800 pt-1">
                  Secure Infrastructure
                </h4>
              </div>
              <div class="md:w-2/3">
                <p class="text-slate-600 text-sm leading-relaxed">
                  All learning platforms and lab resources are secured using official Microsoft authentication mechanisms. This guarantees data privacy for both individual students and corporate clients, creating a trusted portal for career development.
                </p>
              </div>
            </div>

          </div>
        </div>

        <!-- Bottom CTA Glass Card -->
        <div class="relative rounded-3xl overflow-hidden p-8 sm:p-12 text-center space-y-6 border border-slate-200/80 bg-gradient-to-r from-sky-50 to-blue-50/50 shadow-sm flex flex-col items-center">
          <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-sky-100/30 via-transparent to-transparent opacity-60"></div>
          <div class="space-y-2 relative z-10 max-w-xl">
            <h3 class="text-2xl font-bold text-slate-900">Empower Your Technology Career</h3>
            <p class="text-sm text-slate-500 leading-relaxed">
              Enroll in a Sky States program today and gain access to official Microsoft vouchers, sandbox cloud systems, and professional career transitions.
            </p>
          </div>
          <div class="flex flex-wrap gap-4 justify-center relative z-10">
            <a
              href="/checkout?mode=full"
              class="px-6 py-3 rounded-xl text-white bg-gradient-to-r from-sky-600 to-blue-700 hover:from-sky-500 hover:to-blue-600 shadow-md font-semibold text-sm transition-all"
            >
              Enroll in Program
            </a>
            <a
              href="/contact-us"
              class="px-6 py-3 rounded-xl text-sky-700 bg-sky-50 border border-sky-200 hover:bg-sky-100 font-semibold text-sm transition-all"
            >
              Enterprise Solutions
            </a>
          </div>
        </div>

      </section>
    </main>

    <Footer />
  </body>
</html>
