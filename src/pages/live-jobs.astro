---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import jobsData from '../data/jobs.json';
export const prerender = false;
---

<!DOCTYPE html>
<html class="light" lang="en">
<head>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Geist:wght@400;600;700;800&display=swap" rel="stylesheet"/>

  <link rel="icon" type="image/png" href="/favicon.png" />
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Active Placements & Live Jobs | Sky States</title>
    <meta content="Explore active high-paying job opportunities available for graduates of Sky States career acceleration programs." name="description"/>
    <link rel="canonical" href="https://skystates.us/live-jobs" />
    
    <meta property="og:title" content="Active Placements & Live Jobs | Sky States" />
    <meta property="og:description" content="Explore active high-paying job opportunities available for graduates of Sky States career acceleration programs." />
    <meta property="og:type" content="website" />

    {jobsData.map((job: any) => (
        <script type="application/ld+json" is:inline set:html={JSON.stringify({
          "@context": "https://schema.org",
          "@type": "JobPosting",
          "title": job.title,
          "description": job.description || job.title,
          "datePosted": "2026-06-12",
          "hiringOrganization": {
            "@type": "Organization",
            "name": job.company,
            "sameAs": "https://skystates.us"
          },
          "jobLocation": {
            "@type": "Place",
            "address": {
              "@type": "PostalAddress",
              "addressLocality": job.location,
              "addressCountry": "US"
            }
          },
          "baseSalary": {
            "@type": "MonetaryAmount",
            "currency": "USD",
            "value": {
              "@type": "QuantitativeValue",
              "value": job.salary,
              "unitText": "YEAR"
            }
          }
        })} />
    ))}
    
    
    
    
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
        }
        .upward-gradient {
            background: linear-gradient(to top, #ffffff, #d3e2ed);
        }
        .ambient-shadow {
            box-shadow: 0 10px 30px -5px rgba(15, 29, 37, 0.04);
        }
    </style>
</head>
<body class="bg-background text-on-background font-body-md overflow-x-hidden">
    <!-- Top Nav -->
    <Header />

    <main class="max-w-[1280px] mx-auto px-margin-desktop py-12">
        <!-- Breadcrumbs -->
        <nav class="mb-6 text-[10px] font-bold uppercase tracking-widest text-secondary flex items-center gap-2">
            <a href="/" class="hover:text-primary transition-colors">Home</a>
            <span class="material-symbols-outlined text-[12px] opacity-40">chevron_right</span>
            <span class="text-on-surface-variant">Live Placements</span>
        </nav>
        <!-- Hero Header Section -->
        <div class="mb-12 rounded-xl p-12 upward-gradient flex flex-col gap-2 relative overflow-hidden shadow-sm">
            <div class="absolute -right-10 -top-10 w-40 h-40 bg-primary/5 rounded-full blur-2xl"></div>
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-primary text-white rounded-full w-fit text-xs font-bold uppercase tracking-wider mb-2">
                <span class="material-symbols-outlined text-[14px]">work</span>
                <span>Active Placements</span>
            </div>
            <h1 class="font-headline-xl text-headline-xl text-primary leading-tight">Live Career Openings</h1>
            <p class="text-on-surface-variant max-w-2xl font-body-lg text-body-lg">
                Verified high-prestige roles from our institutional partner networks. Available for immediate application.
            </p>
        </div>

        <!-- Search Controls -->
        <div class="mb-8 bg-surface-container-lowest p-6 rounded-xl border border-outline-variant/20 ambient-shadow">
            <div class="relative w-full">
                <input 
                    type="text" 
                    id="search-input" 
                    placeholder="Search by role, company, or skill..." 
                    class="w-full h-12 pl-12 pr-4 bg-white border border-outline-variant/30 rounded-lg outline-none focus:border-primary transition-all form-glow"
                />
                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-secondary">search</span>
            </div>
        </div>

        <!-- Jobs Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="jobs-container">
            {jobsData.map((job: any) => (
                <div class="job-card bg-surface-container-lowest p-6 rounded-xl border border-outline-variant/20 shadow-sm hover:shadow-md hover:border-primary/20 transition-all flex flex-col justify-between h-full group cursor-pointer" data-job={JSON.stringify(job)} data-tags={JSON.stringify(job.tags)} data-search-text={`${job.title} ${job.company} ${job.description} ${job.location}`}>
                    <div>
                        <!-- Header info -->
                        <div class="flex justify-between items-start mb-4">
                            <div>
                                <span class="text-xs uppercase tracking-wider text-secondary font-semibold">{job.company}</span>
                                <h3 class="font-headline-md text-lg font-bold text-on-surface mt-1 group-hover:text-primary transition-colors">{job.title}</h3>
                            </div>
                            <div class="w-12 h-12 rounded-lg overflow-hidden flex items-center justify-center bg-white border border-outline-variant/10 p-1 flex-shrink-0">
                                {job.featured_image ? (
                                    <img src={job.featured_image} alt={`${job.company} logo`} class="w-full h-full object-contain" />
                                ) : (
                                    <span class="material-symbols-outlined text-primary text-xl">work</span>
                                )}
                            </div>
                        </div>

                        <!-- Info tags -->
                        <div class="flex flex-col gap-1.5 text-xs text-on-surface-variant mb-4 font-medium">
                            <div class="flex items-center gap-1.5">
                                <span class="material-symbols-outlined text-sm">location_on</span>
                                <span>{job.location}</span>
                            </div>
                            <div class="flex items-center gap-1.5">
                                <span class="material-symbols-outlined text-sm">payments</span>
                                <span>{job.salary}</span>
                            </div>
                        </div>

                        <p class="text-sm text-secondary leading-relaxed mb-6 font-normal line-clamp-3">
                            {job.description}
                        </p>
                    </div>

                    <div>
                        <!-- Tags -->
                        <div class="flex flex-wrap gap-1.5 mb-6">
                            {job.tags.map((tag: any) => (
                                <span class="px-2.5 py-1 text-[10px] uppercase font-bold tracking-wider bg-surface-container text-secondary rounded-md">
                                    {tag}
                                </span>
                            ))}
                        </div>

                        <!-- Contact Us Button -->
                        <a href="/contact-us" class="flex items-center justify-center gap-1 w-full bg-primary text-white py-3 rounded-lg font-label-md text-xs uppercase tracking-wider hover:bg-opacity-90 transition-all font-bold text-center">
                            <span>Contact Us to Know More</span>
                            <span class="material-symbols-outlined text-sm">arrow_forward</span>
                        </a>
                    </div>
                </div>
            ))}
        </div>

        <div id="no-jobs-found" class="hidden text-center py-20 bg-surface-container-lowest rounded-xl border border-outline-variant/10 ambient-shadow">
            <span class="material-symbols-outlined text-secondary text-5xl mb-4">search_off</span>
            <h3 class="text-xl font-bold text-on-surface">No jobs found</h3>
            <p class="text-secondary mt-1">Try refining your search terms or tags.</p>
        </div>
    </main>

    <!-- Job Detail Full-screen Modal -->
    <div id="job-detail-modal" class="fixed inset-0 bg-black/60 backdrop-blur-md flex items-center justify-center hidden opacity-0 transition-opacity duration-300" style="z-index: 9999999999 !important;">
        <div class="bg-surface w-[calc(100%-2rem)] max-w-4xl h-[90vh] max-h-[800px] rounded-2xl md:rounded-3xl shadow-2xl relative flex flex-col overflow-hidden border border-outline-variant/20 translate-y-8 transition-transform duration-300" id="job-detail-panel">
            
            <!-- Close Button (Absolute positioned to prevent overlapping text) -->
            <button onclick="closeJobDetailModal()" class="absolute top-4 right-4 md:top-6 md:right-6 p-2 hover:bg-surface-container rounded-full text-secondary hover:text-primary transition-all duration-200 z-20">
                <span class="material-symbols-outlined text-[24px]">close</span>
            </button>

            <!-- Modal Header -->
            <div class="p-6 md:p-8 pr-12 md:pr-16 border-b border-outline-variant/20 bg-surface-container-low flex items-center gap-4">
                <div id="detail-logo-container" class="w-14 h-14 rounded-xl overflow-hidden flex items-center justify-center bg-white border border-outline-variant/20 p-1 flex-shrink-0 hidden">
                    <img id="detail-logo" src="" alt="Company logo" class="w-full h-full object-contain" />
                </div>
                <div>
                    <span id="detail-company" class="text-xs uppercase tracking-widest text-primary font-bold"></span>
                    <h2 id="detail-title" class="font-headline-xl text-xl sm:text-2xl md:text-3xl font-extrabold text-on-surface mt-1 leading-tight"></h2>
                    <div class="flex flex-wrap gap-x-4 gap-y-1.5 mt-2.5 text-xs text-on-surface-variant font-medium">
                        <div class="flex items-center gap-1.5">
                            <span class="material-symbols-outlined text-sm text-primary">location_on</span>
                            <span id="detail-location"></span>
                        </div>
                        <div class="flex items-center gap-1.5">
                            <span class="material-symbols-outlined text-sm text-primary">payments</span>
                            <span id="detail-salary"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Modal Content (Scrollable) -->
            <div class="flex-1 overflow-y-auto p-6 md:p-8 space-y-6 md:space-y-8">
                <!-- Job Description -->
                <div class="space-y-2 md:space-y-3">
                    <h4 class="font-label-md text-sm text-primary uppercase tracking-wider font-bold">Role Description</h4>
                    <p id="detail-description" class="text-secondary leading-relaxed font-normal text-sm md:text-base"></p>
                </div>

                <!-- Dynamic Responsibilities & Qualifications -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
                    <div class="space-y-2 md:space-y-3">
                        <h4 class="font-label-md text-sm text-primary uppercase tracking-wider font-bold">Key Responsibilities</h4>
                        <ul id="detail-responsibilities" class="space-y-2 text-secondary text-sm leading-relaxed list-disc pl-5"></ul>
                    </div>
                    <div class="space-y-2 md:space-y-3">
                        <h4 class="font-label-md text-sm text-primary uppercase tracking-wider font-bold">Position Requirements</h4>
                        <ul id="detail-requirements" class="space-y-2 text-secondary text-sm leading-relaxed list-disc pl-5"></ul>
                    </div>
                </div>

                <!-- Technologies Badges -->
                <div class="space-y-2 md:space-y-3">
                    <h4 class="font-label-md text-sm text-primary uppercase tracking-wider font-bold">Technologies & Skills</h4>
                    <div id="detail-tags" class="flex flex-wrap gap-2"></div>
                </div>

                <!-- Benefits & Trajectory -->
                <div class="bg-surface-container-low p-5 md:p-6 rounded-xl md:rounded-2xl border border-outline-variant/20 space-y-2">
                    <h4 class="font-label-md text-xs text-primary uppercase tracking-widest font-bold">Program Placement Advantages</h4>
                    <p class="text-secondary text-xs leading-relaxed">
                        This is an exclusive unlisted placement sourced through Sky States corporate staffing relations. Eligible graduates receive direct introductions to the hiring committee, warm referrals, and customized interview preparation based on actual client rubrics.
                    </p>
                </div>
            </div>

            <!-- Modal Footer -->
            <div class="p-6 md:p-8 border-t border-outline-variant/20 bg-surface-container-low flex flex-col sm:flex-row gap-3 justify-end">
                <button onclick="closeJobDetailModal()" class="px-6 py-3 border border-outline-variant/40 hover:bg-surface-container rounded-xl font-label-md text-xs uppercase tracking-wider font-bold transition-all text-center">
                    Close Details
                </button>
                <a href="/contact-us" class="px-8 py-3 bg-primary text-white hover:bg-opacity-90 rounded-xl font-label-md text-xs uppercase tracking-wider font-bold transition-all text-center flex items-center justify-center gap-2">
                    <span>Contact Us to Apply</span>
                    <span class="material-symbols-outlined text-sm">arrow_forward</span>
                </a>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <Footer />

    <script is:inline>
        const searchInput = document.getElementById('search-input');
        const jobCards = document.querySelectorAll('.job-card');
        const noJobs = document.getElementById('no-jobs-found');

        // Modal elements
        const detailModal = document.getElementById('job-detail-modal');
        const detailPanel = document.getElementById('job-detail-panel');
        const detailCompany = document.getElementById('detail-company');
        const detailTitle = document.getElementById('detail-title');
        const detailLocation = document.getElementById('detail-location');
        const detailSalary = document.getElementById('detail-salary');
        const detailDescription = document.getElementById('detail-description');
        const detailResponsibilities = document.getElementById('detail-responsibilities');
        const detailRequirements = document.getElementById('detail-requirements');
        const detailTags = document.getElementById('detail-tags');

        // Prepopulated detailed guidelines to look premium and authentic
        const jobDetailsCache = {
            "Senior AI Architect": {
                responsibilities: [
                    "Design, implement, and deploy large-scale LLM solutions and models to prevent fraud across high-volume pipelines.",
                    "Optimize training loops, tuning methodologies, and inference speeds utilizing PyTorch.",
                    "Collaborate with API management stakeholders to scale neural networks into serverless cloud environments."
                ],
                requirements: [
                    "Strong background (M.S. or Ph.D. preferred) in Computer Science, Applied Mathematics, or Deep Learning.",
                    "3+ years of professional development experience with Python, PyTorch, and Transformer pipelines.",
                    "Hands-on background with high-scale vector data architectures and MLOps platforms."
                ]
            },
            "Cloud DevOps Lead": {
                responsibilities: [
                    "Architect and orchestrate multi-region AWS environments using clean, modular Terraform configuration templates.",
                    "Implement reliable zero-downtime blue/green deployment structures and rollbacks.",
                    "Manage, scale, and secure multi-tenant Kubernetes clusters."
                ],
                requirements: [
                    "Expertise in AWS infrastructure governance, provisioning, and monitoring systems.",
                    "4+ years experience in CI/CD container automation pipelines (GitOps, Jenkins, Actions).",
                    "Proficiency in Go or Bash shell scripting for automate processes."
                ]
            },
            "Senior Security Engineer": {
                responsibilities: [
                    "Integrate zero-trust boundary architecture frameworks to safeguard private resources.",
                    "Continuously assess systems vulnerability vectors and deploy active threat mitigation measures.",
                    "Provide clear cryptographic guidance to align security models with international standard compliance protocols."
                ],
                requirements: [
                    "Active CISSP, SC-900, or equivalent professional cybersecurity credentials.",
                    "Deep administrative expertise in Microsoft Azure Sentinel and Active Directory.",
                    "Prior background orchestrating security operations center (SOC) remediation frameworks."
                ]
            }
        };

        function filterJobs() {
            const query = searchInput.value.toLowerCase();
            let visibleCount = 0;

            jobCards.forEach(card => {
                const searchText = card.getAttribute('data-search-text').toLowerCase();
                const matchesQuery = searchText.includes(query);

                if (matchesQuery) {
                    card.style.display = 'flex';
                    visibleCount++;
                } else {
                    card.style.display = 'none';
                }
            });

            if (visibleCount === 0) {
                noJobs.classList.remove('hidden');
            } else {
                noJobs.classList.add('hidden');
            }
        }

        window.openJobDetailModal = function(job) {
            // Populate basic info
            detailCompany.textContent = job.company;
            detailTitle.textContent = job.title;
            detailLocation.textContent = job.location;
            detailSalary.textContent = job.salary;
            detailDescription.textContent = job.description;

            // Populate logo if present
            const logoContainer = document.getElementById('detail-logo-container');
            const logoImg = document.getElementById('detail-logo');
            if (job.featured_image) {
                logoImg.src = job.featured_image;
                logoImg.alt = `${job.company} logo`;
                logoContainer.classList.remove('hidden');
            } else {
                logoContainer.classList.add('hidden');
            }

            // Clear dynamic elements
            detailResponsibilities.innerHTML = "";
            detailRequirements.innerHTML = "";
            detailTags.innerHTML = "";

            // Populate specific guidelines
            const cache = jobDetailsCache[job.title] || {
                responsibilities: ["Develop and implement key processes aligned with organizational targets.", "Work with cross-functional partners to identify roadmap opportunities."],
                requirements: ["Relevant degree or equivalent industrial experience.", "Proficiency with the core program technology stack."]
            };

            cache.responsibilities.forEach(resp => {
                const li = document.createElement('li');
                li.textContent = resp;
                detailResponsibilities.appendChild(li);
            });

            cache.requirements.forEach(req => {
                const li = document.createElement('li');
                li.textContent = req;
                detailRequirements.appendChild(li);
            });

            // Populate Tags
            job.tags.forEach(tag => {
                const span = document.createElement('span');
                span.className = "px-3 py-1 text-xs font-semibold bg-surface border border-outline-variant/30 rounded-full text-secondary";
                span.textContent = tag;
                detailTags.appendChild(span);
            });

            // Show modal
            detailModal.classList.remove('hidden');
            requestAnimationFrame(() => {
                detailModal.classList.remove('opacity-0');
                detailPanel.classList.remove('translate-y-8');
            });
        };

        window.closeJobDetailModal = function() {
            detailModal.classList.add('opacity-0');
            detailPanel.classList.add('translate-y-8');
            setTimeout(() => {
                detailModal.classList.add('hidden');
            }, 300);
        };

        // Attach card listeners safely
        jobCards.forEach(card => {
            card.addEventListener('click', (e) => {
                // If clicked on contact button, let it redirect without modal
                if (e.target.closest('a')) {
                    return;
                }
                const jobData = JSON.parse(card.getAttribute('data-job'));
                openJobDetailModal(jobData);
            });
        });

        // Close on backdrop click
        detailModal?.addEventListener('click', (e) => {
            if (e.target === detailModal) closeJobDetailModal();
        });

        searchInput?.addEventListener('input', filterJobs);
    </script>
</body>
</html>
