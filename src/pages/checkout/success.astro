---
import "../../styles/global.css";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { retrievePaidSession, finalizeCheckoutSession } from "../../lib/checkout.js";

export const prerender = false;

const sessionId = Astro.url.searchParams.get("session_id");
const isFreeCheckout = Astro.url.searchParams.get("free") === "1";
let payment = null;
let orderRef = "";
let emailSent = false;
let isProcessing = false;
let error = "";

if (isFreeCheckout) {
  payment = {
    status: "paid",
    amount_total: 0,
    id: "FREE-CHECKOUT",
    metadata: { courseName: "Sky States Program" },
    customer_email: "",
  };
} else if (sessionId) {
  try {
    const { ok, session, error: sessionError } = await retrievePaidSession(sessionId);

    if (ok && session) {
      const result = await finalizeCheckoutSession(session);
      orderRef = result.orderRef || session.metadata?.orderRef || "";
      emailSent = result.emailResult?.sent === true;

      payment = {
        status: session.payment_status,
        amount_total: session.amount_total,
        id: session.id,
        metadata: session.metadata || {},
        customer_email: session.customer_email || session.metadata?.customerEmail || "",
      };
    } else if (session && session.status === "complete" && session.payment_status === "unpaid") {
      isProcessing = true;
      payment = {
        status: "processing",
        amount_total: session.amount_total || 0,
        id: session.id,
        metadata: session.metadata || {},
        customer_email: session.customer_email || session.metadata?.customerEmail || "",
      };
      orderRef = session.metadata?.orderRef || "";
    } else {
      error = sessionError || "Your payment has not completed yet. Please contact support if funds were charged.";
    }
  } catch (err) {
    console.error("Success page error:", err);
    error = "Unable to verify your payment. Please contact support@skystates.us.";
  }
} else {
  error = "Missing payment reference.";
}
---

<!doctype html>
<html class="light" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Payment Successful | Sky States</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href="https://skystates.us/checkout/success" />
  </head>
  <body class="bg-slate-50/50 text-slate-800 font-sans min-h-screen">
    <Header />
    <main class="max-w-2xl mx-auto px-4 pt-32 pb-16">
      <section class="bg-white rounded-3xl p-8 sm:p-12 border border-slate-200/80 shadow-sm text-center">
        {
          payment && !error ? (
            <>
              <div class="mx-auto mb-6 h-16 w-16 rounded-full bg-green-50 border border-green-100 flex items-center justify-center">
                <span class="text-3xl">✓</span>
              </div>
              <h1 class="text-3xl font-extrabold text-slate-900 mb-3">
                {isProcessing ? "Payment Processing" : "Payment Successful"}
              </h1>
              <p class="text-slate-600 mb-6">
                {
                  isProcessing
                    ? <>Your payment is being confirmed. For bank transfers and some methods this can take 1–3 business days. We will email{" "}
                        {payment.metadata?.customerEmail || payment.customer_email || "you"} once it clears.</>
                    : payment.amount_total === 0
                    ? "Your enrollment is confirmed. Our team will follow up with next steps shortly."
                    : <>Thank you for enrolling with Sky States. A confirmation email has been sent to{" "}
                        {payment.metadata?.customerEmail || payment.customer_email || "your email"}.</>
                }
              </p>
              <div class="rounded-2xl bg-slate-50 border border-slate-100 p-5 text-left text-sm space-y-2 mb-8">
                <p><span class="font-semibold text-slate-700">Program:</span> {payment.metadata?.courseName || "Sky States Program"}</p>
                {
                  payment.amount_total > 0 && (
                    <>
                      <p><span class="font-semibold text-slate-700">Amount paid:</span> ${(payment.amount_total / 100).toFixed(2)} USD</p>
                      {orderRef && (
                        <p><span class="font-semibold text-slate-700">Order reference:</span> {orderRef}</p>
                      )}
                    </>
                  )
                }
                {!emailSent && payment.amount_total > 0 && (
                  <p class="text-xs text-amber-600 pt-2">Email delivery pending — save your order reference above.</p>
                )}
              </div>
              <div class="flex flex-col sm:flex-row gap-3 justify-center">
                <a href="/" class="inline-flex items-center justify-center h-12 px-6 bg-slate-900 hover:bg-slate-800 text-white rounded-xl text-xs uppercase font-bold tracking-wider transition-all">
                  Return Home
                </a>
              </div>
            </>
          ) : (
            <>
              <h1 class="text-2xl font-bold text-slate-900 mb-3">Payment Status</h1>
              <p class="text-slate-600 mb-8">{error}</p>
              <a href="/checkout" class="inline-flex items-center justify-center h-12 px-6 bg-slate-900 hover:bg-slate-800 text-white rounded-xl text-xs uppercase font-bold tracking-wider transition-all">
                Back to Checkout
              </a>
            </>
          )
        }
      </section>
    </main>
    <Footer />
  </body>
</html>
