---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Geist:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Contact Us - Sky States</title>
    <meta
      name="description"
      content="Get in touch with the Sky States team for enrollment inquiries, corporate partnerships, or career support assistance."
    />
    <link rel="canonical" href="https://skystates.us/contact-us" />
  </head>
  <body class="bg-surface text-on-surface font-body-md overflow-x-hidden">
    <Header />
    <main class="mt-20">
      <!-- Hero Section -->
      <section
        class="py-20 bg-surface-bright text-center px-6 border-b border-outline-variant/10"
      >
        <div class="max-w-4xl mx-auto space-y-6">
          <h1
            class="font-headline-xl text-5xl font-bold text-on-background leading-tight"
          >
            Get in Touch
          </h1>
          <p class="text-secondary font-body-lg max-w-2xl mx-auto">
            Have questions about our courses, seat deposits, or placement
            opportunities? Our support team is here to guide your technical
            career transition.
          </p>
        </div>
      </section>

      <!-- Information Grid -->
      <section class="py-section-gap max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
          <!-- Address Card -->
          <div
            class="p-8 rounded-3xl bg-surface-container-lowest border border-outline-variant/10 shadow-sm space-y-4 hover:shadow-md transition-all"
          >
            <div
              class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-primary"
            >
              <span class="material-symbols-outlined text-2xl">location_on</span
              >
            </div>
            <h3 class="font-headline-md text-xl font-bold">Our Headquarters</h3>
            <p class="text-secondary">
              1316 Wall St, Suite 2C,<br />
              Everett, WA 98201, USA
            </p>
          </div>

          <!-- Call Card -->
          <div
            class="p-8 rounded-3xl bg-surface-container-lowest border border-outline-variant/10 shadow-sm space-y-4 hover:shadow-md transition-all"
          >
            <div
              class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-primary"
            >
              <span class="material-symbols-outlined text-2xl">phone</span>
            </div>
            <h3 class="font-headline-md text-xl font-bold">Call Toll-Free</h3>
            <p class="text-secondary space-y-1">
              Reach out directly for rapid assistance:<br />
              <a
                href="tel:+18888102434"
                class="text-primary font-bold hover:underline">(888) 810-2434</a
              ><br />
            </p>
          </div>

          <!-- Email Card -->
          <div
            class="p-8 rounded-3xl bg-surface-container-lowest border border-outline-variant/10 shadow-sm space-y-4 hover:shadow-md transition-all"
          >
            <div
              class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-primary"
            >
              <span class="material-symbols-outlined text-2xl">mail</span>
            </div>
            <h3 class="font-headline-md text-xl font-bold">
              Email Communications
            </h3>
            <p class="text-secondary flex flex-col gap-0.5">
              <a
                href="mailto:info@skystates.us"
                class="text-primary font-bold hover:underline"
                >info@skystates.us</a
              >
              <a
                href="mailto:support@skystates.us"
                class="text-primary font-bold hover:underline"
                >support@skystates.us</a
              >
            </p>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
