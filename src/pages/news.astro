<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            display: inline-block;
            vertical-align: middle;
        }
        .upward-gradient {
            background: linear-gradient(to top, #ffffff, #d6e5ef);
        }
        .ambient-shadow {
            box-shadow: 0 30px 60px -12px rgba(15, 29, 37, 0.04);
        }
        .hover-lift {
            transition: transform 0.4s cubic-bezier(0.2, 1, 0.3, 1), box-shadow 0.4s ease;
        }
        .hover-lift:hover {
            transform: translateY(-8px);
            box-shadow: 0 40px 80px -15px rgba(15, 29, 37, 0.08);
        }
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .no-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>

<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
