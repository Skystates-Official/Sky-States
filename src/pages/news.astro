  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Geist:wght@400;600;700;800&display=swap" rel="stylesheet"/>

  <link rel="icon" type="image/png" href="/favicon.png" />
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Sky States | Industry Insights &amp; Career Intelligence</title>
<meta name="description" content="Read our latest technical insights, architectural guides, career transition reports, and market analyses for senior tech roles." />
