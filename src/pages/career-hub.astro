<img alt="Data Science Professional Guide" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAIbcUTXhb_vFXbDmSgk3HaknYUqXc8K1wBM25A-AWCQDv-6pqjCE5KBkbS5f72foe1Vh2qPrdNhKAE0z0B4k10rks8TtbtPps_CVpdE-B7XElVAPv-oq713fMAjb5OTQTQ2w4XWcaPSnohqMdpLUadxHwZM6kGXgXrCvsP6d_2FFnQCGBvOCLQ-mWST_u_GyUWOK9YuCxJLWPRiOMsBA9K38PWIqh6hxPX0wo15yAzOIyAR_IG_8ouWrcvJrnjW3Jg4Nr_9vvpJs4"/>
</div>
<div class="p-6 flex flex-col flex-1">
