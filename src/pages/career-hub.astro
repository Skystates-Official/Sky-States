<div class="aspect-[4/3] overflow-hidden">
<img alt="SOC Analyst Career Path" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="https://lh3.googleusercontent.com/aida-public/AB6AXuC3eEQK4GDpJO3UzjC1aWAxT7qqt6c_RoQKHHH_zrPvjEKd4ELOFdFCOE9WPDow-VXZu4pXOrkKW0nsFp0VgiAKyhg71Q72u1bjuM6oAe_SNGzm1p3UFge9K2TA5pd-v0ztkCF4V-jYD51A3JtaKscxkgGTjBPwK3cDJEtnFcecS-0QvcCnO7ia10v0wOOr5PHszamBjLmjtoHfAzKQTVPrQVsZWd41m38oD3y7Ak5EScdG1fp7kaF3tahAcG0Ul9B9PleWZ0zfdoc"/>
