<div class="aspect-[4/3] overflow-hidden">
<img alt="Cloud Architect Strategy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDMweYiKLy9a5CYN7Rw3vzhM2ThggWVxb7jjeYSe7OPE7dxP_EEgV-x29pWU2DYvDgMTv0yfCMLlNiTYb1Q2N-kb5BuN1QAnyeEcIxMC_DUfMNKGuBZwFglDo0ujPHZ5l7-PGfcLJSU2bBQUHbLr4SJktF8D9q0gFhgDv_pEohFEvRFDAt-0K6XsZWp60wrdQlqCMgwFDN0E8X4HwkvEaXtjv7FK9du8sB-DI7vL2RoHwvHAwS1_jl8O_Zk5XrfC1eqHAvlGkzAsq4"/>
