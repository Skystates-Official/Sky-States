---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import faqData from '../data/faq.json';

const { hero, questions } = faqData;
---

<!DOCTYPE html>

<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Institutional Knowledge Base | Sky States</title>
<!-- Google Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&amp;display=swap" rel="stylesheet"/>
<!-- Material Symbols -->
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>

<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .upward-gradient {
            background: linear-gradient(180deg, #d3e2ed 0%, #f9f9f9 100%);
        }
        .ambient-shadow {
            box-shadow: 0 10px 30px -10px rgba(15, 29, 37, 0.04);
        }
        .glass-blur {
            backdrop-filter: blur(8px);
            background: rgba(255, 255, 255, 0.7);
        }
        details > summary::-webkit-details-marker {
            display: none;
        }
        details[open] .collapse-icon {
            transform: rotate(180deg);
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-surface text-on-surface font-body-md selection:bg-primary-fixed selection:text-on-primary-fixed">
<!-- TopAppBar -->
<Header />
<main class="pt-20">
<section class="upward-gradient pt-24 pb-16 px-4 md:px-16">
<div class="max-w-4xl mx-auto text-center">
<span class="inline-block px-4 py-1 rounded-full bg-primary-fixed text-on-primary-fixed-variant font-label-sm text-label-sm mb-6 uppercase tracking-widest">{hero.badge}</span>
<h1 class="font-headline-xl text-headline-xl text-on-surface mb-6">{hero.title}</h1>
<p class="font-body-lg text-body-lg text-on-surface-variant mb-12 max-w-2xl mx-auto">
    {hero.description}
</p>
</div>
</section>

<!-- Category Grid -->
<section class="py-section-gap px-4 md:px-16 max-w-7xl mx-auto">
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-6">
<div class="bg-surface-container-lowest p-8 rounded-xl ambient-shadow hover:scale-[1.02] transition-transform cursor-pointer group">
<span class="material-symbols-outlined text-primary mb-4 text-4xl group-hover:scale-110 transition-transform">how_to_reg</span>
<h3 class="font-headline-md text-headline-md mb-2">Enrollment &amp; Sales</h3>
<p class="font-label-sm text-label-sm text-on-surface-variant">Admission windows and verification.</p>
</div>
<div class="bg-surface-container-lowest p-8 rounded-xl ambient-shadow hover:scale-[1.02] transition-transform cursor-pointer group">
<span class="material-symbols-outlined text-primary mb-4 text-4xl group-hover:scale-110 transition-transform">payments</span>
<h3 class="font-headline-md text-headline-md mb-2">Pricing &amp; Payments</h3>
<p class="font-label-sm text-label-sm text-on-surface-variant">Investment structures and plans.</p>
</div>
<div class="bg-surface-container-lowest p-8 rounded-xl ambient-shadow hover:scale-[1.02] transition-transform cursor-pointer group border-b-4 border-primary">
<span class="material-symbols-outlined text-primary mb-4 text-4xl group-hover:scale-110 transition-transform">school</span>
<h3 class="font-headline-md text-headline-md mb-2">Curriculum &amp; Training</h3>
<p class="font-label-sm text-label-sm text-on-surface-variant">Certification pathways and modules.</p>
</div>
<div class="bg-surface-container-lowest p-8 rounded-xl ambient-shadow hover:scale-[1.02] transition-transform cursor-pointer group">
<span class="material-symbols-outlined text-primary mb-4 text-4xl group-hover:scale-110 transition-transform">work</span>
<h3 class="font-headline-md text-headline-md mb-2">Placement &amp; Careers</h3>
<p class="font-label-sm text-label-sm text-on-surface-variant">Job-ready metrics and coaching.</p>
</div>
<div class="bg-surface-container-lowest p-8 rounded-xl ambient-shadow hover:scale-[1.02] transition-transform cursor-pointer group">
<span class="material-symbols-outlined text-primary mb-4 text-4xl group-hover:scale-110 transition-transform">verified_user</span>
<h3 class="font-headline-md text-headline-md mb-2">Privacy &amp; Security</h3>
<p class="font-label-sm text-label-sm text-on-surface-variant">Data standards and SSL integrity.</p>
</div>
</div>
</section>

<!-- Top Queries (Accordions) -->
<section class="bg-surface-container-low py-section-gap px-4 md:px-16">
<div class="max-w-4xl mx-auto">
<div class="flex items-center justify-between mb-12">
<h2 class="font-headline-lg text-headline-lg text-on-surface">Top Queries &amp; Compliance</h2>
</div>
<div class="space-y-4">
    {questions.map((question) => (
        <details class="group bg-surface-container-lowest rounded-xl overflow-hidden ambient-shadow">
            <summary class="flex justify-between items-center p-6 cursor-pointer hover:bg-surface-container transition-colors list-none">
                <span class="font-headline-md text-headline-md text-on-surface">{question.q}</span>
                <span class="material-symbols-outlined transition-transform duration-300 collapse-icon text-primary">expand_more</span>
            </summary>
            <div class="px-6 pb-6 pt-2 text-on-surface-variant" set:html={question.a}>
            </div>
        </details>
    ))}
</div>
</div>
</section>
</main>
<!-- Footer -->
<Footer />
</body></html>