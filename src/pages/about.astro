---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import aboutData from '../data/about.json';

const { hero, story, registry } = aboutData;
export const prerender = false;
---

<!DOCTYPE html>

<html class="light" lang="en"><head>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Geist:wght@400;600;700;800&display=swap" rel="stylesheet"/>

  <link rel="icon" type="image/png" href="/favicon.png" />
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Institutional Registry &amp; Corporate Dossier | Sky States</title>
<meta name="description" content="Learn about Sky States, our mission, story, vision, and legal corporate registries in Delaware and Wyoming." />
<link rel="canonical" href="https://skystates.us/about" />
<meta property="og:title" content="About Sky States | Institutional Excellence in Tech Careers" />
<meta property="og:description" content="Learn about Sky States, our mission, story, vision, and legal corporate registries in Delaware and Wyoming." />
<meta property="og:type" content="website" />

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  "name": "Sky States",
  "url": "https://skystates.us",
  "logo": "https://skystates.us/logo.svg",
  "description": "US-registered career platform offering live instructor-led training and placement support in high-demand technology roles.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "30 N Gould St",
    "addressLocality": "Sheridan",
    "addressRegion": "WY",
    "postalCode": "82801",
    "addressCountry": "US"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+1-888-810-2434",
    "contactType": "customer service",
    "email": "info@skystates.us"
  }
}
</script>





<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .upward-gradient {
            background: linear-gradient(to top, #ffffff 0%, #d3e2ed 100%);
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(10px);
        }
        .text-midnight { color: #0f1d25; }
        .bg-horizon { background-color: #0077b6; }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(24px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .animate-team-card {
            opacity: 0;
            animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-background font-body-md text-on-surface">
<!-- TopAppBar -->
<Header />
<main>
<!-- Editorial Hero -->
<section class="relative w-full pt-20 pb-32 overflow-hidden upward-gradient">
<div class="max-w-[1280px] mx-auto px-margin-desktop grid grid-cols-1 md:grid-cols-2 items-center gap-gutter relative z-10">
<div class="space-y-6">
<span class="inline-block px-4 py-1 rounded-full bg-secondary-container text-on-secondary-container text-label-sm uppercase tracking-widest">{hero.badge}</span>
<h1 class="font-headline-xl text-headline-xl text-midnight leading-tight">{hero.title}</h1>
<p class="text-body-lg text-on-surface-variant max-w-xl">{hero.description}</p>
</div>
<div class="hidden md:block relative h-[500px]">
<div class="absolute inset-0 bg-white/20 rounded-xl overflow-hidden shadow-[0_30px_30px_rgba(0,0,0,0.04)]">
<img class="w-full h-full object-cover" alt="A serene, minimalist digital render of a wide-open sky during dawn." src="https://lh3.googleusercontent.com/aida-public/AB6AXuAVXdCtcsLtrGBHQO8yoFH2I5xbRvNJxnjWo86QnFxf7dj5ZMz6CQB1EC5DjhpMk0zm95v3jo4nsgZuF4iH9bfL2DqHna1Xr7w8sqaBwiYQ44ZrLgmOT9Z6MrEw9yk0qG1L0UcHQzxMo76TCehTYyS3OXp0MMFhEdb54lBmgJNMMscRNWEVEBqEBtaHEh_8GCeNQXCAHE7idOhObUohs9zGpRy4p66-CD1gyqbXr4Ea6po7KEn0kW3j1FbZWl9IXvl378AB1Tl4Zvo"/>
</div>
</div>
</div>
</section>
<!-- The Sky States Story (Narrative) -->
<section class="max-w-[1280px] mx-auto px-margin-desktop mt-section-gap">
<div class="flex flex-col md:flex-row gap-gutter">
<div class="md:w-1/3">
<h2 class="font-headline-lg text-headline-lg text-primary">{story.title}</h2>
</div>
<div class="md:w-2/3 space-y-8">
<p class="font-body-lg text-on-surface leading-relaxed">{story.paragraph}</p>
<div class="grid grid-cols-1 md:grid-cols-2 gap-gutter">
<div class="space-y-4">
<h4 class="font-label-md text-primary">{story.vision_title}</h4>
<p class="text-body-md text-on-surface-variant">{story.vision_desc}</p>
</div>
<div class="space-y-4">
<h4 class="font-label-md text-primary">{story.method_title}</h4>
<p class="text-body-md text-on-surface-variant">{story.method_desc}</p>
</div>
</div>
</div>
</div>
</section>
<!-- Institutional Registry -->
<section class="max-w-[1280px] mx-auto px-margin-desktop mt-section-gap">
<div class="bg-surface-container-low rounded-xl p-12 shadow-[0_30px_30px_rgba(0,0,0,0.04)] border border-outline-variant/30">
<div class="grid grid-cols-1 md:grid-cols-3 gap-12">
<div class="space-y-4">
<span class="material-symbols-outlined text-primary-container" style="font-variation-settings: 'FILL' 1;">verified</span>
<h3 class="font-headline-md text-headline-md text-on-surface">{registry.legal_title}</h3>
<p class="text-body-md text-on-surface-variant">{registry.legal_desc}</p>
<div class="pt-4 border-t border-outline-variant space-y-2">
<p class="text-label-md text-on-surface">
  <a href="https://icis.corp.delaware.gov/ecorp/" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline inline-flex items-center gap-1 font-semibold">
    Verify Delaware Registry (#8291-XX) <span class="material-symbols-outlined text-xs">open_in_new</span>
  </a>
</p>
<p class="text-label-md text-on-surface">
  <a href="https://wyobiz.wyo.gov/Business/FilingSearch.aspx" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline inline-flex items-center gap-1 font-semibold">
    Verify Wyoming Corporate ID (#X229-L) <span class="material-symbols-outlined text-xs">open_in_new</span>
  </a>
</p>
</div>
</div>
<div class="space-y-4">
<span class="material-symbols-outlined text-primary-container" style="font-variation-settings: 'FILL' 1;">location_on</span>
<h3 class="font-headline-md text-headline-md text-on-surface">{registry.presence_title}</h3>
<div class="space-y-6">
<div>
<p class="text-label-sm text-primary uppercase">Corporate Office</p>
<p class="text-body-md text-on-surface">{registry.wyoming_address}</p>
</div>
</div>
</div>
<div class="space-y-4">
<span class="material-symbols-outlined text-primary-container" style="font-variation-settings: 'FILL' 1;">contact_support</span>
<h3 class="font-headline-md text-headline-md text-on-surface">{registry.contact_title}</h3>
<p class="text-body-md text-on-surface-variant">For official inquiries, compliance audits, or partnership proposals.</p>
<div class="space-y-2 pt-4">
<a class="flex items-center gap-2 text-label-md text-primary hover:underline transition-all" href="tel:+18888102434">
<span class="material-symbols-outlined text-sm">call</span> (888) 810-2434
                            </a>
<a class="flex items-center gap-2 text-label-md text-primary hover:underline transition-all" href="tel:+18889277072">
<span class="material-symbols-outlined text-sm">call</span> (888) 927-7072
                            </a>
<a class="flex items-center gap-2 text-label-md text-primary hover:underline transition-all" href={`mailto:${registry.email}`}>
<span class="material-symbols-outlined text-sm">mail</span> {registry.email}
                            </a>
</div>
</div>
</div>
</div>
</section>
<!-- What We Are vs What We Are Not -->
<section class="max-w-[1280px] mx-auto px-margin-desktop mt-section-gap">
<div class="text-center mb-16">
<h2 class="font-headline-lg text-headline-lg text-on-surface">Defining Our Standards</h2>
<p class="text-body-md text-on-surface-variant max-w-2xl mx-auto mt-4">We maintain transparency by clearly defining the boundaries of our services and our commitment to quality.</p>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 border border-outline-variant rounded-xl overflow-hidden shadow-[0_30px_30px_rgba(0,0,0,0.04)]">
<div class="bg-surface p-10 md:border-r border-outline-variant">
<h3 class="font-headline-md text-headline-md text-primary flex items-center gap-3 mb-8">
<span class="material-symbols-outlined">check_circle</span>
                        What We Are
                    </h3>
<ul class="space-y-6">
<li class="flex items-start gap-4">
<span class="material-symbols-outlined text-primary pt-1">done</span>
<div>
<p class="text-label-md text-on-surface">Live Instructor-Led</p>
<p class="text-body-md text-on-surface-variant">Every session is taught live by industry veterans for real-time interaction.</p>
</div>
</li>
<li class="flex items-start gap-4">
<span class="material-symbols-outlined text-primary pt-1">done</span>
<div>
<p class="text-label-md text-on-surface">Outcome Focused</p>
<p class="text-body-md text-on-surface-variant">Success is measured by career placements and salary escalations.</p>
</div>
</li>
<li class="flex items-start gap-4">
<span class="material-symbols-outlined text-primary pt-1">done</span>
<div>
<p class="text-label-md text-on-surface">Institutionally Accountable</p>
<p class="text-body-md text-on-surface-variant">We provide full legal and financial transparency to all our stakeholders.</p>
</div>
</li>
</ul>
</div>
<div class="bg-surface-container-low p-10">
<h3 class="font-headline-md text-headline-md text-error flex items-center gap-3 mb-8">
<span class="material-symbols-outlined">cancel</span>
                        What We Are Not
                    </h3>
<ul class="space-y-6">
<li class="flex items-start gap-4">
<span class="material-symbols-outlined text-error pt-1">close</span>
<div>
<p class="text-label-md text-on-surface">Pre-Recorded Video Library</p>
<p class="text-body-md text-on-surface-variant">We do not sell static content. Our value is in synchronous expert mentorship.</p>
</div>
</li>
<li class="flex items-start gap-4">
<span class="material-symbols-outlined text-error pt-1">close</span>
<div>
<p class="text-label-md text-on-surface">A Certification Mill</p>
<p class="text-body-md text-on-surface-variant">We prioritize skills and portfolio results over generic certificates.</p>
</div>
</li>
<li class="flex items-start gap-4">
<span class="material-symbols-outlined text-error pt-1">close</span>
<div>
<p class="text-label-md text-on-surface">Anonymous Support</p>
<p class="text-body-md text-on-surface-variant">We do not outsource support. You have direct access to our core team.</p>
</div>
</li>
</ul>
</div>
</div>
</section>

<!-- Core Leadership Team Section -->
<section class="max-w-[1280px] mx-auto px-margin-desktop mt-section-gap">
<div class="text-center mb-16">
<span class="inline-block px-4 py-1 rounded-full bg-primary-container text-on-primary-container text-label-sm uppercase tracking-widest font-bold">Executive Board</span>
<h2 class="font-headline-lg text-headline-lg text-on-surface mt-4">Core Leadership Team</h2>
<p class="text-body-md text-on-surface-variant max-w-2xl mx-auto mt-2">Our institution is guided by veteran engineers, security directors, and platform architects dedicated to student placement outcomes.</p>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
  <!-- CTO Card -->
  <div class="animate-team-card bg-white rounded-2xl overflow-hidden border border-outline-variant/30 shadow-[0_10px_30px_rgba(0,0,0,0.02)] hover:shadow-lg hover:-translate-y-1.5 hover:border-primary/20 transition-all duration-300 flex flex-col" style="animation-delay: 100ms;">
    <div class="h-64 overflow-hidden relative bg-slate-100">
      <img src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=400&auto=format&fit=crop" alt="Dr. Evelyn Sterling" class="w-full h-full object-cover object-top hover:scale-105 transition-transform duration-500" />
    </div>
    <div class="p-6 text-center space-y-1">
      <h3 class="font-bold text-lg text-midnight">Dr. Evelyn Sterling</h3>
      <p class="text-primary text-xs font-semibold uppercase tracking-wider">Chief Technology Officer</p>
    </div>
  </div>

  <!-- Security Card -->
  <div class="animate-team-card bg-white rounded-2xl overflow-hidden border border-outline-variant/30 shadow-[0_10px_30px_rgba(0,0,0,0.02)] hover:shadow-lg hover:-translate-y-1.5 hover:border-primary/20 transition-all duration-300 flex flex-col" style="animation-delay: 200ms;">
    <div class="h-64 overflow-hidden relative bg-slate-100">
      <img src="https://images.unsplash.com/photo-1560250097-0b93528c311a?q=80&w=400&auto=format&fit=crop" alt="Arthur Vance" class="w-full h-full object-cover object-top hover:scale-105 transition-transform duration-500" />
    </div>
    <div class="p-6 text-center space-y-1">
      <h3 class="font-bold text-lg text-midnight">Arthur Vance</h3>
      <p class="text-primary text-xs font-semibold uppercase tracking-wider">Director of Security Operations</p>
    </div>
  </div>

  <!-- DevOps Card -->
  <div class="animate-team-card bg-white rounded-2xl overflow-hidden border border-outline-variant/30 shadow-[0_10px_30px_rgba(0,0,0,0.02)] hover:shadow-lg hover:-translate-y-1.5 hover:border-primary/20 transition-all duration-300 flex flex-col" style="animation-delay: 300ms;">
    <div class="h-64 overflow-hidden relative bg-slate-100">
      <img src="https://images.unsplash.com/photo-1580489944761-15a19d654956?q=80&w=400&auto=format&fit=crop" alt="Sarah Jenkins" class="w-full h-full object-cover object-top hover:scale-105 transition-transform duration-500" />
    </div>
    <div class="p-6 text-center space-y-1">
      <h3 class="font-bold text-lg text-midnight">Sarah Jenkins</h3>
      <p class="text-primary text-xs font-semibold uppercase tracking-wider">Head of DevOps & Placements</p>
    </div>
  </div>

  <!-- Manager Card -->
  <div class="animate-team-card bg-white rounded-2xl overflow-hidden border border-outline-variant/30 shadow-[0_10px_30px_rgba(0,0,0,0.02)] hover:shadow-lg hover:-translate-y-1.5 hover:border-primary/20 transition-all duration-300 flex flex-col" style="animation-delay: 400ms;">
    <div class="h-64 overflow-hidden relative bg-slate-100">
      <img src="https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?q=80&w=400&auto=format&fit=crop" alt="David Choi" class="w-full h-full object-cover object-top hover:scale-105 transition-transform duration-500" />
    </div>
    <div class="p-6 text-center space-y-1">
      <h3 class="font-bold text-lg text-midnight">David Choi</h3>
      <p class="text-primary text-xs font-semibold uppercase tracking-wider">Student Success Manager</p>
    </div>
  </div>
</div>
</section>

<!-- Leadership & Authority (Editorial Standards) -->
<section class="max-w-[1280px] mx-auto px-margin-desktop mt-section-gap">
<div class="flex flex-col md:flex-row items-center gap-gutter bg-primary-container p-16 rounded-xl text-on-primary-container overflow-hidden relative">
<div class="relative z-10 md:w-1/2 space-y-6">
<h2 class="text-headline-xl text-white font-bold">Sky States Standards</h2>
<p class="text-body-lg text-blue-100 opacity-90">Every curriculum, mentor, and interaction is governed by the Sky States Board. We ensure that our educational products meet the highest benchmarks of technical accuracy and professional relevance.</p>
<div class="flex flex-wrap gap-4 pt-4">
<span class="px-4 py-2 bg-white/20 rounded-full text-label-sm backdrop-blur-md">Quarterly Audits</span>
<span class="px-4 py-2 bg-white/20 rounded-full text-label-sm backdrop-blur-md">Subject Matter Experts</span>
<span class="px-4 py-2 bg-white/20 rounded-full text-label-sm backdrop-blur-md">Compliance First</span>
</div>
</div>
</div>
</section>
</main>
<!-- Footer -->
<Footer />
</body></html>