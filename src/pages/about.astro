---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import aboutData from "../data/about.json";

const { hero, story, registry, team = [] } = aboutData;
export const prerender = false;
---

<!doctype html>
<html class="light" lang="en">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Geist:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Institutional Registry &amp; Corporate Dossier | Sky States</title>
    <meta
      name="description"
      content="Learn about Sky States, our mission, story, vision, and legal corporate registries in Delaware and Wyoming."
    />
    <link rel="canonical" href="https://skystates.us/about" />
    <meta
      property="og:title"
      content="About Sky States | Institutional Excellence in Tech Careers"
    />
    <meta
      property="og:description"
      content="Learn about Sky States, our mission, story, vision, and legal corporate registries in Delaware and Wyoming."
    />
    <meta property="og:type" content="website" />

    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "EducationalOrganization",
        "name": "Sky States",
        "url": "https://skystates.us",
        "logo": "https://skystates.us/logo.svg",
        "description": "US-registered career platform offering live instructor-led training and placement support in high-demand technology roles.",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "1316 Wall St, Suite 2C",
          "addressLocality": "Everett",
          "addressRegion": "WA",
          "postalCode": "98201",
          "addressCountry": "US"
        },
        "contactPoint": {
          "@type": "ContactPoint",
          "telephone": "+1-888-810-2434",
          "contactType": "customer service",
          "email": ["info@skystates.us", "support@skystates.us"]
        }
      }
    </script>

    <style>
      .material-symbols-outlined {
        font-variation-settings:
          "FILL" 0,
          "wght" 400,
          "GRAD" 0,
          "opsz" 24;
      }
      .upward-gradient {
        background: linear-gradient(to top, #ffffff 0%, #d3e2ed 100%);
      }
      .glass-card {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(10px);
      }
      .text-midnight {
        color: #0f1d25;
      }
      .bg-horizon {
        background-color: #0077b6;
      }

      @keyframes fadeInUp {
        from {
          opacity: 0;
          transform: translateY(24px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .animate-team-card {
        opacity: 0;
        animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }
    </style>
    <style>
      body {
        min-height: max(884px, 100dvh);
      }
    </style>
  </head>
  <body class="bg-slate-50/50 text-slate-800 font-sans min-h-screen">
    <!-- TopAppBar -->
    <Header />
    <main>
      <!-- Editorial Hero -->
      <section
        class="relative w-full pt-28 md:pt-36 pb-32 overflow-hidden bg-gradient-to-b from-sky-50 via-white to-slate-50/30 border-b border-slate-100"
      >
        <div
          class="max-w-[1280px] mx-auto px-4 md:px-margin-desktop grid grid-cols-1 md:grid-cols-2 items-center gap-12 relative z-10"
        >
          <div class="space-y-6">
            <span
              class="inline-block mb-10 px-4 py-1.5 rounded-full bg-sky-50 border border-sky-100 text-sky-700 text-xs font-bold uppercase tracking-wider"
              >{hero.badge}</span
            >
            <!-- Our Mission Card -->
            <div class="space-y-6">
              <h3 class="text-4xl font-bold text-slate-900">
                {story.vision_title}
              </h3>
              <p class="text-slate-650 text-sm sm:text-base leading-relaxed">
                {story.vision_desc}
              </p>
            </div>

            <h1 class="text-3xl font-bold text-slate-900 tracking-tight">
              {hero.title}
            </h1>
            <p class="text-slate-650 text-sm sm:text-base leading-relaxed">
              {hero.description}
            </p>
          </div>
          <div class="hidden md:block relative h-[450px]">
            <!-- Glowing background ambient light -->
            <div
              class="absolute -inset-4 bg-gradient-to-tr from-sky-400/20 to-blue-500/20 blur-3xl opacity-85 rounded-full"
            >
            </div>
            <div
              class="relative p-1.5 bg-gradient-to-b from-slate-100 via-slate-200/60 to-slate-300 rounded-[24px] shadow-2xl border border-slate-200/30 overflow-hidden w-full h-full"
            >
              <img
                class="w-full h-full object-cover object-top rounded-[18px]"
                alt="Sky States corporate headquarters building"
                src="/admin/Sky_states_building.png"
              />
            </div>
          </div>
        </div>
      </section>

      <!-- Stats Section -->
      <section
        class="max-w-[1280px] mx-auto px-4 md:px-margin-desktop -mt-16 relative z-20"
      >
        <div
          class="bg-white/85 backdrop-blur-md rounded-3xl p-8 md:p-10 border border-slate-200/80 shadow-lg grid grid-cols-2 md:grid-cols-4 gap-8 text-center"
        >
          <div class="space-y-1">
            <h3 class="text-3xl md:text-4xl font-black text-sky-600">5,000+</h3>
            <p
              class="text-[10px] md:text-xs uppercase font-bold text-slate-500 tracking-wider"
            >
              Careers Accelerated
            </p>
          </div>
          <div class="space-y-1 border-l border-slate-200">
            <h3 class="text-3xl md:text-4xl font-black text-sky-600">140%</h3>
            <p
              class="text-[10px] md:text-xs uppercase font-bold text-slate-500 tracking-wider"
            >
              Average Salary Lift
            </p>
          </div>
          <div class="space-y-1 border-l border-slate-200">
            <h3 class="text-3xl md:text-4xl font-black text-sky-600">96%</h3>
            <p
              class="text-[10px] md:text-xs uppercase font-bold text-slate-500 tracking-wider"
            >
              Placement Rate
            </p>
          </div>
          <div class="space-y-1 border-l border-slate-200">
            <h3 class="text-3xl md:text-4xl font-black text-sky-600">1-on-1</h3>
            <p
              class="text-[10px] md:text-xs uppercase font-bold text-slate-500 tracking-wider"
            >
              Mentorship Model
            </p>
          </div>
        </div>
      </section>

      <!-- Narrative Stack: Who We Are / Meet Our Team side-by-side (Lepide-style) -->
      <section class="max-w-[1280px] mx-auto px-4 md:px-margin-desktop py-28">
        <div
          class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center"
        >
          <!-- Left Column: 2x3 circular avatars grid & button -->
          <div class="lg:col-span-6 flex flex-col items-center gap-10">
            <!-- 2x3 Avatar Grid -->
            <div
              class="grid grid-cols-3 gap-6 sm:gap-8 justify-items-center w-full max-w-md"
            >
              {
                team.map((member) => (
                  <div class="flex flex-col items-center group">
                    <div class="h-24 w-24 sm:h-28 sm:w-28 rounded-full overflow-hidden border-2 border-white shadow-md ring-2 ring-[#1b4a9a] hover:ring-sky-500 hover:scale-[1.03] transition-all duration-300">
                      <img
                        src={
                          member.photo_profile ||
                          member.photo ||
                          "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=400&auto=format&fit=crop"
                        }
                        alt={member.name}
                        class="w-full h-full object-cover"
                      />
                    </div>
                  </div>
                ))
              }
            </div>

            <!-- Meet the team button centered under avatars -->
            <a
              href="/about/team"
              class="inline-flex items-center justify-center px-8 py-3.5 bg-[#1b4a9a] hover:bg-[#153b7c] text-white rounded-full text-xs uppercase font-bold tracking-wider transition-all shadow-md hover:shadow-lg active:scale-[0.98] cursor-pointer"
            >
              <span>Meet the team</span>
            </a>
          </div>

          <!-- Right Column: Who We Are text content -->
          <div class="lg:col-span-6 space-y-6">
            <span
              class="text-[10px] font-bold uppercase tracking-wider text-sky-700"
              >The Core Philosophy</span
            >
            <h2
              class="text-3xl sm:text-4xl font-extrabold text-[#0f3473] tracking-tight"
            >
              {story.title}
            </h2>
            <p
              class="text-slate-650 text-base sm:text-lg leading-relaxed whitespace-pre-line"
            >
              {story.paragraph}
            </p>
          </div>
        </div>
      </section>

      <!-- What We Are vs What We Are Not -->
      <section class="max-w-[1280px] mx-auto px-4 md:px-margin-desktop py-24">
        <div class="text-center mb-16 space-y-3">
          <span
            class="text-[10px] font-bold uppercase tracking-wider text-sky-700"
            >Transparency First</span
          >
          <h2 class="text-3xl font-extrabold text-slate-900 tracking-tight">
            Defining Our Standards
          </h2>
          <p class="text-slate-600 text-sm sm:text-base max-w-2xl mx-auto">
            We maintain complete clarity by defining the boundaries of our
            services and our commitment to educational excellence.
          </p>
        </div>
        <div
          class="grid grid-cols-1 md:grid-cols-2 border border-slate-200/80 rounded-3xl overflow-hidden shadow-sm max-w-4xl mx-auto bg-white"
        >
          <div
            class="p-8 sm:p-10 border-b md:border-b-0 md:border-r border-slate-200/80"
          >
            <h3
              class="text-lg font-bold text-slate-900 flex items-center gap-3 mb-8"
            >
              <span class="material-symbols-outlined text-green-600"
                >check_circle</span
              >
              What We Are
            </h3>
            <ul class="space-y-6">
              <li class="flex items-start gap-4">
                <span
                  class="material-symbols-outlined text-sky-600 text-lg shrink-0 mt-0.5"
                  >done</span
                >
                <div>
                  <p class="font-bold text-sm text-slate-800">
                    Live Instructor-Led
                  </p>
                  <p class="text-xs text-slate-500 mt-1 leading-relaxed">
                    Every session is taught live by industry veterans for
                    real-time interaction.
                  </p>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <span
                  class="material-symbols-outlined text-sky-600 text-lg shrink-0 mt-0.5"
                  >done</span
                >
                <div>
                  <p class="font-bold text-sm text-slate-800">
                    Outcome Focused
                  </p>
                  <p class="text-xs text-slate-500 mt-1 leading-relaxed">
                    Success is measured by career placements and salary
                    escalations.
                  </p>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <span
                  class="material-symbols-outlined text-sky-600 text-lg shrink-0 mt-0.5"
                  >done</span
                >
                <div>
                  <p class="font-bold text-sm text-slate-800">
                    Institutionally Accountable
                  </p>
                  <p class="text-xs text-slate-500 mt-1 leading-relaxed">
                    We provide full legal and financial transparency to all our
                    stakeholders.
                  </p>
                </div>
              </li>
            </ul>
          </div>

          <div class="p-8 sm:p-10 bg-slate-50/50">
            <h3
              class="text-lg font-bold text-slate-900 flex items-center gap-3 mb-8"
            >
              <span class="material-symbols-outlined text-red-500">cancel</span>
              What We Are Not
            </h3>
            <ul class="space-y-6">
              <li class="flex items-start gap-4">
                <span
                  class="material-symbols-outlined text-slate-400 text-lg shrink-0 mt-0.5"
                  >close</span
                >
                <div>
                  <p class="font-bold text-sm text-slate-800">
                    Pre-Recorded Video Library
                  </p>
                  <p class="text-xs text-slate-500 mt-1 leading-relaxed">
                    We do not sell static content. Our value is in synchronous
                    expert mentorship.
                  </p>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <span
                  class="material-symbols-outlined text-slate-400 text-lg shrink-0 mt-0.5"
                  >close</span
                >
                <div>
                  <p class="font-bold text-sm text-slate-800">
                    A Certification Mill
                  </p>
                  <p class="text-xs text-slate-500 mt-1 leading-relaxed">
                    We prioritize skills and portfolio results over generic
                    certificates.
                  </p>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <span
                  class="material-symbols-outlined text-slate-400 text-lg shrink-0 mt-0.5"
                  >close</span
                >
                <div>
                  <p class="font-bold text-sm text-slate-800">
                    Anonymous Support
                  </p>
                  <p class="text-xs text-slate-500 mt-1 leading-relaxed">
                    We do not outsource support. You have direct access to our
                    core team.
                  </p>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Editorial standards card (What We Do methodology card) -->
      <section class="max-w-7xl mx-auto px-4 md:px-margin-desktop py-6">
        <div
          class="flex flex-col md:flex-row items-center justify-between gap-12 bg-gradient-to-br from-sky-50 to-blue-100/50 p-8 sm:p-16 rounded-3xl border border-sky-100 relative overflow-hidden"
        >
          <!-- Ambient light effect -->
          <div
            class="absolute -right-10 -top-10 w-40 h-40 bg-sky-300/10 blur-3xl rounded-full"
          >
          </div>

          <!-- Content Left Column -->
          <div class="relative z-10 w-full md:w-2/3 space-y-4 text-left">
            <h3
              class="text-2xl sm:text-3xl font-bold text-slate-900 leading-tight"
            >
              {story.method_title}
            </h3>
            <p
              class="text-slate-650 text-sm sm:text-base text-justify leading-relaxed"
            >
              {story.method_desc}
            </p>
          </div>

          <!-- Image Right Column -->
          <div
            class="relative z-10 w-full md:w-1/3 flex items-center justify-center"
          >
            <img
              class="w-full max-w-[200px] sm:max-w-[240px] aspect-square object-contain drop-shadow-md hover:scale-105 transition-transform duration-300"
              src={story.method_image}
              alt="What We Do logo illustration"
            />
          </div>
        </div>
      </section>

      <!-- Institutional Registry Info -->
      <section class="max-w-7xl mx-auto px-4 md:px-margin-desktop py-12">
        <div
          class="p-8 sm:p-12 text-slate-800 relative overflow-hidden flex flex-col items-center text-center w-full"
        >
          <!-- Ambient light dot -->
          <div
            class="absolute -right-10 -top-10 w-40 h-40 bg-sky-300/10 blur-3xl rounded-full"
          >
          </div>

          <span
            class="material-symbols-outlined text-sky-600 text-4xl mb-4"
            style="font-variation-settings: 'FILL' 1;">contact_support</span
          >
          <h3
            class="text-2xl sm:text-3xl font-bold tracking-tight text-slate-900 mb-3"
          >
            {registry.contact_title}
          </h3>
          <p class="text-slate-650 max-w-xl text-sm sm:text-base mb-8">
            For official inquiries, compliance audits, registry requests, or
            partnership proposals.
          </p>

          <div
            class="grid grid-cols-1 sm:grid-cols-2 gap-8 w-full max-w-3xl border-t border-sky-100 pt-8 text-sm"
          >
            <div class="flex flex-col gap-2.5 items-center">
              <span
                class="text-[10px] font-bold uppercase tracking-wider text-sky-700 font-bold"
                >Institutional Hotline</span
              >
              <a
                class="flex items-center gap-2 font-semibold text-slate-700 hover:text-sky-600 transition-colors"
                href="tel:+18888102434"
              >
                <span class="material-symbols-outlined text-slate-400 text-sm"
                  >call</span
                > (888) 810-2434
              </a>
              <a
                class="flex items-center gap-2 font-semibold text-slate-700 hover:text-sky-600 transition-colors"
                href="tel:+18889277072"
              >
                <span class="material-symbols-outlined text-slate-400 text-sm"
                  >call</span
                > (888) 927-7072
              </a>
            </div>

            <div class="flex flex-col gap-2.5 items-center">
              <span
                class="text-[10px] font-bold uppercase tracking-wider text-sky-700 font-bold"
                >Inquiry Inboxes</span
              >
              <a
                class="flex items-center gap-2 font-semibold text-slate-700 hover:text-sky-600 transition-colors"
                href={`mailto:${registry.email}`}
              >
                <span class="material-symbols-outlined text-slate-400 text-sm"
                  >mail</span
                >
                {registry.email}
              </a>
              <a
                class="flex items-center gap-2 font-semibold text-slate-700 hover:text-sky-600 transition-colors"
                href="mailto:support@skystates.us"
              >
                <span class="material-symbols-outlined text-slate-400 text-sm"
                  >mail</span
                > support@skystates.us
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- book live demo -->
      <section></section>
    </main>
  </body>
  <!-- Footer -->
  <Footer />
</html>
