---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import aboutData from '../data/about.json';

const { hero, story, registry } = aboutData;
---

<!DOCTYPE html>

<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>About Sky States | Institutional Excellence in Tech Careers</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap" rel="stylesheet"/>

<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .upward-gradient {
            background: linear-gradient(to top, #ffffff 0%, #d3e2ed 100%);
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(10px);
        }
        .text-midnight { color: #0f1d25; }
        .bg-horizon { background-color: #0077b6; }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-background font-body-md text-on-surface">
<!-- TopAppBar -->
<Header />
<main>
<!-- Editorial Hero -->
<section class="relative w-full pt-20 pb-32 overflow-hidden upward-gradient">
<div class="max-w-[1280px] mx-auto px-margin-desktop grid grid-cols-1 md:grid-cols-2 items-center gap-gutter relative z-10">
<div class="space-y-6">
<span class="inline-block px-4 py-1 rounded-full bg-secondary-container text-on-secondary-container text-label-sm uppercase tracking-widest">{hero.badge}</span>
<h1 class="font-headline-xl text-headline-xl text-midnight leading-tight">{hero.title}</h1>
<p class="text-body-lg text-on-surface-variant max-w-xl">{hero.description}</p>
</div>
<div class="hidden md:block relative h-[500px]">
<div class="absolute inset-0 bg-white/20 rounded-xl overflow-hidden shadow-[0_30px_30px_rgba(0,0,0,0.04)]">
<img class="w-full h-full object-cover" data-alt="A serene, minimalist digital render of a wide-open sky during dawn." src="https://lh3.googleusercontent.com/aida-public/AB6AXuAVXdCtcsLtrGBHQO8yoFH2I5xbRvNJxnjWo86QnFxf7dj5ZMz6CQB1EC5DjhpMk0zm95v3jo4nsgZuF4iH9bfL2DqHna1Xr7w8sqaBwiYQ44ZrLgmOT9Z6MrEw9yk0qG1L0UcHQzxMo76TCehTYyS3OXp0MMFhEdb54lBmgJNMMscRNWEVEBqEBtaHEh_8GCeNQXCAHE7idOhObUohs9zGpRy4p66-CD1gyqbXr4Ea6po7KEn0kW3j1FbZWl9IXvl378AB1Tl4Zvo"/>
</div>
</div>
</div>
</section>
<!-- The Sky States Story (Narrative) -->
<section class="max-w-[1280px] mx-auto px-margin-desktop mt-section-gap">
<div class="flex flex-col md:flex-row gap-gutter">
<div class="md:w-1/3">
<h2 class="font-headline-lg text-headline-lg text-primary">{story.title}</h2>
</div>
<div class="md:w-2/3 space-y-8">
<p class="font-body-lg text-on-surface leading-relaxed">{story.paragraph}</p>
<div class="grid grid-cols-1 md:grid-cols-2 gap-gutter">
<div class="space-y-4">
<h4 class="font-label-md text-primary">{story.vision_title}</h4>
<p class="text-body-md text-on-surface-variant">{story.vision_desc}</p>
</div>
<div class="space-y-4">
<h4 class="font-label-md text-primary">{story.method_title}</h4>
<p class="text-body-md text-on-surface-variant">{story.method_desc}</p>
</div>
</div>
</div>
</div>
</section>
<!-- Institutional Registry -->
<section class="max-w-[1280px] mx-auto px-margin-desktop mt-section-gap">
<div class="bg-surface-container-low rounded-xl p-12 shadow-[0_30px_30px_rgba(0,0,0,0.04)] border border-outline-variant/30">
<div class="grid grid-cols-1 md:grid-cols-3 gap-12">
<div class="space-y-4">
<span class="material-symbols-outlined text-primary-container" style="font-variation-settings: 'FILL' 1;">verified</span>
<h3 class="font-headline-md text-headline-md text-on-surface">{registry.legal_title}</h3>
<p class="text-body-md text-on-surface-variant">{registry.legal_desc}</p>
<div class="pt-4 border-t border-outline-variant">
<p class="text-label-md text-on-surface">Delaware Division of Corporations</p>
<p class="text-label-md text-on-surface">Wyoming Secretary of State</p>
</div>
</div>
<div class="space-y-4">
<span class="material-symbols-outlined text-primary-container" style="font-variation-settings: 'FILL' 1;">location_on</span>
<h3 class="font-headline-md text-headline-md text-on-surface">{registry.presence_title}</h3>
<div class="space-y-6">
<div>
<p class="text-label-sm text-primary uppercase">Delaware HQ</p>
<p class="text-body-md text-on-surface">{registry.delaware_address}</p>
</div>
<div>
<p class="text-label-sm text-primary uppercase">Wyoming Operations</p>
<p class="text-body-md text-on-surface">{registry.wyoming_address}</p>
</div>
</div>
</div>
<div class="space-y-4">
<span class="material-symbols-outlined text-primary-container" style="font-variation-settings: 'FILL' 1;">contact_support</span>
<h3 class="font-headline-md text-headline-md text-on-surface">{registry.contact_title}</h3>
<p class="text-body-md text-on-surface-variant">For official inquiries, compliance audits, or partnership proposals.</p>
<div class="space-y-2 pt-4">
<a class="flex items-center gap-2 text-label-md text-primary hover:underline transition-all" href={`tel:${registry.phone.replace(/[^0-9+]/g, '')}`}>
<span class="material-symbols-outlined text-sm">call</span> {registry.phone}
                            </a>
<a class="flex items-center gap-2 text-label-md text-primary hover:underline transition-all" href={`mailto:${registry.email}`}>
<span class="material-symbols-outlined text-sm">mail</span> {registry.email}
                            </a>
</div>
</div>
</div>
</div>
</section>
<!-- What We Are vs What We Are Not -->
<section class="max-w-[1280px] mx-auto px-margin-desktop mt-section-gap">
<div class="text-center mb-16">
<h2 class="font-headline-lg text-headline-lg text-on-surface">Defining Our Standards</h2>
<p class="text-body-md text-on-surface-variant max-w-2xl mx-auto mt-4">We maintain transparency by clearly defining the boundaries of our services and our commitment to quality.</p>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 border border-outline-variant rounded-xl overflow-hidden shadow-[0_30px_30px_rgba(0,0,0,0.04)]">
<div class="bg-surface p-10 md:border-r border-outline-variant">
<h3 class="font-headline-md text-headline-md text-primary flex items-center gap-3 mb-8">
<span class="material-symbols-outlined">check_circle</span>
                        What We Are
                    </h3>
<ul class="space-y-6">
<li class="flex items-start gap-4">
<span class="material-symbols-outlined text-primary pt-1">done</span>
<div>
<p class="text-label-md text-on-surface">Live Instructor-Led</p>
<p class="text-body-md text-on-surface-variant">Every session is taught live by industry veterans for real-time interaction.</p>
</div>
</li>
<li class="flex items-start gap-4">
<span class="material-symbols-outlined text-primary pt-1">done</span>
<div>
<p class="text-label-md text-on-surface">Outcome Focused</p>
<p class="text-body-md text-on-surface-variant">Success is measured by career placements and salary escalations.</p>
</div>
</li>
<li class="flex items-start gap-4">
<span class="material-symbols-outlined text-primary pt-1">done</span>
<div>
<p class="text-label-md text-on-surface">Institutionally Accountable</p>
<p class="text-body-md text-on-surface-variant">We provide full legal and financial transparency to all our stakeholders.</p>
</div>
</li>
</ul>
</div>
<div class="bg-surface-container-low p-10">
<h3 class="font-headline-md text-headline-md text-error flex items-center gap-3 mb-8">
<span class="material-symbols-outlined">cancel</span>
                        What We Are Not
                    </h3>
<ul class="space-y-6">
<li class="flex items-start gap-4">
<span class="material-symbols-outlined text-error pt-1">close</span>
<div>
<p class="text-label-md text-on-surface">Pre-Recorded Video Library</p>
<p class="text-body-md text-on-surface-variant">We do not sell static content. Our value is in synchronous expert mentorship.</p>
</div>
</li>
<li class="flex items-start gap-4">
<span class="material-symbols-outlined text-error pt-1">close</span>
<div>
<p class="text-label-md text-on-surface">A Certification Mill</p>
<p class="text-body-md text-on-surface-variant">We prioritize skills and portfolio results over generic certificates.</p>
</div>
</li>
<li class="flex items-start gap-4">
<span class="material-symbols-outlined text-error pt-1">close</span>
<div>
<p class="text-label-md text-on-surface">Anonymous Support</p>
<p class="text-body-md text-on-surface-variant">We do not outsource support. You have direct access to our core team.</p>
</div>
</li>
</ul>
</div>
</div>
</section>
<!-- Leadership & Authority (Editorial Standards) -->
<section class="max-w-[1280px] mx-auto px-margin-desktop mt-section-gap">
<div class="flex flex-col md:flex-row items-center gap-gutter bg-primary-container p-16 rounded-xl text-on-primary-container overflow-hidden relative">
<div class="relative z-10 md:w-1/2 space-y-6">
<h2 class="font-headline-xl text-headline-xl text-white">Sky Editorial Standards</h2>
<p class="text-body-lg text-blue-100 opacity-90">Every curriculum, mentor, and interaction is governed by the Sky Editorial Board. We ensure that our educational products meet the highest benchmarks of technical accuracy and professional relevance.</p>
<div class="flex flex-wrap gap-4 pt-4">
<span class="px-4 py-2 bg-white/20 rounded-full text-label-sm backdrop-blur-md">Quarterly Audits</span>
<span class="px-4 py-2 bg-white/20 rounded-full text-label-sm backdrop-blur-md">Subject Matter Experts</span>
<span class="px-4 py-2 bg-white/20 rounded-full text-label-sm backdrop-blur-md">Compliance First</span>
</div>
</div>
</div>
</section>
</main>
<!-- Footer -->
<Footer />
</body></html>