---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import EmployerLogoMarquee from "../components/EmployerLogoMarquee.astro";
import homepageData from "../data/homepage.json";
import ConsultationModal from "../components/ConsultationModal.astro";

const {
  hero,
  trust_bar,
  about,
  why_choose,
  programs_section,
  learning_paths,
  methodology,
  certificate,
} = homepageData;
export const prerender = false;
---

<!doctype html>
<html lang="en">
  <head>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <title>Sky States | Data Science, AI & Cybersecurity Training & Bootcamp</title>
    <meta
      content="Sky States is an EdTech platform offering online training in Data Science, AI, Cybersecurity, DevOps, and other in-demand tech skills with career support."
      name="description"
    />
    <meta
      content="Best online data science bootcamp in USA, AI certification training online, Cybersecurity training with job placement, Online DevOps bootcamp USA, Career-focused IT training, Tech bootcamps for beginners, Online AI and machine learning course, Learn cybersecurity online, Data science certification online, Online coding bootcamp with career support"
      name="keywords"
    />
    <link rel="canonical" href="https://skystates.us/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Geist:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />

    <style>
      .material-symbols-outlined {
        font-variation-settings:
          "FILL" 0,
          "wght" 400,
          "GRAD" 0,
          "opsz" 24;
      }
      .ambient-shadow {
        box-shadow: 0 10px 30px -5px rgba(15, 29, 37, 0.04);
      }
      @keyframes marquee {
        0% {
          transform: translateX(0);
        }
        100% {
          transform: translateX(-50%);
        }
      }
      .marquee {
        animation: marquee 30s linear infinite;
      }
    </style>
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Sky States",
        "url": "https://skystates.us/",
        "publisher": {
          "@type": "Organization",
          "name": "Sky States",
          "url": "https://skystates.us/"
        }
      }
    </script>
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Sky States",
        "url": "https://skystates.us",
        "logo": "https://skystates.us/logo.svg",
        "contactPoint": {
          "@type": "ContactPoint",
          "telephone": "+1-888-810-2434",
          "contactType": "customer service",
          "email": ["info@skystates.us", "support@skystates.us"]
        }
      }
    </script>
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "What makes Sky States different from other?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "We focus on practical learning rather than theory alone. Every student gets hands-on project experience, mentorship from industry professionals, career guidance, resume support, and interview preparation to help build real-world skills."
            }
          },
          {
            "@type": "Question",
            "name": "Do you have a Physical address / Physical Classes?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes we do have phyical classes as we are located in Seattle, washington so you can take your class over there"
            }
          },
          {
            "@type": "Question",
            "name": "Do you help with interview preparation?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes. We conduct mock interviews, provide technical interview guidance, help improve communication skills, and share practical tips to help you perform confidently during hiring processes."
            }
          },
          {
            "@type": "Question",
            "name": "Will I receive a certificate after completing the program?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes. Students who successfully complete the program receive a certificate of completion. Depending on the learning path, you'll also be guided toward preparing for relevant industry certifications."
            }
          },
          {
            "@type": "Question",
            "name": "Are the classes live or pre-recorded?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Our programs include live instructor-led sessions along with recorded lectures, allowing you to revisit important topics whenever you need."
            }
          },
          {
            "@type": "Question",
            "name": "Do you provide job placement assistance?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes. We offer career support that includes resume building, LinkedIn profile optimization, mock interviews, career coaching, and Placement. While no institute can guarantee employment, we work closely with students to improve their job readiness."
            }
          },
          {
            "@type": "Question",
            "name": "Can working professionals join the program?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes. Many of our students are working professionals who want to switch careers or upgrade their technical skills. Our flexible learning format makes it easier to learn while managing your job."
            }
          },
          {
            "@type": "Question",
            "name": "What if I miss a live class?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "No problem. Recorded sessions are available so you can catch up at your convenience without missing important concepts."
            }
          }
        ]
      }
    </script>
  </head>
  <body
    class="bg-background text-on-background selection:bg-primary-fixed selection:text-on-primary-fixed overflow-x-hidden"
  >
    <!-- TopAppBar -->
    <Header />
    <!-- Hero Section -->
    <section
      class="relative min-h-[80vh] flex flex-col items-center overflow-hidden bg-white pt-24 md:pt-28 lg:pt-32"
    >
      <div
        class="max-w-7xl mx-auto px-4 md:px-margin-desktop grid grid-cols-1 lg:grid-cols-12 gap-12 items-center z-10 pb-12 pt-4 lg:py-12"
      >
        <!-- Left Content Column (col-7) -->
        <div class="flex flex-col gap-6 lg:col-span-7">
          <!-- Bolder Typography for Hero Headline -->
          <h1
            class="text-4xl font-bold text-sky-500 tracking-tight leading-[1.3]"
            set:html={hero.headline}
          />
          <p
            class="text-base sm:text-lg text-slate-600 text-justify max-w-xl leading-relaxed"
          >
            {hero.description}
          </p>
          <!-- Tactile conversion-focused action buttons -->
          <div class="flex flex-col sm:flex-row gap-4 mt-2">
            <a
              class="group flex items-center justify-center px-4 py-2 rounded-xl bg-gradient-to-r from-sky-600 to-blue-700 text-white text-label-md font-semibold hover:from-sky-500 hover:to-blue-600 hover:scale-[1.02] shadow-lg shadow-sky-600/10 hover:shadow-sky-600/20 active:scale-[0.98] transition-all duration-200"
              href={hero.button_url || "#programs"}
            >
              <span>{hero.button_text || "Explore Programs"}</span>
              <span
                class="material-symbols-outlined text-lg ml-2 font-bold transition-transform duration-200 group-hover:translate-x-1"
                >arrow_forward</span
              >
            </a>
            <a
              class="group flex items-center justify-center px-8 py-4 rounded-xl text-sky-700 bg-sky-50/50 border border-sky-200/80 hover:bg-sky-50 hover:border-sky-300 hover:scale-[1.02] active:scale-[0.98] transition-all duration-200 font-semibold"
              href={hero.consultation_url || "/contact-us"}
              data-trigger-consultation
            >
              <span
                class="material-symbols-outlined text-lg mr-2 font-bold transition-transform duration-200 group-hover:rotate-6"
                >calendar_month</span
              >
              <span
                >{
                  hero.consultation_text || "Book a Free Career Consultation"
                }</span
              >
            </a>
          </div>
        </div>

        <!-- Right Video Mockup Column (col-5) -->
        <div class="relative w-full max-w-5xl lg:mx-0 lg:col-span-5">
          <!-- Device frame wrapper -->
          <div
            class="relative p-1.5 bg-slate-100 rounded-2xl shadow-xl border border-slate-200 overflow-hidden"
          >
            <video
              autoplay
              loop
              muted
              playsinline
              class="relative rounded-[14px] w-full aspect-video object-cover"
            >
              <source
                src="/assets/videos/home%20page%20hero%20section.mp4"
                type="video/mp4"
              />
              Your browser does not support the video tag.
            </video>
          </div>
        </div>
      </div>

      <!-- Trust Bar / Highlights -->
      <div class="w-full py-4 mt-20 bg-white">
        <div class="max-w-7xl mx-auto px-4 md:px-margin-desktop">
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            {
              trust_bar &&
                trust_bar.map((highlight, index) => {
                  const icons = [
                    "live_tv",
                    "terminal",
                    "school",
                    "calendar_month",
                  ];
                  const labels = [
                    "Classes",
                    "Practice",
                    "Guidance",
                    "Schedule",
                  ];
                  return (
                    <div class="flex items-center gap-4 p-5 bg-sky-50 border border-sky-200/80 rounded-2xl shadow-sm hover:shadow-md hover:-translate-y-0.5 hover:border-sky-100/80 transition-all duration-300 group">
                      <div class="w-12 h-12 rounded-xl bg-sky-50/60 border border-sky-100/50 flex items-center justify-center text-sky-600 group-hover:bg-sky-600 group-hover:text-white transition-colors duration-300 shrink-0">
                        <span
                          class="material-symbols-outlined text-xl transition-colors duration-300"
                          style="font-variation-settings: 'FILL' 1;"
                        >
                          {icons[index] || "verified"}
                        </span>
                      </div>
                      <div>
                        <span class="block text-[16px] font-bold text-slate-400 uppercase tracking-widest mb-0.5">
                          {labels[index] || "Highlight"}
                        </span>
                        <span class="text-base font-bold text-slate-800 tracking-tight leading-tight">
                          {highlight}
                        </span>
                      </div>
                    </div>
                  );
                })
            }
          </div>
        </div>
      </div>
    </section>

    <!-- About Us Section -->
    <section class="py-section-gap bg-surface-container-lowest">
      <div class="max-w-7xl mx-auto px-4 md:px-margin-desktop">
        <div class="text-center mb-16">
          <h2 class="text-headline-lg text-on-surface font-bold mb-4">
            {about.title}
          </h2>
          <div class="w-24 h-1 bg-primary mx-auto rounded-full"></div>
        </div>

        <!-- Description (left) + Video (right) -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div class="flex flex-col gap-6">
            {
              about.description &&
                about.description
                  .split("\n\n")
                  .map((p) => (
                    <p class="text-body-lg text-justify text-on-surface-variant leading-relaxed">
                      {p}
                    </p>
                  ))
            }
          </div>
          <div class="relative">
            <div
              class="aspect-video bg-white rounded-3xl ambient-shadow overflow-hidden border border-outline-variant/30 flex items-center justify-center relative"
            >
              <video
                autoplay
                loop
                muted
                playsinline
                class="absolute inset-0 w-full h-full object-cover"
              >
                <source
                  src="/admin/Sky_States_career_acceleration_program_202606270007.mp4"
                  type="video/mp4"
                />
                Your browser does not support the video tag.
              </video>
            </div>
          </div>
        </div>

        <!-- Certification / Recognition block (full width, centered) -->
        <div class="mt-10 pt-6 border-t border-slate-100 text-center">
          <h3 class="text-2xl font-bold text-on-surface mb-6">
            Get Graduated with Practical Skills and Industry Recognition
          </h3>
          <div class="flex flex-wrap justify-center gap-4">
            <div
              class="flex items-center gap-2 px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg"
            >
              <span class="material-symbols-outlined text-primary text-xl"
                >workspace_premium</span
              >
              <span class="text-sm font-semibold text-slate-700"
                >Microsoft Certified Partner</span
              >
            </div>
            <div
              class="flex items-center gap-2 px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg"
            >
              <span class="material-symbols-outlined text-primary text-xl"
                >cloud</span
              >
              <span class="text-sm font-semibold text-slate-700"
                >AWS Academy Curriculum</span
              >
            </div>
            <div
              class="flex items-center gap-2 px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg"
            >
              <span class="material-symbols-outlined text-primary text-xl"
                >security</span
              >
              <span class="text-sm font-semibold text-slate-700"
                >CompTIA Security+ Prep</span
              >
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Should You Choose SkyStates? -->
    <section class="py-section-gap bg-white">
      <div class="max-w-7xl mx-auto px-4 md:px-margin-desktop">
        <div class="text-center mb-16">
          <h2 class="text-headline-lg text-on-surface font-bold mb-4">
            Why Should You Choose SkyStates?
          </h2>
          <div class="w-24 h-1 bg-primary mx-auto rounded-full"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {
            why_choose &&
              why_choose.map((feat) => {
                const iconMap = {
                  "Learn from Industry Professionals": "workspace_premium",
                  "Practical Learning Method": "terminal",
                  "Adaptable Learning Paths": "route",
                  "Career Development Assistance": "support_agent",
                  "Updated Curriculum": "sync",
                  "Continuous Learning": "history_edu",
                };
                const icon = iconMap[feat.title] || "verified";
                return (
                  <div class="group bg-sky-50 p-8 rounded-2xl border border-sky-100 flex flex-col items-center text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-sky-100 hover:border-sky-200">
                    <div class="w-14 h-14 bg-white text-primary rounded-full flex items-center justify-center mb-6 shadow-sm transition-all duration-300 group-hover:bg-primary group-hover:text-white group-hover:scale-110">
                      <span class="material-symbols-outlined text-2xl font-bold">
                        {icon}
                      </span>
                    </div>
                    <h3 class="text-xl font-bold text-on-surface mb-3">
                      {feat.title}
                    </h3>
                    <p class="text-base leading-relaxed">{feat.description}</p>
                  </div>
                );
              })
          }
        </div>
      </div>
    </section>

<!-- certificate -->

<section class="bg-white py-16 lg:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <!-- Heading -->
    <div class="mx-auto mb-14 max-w-3xl text-center">


      <h2
        class="mt-5 text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl"
      >
        Most Popular Certificates
      </h2>

      <p class="mt-4 text-lg leading-8 text-slate-600">
        Gain industry-recognized Microsoft certifications and build skills that
        employers value.
      </p>
    </div>

    <!-- Cards -->
    <div class="grid gap-8 md:grid-cols-2 xl:grid-cols-3">
      {
        certificate.map((cert) => (
          <article
            class="group overflow-hidden border border-slate-200 bg-white shadow-sm transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl"
          >
            <!-- IMAGE -->
            <div class="overflow-hidden p-3">
              <img
                src={cert.image}
                alt={cert.title}
                loading="lazy"
                class="aspect-[16/10] w-full object-containt transition duration-500 group-hover:scale-15"
              />
            </div>

            <!-- CONTENT -->
            <div class="p-7">

              <!-- Microsoft -->
              <div class="mb-5 flex items-center justify-between">

                <div class="flex items-center gap-2">

                  <svg width="22" height="22" viewBox="0 0 24 24">
                    <rect x="2" y="2" width="9" height="9" fill="#F35325"/>
                    <rect x="13" y="2" width="9" height="9" fill="#81BC06"/>
                    <rect x="2" y="13" width="9" height="9" fill="#05A6F0"/>
                    <rect x="13" y="13" width="9" height="9" fill="#FFBA08"/>
                  </svg>

                  <span class="font-medium text-slate-700">
                    Microsoft
                  </span>

                </div>

                <span
                  class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700"
                >
                  Official
                </span>

              </div>

              <!-- Title -->

              <h3 class="text-2xl font-bold text-slate-900">
                {cert.title}
              </h3>

              <!-- Description -->

              <p class="mt-3 text-[15px] leading-7 text-slate-600">
                {cert.description}
              </p>

              <a
                href={cert.href}
                class="mt-7 flex items-center justify-center gap-2 rounded-xl bg-[#005da6] px-5 py-3 font-semibold text-white transition hover:bg-[#004b87]"
              >
                Enroll Program

                <svg
                  width="18"
                  height="18"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                >
                  <path d="M5 12h14"></path>
                  <path d="m12 5 7 7-7 7"></path>
                </svg>

              </a>

            </div>
          </article>
        ))
      }
    </div>

  </div>
</section>

    <!-- Discover SkyStates Technology Programs Section -->
    <section id="programs" class="w-full bg-white">
      <div class="max-w-7xl mx-auto px-4 md:px-margin-desktop py-section-gap">
        <div class="text-center mb-12 md:mb-16">
          <h2 class="text-headline-lg text-on-surface font-bold mb-4">
            {programs_section.title}
          </h2>
          <p class="text-on-surface-variant max-w-2xl mx-auto text-body-md">
            {programs_section.subtitle}
          </p>
          <div class="w-24 h-1 bg-primary mx-auto rounded-full mt-4 mb-4"></div>
        </div>
        <div
          class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8 mb-16"
        >
          {
            programs_section.programs &&
              programs_section.programs.map((prog, index) => {
                const cardColors = [
                  "bg-white text-on-surface border border-slate-200 hover:border-sky-300 group",
                  "bg-sky-700 text-white",
                  "bg-white text-on-surface border border-slate-200 hover:border-sky-300 group",
                ];
                const iconColors = [
                  "bg-sky-50 text-sky-700",
                  "bg-white/15 text-white",
                  "bg-sky-50 text-sky-700",
                ];
                const bulletColors = [
                  "text-sky-700",
                  "text-white",
                  "text-sky-700",
                ];
                const buttonColors = [
                  "bg-sky-700 text-white hover:bg-sky-800",
                  "bg-white text-sky-700 hover:bg-sky-50",
                  "bg-sky-700 text-white hover:bg-sky-800",
                ];
                const linkColors = [
                  "text-sky-700",
                  "text-white",
                  "text-sky-700",
                ];
                const textSecondaryColors = [
                  "text-on-surface-variant",
                  "text-sky-50",
                  "text-on-surface-variant",
                ];
                const labelColors = [
                  "text-slate-400",
                  "text-sky-100/70",
                  "text-slate-400",
                ];
                const icons = ["analytics", "security", "cloud_queue"];

                const themeIdx = index % 3;
                return (
                  <div
                    class={`rounded-2xl p-6 sm:p-8 shadow-sm hover:shadow-lg transition-all duration-300 flex flex-col h-full ${cardColors[themeIdx]}`}
                  >
                    <div
                      class={`w-12 h-12 sm:w-14 sm:h-14 rounded-xl flex items-center justify-center mb-5 sm:mb-6 transition-transform duration-300 group-hover:scale-110 ${iconColors[themeIdx]}`}
                    >
                      <span class="material-symbols-outlined text-2xl sm:text-3xl">
                        {icons[themeIdx] || "school"}
                      </span>
                    </div>
                    <h3 class="text-2xl font-bold mb-3 sm:mb-4 font-bold">
                      {prog.title}
                    </h3>
                    <div class="text-2xl sm:text-3xl font-extrabold mb-4">
                      {prog.price}
                    </div>
                    <p
                      class={`text-body-md flex-grow mb-6 ${textSecondaryColors[themeIdx]}`}
                    >
                      {prog.description}
                    </p>
                    <div class="mb-6">
                      <h4
                        class={`text-xs font-bold uppercase tracking-wider mb-3 ${labelColors[themeIdx]}`}
                      >
                        Program Highlights
                      </h4>
                      <ul class="space-y-2 text-sm">
                        {prog.highlights.map((h) => (
                          <li class="flex items-start gap-2">
                            <span
                              class={`material-symbols-outlined text-base shrink-0 ${bulletColors[themeIdx]}`}
                            >
                              done
                            </span>
                            <span>{h}</span>
                          </li>
                        ))}
                      </ul>
                    </div>
                    <div class="pt-6 border-t border-current/10 flex flex-col gap-4">
                      <a
                        href={`/checkout?program=${prog.id}`}
                        class={`w-full text-center py-3 font-bold rounded-xl transition-colors duration-200 ${buttonColors[themeIdx]}`}
                      >
                        Enroll Today
                      </a>
                      <a
                        href={`/programs/${prog.id}`}
                        class={`text-label-md flex items-center justify-center gap-1 hover:gap-2 transition-all duration-200 ${linkColors[themeIdx]}`}
                      >
                        Details{" "}
                        <span class="material-symbols-outlined">
                          arrow_forward
                        </span>
                      </a>
                    </div>
                  </div>
                );
              })
          }
        </div>
      </div>
    </section>

    <!-- Testimonials Section -->
    <section class="py-section-gap bg-surface-container-low overflow-hidden">
      <div class="max-w-7xl mx-auto px-4 md:px-margin-desktop">
        <div class="text-center mb-16">
          <h2 class="text-headline-lg text-on-surface font-bold mb-4">
            Verified Student Outcomes
          </h2>
          <p class="text-on-surface-variant max-w-2xl mx-auto">
            Real stories from professionals who successfully transitioned their
            careers through our platform.
          </p>
          <div class="w-24 h-1 bg-primary mx-auto rounded-full mt-4 mb-4"></div>
          <a
            class="text-primary text-label-md inline-flex items-center gap-2"
            href="https://skyreviews.us"
            target="_blank"
            >Read more at skyreviews.us <span class="material-symbols-outlined"
              >open_in_new</span
            ></a
          >
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <!-- Testimonial Card 1 -->
          <div
            class="bg-white p-8 rounded-2xl flex flex-col gap-4 ambient-shadow"
          >
            <div class="flex text-amber-400 mb-2">
              <span
                class="material-symbols-outlined"
                style="font-variation-settings: 'FILL' 1;">star</span
              ><span
                class="material-symbols-outlined"
                style="font-variation-settings: 'FILL' 1;">star</span
              ><span
                class="material-symbols-outlined"
                style="font-variation-settings: 'FILL' 1;">star</span
