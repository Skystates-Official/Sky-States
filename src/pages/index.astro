---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import homepageData from '../data/homepage.json';

const { hero, trust_bar, about, pricing, why_choose, programs_section, learning_paths, methodology } = homepageData;
export const prerender = false;
---

<!DOCTYPE html>

<html lang="en"><head>
  <link rel="icon" type="image/png" href="/favicon.png" />
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Sky States | Accelerate Your Legacy in Technology</title>
<meta content="US-registered career platform offering live instructor-led training in Data Science, Cyber Security, and DevOps. $2,999 program with active placement support." name="description"/>
<link rel="canonical" href="https://skystates.us" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Geist:wght@400;600;700;800&display=swap" rel="stylesheet"/>




<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .ambient-shadow {
            box-shadow: 0 10px 30px -5px rgba(15, 29, 37, 0.04);
        }
        @keyframes marquee {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }
        .marquee {
            animation: marquee 30s linear infinite;
        }
    </style>
<script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Sky States",
      "url": "https://skystates.us",
      "logo": "https://skystates.us/logo.svg",
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+1-888-810-2434",
        "contactType": "customer service",
        "email": ["info@skystates.us", "support@skystates.us"]
      }
    }
    </script>
<script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [{
        "@type": "Question",
        "name": "Is Sky States a legitimate company?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, Sky States is a US-registered Career Acceleration Platform based in Wyoming and Delaware, focusing on career transitions for ambitious individuals at all experience levels."
        }
      }, {
        "@type": "Question",
        "name": "How frequent are the training calls?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Training sessions are live and instructor-led, held every weekend to accommodate working professionals."
        }
      }, {
        "@type": "Question",
        "name": "Does Sky States collect my SSN?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. Sky States explicitly states that we do NOT collect Social Security Numbers (SSN) from our students."
        }
      }, {
        "@type": "Question",
        "name": "Is screen sharing required?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "During live labs and project evaluations, screen sharing may be used to provide direct instructor feedback and support."
        }
      }]
    }
    </script>
</head>
<body class="bg-background text-on-background selection:bg-primary-fixed selection:text-on-primary-fixed overflow-x-hidden">
<!-- TopAppBar -->
<Header />
<!-- Hero Section -->
<section class="relative min-h-[80vh] flex flex-col items-center overflow-hidden bg-white pt-24 md:pt-28 lg:pt-32">
<div class="max-w-7xl mx-auto px-4 md:px-margin-desktop grid grid-cols-1 lg:grid-cols-2 gap-12 items-center z-10 pb-12 pt-4 lg:py-12">
<div class="flex flex-col gap-6">
<div class="inline-flex items-center gap-2 px-4 py-1.5 bg-primary-fixed text-on-primary-fixed rounded-full w-fit">
<span class="material-symbols-outlined text-sm">verified</span>
<span class="text-label-sm font-bold uppercase tracking-wider">US Registered Company</span>
</div>
<h1 class="text-headline-xl text-on-surface leading-tight font-extrabold" set:html={hero.headline}>
</h1>
<p class="text-body-lg text-on-surface-variant max-w-lg leading-relaxed">
  {hero.description}
</p>
<div class="flex flex-col sm:flex-row gap-4 mt-4">
<a class="flex items-center justify-center px-8 py-4 rounded-xl bg-primary text-white text-label-md font-semibold hover:bg-opacity-90 shadow-md transition-all" href={hero.button_url || "#programs"}>
  {hero.button_text || "Explore Programs"}
</a>
<a class="flex items-center justify-center px-8 py-4 rounded-xl text-primary text-label-md border-2 border-primary-fixed hover:bg-primary-fixed/10 transition-all font-semibold" href={hero.consultation_url || "/contact-us"}>
  {hero.consultation_text || "Book a Free Career Consultation"}
</a>
</div>
</div>
<div class="relative group w-full max-w-2xl mx-auto lg:mx-0">
<div class="absolute -inset-4 bg-primary-fixed/20 blur-3xl rounded-full"></div>
<video autoplay loop muted playsinline class="relative rounded-3xl ambient-shadow w-full aspect-video object-cover transition-transform duration-700 group-hover:scale-[1.01]">
<source src="/assets/videos/home%20page%20hero%20section.mp4" type="video/mp4"/>
Your browser does not support the video tag.
</video>
</div>
</div>
<!-- Trust Bar / Highlights -->
<div class="w-full bg-slate-50/80 border-y border-slate-100 py-8 mt-16">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-4 items-center justify-items-center">
      
      {trust_bar && trust_bar.map((highlight, index) => {
         const icons = ["live_tv", "terminal", "school", "calendar_month"];
         const labels = ["Classes", "Practice", "Guidance", "Schedule"];
         return (
           <div class="flex items-center gap-3 text-left">
             <div class="w-10 h-10 rounded-full bg-sky-50 border border-sky-100 flex items-center justify-center text-sky-600 shrink-0">
               <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 1;">{icons[index] || 'verified'}</span>
             </div>
             <div>
               <span class="block text-xs font-bold text-slate-400 uppercase tracking-widest">{labels[index] || 'Highlight'}</span>
               <span class="text-sm font-semibold text-slate-800">{highlight}</span>
             </div>
           </div>
         );
      })}

    </div>
  </div>
</div>
</section>
<!-- About Us Section -->
<section class="py-section-gap bg-surface-container-lowest">
<div class="max-w-7xl mx-auto px-4 md:px-margin-desktop">
<div class="text-center mb-16">
<h2 class="text-headline-lg text-on-surface font-extrabold mb-4">{about.title}</h2>
<div class="w-24 h-1 bg-primary mx-auto rounded-full"></div>
</div>
<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
<div class="flex flex-col gap-6">
{about.description && about.description.split('\n\n').map(p => (
  <p class="text-body-md text-on-surface-variant leading-relaxed">
    {p}
  </p>
))}
<div class="mt-4 pt-4 border-t border-slate-100">
  <h3 class="text-title-medium font-bold text-on-surface mb-4">Get Graduated with Practical Skills and Industry Recognition</h3>
  <!-- Certification Badges Grid -->
  <div class="flex flex-wrap gap-4 items-center">
    <div class="flex items-center gap-2 px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg">
      <span class="material-symbols-outlined text-primary text-xl">workspace_premium</span>
      <span class="text-xs font-semibold text-slate-700">Microsoft Certified Partner</span>
    </div>
    <div class="flex items-center gap-2 px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg">
      <span class="material-symbols-outlined text-primary text-xl">cloud</span>
      <span class="text-xs font-semibold text-slate-700">AWS Academy Curriculum</span>
    </div>
    <div class="flex items-center gap-2 px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg">
      <span class="material-symbols-outlined text-primary text-xl">security</span>
      <span class="text-xs font-semibold text-slate-700">CompTIA Security+ Prep</span>
    </div>
  </div>
</div>
</div>
<div class="relative">
<div class="aspect-video bg-white rounded-3xl ambient-shadow overflow-hidden border border-outline-variant/30 flex items-center justify-center relative">
<video autoplay loop muted playsinline class="absolute inset-0 w-full h-full object-cover">
<source src="/admin/Sky_States_career_acceleration_program_202606270007.mp4" type="video/mp4"/>
Your browser does not support the video tag.
</video>
</div>
</div>
</div>
</div>
</section>
<!-- Why Should You Choose SkyStates? -->
<section class="py-section-gap bg-slate-50">
<div class="max-w-7xl mx-auto px-4 md:px-margin-desktop">
<div class="text-center mb-16">
<h2 class="text-headline-lg text-on-surface font-extrabold mb-4">Why Should You Choose SkyStates?</h2>
<div class="w-24 h-1 bg-primary mx-auto rounded-full"></div>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
  {why_choose && why_choose.map((feat) => {
    const iconMap = {
      "Learn from Industry Professionals": "workspace_premium",
      "Practical Learning Method": "terminal",
      "Adaptable Learning Paths": "route",
      "Career Development Assistance": "support_agent",
      "Updated Curriculum": "sync",
      "Continuous Learning": "history_edu"
    };
    const icon = iconMap[feat.title] || "verified";
    return (
      <div class="bg-white p-8 rounded-2xl ambient-shadow border border-outline-variant/10 hover:border-primary/20 transition-all">
        <div class="w-12 h-12 bg-primary-fixed/20 text-primary rounded-xl flex items-center justify-center mb-6">
          <span class="material-symbols-outlined text-2xl font-bold">{icon}</span>
        </div>
        <h3 class="text-title-large font-bold text-on-surface mb-3">{feat.title}</h3>
        <p class="text-body-md text-on-surface-variant leading-relaxed">
          {feat.description}
        </p>
      </div>
    );
  })}
</div>
</div>
</section>

<!-- Discover SkyStates Technology Programs Section -->
<section id="programs" class="py-section-gap max-w-7xl mx-auto px-4 md:px-margin-desktop">
<div class="text-center mb-16">
<h2 class="text-headline-lg text-on-surface font-extrabold mb-4">{programs_section.title}</h2>
<p class="text-on-surface-variant max-w-2xl mx-auto">{programs_section.subtitle}</p>
</div>
<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-16">
{programs_section.programs && programs_section.programs.map((prog, index) => {
  const cardColors = [
    "bg-white text-on-surface border border-outline-variant/20 hover:border-primary/30 group",
    "bg-primary text-on-primary",
    "bg-white text-on-surface border border-outline-variant/20 hover:border-primary/30 group"
  ];
  const iconColors = [
    "bg-primary-fixed/30 text-primary",
    "bg-white/20 text-white",
    "bg-primary-fixed/30 text-primary"
  ];
  const bulletColors = [
    "text-primary",
    "text-white",
    "text-primary"
  ];
  const buttonColors = [
    "bg-primary text-white hover:bg-opacity-90",
    "bg-white text-primary hover:bg-opacity-90",
    "bg-primary text-white hover:bg-opacity-90"
  ];
  const linkColors = [
    "text-primary",
    "text-white",
    "text-primary"
  ];
  const textSecondaryColors = [
    "text-on-surface-variant",
    "text-primary-fixed",
    "text-on-surface-variant"
  ];
  const labelColors = [
    "text-slate-400",
    "text-primary-fixed/60",
    "text-slate-400"
  ];
  const icons = ["analytics", "security", "cloud_queue"];
  
  const themeIdx = index % 3;
  return (
    <div class={`rounded-2xl p-8 ambient-shadow transition-all flex flex-col h-full ${cardColors[themeIdx]}`}>
      <div class={`w-14 h-14 rounded-xl flex items-center justify-center mb-6 transition-transform group-hover:scale-110 ${iconColors[themeIdx]}`}>
        <span class="material-symbols-outlined text-3xl">{icons[themeIdx] || 'school'}</span>
      </div>
      <h3 class="text-headline-md mb-4 font-bold">{prog.title}</h3>
      <div class="text-3xl font-extrabold mb-4">{prog.price}</div>
      <p class={`text-body-md flex-grow mb-6 ${textSecondaryColors[themeIdx]}`}>
        {prog.description}
      </p>
      <div class="mb-6">
        <h4 class={`text-xs font-bold uppercase tracking-wider mb-3 ${labelColors[themeIdx]}`}>Program Highlights</h4>
        <ul class="space-y-2 text-sm">
          {prog.highlights.map(h => (
            <li class="flex items-center gap-2">
              <span class={`material-symbols-outlined text-base ${bulletColors[themeIdx]}`}>done</span>
              <span>{h}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="pt-6 border-t border-current/10 flex flex-col gap-4">
        <a href={`/checkout?program=${prog.id}`} class={`w-full text-center py-3 font-bold rounded-xl transition-all ${buttonColors[themeIdx]}`}>Enroll Today</a>
        <a href={`/programs/${prog.id}`} class={`text-label-md flex items-center justify-center gap-1 hover:gap-2 transition-all ${linkColors[themeIdx]}`}>Details <span class="material-symbols-outlined">arrow_forward</span></a>
      </div>
    </div>
  );
})}
</div>
</section>
<!-- Testimonials Section -->
<section class="py-section-gap bg-surface-container-low overflow-hidden">
<div class="max-w-7xl mx-auto px-4 md:px-margin-desktop">
<div class="text-center mb-16">
<h2 class="text-headline-lg text-on-surface font-extrabold mb-4">Verified Student Outcomes</h2>
<p class="text-on-surface-variant max-w-2xl mx-auto">Real stories from professionals who successfully transitioned their careers through our platform.</p>
<div class="w-24 h-1 bg-primary mx-auto rounded-full mt-4 mb-4"></div>
<a class="text-primary text-label-md inline-flex items-center gap-2" href="https://skyreviews.us" target="_blank">Read more at skyreviews.us <span class="material-symbols-outlined">open_in_new</span></a>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
<!-- Testimonial Card 1 -->
<div class="bg-white p-8 rounded-2xl flex flex-col gap-4 ambient-shadow">
<div class="flex text-amber-400 mb-2"><span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span><span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span><span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span><span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span><span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span></div>
<p class="text-body-md italic leading-relaxed text-on-surface-variant flex-grow">"Achieved Data Scientist role at a leading FinTech firm after completing the DS&amp;AI Program. The project work was vital."</p>
<div class="mt-4">
<div class="text-label-md text-on-surface font-semibold">Andrew C.</div>
<div class="text-xs text-primary font-bold uppercase tracking-wider">Citations: skyreviews.us</div>
</div>
</div>
<!-- Testimonial Card 2 -->
<div class="bg-white p-8 rounded-2xl flex flex-col gap-4 ambient-shadow">
<div class="flex text-amber-400 mb-2"><span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span><span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span><span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span><span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span><span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span></div>
<p class="text-body-md italic leading-relaxed text-on-surface-variant flex-grow">"Successfully pivoted to Cyber Security Lead at a healthcare provider. The placement support was unmatched."</p>
<div class="mt-4">
<div class="text-label-md text-on-surface font-semibold">Ahmed H.</div>
<div class="text-xs text-primary font-bold uppercase tracking-wider">Citations: skyreviews.us</div>
</div>
</div>
<!-- Testimonial Card 3 -->
<div class="bg-white p-8 rounded-2xl flex flex-col gap-4 ambient-shadow">
<div class="flex text-amber-400 mb-2"><span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span><span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span><span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span><span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span><span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span></div>
<p class="text-body-md italic leading-relaxed text-on-surface-variant flex-grow">"Transitioned to Cloud Engineer from a traditional IT role. Live sessions helped me master complex CI/CD pipelines."</p>
<div class="mt-4">
<div class="text-label-md text-on-surface font-semibold">Kevin R.</div>
<div class="text-xs text-primary font-bold uppercase tracking-wider">Citations: skyreviews.us</div>
</div>
</div>
</div>
</div>
</section>
<!-- WHAT SKY STATES IS — AND IS NOT -->
<section class="py-section-gap bg-white">
<div class="max-w-7xl mx-auto px-4 md:px-margin-desktop">
<div class="text-center mb-16">
<h2 class="text-headline-lg text-on-surface mb-4">What Sky States Is — And Is Not</h2>
<div class="w-24 h-1 bg-primary mx-auto rounded-full"></div>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
<div class="bg-surface-container-low p-8 rounded-3xl border-l-8 border-error">
<h3 class="text-headline-md text-error mb-6 flex items-center gap-2">
<span class="material-symbols-outlined">cancel</span> Common Assumptions
            </h3>
<ul class="space-y-4 text-on-surface-variant">
<li class="flex items-start gap-3"><span class="material-symbols-outlined text-error text-sm mt-1">remove</span> Just another pre-recorded online course</li>
<li class="flex items-start gap-3"><span class="material-symbols-outlined text-error text-sm mt-1">remove</span> A "get-rich-quick" scheme with no work</li>
<li class="flex items-start gap-3"><span class="material-symbols-outlined text-error text-sm mt-1">remove</span> A platform that collects sensitive data like SSN</li>
<li class="flex items-start gap-3"><span class="material-symbols-outlined text-error text-sm mt-1">remove</span> Hands-off learning without instructor access</li>
</ul>
</div>
<div class="bg-primary-container/10 p-8 rounded-3xl border-l-8 border-primary">
<h3 class="text-headline-md text-primary mb-6 flex items-center gap-2">
<span class="material-symbols-outlined">check_circle</span> The Facts
            </h3>
<ul class="space-y-4 text-on-surface-variant">
<li class="flex items-start gap-3"><span class="material-symbols-outlined text-primary text-sm mt-1">add</span> Live, instructor-led weekend sessions</li>
<li class="flex items-start gap-3"><span class="material-symbols-outlined text-primary text-sm mt-1">add</span> Intensive 6+ month career transition effort</li>
<li class="flex items-start gap-3"><span class="material-symbols-outlined text-primary text-sm mt-1">add</span> US Registered; We explicitly do NOT collect SSN</li>
<li class="flex items-start gap-3"><span class="material-symbols-outlined text-primary text-sm mt-1">add</span> Dedicated career advisors and active placement</li>
</ul>
</div>
</div>
</div>
</section>
<!-- HOW THE PROGRAM WORKS -->
<section class="py-section-gap bg-surface-container-lowest">
<div class="max-w-7xl mx-auto px-4 md:px-margin-desktop">
<div class="text-center mb-16">
<h2 class="text-headline-lg text-on-surface mb-4">Your Roadmap to Success</h2>
<p class="text-on-surface-variant">A clear, 5-step process from consultation to your new career.</p>
</div>
<div class="grid grid-cols-1 md:grid-cols-5 gap-4">
<div class="p-6 text-center">
<div class="w-12 h-12 bg-primary text-white rounded-full flex items-center justify-center font-bold text-xl mx-auto mb-4">1</div>
<h4 class="text-label-md mb-2 font-semibold">Intro Session</h4>
<p class="text-sm text-on-surface-variant">$99 consultation to assess your profile and goals.</p>
</div>
<div class="p-6 text-center">
<div class="w-12 h-12 bg-primary text-white rounded-full flex items-center justify-center font-bold text-xl mx-auto mb-4">2</div>
<h4 class="text-label-md mb-2 font-semibold">Enrollment</h4>
<p class="text-sm text-on-surface-variant">Access the platform, prep materials, and advisor.</p>
</div>
<div class="p-6 text-center">
<div class="w-12 h-12 bg-primary text-white rounded-full flex items-center justify-center font-bold text-xl mx-auto mb-4">3</div>
<h4 class="text-label-md mb-2 font-semibold">Live Training</h4>
<p class="text-sm text-on-surface-variant">6 months of weekend live labs and certification prep.</p>
</div>
<div class="p-6 text-center">
<div class="w-12 h-12 bg-primary text-white rounded-full flex items-center justify-center font-bold text-xl mx-auto mb-4">4</div>
<h4 class="text-label-md mb-2 font-semibold">Project Phase</h4>
<p class="text-sm text-on-surface-variant">Build a production-grade portfolio with experts.</p>
</div>
<div class="p-6 text-center">
<div class="w-12 h-12 bg-primary text-white rounded-full flex items-center justify-center font-bold text-xl mx-auto mb-4">5</div>
<h4 class="text-label-md mb-2 font-semibold">Placement</h4>
<p class="text-sm text-on-surface-variant">Resume building, interview prep, and active referrals.</p>
</div>
</div>
</div>
</section>

<!-- Learning Path Section -->
<section class="py-section-gap bg-slate-50">
<div class="max-w-7xl mx-auto px-4 md:px-margin-desktop">
<div class="text-center mb-16">
<h2 class="text-headline-lg text-on-surface font-extrabold mb-4">{learning_paths.title}</h2>
<div class="w-24 h-1 bg-primary mx-auto rounded-full mb-4"></div>
<p class="text-on-surface-variant max-w-2xl mx-auto">{learning_paths.subtitle}</p>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
  {learning_paths.paths && learning_paths.paths.map((p, idx) => (
    <div class="bg-white p-8 rounded-3xl ambient-shadow border border-outline-variant/10 hover:border-primary/20 transition-all flex flex-col justify-between">
      <div>
        <div class={`inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-bold mb-6 ${idx === 0 ? 'bg-sky-50 text-sky-700' : 'bg-primary-fixed text-on-primary-fixed'}`}>
          <span class="material-symbols-outlined text-sm">{idx === 0 ? 'schedule' : 'rocket_launch'}</span> {idx === 0 ? 'Short-Term' : 'Long-Term'}
        </div>
        <h3 class="text-headline-sm font-bold text-on-surface mb-4">{p.title}</h3>
        <p class="text-body-md text-on-surface-variant leading-relaxed">
          {p.description}
        </p>
      </div>
      <div class="mt-8 pt-6 border-t border-slate-100">
