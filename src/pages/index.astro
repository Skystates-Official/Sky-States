---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>

<html lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Sky States | Career Acceleration &amp; Transition Platform</title>
<meta content="US-registered career platform offering live instructor-led training in Data Science, Cyber Security, and DevOps. $2,999 program with active placement support." name="description"/>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>

<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .ambient-shadow {
            box-shadow: 0 10px 30px -5px rgba(15, 29, 37, 0.04);
        }
    </style>
<script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Sky States",
      "url": "https://skystates.us",
      "logo": "https://skystates.us/logo.png",
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+1-888-810-2434",
        "contactType": "customer service",
        "email": "info@skystates.us"
      }
    }
    </script>
<script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [{
        "@type": "Question",
        "name": "Is Sky States a legitimate company?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, Sky States is a US-registered Career Acceleration Platform based in Wyoming and Delaware, focusing on senior professional career transitions."
        }
      }, {
        "@type": "Question",
        "name": "How frequent are the training calls?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Training sessions are live and instructor-led, held every weekend to accommodate working professionals."
        }
      }, {
        "@type": "Question",
        "name": "Does Sky States collect my SSN?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. Sky States explicitly states that we do NOT collect Social Security Numbers (SSN) from our students."
        }
      }, {
        "@type": "Question",
        "name": "Is screen sharing required?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "During live labs and project evaluations, screen sharing may be used to provide direct instructor feedback and support."
        }]
    }
    </script>
</head>
<body class="bg-background text-on-background selection:bg-primary-fixed selection:text-on-primary-fixed overflow-x-hidden">
