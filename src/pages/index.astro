      </div>

      <!-- STUDENT OUTCOMES (Alumni Placements) -->
      <section class="relative bg-white pt-16 pb-12 overflow-hidden">
        <div class="max-w-7xl mx-auto px-4">
          <div class="w-full text-center" style="opacity: 1;">
            <h2 class="text-headline-lg text-on-surface text-center font-bold">
              Where Our Alumni Work
            </h2>
            <p
              class="mt-3 text-on-surface-variant text-sm sm:text-base max-w-2xl mx-auto"
            >
              Sky States graduates have successfully transitioned into roles at
              these industry-leading global companies.
            </p>
          </div>
          <EmployerLogoMarquee />
        </div>

        <!-- Footer -->
        <Footer />

        <script>
          // Reveal animations
          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add("opacity-100", "translate-y-0");
                  entry.target.classList.remove("opacity-0", "translate-y-10");
                }
              });
            },
            { threshold: 0.1 },
          );

          document.querySelectorAll("section").forEach((section) => {
            section.classList.add(
              "transition-[opacity,transform]",
              "duration-1000",
              "opacity-0",
              "translate-y-10",
            );
            observer.observe(section);
          });

          // Lightbox & Interactive Video controller
          const videoTrigger = document.getElementById("play-video-trigger");
          const lightbox = document.getElementById("video-lightbox");
          const lightboxClose = document.getElementById("lightbox-close-btn");
          const lightboxBgClose = document.getElementById("lightbox-bg-close");
          const lightboxPlayer = document.getElementById(
            "lightbox-player",
          ) as HTMLVideoElement;
          const previewVideo = document.getElementById(
            "preview-video",
          ) as HTMLVideoElement;

          function openLightbox() {
            if (!lightbox || !lightboxPlayer) return;
            lightbox.classList.remove("opacity-0", "pointer-events-none");
            lightbox.classList.add("opacity-100");

            const content = document.getElementById("lightbox-content");
            if (content) {
              content.classList.remove("scale-95");
              content.classList.add("scale-100");
            }

            // Pause preview, play main video
            if (previewVideo) previewVideo.pause();
            lightboxPlayer
              .play()
              .catch((err: any) => console.log("Playback error:", err));
          }

          function closeLightbox() {
            if (!lightbox || !lightboxPlayer) return;
            lightbox.classList.add("opacity-0", "pointer-events-none");
            lightbox.classList.remove("opacity-100");

            const content = document.getElementById("lightbox-content");
            if (content) {
              content.classList.add("scale-95");
              content.classList.remove("scale-100");
            }

            lightboxPlayer.pause();
            lightboxPlayer.currentTime = 0;

            // Resume preview
            if (previewVideo) previewVideo.play().catch(() => {});
          }

          if (videoTrigger) {
            videoTrigger.addEventListener("click", openLightbox);
          }
          if (lightboxClose) {
            lightboxClose.addEventListener("click", closeLightbox);
          }
          if (lightboxBgClose) {
            lightboxBgClose.addEventListener("click", closeLightbox);
          }

          // Escape Key Bindings
          window.addEventListener("keydown", (e) => {
            if (e.key === "Escape") {
              closeLightbox();
            }
          });

          // Parallax Mouse Movement on Floating Cards
          const section = document.getElementById("experience-sky-states");
          const lmsCard = document.getElementById("floating-card-lms");
          const officeCard = document.getElementById("floating-card-office");

          if (section && window.innerWidth > 1024) {
            section.addEventListener("mousemove", (e) => {
              const rect = section.getBoundingClientRect();
              const x = e.clientX - rect.left - rect.width / 2;
              const y = e.clientY - rect.top - rect.height / 2;

              if (lmsCard) {
                lmsCard.style.transform = `translate(${x * 0.02}px, ${y * 0.02}px)`;
              }
              if (officeCard) {
                officeCard.style.transform = `translate(${x * -0.015}px, ${y * -0.015}px)`;
              }
            });

            section.addEventListener("mouseleave", () => {
              if (lmsCard) lmsCard.style.transform = "translate(0px, 0px)";
              if (officeCard)
                officeCard.style.transform = "translate(0px, 0px)";
            });
          }
        </script>
      </section>
    </section>
    <ConsultationModal />
  </body>
</html>
