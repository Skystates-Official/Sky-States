    {authenticated && (
        <script is:inline define:vars={{ homepageData, aboutData, faqData, programsData, couponConfigData }}>
            // Tab Switching Logic
            window.switchTab = function(tabName) {
                const panels = document.querySelectorAll('.tab-panel');
                panels.forEach(p => p.classList.add('hidden'));
                
                const panel = document.getElementById(`panel-${tabName}`);
                if (panel) panel.classList.remove('hidden');

                const buttons = document.querySelectorAll('[id^="tab-btn-"]');
                buttons.forEach(btn => {
                    btn.classList.remove('border-primary', 'text-primary');
                    btn.classList.add('border-transparent', 'text-secondary');
                });

                const activeBtn = document.getElementById(`tab-btn-${tabName}`);
                if (activeBtn) {
                    activeBtn.classList.remove('border-transparent', 'text-secondary');
                    activeBtn.classList.add('border-primary', 'text-primary');
                }
            }

            // Media Library Client-Side Operations
            window.uploadMedia = async function(e) {
                e.preventDefault();
                const fileInput = document.getElementById('media-file-input');
                const altInput = document.getElementById('media-alt-input');
                const titleInput = document.getElementById('media-title-input');
                
                if (!fileInput.files.length) {
                    alert('Please select a file to upload.');
                    return;
                }

                const formData = new FormData();
                formData.append('file', fileInput.files[0]);
                formData.append('alt_text', altInput.value);
                formData.append('title', titleInput.value);

                try {
                    const response = await fetch('/api/media', {
                        method: 'POST',
                        body: formData
                    });
                    
                    if (response.ok) {
                        alert('Asset uploaded successfully!');
                        window.location.reload();
                    } else {
                        const errData = await response.json();
                        alert('Upload failed: ' + (errData.error || 'Unknown error'));
                    }
                } catch (err) {
                    console.error('Upload request error:', err);
                    alert('Upload request failed.');
                }
            }

            window.copyToClipboard = function(text) {
                const absoluteUrl = window.location.origin + text;
                navigator.clipboard.writeText(absoluteUrl).then(() => {
                    alert('Copied URL to clipboard: ' + absoluteUrl);
                }).catch(err => {
                    console.error('Clipboard error:', err);
                    alert('Failed to copy. URL: ' + absoluteUrl);
                });
            }

            window.deleteMedia = async function(id) {
                if (!confirm('Are you sure you want to permanently delete this asset?')) return;

                try {
                    const response = await fetch('/api/media', {
                        method: 'DELETE',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ id })
                    });

                    if (response.ok) {
                        const el = document.getElementById(`media-${id}`);
                        if (el) el.remove();
                    } else {
                        const errData = await response.json();
                        alert('Delete failed: ' + (errData.error || 'Unknown error'));
                    }
                } catch (err) {
                    console.error('Delete request error:', err);
                    alert('Delete request failed.');
                }
            }

            // Dynamic Pages Operations
            const pageModal = document.getElementById('page-modal');
            const pageEditorModal = document.getElementById('page-editor-modal');
            let activePageBlocks = [];

            window.openPageModal = function() {
                document.getElementById('page-create-title').value = '';
                document.getElementById('page-create-slug').value = '';
                pageModal.classList.remove('hidden');
            }

            window.closePageModal = function() {
                pageModal.classList.add('hidden');
            }

            window.createPage = async function(e) {
                e.preventDefault();
                const title = document.getElementById('page-create-title').value;
                const slug = document.getElementById('page-create-slug').value.toLowerCase().replace(/[^a-z0-9-/]+/g, '-');

                try {
                    const response = await fetch('/api/pages', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ title, slug })
                    });

                    if (response.ok) {
                        alert('Page draft created successfully!');
                        window.location.reload();
                    } else {
                        const err = await response.json();
                        alert('Error: ' + (err.error || 'Failed to create page'));
                    }
                } catch (err) {
                    console.error(err);
                    alert('Request failed');
                }
            }

            window.deletePage = async function(id) {
                if (!confirm('Are you absolutely sure you want to delete this page? All dynamic blocks will be lost.')) return;

                try {
                    const response = await fetch('/api/pages', {
                        method: 'DELETE',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ id })
                    });

                    if (response.ok) {
                        const row = document.getElementById(`page-row-${id}`);
                        if (row) row.remove();
