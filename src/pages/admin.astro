                        <label for="form-coupon-description" class="text-xs font-bold uppercase text-secondary">Description</label>
                        <input type="text" id="form-coupon-description" class="h-11 px-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-sm" placeholder="Launch promotion" />
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div class="flex flex-col gap-1.5">
                            <label for="form-coupon-max-uses" class="text-xs font-bold uppercase text-secondary">Max Uses</label>
                            <input type="number" id="form-coupon-max-uses" min="1" class="h-11 px-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-sm" placeholder="Unlimited" />
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label for="form-coupon-expires" class="text-xs font-bold uppercase text-secondary">Expiry Date</label>
                            <input type="date" id="form-coupon-expires" class="h-11 px-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-sm" />
                        </div>
                    </div>
                    <label class="flex items-center gap-2 text-sm text-slate-700">
                        <input type="checkbox" id="form-coupon-active" checked class="rounded border-slate-300" />
                        <span>Coupon is active</span>
                    </label>
                    <div class="pt-2 flex gap-3 justify-end border-t border-outline-variant/10 mt-4">
                        <button type="button" onclick="closeCouponModal()" class="px-5 py-2.5 border border-outline-variant/40 hover:bg-surface-container rounded-lg text-xs uppercase tracking-wider font-bold transition-all">Cancel</button>
                        <button type="submit" class="px-5 py-2.5 bg-primary text-white hover:bg-opacity-90 rounded-lg text-xs uppercase tracking-wider font-bold transition-all">Save Coupon</button>
                    </div>
                </form>
            </div>
        </div>

        <div id="user-modal" class={isFullAdmin ? "fixed inset-0 bg-black/50 backdrop-blur-sm z-[100] flex items-center justify-center hidden" : "hidden"}>
            <div class="bg-white rounded-2xl w-full max-w-md p-8 shadow-2xl relative border border-outline-variant/10" onclick="event.stopPropagation()">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-outline-variant/10">
                    <h2 id="user-modal-title" class="font-headline-md text-xl text-primary">Add Admin User</h2>
                    <button onclick="closeUserModal()" class="p-2 hover:bg-surface-container rounded-lg transition-colors cursor-pointer">
                        <span class="material-symbols-outlined text-[20px]">close</span>
                    </button>
                </div>
                <form onsubmit="saveAdminUser(event)" class="space-y-4">
                    <input type="hidden" id="form-user-id" />
                    <div class="flex flex-col gap-1.5">
                        <label for="form-user-username" class="text-xs font-bold uppercase text-secondary">Username / Email</label>
                        <input type="text" id="form-user-username" required class="h-11 px-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-sm" placeholder="editor@skystates.us" />
                    </div>
                    <div class="flex flex-col gap-1.5">
                        <label for="form-user-password" class="text-xs font-bold uppercase text-secondary">Password</label>
                        <input type="password" id="form-user-password" class="h-11 px-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-sm" placeholder="Minimum 8 characters" />
                        <p id="form-user-password-help" class="text-[11px] text-secondary">Required for new users. Leave blank when editing to keep the current password.</p>
                    </div>
                    <div class="flex flex-col gap-1.5">
                        <label for="form-user-role" class="text-xs font-bold uppercase text-secondary">Access Role</label>
                        <select id="form-user-role" required class="h-11 px-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-sm bg-white">
                            <option value="editor">Editor — content updates</option>
                            <option value="admin">Administrator — full platform control</option>
                        </select>
                    </div>
                    <div class="pt-2 flex gap-3 justify-end border-t border-outline-variant/10 mt-4">
                        <button type="button" onclick="closeUserModal()" class="px-5 py-2.5 border border-outline-variant/40 hover:bg-surface-container rounded-lg text-xs uppercase tracking-wider font-bold transition-all">Cancel</button>
                        <button type="submit" class="px-5 py-2.5 bg-primary text-white hover:bg-opacity-90 rounded-lg text-xs uppercase tracking-wider font-bold transition-all">Save User</button>
                    </div>
                </form>
            </div>
        </div>
    )}

    <!-- Footer -->
    {!authenticated && <Footer />}

    {authenticated && (
        <script is:inline define:vars={{ homepageData, aboutData, faqData, programsData, couponConfigData, storiesData }}>
            const adminTitles = {
                dashboard: 'Overview',
                jobs: 'Jobs & Placements',
                stories: 'Stories & Blogs',
                coupons: 'Coupons',
                homepage: 'Site Content',
                media: 'Media Library',
                pages: 'Dynamic Pages',
                users: 'Team Access',
            };

            window.switchTab = function(tabName) {
                const panels = document.querySelectorAll('.tab-panel');
                panels.forEach(p => p.classList.add('hidden'));
                
                const panel = document.getElementById(`panel-${tabName}`);
                if (panel) panel.classList.remove('hidden');

                const buttons = document.querySelectorAll('.admin-nav-btn[id^="tab-btn-"]');
                buttons.forEach(btn => btn.classList.remove('active'));

                const activeBtn = document.getElementById(`tab-btn-${tabName}`);
                if (activeBtn) activeBtn.classList.add('active');

                const titleEl = document.getElementById('admin-page-title');
                if (titleEl && adminTitles[tabName]) titleEl.textContent = adminTitles[tabName];
            }

            // Media Library Client-Side Operations
            window.uploadMedia = async function(e) {
                e.preventDefault();
                const fileInput = document.getElementById('media-file-input');
                const altInput = document.getElementById('media-alt-input');
                const titleInput = document.getElementById('media-title-input');
                
                if (!fileInput.files.length) {
                    alert('Please select a file to upload.');
                    return;
                }

                const formData = new FormData();
                formData.append('file', fileInput.files[0]);
                formData.append('alt_text', altInput.value);
                formData.append('title', titleInput.value);

                try {
                    const response = await fetch('/api/media', {
                        method: 'POST',
                        body: formData
                    });
                    
                    if (response.ok) {
                        alert('Asset uploaded successfully!');
                        window.location.reload();
                    } else {
                        const errData = await response.json();
                        alert('Upload failed: ' + (errData.error || 'Unknown error'));
                    }
                } catch (err) {
                    console.error('Upload request error:', err);
                    alert('Upload request failed.');
                }
            }

            window.copyToClipboard = function(text) {
                const absoluteUrl = window.location.origin + text;
                navigator.clipboard.writeText(absoluteUrl).then(() => {
                    alert('Copied URL to clipboard: ' + absoluteUrl);
                }).catch(err => {
                    console.error('Clipboard error:', err);
                    alert('Failed to copy. URL: ' + absoluteUrl);
                });
            }

            window.deleteMedia = async function(id) {
                if (!confirm('Are you sure you want to permanently delete this asset?')) return;

                try {
                    const response = await fetch('/api/media', {
                        method: 'DELETE',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ id })
                    });

                    if (response.ok) {
                        const el = document.getElementById(`media-${id}`);
                        if (el) el.remove();
                    } else {
                        const errData = await response.json();
                        alert('Delete failed: ' + (errData.error || 'Unknown error'));
                    }
                } catch (err) {
                    console.error('Delete request error:', err);
                    alert('Delete request failed.');
                }
            }

            // Dynamic Pages Operations
            const pageModal = document.getElementById('page-modal');
            const pageEditorModal = document.getElementById('page-editor-modal');
            let activePageBlocks = [];

            window.openPageModal = function() {
                document.getElementById('page-create-title').value = '';
                document.getElementById('page-create-slug').value = '';
                pageModal.classList.remove('hidden');
            }

            window.closePageModal = function() {
                pageModal.classList.add('hidden');
            }

            window.createPage = async function(e) {
                e.preventDefault();
                const title = document.getElementById('page-create-title').value;
                const slug = document.getElementById('page-create-slug').value.toLowerCase().replace(/[^a-z0-9-/]+/g, '-');

                try {
                    const response = await fetch('/api/pages', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ title, slug })
                    });

                    if (response.ok) {
                        alert('Page draft created successfully!');
                        window.location.reload();
                    } else {
                        const err = await response.json();
                        alert('Error: ' + (err.error || 'Failed to create page'));
                    }
                } catch (err) {
                    console.error(err);
                    alert('Request failed');
                }
            }

            window.deletePage = async function(id) {
                if (!confirm('Are you absolutely sure you want to delete this page? All dynamic blocks will be lost.')) return;

                try {
                    const response = await fetch('/api/pages', {
                        method: 'DELETE',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ id })
                    });

                    if (response.ok) {
                        const row = document.getElementById(`page-row-${id}`);
                        if (row) row.remove();
                    } else {
                        alert('Delete page failed.');
                    }
                } catch (err) {
                    console.error(err);
                    alert('Request failed');
                }
            }

            window.openPageEditor = function(page) {
                document.getElementById('editor-page-title').textContent = `Edit Layout: ${page.title}`;
                document.getElementById('editor-page-id').value = page.id;
                document.getElementById('editor-title').value = page.title;
                document.getElementById('editor-slug').value = page.slug;
                document.getElementById('editor-status').value = page.status;
                document.getElementById('editor-meta-title').value = page.meta_title || '';
                document.getElementById('editor-meta-desc').value = page.meta_description || '';
                
                try {
                    activePageBlocks = JSON.parse(page.content_blocks || '[]');
                } catch (e) {
                    activePageBlocks = [];
                }
                
                renderEditorBlocks();
                pageEditorModal.classList.remove('hidden');
            }

            window.closePageEditor = function() {
                pageEditorModal.classList.add('hidden');
            }

            window.renderEditorBlocks = function() {
                const container = document.getElementById('editor-blocks-container');
                container.innerHTML = '';

                if (activePageBlocks.length === 0) {
                    container.innerHTML = `
                        <div class="p-8 border border-dashed border-outline-variant/35 rounded-xl text-center text-secondary text-sm">
                            No content blocks yet. Pick a block type above and click "Add Block" to start designing.
                        </div>
                    `;
                    return;
                }

                activePageBlocks.forEach((block, idx) => {
                    const card = document.createElement('div');
                    card.className = 'bg-white p-5 rounded-xl border border-outline-variant/20 shadow-sm space-y-4';
                    
                    let fieldsHtml = '';
                    if (block.type === 'hero') {
                        fieldsHtml = `
                            <div class="grid grid-cols-2 gap-3">
                                <div class="flex flex-col gap-1">
                                    <label class="text-[10px] font-bold text-secondary uppercase">Badge Text</label>
                                    <input type="text" class="block-input h-9 px-3 border border-outline-variant/30 rounded text-xs" data-key="badge" value="${block.data.badge || ''}" />
                                </div>
                                <div class="flex flex-col gap-1">
                                    <label class="text-[10px] font-bold text-secondary uppercase">CTA Button Text</label>
                                    <input type="text" class="block-input h-9 px-3 border border-outline-variant/30 rounded text-xs" data-key="cta_label" value="${block.data.cta_label || ''}" />
                                </div>
                            </div>
                            <div class="flex flex-col gap-1">
                                <label class="text-[10px] font-bold text-secondary uppercase">Hero Headline (Supports HTML/Tags)</label>
                                <textarea class="block-input p-3 border border-outline-variant/30 rounded text-xs resize-none" rows="2" data-key="headline">${block.data.headline || ''}</textarea>
                            </div>
                            <div class="flex flex-col gap-1">
                                <label class="text-[10px] font-bold text-secondary uppercase">Hero Subtitle / Description</label>
                                <textarea class="block-input p-3 border border-outline-variant/30 rounded text-xs resize-none" rows="2" data-key="subtitle">${block.data.subtitle || ''}</textarea>
                            </div>
                            <div class="flex flex-col gap-1">
                                <label class="text-[10px] font-bold text-secondary uppercase">CTA Button URL Link</label>
                                <input type="text" class="block-input h-9 px-3 border border-outline-variant/30 rounded text-xs" data-key="cta_url" value="${block.data.cta_url || ''}" />
                            </div>
                        `;
                    } else if (block.type === 'cta') {
                        fieldsHtml = `
                            <div class="flex flex-col gap-1">
                                <label class="text-[10px] font-bold text-secondary uppercase">Banner Headline</label>
                                <input type="text" class="block-input h-9 px-3 border border-outline-variant/30 rounded text-xs" data-key="title" value="${block.data.title || ''}" />
                            </div>
                            <div class="flex flex-col gap-1">
                                <label class="text-[10px] font-bold text-secondary uppercase">Description</label>
                                <textarea class="block-input p-3 border border-outline-variant/30 rounded text-xs resize-none" rows="2" data-key="description">${block.data.description || ''}</textarea>
                            </div>
                            <div class="grid grid-cols-2 gap-3">
                                <div class="flex flex-col gap-1">
                                    <label class="text-[10px] font-bold text-secondary uppercase">Button Text</label>
                                    <input type="text" class="block-input h-9 px-3 border border-outline-variant/30 rounded text-xs" data-key="btn_label" value="${block.data.btn_label || ''}" />
                                </div>
                                <div class="flex flex-col gap-1">
                                    <label class="text-[10px] font-bold text-secondary uppercase">Button Link URL</label>
                                    <input type="text" class="block-input h-9 px-3 border border-outline-variant/30 rounded text-xs" data-key="btn_url" value="${block.data.btn_url || ''}" />
                                </div>
                            </div>
                        `;
                    } else if (block.type === 'rich_text') {
                        fieldsHtml = `
                            <div class="flex flex-col gap-1">
                                <label class="text-[10px] font-bold text-secondary uppercase">HTML Markup Content</label>
                                <textarea class="block-input p-3 border border-outline-variant/30 rounded text-xs font-mono" rows="6" data-key="content">${block.data.content || ''}</textarea>
                            </div>
                        `;
                    } else if (block.type === 'features') {
                        fieldsHtml = `
                            <div class="space-y-3">
                                <div class="flex justify-between items-center">
                                    <span class="text-[10px] font-bold text-slate-400 uppercase">Feature List</span>
                                    <button type="button" onclick="addFeatureItem(${idx})" class="text-primary hover:underline text-[10px] font-bold uppercase tracking-wider cursor-pointer">Add Item</button>
                                </div>
                                <div class="space-y-3" id="feature-items-${idx}">
                                    ${(block.data.items || []).map((item, itemIdx) => `
                                        <div class="p-3 border border-outline-variant/15 rounded bg-slate-50 relative space-y-2">
                                            <button type="button" onclick="removeFeatureItem(${idx}, ${itemIdx})" class="absolute top-2 right-2 text-error text-[10px] font-bold hover:underline cursor-pointer">Remove</button>
                                            <div class="grid grid-cols-2 gap-2">
                                                <input type="text" placeholder="Icon (e.g. verified)" class="feat-icon h-8 px-2 border rounded text-xs" value="${item.icon || ''}" />
                                                <input type="text" placeholder="Title" class="feat-title h-8 px-2 border rounded text-xs" value="${item.title || ''}" />
                                            </div>
                                            <input type="text" placeholder="Short description..." class="feat-desc h-8 px-2 border rounded text-xs w-full" value="${item.description || ''}" />
                                        </div>
                                    `).join('')}
                                </div>
                            </div>
                        `;
                    } else if (block.type === 'faq') {
                        fieldsHtml = `
                            <div class="space-y-3">
                                <div class="flex justify-between items-center">
                                    <span class="text-[10px] font-bold text-slate-400 uppercase">FAQ Accordion Questions</span>
                                    <button type="button" onclick="addFaqItem(${idx})" class="text-primary hover:underline text-[10px] font-bold uppercase tracking-wider cursor-pointer">Add Question</button>
                                </div>
                                <div class="space-y-3" id="faq-items-${idx}">
                                    ${(block.data.items || []).map((item, itemIdx) => `
                                        <div class="p-3 border border-outline-variant/15 rounded bg-slate-50 relative space-y-2">
                                            <button type="button" onclick="removeFaqItem(${idx}, ${itemIdx})" class="absolute top-2 right-2 text-error text-[10px] font-bold hover:underline cursor-pointer">Remove</button>
                                            <input type="text" placeholder="Question" class="faq-q h-8 px-2 border rounded text-xs w-full" value="${item.q || ''}" />
                                            <textarea placeholder="Answer..." class="faq-a p-2 border rounded text-xs w-full resize-none" rows="2">${item.a || ''}</textarea>
                                        </div>
                                    `).join('')}
                                </div>
                            </div>
                        `;
                    }

                    card.innerHTML = `
                        <div class="flex justify-between items-center pb-2 border-b border-outline-variant/10">
                            <div class="flex items-center gap-2">
                                <span class="px-2 py-0.5 rounded bg-slate-100 border text-[9px] uppercase tracking-wider font-bold text-slate-500">${block.type}</span>
                                <h4 class="font-bold text-xs text-slate-700">Block #${idx + 1}</h4>
                            </div>
                            <div class="flex items-center gap-1.5">
                                <button type="button" onclick="moveBlock(${idx}, -1)" ${idx === 0 ? 'disabled' : ''} class="p-1 hover:bg-slate-100 rounded text-slate-500 disabled:opacity-30 cursor-pointer">
                                    <span class="material-symbols-outlined text-[16px]">arrow_upward</span>
                                </button>
                                <button type="button" onclick="moveBlock(${idx}, 1)" ${idx === activePageBlocks.length - 1 ? 'disabled' : ''} class="p-1 hover:bg-slate-100 rounded text-slate-500 disabled:opacity-30 cursor-pointer">
                                    <span class="material-symbols-outlined text-[16px]">arrow_downward</span>
                                </button>
                                <button type="button" onclick="removeBlock(${idx})" class="p-1 hover:bg-red-50 text-error rounded cursor-pointer">
                                    <span class="material-symbols-outlined text-[16px]">delete</span>
                                </button>
                            </div>
                        </div>
                        <div class="space-y-3 block-form-fields" data-index="${idx}">
                            ${fieldsHtml}
                        </div>
                    `;
                    container.appendChild(card);
                });
            }

            window.addEditorBlock = function() {
                const select = document.getElementById('block-select');
                const type = select.value;
                
                let defaultData = {};
                if (type === 'hero') {
                    defaultData = { badge: 'New', headline: 'Dynamic Title', subtitle: 'Block details here.', cta_label: 'Button', cta_url: '/' };
                } else if (type === 'cta') {
                    defaultData = { title: 'Call to Action', description: 'Highlight this layout banner.', btn_label: 'Proceed', btn_url: '/' };
                } else if (type === 'rich_text') {
                    defaultData = { content: '<p>Edit this markup content...</p>' };
                } else if (type === 'features') {
                    defaultData = { items: [{ icon: 'verified', title: 'Feature', description: 'Details here' }] };
                } else if (type === 'faq') {
                    defaultData = { items: [{ q: 'Question?', a: 'Answer.' }] };
                }

                activePageBlocks.push({ type, data: defaultData });
                renderEditorBlocks();
            }

            window.moveBlock = function(idx, direction) {
                // Sync values first
                syncBlocksState();
                const targetIdx = idx + direction;
                if (targetIdx < 0 || targetIdx >= activePageBlocks.length) return;
                
                const temp = activePageBlocks[idx];
                activePageBlocks[idx] = activePageBlocks[targetIdx];
                activePageBlocks[targetIdx] = temp;
                
                renderEditorBlocks();
            }

            window.removeBlock = function(idx) {
                syncBlocksState();
                activePageBlocks.splice(idx, 1);
                renderEditorBlocks();
            }

            // Feature Item helpers
            window.addFeatureItem = function(blockIdx) {
                syncBlocksState();
                activePageBlocks[blockIdx].data.items.push({ icon: 'verified', title: 'Feature Item', description: 'Detail text' });
                renderEditorBlocks();
            }

            window.removeFeatureItem = function(blockIdx, itemIdx) {
                syncBlocksState();
                activePageBlocks[blockIdx].data.items.splice(itemIdx, 1);
                renderEditorBlocks();
            }

            // FAQ Item helpers
            window.addFaqItem = function(blockIdx) {
                syncBlocksState();
                activePageBlocks[blockIdx].data.items.push({ q: 'Question?', a: 'Answer detail.' });
                renderEditorBlocks();
            }

            window.removeFaqItem = function(blockIdx, itemIdx) {
                syncBlocksState();
                activePageBlocks[blockIdx].data.items.splice(itemIdx, 1);
                renderEditorBlocks();
            }

            // Syncs the DOM inputs back into the activePageBlocks array in memory
            function syncBlocksState() {
                const forms = document.querySelectorAll('.block-form-fields');
                forms.forEach(form => {
                    const idx = parseInt(form.getAttribute('data-index'), 10);
                    const block = activePageBlocks[idx];
                    
                    if (block.type === 'hero' || block.type === 'cta' || block.type === 'rich_text') {
                        const inputs = form.querySelectorAll('.block-input');
                        inputs.forEach(input => {
                            const key = input.getAttribute('data-key');
                            block.data[key] = input.value;
                        });
                    } else if (block.type === 'features') {
                        const items = [];
                        const rows = form.querySelectorAll('#feature-items-' + idx + ' > div');
                        rows.forEach(row => {
                            const icon = row.querySelector('.feat-icon').value;
                            const title = row.querySelector('.feat-title').value;
                            const description = row.querySelector('.feat-desc').value;
                            items.push({ icon, title, description });
                        });
                        block.data.items = items;
                    } else if (block.type === 'faq') {
                        const items = [];
                        const rows = form.querySelectorAll('#faq-items-' + idx + ' > div');
                        rows.forEach(row => {
                            const q = row.querySelector('.faq-q').value;
                            const a = row.querySelector('.faq-a').value;
                            items.push({ q, a });
                        });
                        block.data.items = items;
                    }
                });
            }

            window.savePageBlocks = async function() {
                syncBlocksState();
                const id = document.getElementById('editor-page-id').value;
                const title = document.getElementById('editor-title').value;
                const slug = document.getElementById('editor-slug').value.toLowerCase().replace(/[^a-z0-9-/]+/g, '-');
                const status = document.getElementById('editor-status').value;
                const meta_title = document.getElementById('editor-meta-title').value;
                const meta_description = document.getElementById('editor-meta-desc').value;

                const payload = {
                    id,
                    title,
                    slug,
                    status,
                    meta_title,
                    meta_description,
                    canonical_url: window.location.origin + '/' + slug,
                    content_blocks: activePageBlocks
                };

                try {
                    const response = await fetch('/api/pages', {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    if (response.ok) {
                        alert('Page layout and configurations saved successfully!');
                        window.location.reload();
                    } else {
                        const err = await response.json();
                        alert('Save failed: ' + (err.error || 'Unknown error'));
                    }
                } catch (e) {
                    console.error(e);
                    alert('Request failed');
                }
            }

            // CMS Page-by-Page Selector Logic
            window.switchCmsPage = function(pageId) {
                const subPanels = document.querySelectorAll('.cms-sub-panel');
                subPanels.forEach(p => p.classList.add('hidden'));
                
                const activePanel = document.getElementById(`cms-sub-${pageId}`);
                if (activePanel) activePanel.classList.remove('hidden');
            }

            // Populate CMS inputs on load
            if (homepageData) {
                document.getElementById('cms-hero-headline').value = homepageData.hero?.headline || '';
                document.getElementById('cms-hero-description').value = homepageData.hero?.description || '';
                document.getElementById('cms-hero-btn-text').value = homepageData.hero?.button_text || '';
                document.getElementById('cms-hero-btn-url').value = homepageData.hero?.button_url || '';
                document.getElementById('cms-hero-consult-text').value = homepageData.hero?.consultation_text || '';
                document.getElementById('cms-hero-consult-url').value = homepageData.hero?.consultation_url || '';
                document.getElementById('cms-trust-bar').value = (homepageData.trust_bar || []).join(', ');
                document.getElementById('cms-about-title').value = homepageData.about?.title || '';
                document.getElementById('cms-about-description').value = homepageData.about?.description || '';
                
                // Why Choose
                if (homepageData.why_choose) {
                    homepageData.why_choose.forEach((feat, idx) => {
