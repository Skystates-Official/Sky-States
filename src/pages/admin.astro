            window.addEditorBlock = function() {
                const select = document.getElementById('block-select');
                const type = select.value;
                
                let defaultData = {};
                if (type === 'hero') {
                    defaultData = { badge: 'New', headline: 'Dynamic Title', subtitle: 'Block details here.', cta_label: 'Button', cta_url: '/' };
                } else if (type === 'cta') {
                    defaultData = { title: 'Call to Action', description: 'Highlight this layout banner.', btn_label: 'Proceed', btn_url: '/' };
                } else if (type === 'rich_text') {
                    defaultData = { content: '<p>Edit this markup content...</p>' };
                } else if (type === 'features') {
                    defaultData = { items: [{ icon: 'verified', title: 'Feature', description: 'Details here' }] };
                } else if (type === 'faq') {
                    defaultData = { items: [{ q: 'Question?', a: 'Answer.' }] };
                }

                activePageBlocks.push({ type, data: defaultData });
                renderEditorBlocks();
            }

            window.moveBlock = function(idx, direction) {
                // Sync values first
                syncBlocksState();
                const targetIdx = idx + direction;
                if (targetIdx < 0 || targetIdx >= activePageBlocks.length) return;
                
                const temp = activePageBlocks[idx];
                activePageBlocks[idx] = activePageBlocks[targetIdx];
                activePageBlocks[targetIdx] = temp;
                
                renderEditorBlocks();
            }

            window.removeBlock = function(idx) {
                syncBlocksState();
                activePageBlocks.splice(idx, 1);
                renderEditorBlocks();
            }

            // Feature Item helpers
            window.addFeatureItem = function(blockIdx) {
                syncBlocksState();
                activePageBlocks[blockIdx].data.items.push({ icon: 'verified', title: 'Feature Item', description: 'Detail text' });
                renderEditorBlocks();
            }

            window.removeFeatureItem = function(blockIdx, itemIdx) {
                syncBlocksState();
                activePageBlocks[blockIdx].data.items.splice(itemIdx, 1);
                renderEditorBlocks();
            }

            // FAQ Item helpers
            window.addFaqItem = function(blockIdx) {
                syncBlocksState();
                activePageBlocks[blockIdx].data.items.push({ q: 'Question?', a: 'Answer detail.' });
                renderEditorBlocks();
            }

            window.removeFaqItem = function(blockIdx, itemIdx) {
                syncBlocksState();
                activePageBlocks[blockIdx].data.items.splice(itemIdx, 1);
                renderEditorBlocks();
            }

            // Syncs the DOM inputs back into the activePageBlocks array in memory
            function syncBlocksState() {
                const forms = document.querySelectorAll('.block-form-fields');
                forms.forEach(form => {
                    const idx = parseInt(form.getAttribute('data-index'), 10);
                    const block = activePageBlocks[idx];
                    
                    if (block.type === 'hero' || block.type === 'cta' || block.type === 'rich_text') {
                        const inputs = form.querySelectorAll('.block-input');
                        inputs.forEach(input => {
                            const key = input.getAttribute('data-key');
                            block.data[key] = input.value;
                        });
                    } else if (block.type === 'features') {
                        const items = [];
                        const rows = form.querySelectorAll('#feature-items-' + idx + ' > div');
                        rows.forEach(row => {
                            const icon = row.querySelector('.feat-icon').value;
                            const title = row.querySelector('.feat-title').value;
                            const description = row.querySelector('.feat-desc').value;
                            items.push({ icon, title, description });
                        });
                        block.data.items = items;
                    } else if (block.type === 'faq') {
                        const items = [];
                        const rows = form.querySelectorAll('#faq-items-' + idx + ' > div');
                        rows.forEach(row => {
                            const q = row.querySelector('.faq-q').value;
                            const a = row.querySelector('.faq-a').value;
                            items.push({ q, a });
                        });
                        block.data.items = items;
                    }
                });
            }

            window.savePageBlocks = async function() {
                syncBlocksState();
                const id = document.getElementById('editor-page-id').value;
                const title = document.getElementById('editor-title').value;
                const slug = document.getElementById('editor-slug').value.toLowerCase().replace(/[^a-z0-9-/]+/g, '-');
                const status = document.getElementById('editor-status').value;
                const meta_title = document.getElementById('editor-meta-title').value;
                const meta_description = document.getElementById('editor-meta-desc').value;

                const payload = {
                    id,
                    title,
                    slug,
                    status,
                    meta_title,
                    meta_description,
                    canonical_url: window.location.origin + '/' + slug,
                    content_blocks: activePageBlocks
                };

                try {
                    const response = await fetch('/api/pages', {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    if (response.ok) {
                        alert('Page layout and configurations saved successfully!');
                        window.location.reload();
                    } else {
                        const err = await response.json();
                        alert('Save failed: ' + (err.error || 'Unknown error'));
                    }
                } catch (e) {
                    console.error(e);
                    alert('Request failed');
                }
            }

