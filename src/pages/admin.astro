---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import jobsData from '../data/jobs.json';
import homepageData from '../data/homepage.json';
import aboutData from '../data/about.json';
import faqData from '../data/faq.json';
import programsData from '../data/programs.json';
import couponConfigData from '../data/coupon-config.json';

import { authenticateUser, verifySessionToken, createSessionToken } from '../db/auth.js';

export const prerender = false;

// Authenticate session
let authenticated = false;
let userSession = null;
let loginError = '';

if (Astro.cookies.has('admin_session')) {
    const sessionCookie = Astro.cookies.get('admin_session');
    if (sessionCookie) {
        userSession = verifySessionToken(sessionCookie.value);
        if (userSession) {
            authenticated = true;
        }
    }
}

// Handle login/logout requests
if (Astro.request.method === 'POST') {
    try {
        const formData = await Astro.request.formData();
        const action = formData.get('action');
        
        if (action === 'login') {
            const username = formData.get('username');
            const password = formData.get('password');
            
            const user = await authenticateUser(username, password);
            if (user) {
                const token = createSessionToken(user.username, user.role);
                Astro.cookies.set('admin_session', token, {
                    path: '/',
                    httpOnly: true,
                    sameSite: 'strict',
                    maxAge: 86400
                });
                return Astro.redirect('/admin');
            } else {
                loginError = 'Invalid credentials. Please try again.';
            }
        } else if (action === 'logout') {
            Astro.cookies.delete('admin_session', { path: '/' });
            return Astro.redirect('/admin');
        }
    } catch (e) {
        loginError = 'An error occurred during authentication.';
    }
}

import { query as sqlQuery } from '../db/sqlite.js';
let mediaItems = [];
let dynamicPages = [];
if (authenticated) {
    try {
        mediaItems = await sqlQuery.all("SELECT * FROM media ORDER BY created_at DESC");
        dynamicPages = await sqlQuery.all("SELECT * FROM pages ORDER BY created_at DESC");
    } catch (dbErr) {
        console.error("Error loading CMS items:", dbErr.message);
    }
}
---

<!DOCTYPE html>
<html class="light" lang="en">
<head>
  <link rel="icon" type="image/png" href="/favicon.png" />
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Institutional Admin Portal | Sky States</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Geist:wght@400;600;700;800&display=swap" rel="stylesheet"/>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
        }
        .upward-gradient {
            background: linear-gradient(to top, #ffffff, #d3e2ed);
        }
        .ambient-shadow {
            box-shadow: 0 10px 30px -5px rgba(15, 29, 37, 0.04);
        }
    </style>
</head>
<body class="bg-background text-on-background font-body-md overflow-x-hidden">
    <!-- Top Nav -->
    <Header />

    {authenticated ? (
        <main class="max-w-[1280px] mx-auto px-margin-desktop py-12">
            <!-- Hero Header -->
            <div class="mb-8 flex justify-between items-center bg-surface-container-lowest p-8 rounded-xl border border-outline-variant/20 ambient-shadow">
                <div>
                    <span class="text-xs uppercase tracking-widest text-primary font-bold">Systems Console</span>
                    <h1 class="font-headline-xl text-4xl text-primary leading-tight mt-1">Sky States Content Hub</h1>
                    <p class="text-on-surface-variant font-body-sm text-sm mt-1">Perform administrative modifications and manage placements.</p>
                </div>
                <div class="flex items-center gap-3">
                    <form method="POST" class="inline m-0">
                        <input type="hidden" name="action" value="logout" />
                        <button type="submit" class="border border-outline-variant hover:bg-surface-container text-on-surface transition-all px-5 py-3 rounded-lg font-label-md text-xs uppercase tracking-wider font-bold flex items-center gap-1.5 shadow-sm bg-white">
                            <span class="material-symbols-outlined text-[16px]">logout</span>
                            <span>Log Out</span>
                        </button>
                    </form>
                </div>
            </div>

            <!-- Tab Navigation -->
            <div class="mb-8 border-b border-outline-variant/20 flex gap-6">
                <button 
                    onclick="switchTab('jobs')" 
                    id="tab-btn-jobs" 
                    class="pb-4 text-sm font-bold uppercase tracking-wider border-b-2 border-primary text-primary transition-all cursor-pointer"
                >
                    Placement Directory
                </button>
                <button 
                    onclick="switchTab('homepage')" 
                    id="tab-btn-homepage" 
                    class="pb-4 text-sm font-bold uppercase tracking-wider border-b-2 border-transparent text-secondary hover:text-primary transition-all cursor-pointer"
                >
                    Page Content CMS
                </button>
                <button 
                    onclick="switchTab('media')" 
                    id="tab-btn-media" 
                    class="pb-4 text-sm font-bold uppercase tracking-wider border-b-2 border-transparent text-secondary hover:text-primary transition-all cursor-pointer"
                >
                    Media Library
                </button>
                <button 
                    onclick="switchTab('pages')" 
                    id="tab-btn-pages" 
                    class="pb-4 text-sm font-bold uppercase tracking-wider border-b-2 border-transparent text-secondary hover:text-primary transition-all cursor-pointer"
                >
                    Dynamic Pages
                </button>
            </div>

            <!-- TAB 1: PLACEMENTS -->
            <div id="panel-jobs" class="tab-panel">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="font-headline-md text-xl text-on-surface">Manage Active Placements</h2>
                    <button 
                        onclick="openAddModal()" 
                        class="bg-primary text-white hover:bg-opacity-90 transition-all px-5 py-2.5 rounded-lg font-label-md text-xs uppercase tracking-wider font-bold flex items-center gap-1.5 shadow-sm"
                    >
                        <span class="material-symbols-outlined text-[16px]">add</span>
                        <span>Post New Job</span>
                    </button>
                </div>

                <!-- Table of Jobs -->
                <div class="bg-white rounded-xl border border-outline-variant/20 overflow-hidden ambient-shadow">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="bg-surface-container-low text-secondary font-bold text-xs uppercase border-b border-outline-variant/10">
                                    <th class="px-6 py-4">Role / Title</th>
                                    <th class="px-6 py-4">Company</th>
                                    <th class="px-6 py-4">Location</th>
                                    <th class="px-6 py-4">Salary Range</th>
                                    <th class="px-6 py-4">Skills / Tags</th>
                                    <th class="px-6 py-4 text-right">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="admin-jobs-table-body" class="divide-y divide-outline-variant/10">
                                {jobsData.map(job => (
                                    <tr class="hover:bg-surface-container-lowest/50 transition-colors" id={`row-${job.id}`}>
                                        <td class="px-6 py-5">
                                            <div class="font-semibold text-on-surface">{job.title}</div>
                                            {job.category && (
                                                <span class="inline-block mt-1 px-2 py-0.5 text-[9px] uppercase font-bold tracking-wider bg-primary/10 text-primary rounded-md">
                                                    {job.category}
                                                </span>
                                            )}
                                        </td>
                                        <td class="px-6 py-5 text-secondary">{job.company}</td>
                                        <td class="px-6 py-5 text-secondary">{job.location}</td>
                                        <td class="px-6 py-5 text-secondary">{job.salary}</td>
                                        <td class="px-6 py-5">
                                            <div class="flex flex-wrap gap-1">
                                                {job.tags.map(tag => (
                                                    <span class="px-2 py-0.5 text-[9px] uppercase font-bold tracking-wider bg-surface-container text-secondary rounded">
                                                        {tag}
                                                    </span>
                                                ))}
                                            </div>
                                        </td>
                                        <td class="px-6 py-5 text-right space-x-2">
                                            <button 
                                                onclick={`openEditModal(${JSON.stringify(job)})`} 
                                                class="text-primary hover:bg-primary/5 p-2 rounded-lg transition-colors inline-flex items-center"
                                                title="Edit Job"
                                            >
                                                <span class="material-symbols-outlined text-[20px]">edit</span>
                                            </button>
                                            <button 
                                                onclick={`deleteJob('${job.id}')`} 
                                                class="text-error hover:bg-error/5 p-2 rounded-lg transition-colors inline-flex items-center"
                                                title="Delete Job"
                                            >
                                                <span class="material-symbols-outlined text-[20px]">delete</span>
                                            </button>
                                        </td>
                                    </tr>
                                ))}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- TAB 3: MEDIA LIBRARY -->
            <div id="panel-media" class="tab-panel hidden space-y-6">
                <div class="flex justify-between items-center">
                    <h2 class="font-headline-md text-xl text-on-surface">Media Assets Library</h2>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
                    <!-- Upload File Sidebar -->
                    <div class="lg:col-span-4 bg-white p-6 rounded-xl border border-outline-variant/20 shadow-sm space-y-4 h-fit">
                        <h3 class="font-bold text-sm text-primary uppercase tracking-wider">Upload Asset</h3>
                        
                        <form id="media-upload-form" onsubmit="uploadMedia(event)" class="space-y-4">
                            <div class="flex flex-col gap-1.5">
                                <label class="text-xs font-bold uppercase text-secondary">Choose File</label>
                                <input type="file" id="media-file-input" required class="block w-full text-xs text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-xs file:font-semibold file:bg-sky-50 file:text-sky-700 hover:file:bg-sky-100" />
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-xs font-bold uppercase text-secondary">Alt Text</label>
                                <input type="text" id="media-alt-input" placeholder="Describe this asset for SEO..." class="h-10 px-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-xs" />
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-xs font-bold uppercase text-secondary">Title</label>
                                <input type="text" id="media-title-input" placeholder="Friendly title..." class="h-10 px-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-xs" />
                            </div>
                            <button type="submit" class="w-full bg-primary text-white hover:bg-opacity-90 transition-all py-2.5 rounded-lg font-bold text-xs uppercase tracking-wider flex items-center justify-center gap-1.5 shadow-sm cursor-pointer">
                                <span class="material-symbols-outlined text-[16px]">upload</span>
                                <span>Upload to CDN</span>
                            </button>
                        </form>
                    </div>

                    <!-- Files Grid -->
                    <div class="lg:col-span-8 space-y-4">
                        <div class="grid grid-cols-2 md:grid-cols-3 gap-4" id="media-library-grid">
                            {mediaItems.map(item => (
                                <div class="bg-white rounded-xl border border-outline-variant/20 overflow-hidden shadow-sm flex flex-col justify-between" id={`media-${item.id}`}>
                                    <div class="aspect-video bg-slate-900 flex items-center justify-center overflow-hidden border-b border-outline-variant/10 relative group">
                                        {item.mime_type.startsWith('image/') ? (
                                            <img src={item.path} alt={item.alt_text} class="w-full h-full object-cover" />
                                        ) : item.mime_type.startsWith('video/') ? (
                                            <video src={item.path} class="w-full h-full object-cover" muted />
                                        ) : (
                                            <span class="material-symbols-outlined text-4xl text-slate-400">description</span>
                                        )}
                                    </div>
                                    <div class="p-3 flex-1 flex flex-col justify-between">
                                        <div class="truncate">
                                            <h4 class="font-semibold text-xs text-slate-800 truncate" title={item.filename}>{item.filename}</h4>
                                            <p class="text-[10px] text-slate-400 mt-0.5 truncate">{item.path}</p>
                                        </div>
                                        <div class="flex gap-1.5 mt-3">
                                            <button 
                                                onclick={`copyToClipboard('${item.path}')`} 
                                                class="flex-1 bg-slate-50 hover:bg-slate-100 border border-slate-200 text-slate-600 py-1.5 rounded text-[10px] font-bold uppercase tracking-wider flex items-center justify-center gap-1 cursor-pointer"
                                                title="Copy Link"
                                            >
                                                <span class="material-symbols-outlined text-[12px]">link</span>
                                                <span>Copy</span>
                                            </button>
                                            <button 
                                                onclick={`deleteMedia(${item.id})`}
                                                class="bg-error/5 hover:bg-error/10 text-error p-1.5 rounded border border-error/10 flex items-center justify-center cursor-pointer"
                                                title="Delete File"
                                            >
                                                <span class="material-symbols-outlined text-[14px]">delete</span>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>
            </div>

            <!-- TAB 4: DYNAMIC PAGES -->
            <div id="panel-pages" class="tab-panel hidden space-y-6">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="font-headline-md text-xl text-on-surface">Manage Dynamic Pages</h2>
                    <button 
                        onclick="openPageModal()" 
                        class="bg-primary text-white hover:bg-opacity-90 transition-all px-5 py-2.5 rounded-lg font-label-md text-xs uppercase tracking-wider font-bold flex items-center gap-1.5 shadow-sm cursor-pointer"
                    >
                        <span class="material-symbols-outlined text-[16px]">add</span>
                        <span>Create New Page</span>
                    </button>
                </div>

                <!-- Page List Table -->
                <div class="bg-white rounded-xl border border-outline-variant/20 overflow-hidden shadow-sm">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="bg-surface-container-low text-secondary font-bold text-xs uppercase border-b border-outline-variant/10">
                                    <th class="px-6 py-4">Page Title</th>
                                    <th class="px-6 py-4">Slug / URL Path</th>
                                    <th class="px-6 py-4">Status</th>
                                    <th class="px-6 py-4">Created At</th>
                                    <th class="px-6 py-4 text-right">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="admin-pages-table-body" class="divide-y divide-outline-variant/10">
                                {dynamicPages.map(p => (
                                    <tr class="hover:bg-surface-container-lowest/50 transition-colors" id={`page-row-${p.id}`}>
                                        <td class="px-6 py-5 font-semibold text-on-surface">{p.title}</td>
                                        <td class="px-6 py-5 text-secondary">
                                            <a href={`/${p.slug}`} target="_blank" class="hover:underline text-primary font-semibold">/{p.slug}</a>
                                        </td>
                                        <td class="px-6 py-5">
                                            <span class={`px-2.5 py-1 text-[10px] uppercase font-bold tracking-wider rounded ${p.status === 'published' ? 'bg-emerald-50 text-emerald-700 border border-emerald-100' : 'bg-amber-50 text-amber-700 border border-amber-100'}`}>
                                                {p.status}
                                            </span>
                                        </td>
                                        <td class="px-6 py-5 text-secondary">{new Date(p.created_at).toLocaleDateString()}</td>
                                        <td class="px-6 py-5 text-right space-x-2">
                                            <button 
                                                onclick={`openPageEditor(${JSON.stringify(p)})`} 
                                                class="text-primary hover:bg-primary/5 p-2 rounded-lg transition-colors inline-flex items-center cursor-pointer"
                                                title="Edit Page Blocks"
                                            >
                                                <span class="material-symbols-outlined text-[20px]">construction</span>
                                            </button>
                                            <button 
                                                onclick={`deletePage(${p.id})`} 
                                                class="text-error hover:bg-error/5 p-2 rounded-lg transition-colors inline-flex items-center cursor-pointer"
                                                title="Delete Page"
                                            >
                                                <span class="material-symbols-outlined text-[20px]">delete</span>
                                            </button>
                                        </td>
                                    </tr>
                                ))}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- TAB 2: PAGE CONTENT CMS -->
            <div id="panel-homepage" class="tab-panel hidden space-y-6">
                <!-- Dropdown selector for page-by-page editing -->
                <div class="bg-white rounded-xl p-6 border border-outline-variant/20 ambient-shadow flex items-center justify-between">
                    <div class="flex flex-col gap-1">
                        <span class="text-xs uppercase tracking-widest text-primary font-bold">Scope Selector</span>
                        <h3 class="text-lg font-bold text-on-surface">Which page do you want to edit?</h3>
                    </div>
                    <select id="cms-page-selector" onchange="switchCmsPage(this.value)" class="h-11 px-4 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-sm font-semibold bg-white cursor-pointer min-w-[200px]">
                        <option value="homepage">Homepage</option>
                        <option value="about">About Us Page</option>
                        <option value="faq">FAQ Page</option>
                        <option value="programs">Instructor Programs</option>
                        <option value="coupon-config">Coupon Limits Config</option>
                    </select>
                </div>

                <!-- CMS Sub-Panel: Homepage -->
                <div id="cms-sub-homepage" class="cms-sub-panel space-y-6">
                    <form onsubmit="saveHomepage(event)" class="space-y-6 max-w-4xl">
                        <div class="bg-white rounded-xl p-8 border border-outline-variant/20 ambient-shadow space-y-6">
                            <div class="border-b border-outline-variant/10 pb-4">
                                <h3 class="font-headline-md text-lg text-primary flex items-center gap-2">
                                    <span class="material-symbols-outlined">deck</span>
                                    <span>Hero Section Content</span>
                                </h3>
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-xs font-bold uppercase text-secondary">Hero Title / Headline (Supports HTML)</label>
                                <textarea id="cms-hero-headline" rows="2" required class="p-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-sm resize-none"></textarea>
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-xs font-bold uppercase text-secondary">Hero Description Paragraph</label>
                                <textarea id="cms-hero-description" rows="3" required class="p-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-sm resize-none"></textarea>
                            </div>
                            <div class="grid grid-cols-2 gap-4">
                                <div class="flex flex-col gap-1.5">
                                    <label class="text-xs font-bold uppercase text-secondary">Stories Link Label</label>
                                    <input type="text" id="cms-hero-btn-text" required class="h-11 px-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-sm" />
                                </div>
                                <div class="flex flex-col gap-1.5">
                                    <label class="text-xs font-bold uppercase text-secondary">Stories Link URL</label>
                                    <input type="text" id="cms-hero-btn-url" required class="h-11 px-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-sm" />
                                </div>
                            </div>
                            <div class="grid grid-cols-2 gap-4">
                                <div class="flex flex-col gap-1.5">
                                    <label class="text-xs font-bold uppercase text-secondary">Consultation Link Label</label>
                                    <input type="text" id="cms-hero-consult-text" required class="h-11 px-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-sm" />
                                </div>
                                <div class="flex flex-col gap-1.5">
                                    <label class="text-xs font-bold uppercase text-secondary">Consultation Link URL</label>
                                    <input type="text" id="cms-hero-consult-url" required class="h-11 px-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-sm" />
                                </div>
                            </div>
                        </div>
                        <div class="bg-white rounded-xl p-8 border border-outline-variant/20 ambient-shadow space-y-6">
                            <div class="border-b border-outline-variant/10 pb-4">
                                <h3 class="font-headline-md text-lg text-primary flex items-center gap-2">
                                    <span class="material-symbols-outlined">workspace_premium</span>
                                    <span>Highlights (4 Items)</span>
                                </h3>
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-xs font-bold uppercase text-secondary">Highlight Items (Comma-separated, exactly 4)</label>
                                <input type="text" id="cms-trust-bar" required class="h-11 px-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-sm" />
                            </div>
                        </div>
                        <div class="bg-white rounded-xl p-8 border border-outline-variant/20 ambient-shadow space-y-6">
                            <div class="border-b border-outline-variant/10 pb-4">
                                <h3 class="font-headline-md text-lg text-primary flex items-center gap-2">
                                    <span class="material-symbols-outlined">info</span>
                                    <span>About Us Summary</span>
                                </h3>
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-xs font-bold uppercase text-secondary">Section Title</label>
                                <input type="text" id="cms-about-title" required class="h-11 px-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-sm" />
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-xs font-bold uppercase text-secondary">About Section Description (Use double newlines for paragraphs)</label>
                                <textarea id="cms-about-description" rows="6" required class="p-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-sm resize-none"></textarea>
                            </div>
                        </div>

                        <!-- Why Choose SkyStates Edit Fields -->
                        <div class="bg-white rounded-xl p-8 border border-outline-variant/20 ambient-shadow space-y-6">
                            <div class="border-b border-outline-variant/10 pb-4">
                                <h3 class="font-headline-md text-lg text-primary flex items-center gap-2">
                                    <span class="material-symbols-outlined">help</span>
                                    <span>Why Should You Choose SkyStates? (6 Pillars)</span>
                                </h3>
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="p-4 border border-slate-100 rounded-lg space-y-3">
                                    <label class="text-xs font-bold uppercase text-secondary block">Pillar 1</label>
                                    <input type="text" id="cms-why-1-title" placeholder="Title" required class="h-10 px-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-xs w-full" />
                                    <textarea id="cms-why-1-desc" placeholder="Description" rows="2" required class="p-2 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-xs w-full resize-none"></textarea>
                                </div>
                                <div class="p-4 border border-slate-100 rounded-lg space-y-3">
                                    <label class="text-xs font-bold uppercase text-secondary block">Pillar 2</label>
                                    <input type="text" id="cms-why-2-title" placeholder="Title" required class="h-10 px-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-xs w-full" />
                                    <textarea id="cms-why-2-desc" placeholder="Description" rows="2" required class="p-2 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-xs w-full resize-none"></textarea>
                                </div>
                                <div class="p-4 border border-slate-100 rounded-lg space-y-3">
