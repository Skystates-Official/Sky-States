                try {
                    const response = await fetch('/api/jobs', {
                        method: 'DELETE',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ id })
                    });

                    if (response.ok) {
                        const row = document.getElementById(`row-${id}`);
                        if (row) row.remove();
                    } else {
