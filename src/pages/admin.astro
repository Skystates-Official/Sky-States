---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import jobsData from '../data/jobs.json';
import homepageData from '../data/homepage.json';
import aboutData from '../data/about.json';
import faqData from '../data/faq.json';
import programsData from '../data/programs.json';
import couponConfigData from '../data/coupon-config.json';

import { authenticateUser, verifySessionToken, createSessionToken, isFullAdminRole, ROLE_LABELS, normalizeRole } from '../db/auth.js';
import { query as sqlQuery } from '../db/sqlite.js';
// @ts-ignore
import fs from 'fs';
// @ts-ignore
import path from 'path';

export const prerender = false;

function getRoleLabel(role) {
    return ROLE_LABELS[normalizeRole(role)] || 'Editor';
}

function getRoleBadgeClass(role) {
    const normalized = normalizeRole(role);
    if (normalized === 'admin') return 'bg-sky-50 text-sky-700 border border-sky-100';
    return 'bg-slate-50 text-slate-700 border border-slate-100';
}

// Authenticate session
let authenticated = false;
let userSession = null;
let loginError = '';

if (Astro.cookies.has('admin_session')) {
    const sessionCookie = Astro.cookies.get('admin_session');
    if (sessionCookie) {
        userSession = verifySessionToken(sessionCookie.value);
        if (userSession) {
            authenticated = true;
        }
    }
}

// Handle login/logout requests
if (Astro.request.method === 'POST') {
    try {
        const formData = await Astro.request.formData();
        const action = formData.get('action');
        
        if (action === 'login') {
            const username = formData.get('username');
            const password = formData.get('password');
            
            const user = await authenticateUser(username, password);
            if (user) {
                const token = createSessionToken(user.username, user.role);
                Astro.cookies.set('admin_session', token, {
                    path: '/',
                    httpOnly: true,
                    sameSite: 'strict',
                    maxAge: 86400
                });
                return Astro.redirect('/admin');
            } else {
                loginError = 'Invalid credentials. Please try again.';
            }
        } else if (action === 'logout') {
            Astro.cookies.delete('admin_session', { path: '/' });
            return Astro.redirect('/admin');
        }
    } catch (e) {
        loginError = 'An error occurred during authentication.';
    }
}

const isFullAdmin = !!(userSession && isFullAdminRole(userSession.role));
const signedInRoleLabel = userSession ? getRoleLabel(userSession.role) : '';

let mediaItems = [];
let dynamicPages = [];
let storiesData = [];
let adminUsers = [];
let couponsList = [];

if (authenticated) {
    try {
        mediaItems = await sqlQuery.all("SELECT * FROM media ORDER BY created_at DESC");
        dynamicPages = await sqlQuery.all("SELECT * FROM pages ORDER BY created_at DESC");
        couponsList = await sqlQuery.all("SELECT * FROM coupons ORDER BY created_at DESC");
        
        const storiesPath = path.resolve('src/data/stories.json');
        if (fs.existsSync(storiesPath)) {
            storiesData = JSON.parse(fs.readFileSync(storiesPath, 'utf8'));
        }

        if (isFullAdmin) {
            adminUsers = await sqlQuery.all(
                "SELECT id, username, role, created_at FROM users ORDER BY created_at ASC"
            );
        }
    } catch (dbErr) {
        console.error("Error loading CMS items:", dbErr.message);
    }
}

const statsJobs = jobsData.length;
const statsStories = storiesData.length;
const statsPages = dynamicPages.length;
const statsCoupons = couponsList.filter((c) => c.active).length;
const statsMedia = mediaItems.length;
---

<!DOCTYPE html>
<html class="light" lang="en">
<head>
  <link rel="icon" type="image/png" href="/favicon.png" />
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Sky States Admin Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Geist:wght@400;600;700;800&display=swap" rel="stylesheet"/>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .admin-shell {
            display: flex;
            min-height: 100vh;
            background: #f4f7fb;
        }
        .admin-sidebar {
            width: 260px;
            background: linear-gradient(180deg, #0c2d48 0%, #083049 100%);
            color: #fff;
            flex-shrink: 0;
            position: sticky;
            top: 0;
            height: 100vh;
            display: flex;
            flex-direction: column;
        }
        .admin-sidebar-brand {
            padding: 1.5rem 1.25rem 1rem;
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }
        .admin-nav {
            padding: 1rem 0.75rem;
            flex: 1;
            overflow-y: auto;
        }
        .admin-nav-btn {
            width: 100%;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem 0.875rem;
            border-radius: 0.75rem;
            font-size: 0.8125rem;
            font-weight: 600;
            color: rgba(255,255,255,0.72);
            transition: all 0.2s ease;
            cursor: pointer;
            border: none;
            background: transparent;
            text-align: left;
        }
        .admin-nav-btn:hover,
        .admin-nav-btn.active {
            background: rgba(255,255,255,0.1);
            color: #fff;
        }
        .admin-nav-btn.active {
            background: rgba(14, 165, 233, 0.22);
            box-shadow: inset 0 0 0 1px rgba(125, 211, 252, 0.25);
        }
        .admin-main {
            flex: 1;
            min-width: 0;
            display: flex;
            flex-direction: column;
        }
        .admin-topbar {
            background: #fff;
            border-bottom: 1px solid #e2e8f0;
            padding: 1rem 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 20;
        }
        .admin-content {
            padding: 1.5rem;
        }
        .stat-card {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 1rem;
            padding: 1.25rem;
            box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04);
        }
        .ambient-shadow {
            box-shadow: 0 10px 30px -5px rgba(15, 29, 37, 0.04);
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 font-sans overflow-x-hidden">
    {!authenticated && <Header />}

    {authenticated ? (
        <div class="admin-shell">
            <aside class="admin-sidebar">
                <div class="admin-sidebar-brand">
                    <div class="text-[10px] uppercase tracking-[0.2em] text-sky-300 font-bold">Sky States</div>
                    <div class="text-lg font-extrabold mt-1">Admin Dashboard</div>
                    <div class="text-xs text-white/60 mt-2">{userSession?.username}</div>
                </div>
                <nav class="admin-nav">
                    <button onclick="switchTab('dashboard')" id="tab-btn-dashboard" class="admin-nav-btn active">
                        <span class="material-symbols-outlined text-[18px]">dashboard</span>
                        <span>Overview</span>
                    </button>
                    <button onclick="switchTab('jobs')" id="tab-btn-jobs" class="admin-nav-btn">
                        <span class="material-symbols-outlined text-[18px]">work</span>
                        <span>Jobs & Placements</span>
                    </button>
                    <button onclick="switchTab('stories')" id="tab-btn-stories" class="admin-nav-btn">
                        <span class="material-symbols-outlined text-[18px]">auto_stories</span>
                        <span>Stories & Blogs</span>
                    </button>
                    <button onclick="switchTab('coupons')" id="tab-btn-coupons" class="admin-nav-btn">
                        <span class="material-symbols-outlined text-[18px]">sell</span>
                        <span>Coupons</span>
                    </button>
                    <button onclick="switchTab('homepage')" id="tab-btn-homepage" class="admin-nav-btn">
                        <span class="material-symbols-outlined text-[18px]">web</span>
                        <span>Site Content</span>
                    </button>
                    <button onclick="switchTab('media')" id="tab-btn-media" class="admin-nav-btn">
                        <span class="material-symbols-outlined text-[18px]">perm_media</span>
                        <span>Media Library</span>
                    </button>
                    <button onclick="switchTab('pages')" id="tab-btn-pages" class="admin-nav-btn">
                        <span class="material-symbols-outlined text-[18px]">article</span>
                        <span>Dynamic Pages</span>
                    </button>
                    {isFullAdmin && (
                        <button onclick="switchTab('users')" id="tab-btn-users" class="admin-nav-btn">
                            <span class="material-symbols-outlined text-[18px]">group</span>
                            <span>Team Access</span>
                        </button>
                    )}
                </nav>
                <div class="p-4 border-t border-white/10">
                    <form method="POST" class="m-0">
                        <input type="hidden" name="action" value="logout" />
                        <button type="submit" class="admin-nav-btn w-full">
                            <span class="material-symbols-outlined text-[18px]">logout</span>
                            <span>Sign Out</span>
                        </button>
                    </form>
                </div>
            </aside>

            <div class="admin-main">
                <header class="admin-topbar">
                    <div>
                        <h1 class="text-xl font-bold text-slate-900" id="admin-page-title">Overview</h1>
                        <p class="text-sm text-slate-500 mt-0.5">Manage content, coupons, jobs, and team access from one place.</p>
                    </div>
                    <div class="text-right">
                        <div class="text-xs uppercase tracking-wider text-sky-700 font-bold">{signedInRoleLabel}</div>
                        <div class="text-sm text-slate-600">{userSession?.username}</div>
                    </div>
                </header>

                <div class="admin-content">
            <!-- DASHBOARD -->
            <div id="panel-dashboard" class="tab-panel space-y-6">
                <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-5 gap-4">
                    <div class="stat-card">
                        <div class="text-xs uppercase tracking-wider text-slate-500 font-bold">Active Jobs</div>
                        <div class="text-3xl font-black text-slate-900 mt-2">{statsJobs}</div>
                    </div>
                    <div class="stat-card">
                        <div class="text-xs uppercase tracking-wider text-slate-500 font-bold">Stories</div>
                        <div class="text-3xl font-black text-slate-900 mt-2">{statsStories}</div>
                    </div>
                    <div class="stat-card">
                        <div class="text-xs uppercase tracking-wider text-slate-500 font-bold">Active Coupons</div>
                        <div class="text-3xl font-black text-slate-900 mt-2">{statsCoupons}</div>
                    </div>
                    <div class="stat-card">
                        <div class="text-xs uppercase tracking-wider text-slate-500 font-bold">Dynamic Pages</div>
                        <div class="text-3xl font-black text-slate-900 mt-2">{statsPages}</div>
                    </div>
                    <div class="stat-card">
                        <div class="text-xs uppercase tracking-wider text-slate-500 font-bold">Media Assets</div>
                        <div class="text-3xl font-black text-slate-900 mt-2">{statsMedia}</div>
                    </div>
                </div>
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                    <div class="bg-white rounded-2xl border border-slate-200 p-6">
                        <h2 class="font-bold text-slate-900 mb-3">Quick Actions</h2>
                        <div class="grid grid-cols-2 gap-3">
                            <button onclick="switchTab('coupons'); openCouponModal();" class="h-11 px-4 rounded-xl bg-sky-600 text-white text-xs font-bold uppercase tracking-wider">Create Coupon</button>
                            <button onclick="switchTab('jobs'); openAddModal();" class="h-11 px-4 rounded-xl bg-slate-900 text-white text-xs font-bold uppercase tracking-wider">Post Job</button>
                            <button onclick="switchTab('stories'); openAddStoryModal();" class="h-11 px-4 rounded-xl border border-slate-200 text-slate-700 text-xs font-bold uppercase tracking-wider">Add Story</button>
                            <button onclick="switchTab('homepage')" class="h-11 px-4 rounded-xl border border-slate-200 text-slate-700 text-xs font-bold uppercase tracking-wider">Edit Homepage</button>
                        </div>
                    </div>
                    <div class="bg-white rounded-2xl border border-slate-200 p-6">
                        <h2 class="font-bold text-slate-900 mb-3">Platform Modules</h2>
                        <ul class="space-y-2 text-sm text-slate-600">
                            <li>Jobs, stories, pages, and media are fully editable here.</li>
                            <li>Coupons can be created with custom codes and dollar discounts.</li>
                            <li>Legacy SKY### codes still work using validation limits in Site Content.</li>
                            {isFullAdmin && <li>Administrators can invite editors and manage team access.</li>}
                        </ul>
                    </div>
                </div>
            </div>

            <!-- TAB 1: PLACEMENTS -->
            <div id="panel-jobs" class="tab-panel hidden">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="font-headline-md text-xl text-on-surface">Manage Active Placements</h2>
                    <button 
                        onclick="openAddModal()" 
                        class="bg-primary text-white hover:bg-opacity-90 transition-all px-5 py-2.5 rounded-lg font-label-md text-xs uppercase tracking-wider font-bold flex items-center gap-1.5 shadow-sm"
                    >
                        <span class="material-symbols-outlined text-[16px]">add</span>
                        <span>Post New Job</span>
                    </button>
                </div>

                <!-- Table of Jobs -->
                <div class="bg-white rounded-xl border border-outline-variant/20 overflow-hidden ambient-shadow">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="bg-surface-container-low text-secondary font-bold text-xs uppercase border-b border-outline-variant/10">
                                    <th class="px-6 py-4">Role / Title</th>
                                    <th class="px-6 py-4">Company</th>
                                    <th class="px-6 py-4">Location</th>
                                    <th class="px-6 py-4">Salary Range</th>
                                    <th class="px-6 py-4">Skills / Tags</th>
                                    <th class="px-6 py-4 text-right">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="admin-jobs-table-body" class="divide-y divide-outline-variant/10">
                                {jobsData.map((job: any) => (
                                    <tr class="hover:bg-surface-container-lowest/50 transition-colors" id={`row-${job.id}`}>
                                        <td class="px-6 py-5">
                                            <div class="font-semibold text-on-surface">{job.title}</div>
                                            {job.category && (
                                                <span class="inline-block mt-1 px-2 py-0.5 text-[9px] uppercase font-bold tracking-wider bg-primary/10 text-primary rounded-md">
                                                    {job.category}
                                                </span>
                                            )}
                                        </td>
                                        <td class="px-6 py-5 text-secondary">{job.company}</td>
                                        <td class="px-6 py-5 text-secondary">{job.location}</td>
                                        <td class="px-6 py-5 text-secondary">{job.salary}</td>
                                        <td class="px-6 py-5">
                                            <div class="flex flex-wrap gap-1">
                                                {job.tags.map((tag: any) => (
                                                    <span class="px-2 py-0.5 text-[9px] uppercase font-bold tracking-wider bg-surface-container text-secondary rounded">
                                                        {tag}
                                                    </span>
                                                ))}
                                            </div>
                                        </td>
                                        <td class="px-6 py-5 text-right space-x-2">
                                            <button 
                                                onclick={`openEditModal(${JSON.stringify(job)})`} 
                                                class="text-primary hover:bg-primary/5 p-2 rounded-lg transition-colors inline-flex items-center"
                                                title="Edit Job"
                                            >
                                                <span class="material-symbols-outlined text-[20px]">edit</span>
                                            </button>
                                            <button 
                                                onclick={`deleteJob('${job.id}')`} 
                                                class="text-error hover:bg-error/5 p-2 rounded-lg transition-colors inline-flex items-center"
                                                title="Delete Job"
                                            >
                                                <span class="material-symbols-outlined text-[20px]">delete</span>
                                            </button>
                                        </td>
                                    </tr>
                                ))}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- TAB: STORIES & PODCASTS -->
            <div id="panel-stories" class="tab-panel hidden space-y-6">
                <div class="flex justify-between items-center">
                    <h2 class="font-headline-md text-xl text-on-surface">Manage Stories & Podcasts</h2>
                    <button 
                        onclick="openAddStoryModal()" 
                        class="bg-primary text-white hover:bg-opacity-90 transition-all px-5 py-2.5 rounded-lg font-label-md text-xs uppercase tracking-wider font-bold flex items-center gap-1.5 shadow-sm"
                    >
                        <span class="material-symbols-outlined text-[16px]">add</span>
                        <span>Add New Story / Podcast</span>
                    </button>
                </div>

                <!-- Table of Stories -->
                <div class="bg-white rounded-xl border border-outline-variant/20 overflow-hidden ambient-shadow">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="bg-surface-container-low text-secondary font-bold text-xs uppercase border-b border-outline-variant/10">
                                    <th class="px-6 py-4">Name / Role</th>
                                    <th class="px-6 py-4">Headline</th>
                                    <th class="px-6 py-4">Track</th>
                                    <th class="px-6 py-4">Type</th>
                                    <th class="px-6 py-4 text-right">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="admin-stories-table-body" class="divide-y divide-outline-variant/10">
                                {storiesData.map(story => (
                                    <tr class="hover:bg-surface-container-lowest/50 transition-colors" id={`story-row-${story.id}`}>
                                        <td class="px-6 py-5">
                                            <div class="font-semibold text-on-surface">{story.name}</div>
                                            <div class="text-xs text-secondary mt-0.5">{story.role}</div>
                                        </td>
                                        <td class="px-6 py-5 text-secondary max-w-xs truncate">{story.headline}</td>
                                        <td class="px-6 py-5 text-secondary">{story.track}</td>
                                        <td class="px-6 py-5">
                                            <span class={`inline-block px-2.5 py-0.5 text-[10px] uppercase font-bold tracking-wider rounded-md ${story.type === 'podcast' ? 'bg-indigo-100 text-indigo-700' : 'bg-sky-100 text-sky-700'}`}>
                                                {story.type}
                                            </span>
                                        </td>
                                        <td class="px-6 py-5 text-right space-x-2">
                                            <button 
                                                onclick={`openEditStoryModal(${JSON.stringify(story)})`} 
                                                class="text-primary hover:bg-primary/5 p-2 rounded-lg transition-colors inline-flex items-center"
                                                title="Edit Story"
                                            >
                                                <span class="material-symbols-outlined text-[20px]">edit</span>
                                            </button>
                                            <button 
                                                onclick={`deleteStory('${story.id}')`} 
                                                class="text-error hover:bg-error/5 p-2 rounded-lg transition-colors inline-flex items-center"
                                                title="Delete Story"
                                            >
                                                <span class="material-symbols-outlined text-[20px]">delete</span>
                                            </button>
                                        </td>
                                    </tr>
                                ))}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- TAB: COUPONS -->
            <div id="panel-coupons" class="tab-panel hidden space-y-6">
                <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
                    <div>
                        <h2 class="font-headline-md text-xl text-on-surface">Coupon Management</h2>
                        <p class="text-sm text-secondary mt-1">Create promotional codes with fixed dollar discounts for checkout.</p>
                    </div>
                    <button onclick="openCouponModal()" class="bg-primary text-white hover:bg-opacity-90 transition-all px-5 py-2.5 rounded-lg font-label-md text-xs uppercase tracking-wider font-bold flex items-center gap-1.5 shadow-sm cursor-pointer">
                        <span class="material-symbols-outlined text-[16px]">add</span>
                        <span>Create Coupon</span>
                    </button>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
                    <div class="bg-white rounded-xl p-5 border border-outline-variant/20">
                        <p class="text-xs uppercase tracking-wider text-secondary font-bold">Custom Coupons</p>
                        <p class="text-sm text-on-surface-variant mt-2">Use any code like WELCOME150 or LAUNCH99 with a fixed discount amount.</p>
                    </div>
                    <div class="bg-white rounded-xl p-5 border border-outline-variant/20">
                        <p class="text-xs uppercase tracking-wider text-secondary font-bold">Legacy SKY Codes</p>
                        <p class="text-sm text-on-surface-variant mt-2">SKY150 still works using the validation limits configured under Site Content.</p>
                    </div>
                    <div class="bg-white rounded-xl p-5 border border-outline-variant/20">
                        <p class="text-xs uppercase tracking-wider text-secondary font-bold">Stripe Checkout</p>
                        <p class="text-sm text-on-surface-variant mt-2">Discounts apply before redirecting customers to Stripe's payment portal.</p>
                    </div>
                </div>

                <div class="bg-white rounded-xl border border-outline-variant/20 overflow-hidden shadow-sm">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="bg-surface-container-low text-secondary font-bold text-xs uppercase border-b border-outline-variant/10">
                                    <th class="px-6 py-4">Code</th>
                                    <th class="px-6 py-4">Discount</th>
                                    <th class="px-6 py-4">Usage</th>
                                    <th class="px-6 py-4">Status</th>
                                    <th class="px-6 py-4">Expires</th>
                                    <th class="px-6 py-4 text-right">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="admin-coupons-table-body" class="divide-y divide-outline-variant/10">
                                {couponsList.length === 0 ? (
                                    <tr>
                                        <td colspan="6" class="px-6 py-10 text-center text-secondary text-sm">No coupons yet. Create your first promotional code.</td>
                                    </tr>
                                ) : couponsList.map((coupon) => (
                                    <tr class="hover:bg-surface-container-lowest/50 transition-colors" id={`coupon-row-${coupon.id}`}>
                                        <td class="px-6 py-5">
                                            <div class="font-bold text-on-surface">{coupon.code}</div>
                                            {coupon.description && <div class="text-xs text-secondary mt-1">{coupon.description}</div>}
                                        </td>
                                        <td class="px-6 py-5 font-semibold text-primary">${coupon.discount_amount}</td>
                                        <td class="px-6 py-5 text-secondary">{coupon.used_count}{coupon.max_uses != null ? ` / ${coupon.max_uses}` : ''}</td>
                                        <td class="px-6 py-5">
                                            <span class={`px-2.5 py-1 text-[10px] uppercase font-bold tracking-wider rounded ${coupon.active ? 'bg-emerald-50 text-emerald-700 border border-emerald-100' : 'bg-slate-100 text-slate-500 border border-slate-200'}`}>
                                                {coupon.active ? 'Active' : 'Inactive'}
                                            </span>
                                        </td>
                                        <td class="px-6 py-5 text-secondary">{coupon.expires_at ? new Date(coupon.expires_at).toLocaleDateString() : 'No expiry'}</td>
                                        <td class="px-6 py-5 text-right space-x-2">
                                            <button onclick={`openCouponModal(${JSON.stringify(coupon)})`} class="text-primary hover:bg-primary/5 p-2 rounded-lg transition-colors inline-flex items-center cursor-pointer" title="Edit Coupon">
                                                <span class="material-symbols-outlined text-[20px]">edit</span>
                                            </button>
                                            <button onclick={`deleteCoupon(${coupon.id}, ${JSON.stringify(coupon.code)})`} class="text-error hover:bg-error/5 p-2 rounded-lg transition-colors inline-flex items-center cursor-pointer" title="Delete Coupon">
