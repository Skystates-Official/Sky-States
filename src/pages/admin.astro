                                <textarea id="cms-ds-description" rows="3" required class="p-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-sm resize-none"></textarea>
                            </div>
                        </div>

                        <!-- Cyber Security Card -->
                        <div class="bg-white rounded-xl p-8 border border-outline-variant/20 ambient-shadow space-y-6">
                            <div class="border-b border-outline-variant/10 pb-4">
                                <h3 class="font-headline-md text-lg text-primary flex items-center gap-2">
                                    <span class="material-symbols-outlined">security</span>
                                    <span>Cyber Security Strategist</span>
                                </h3>
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-xs font-bold uppercase text-secondary">Metadata Title (SEO)</label>
                                <input type="text" id="cms-cyber-meta" required class="h-11 px-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-sm" />
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-xs font-bold uppercase text-secondary">Hero Headline (HTML)</label>
                                <textarea id="cms-cyber-headline" rows="2" required class="p-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-sm resize-none"></textarea>
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-xs font-bold uppercase text-secondary">Hero Description</label>
                                <textarea id="cms-cyber-description" rows="3" required class="p-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-sm resize-none"></textarea>
                            </div>
                        </div>

                        <!-- DevOps & Cloud Card -->
                        <div class="bg-white rounded-xl p-8 border border-outline-variant/20 ambient-shadow space-y-6">
                            <div class="border-b border-outline-variant/10 pb-4">
                                <h3 class="font-headline-md text-lg text-primary flex items-center gap-2">
                                    <span class="material-symbols-outlined">terminal</span>
                                    <span>DevOps & Cloud Master</span>
                                </h3>
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-xs font-bold uppercase text-secondary">Metadata Title (SEO)</label>
                                <input type="text" id="cms-devops-meta" required class="h-11 px-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-sm" />
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-xs font-bold uppercase text-secondary">Hero Headline (HTML)</label>
                                <textarea id="cms-devops-headline" rows="2" required class="p-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-sm resize-none"></textarea>
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-xs font-bold uppercase text-secondary">Hero Description</label>
                                <textarea id="cms-devops-description" rows="3" required class="p-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-sm resize-none"></textarea>
                            </div>
                        </div>

                        <button type="submit" class="bg-primary text-white hover:bg-opacity-90 px-8 py-3.5 rounded-xl font-label-md text-sm uppercase tracking-wider font-bold shadow-lg">Save Programs Content</button>
                    </form>
                </div>

                <!-- CMS Sub-Panel: Coupon Config -->
                <div id="cms-sub-coupon-config" class="cms-sub-panel space-y-6 hidden">
                    <form onsubmit="saveCouponConfig(event)" class="space-y-6 max-w-4xl">
                        <div class="bg-white rounded-xl p-8 border border-outline-variant/20 ambient-shadow space-y-6">
                            <div class="border-b border-outline-variant/10 pb-4">
                                <h3 class="font-headline-md text-lg text-primary flex items-center gap-2">
                                    <span class="material-symbols-outlined">settings_suggest</span>
                                    <span>Coupon Code Validation Limits</span>
                                </h3>
                            </div>
                            <div class="grid grid-cols-2 gap-4">
                                <div class="flex flex-col gap-1.5">
                                    <label class="text-xs font-bold uppercase text-secondary">Minimum Coupon Value ($)</label>
                                    <input type="number" id="cms-coupon-min" required min="1" class="h-11 px-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-sm" />
                                </div>
                                <div class="flex flex-col gap-1.5">
                                    <label class="text-xs font-bold uppercase text-secondary">Maximum Coupon Value ($)</label>
                                    <input type="number" id="cms-coupon-max" required min="1" class="h-11 px-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-sm" />
                                </div>
                            </div>
                        </div>
                        <button type="submit" class="bg-primary text-white hover:bg-opacity-90 px-8 py-3.5 rounded-xl font-label-md text-sm uppercase tracking-wider font-bold shadow-lg">Save Coupon Config</button>
                    </form>
                </div>
            </div>
        </main>
    ) : (
        <div class="min-h-[70vh] flex items-center justify-center px-4 py-12">
            <div class="w-full max-w-md bg-white rounded-3xl p-8 border border-outline-variant/20 ambient-shadow space-y-6">
                <div class="text-center space-y-2">
                    <div class="w-16 h-16 bg-primary-fixed text-primary rounded-full flex items-center justify-center mx-auto">
                        <span class="material-symbols-outlined text-3xl font-bold" style="font-variation-settings: 'FILL' 1;">lock</span>
                    </div>
                    <span class="text-xs uppercase tracking-widest text-primary font-bold">Secure Gateway</span>
                    <h2 class="font-headline-md text-2xl text-on-surface">Admin Authentication</h2>
                    <p class="text-on-surface-variant font-body-sm text-sm">Please sign in to access the placement console.</p>
                </div>

                {loginError && (
                    <div class="p-4 bg-error-container text-on-error-container rounded-xl text-sm font-semibold flex items-center gap-2">
                        <span class="material-symbols-outlined text-[18px]">warning</span>
                        <span class="text-red-700">{loginError}</span>
                    </div>
                )}

                <form method="POST" class="space-y-4 m-0">
                    <input type="hidden" name="action" value="login" />
                    
                    <div class="flex flex-col gap-1.5">
                        <label for="username" class="text-xs font-bold uppercase text-secondary">Username</label>
                        <input 
                            type="text" 
                            name="username" 
                            id="username" 
                            required 
                            class="h-11 px-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary transition-all text-sm" 
                            placeholder="admin" 
                        />
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label for="password" class="text-xs font-bold uppercase text-secondary">Password</label>
                        <input 
                            type="password" 
                            name="password" 
                            id="password" 
                            required 
                            class="h-11 px-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary transition-all text-sm" 
                            placeholder="••••••••" 
                        />
                    </div>

                    <button 
                        type="submit" 
                        class="w-full bg-primary text-white hover:bg-opacity-90 transition-all py-3 rounded-lg font-label-md text-xs uppercase tracking-wider font-bold mt-4"
                    >
                        Sign In
                    </button>
                </form>
            </div>
        </div>
    )}

    <!-- Modal Form (Create / Edit) -->
    {authenticated && (
        <div id="job-modal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[100] flex items-center justify-center hidden">
            <div class="bg-white rounded-2xl w-full max-w-xl p-8 shadow-2xl relative border border-outline-variant/10" onclick="event.stopPropagation()">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-outline-variant/10">
                    <h2 id="modal-title" class="font-headline-md text-xl text-primary">Post New Job Listing</h2>
                    <button onclick="closeModal()" class="p-2 hover:bg-surface-container rounded-lg transition-colors">
                        <span class="material-symbols-outlined text-[20px]">close</span>
                    </button>
                </div>

                <form id="job-form" onsubmit="saveJob(event)" class="space-y-4">
                    <input type="hidden" id="form-job-id" />
                    
                    <div class="grid grid-cols-2 gap-4">
                        <div class="flex flex-col gap-1.5">
                            <label for="form-title" class="text-xs font-bold uppercase text-secondary">Job Title</label>
                            <input type="text" id="form-title" required class="h-10 px-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary transition-all text-sm" placeholder="e.g. Senior AI Architect" />
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label for="form-company" class="text-xs font-bold uppercase text-secondary">Company Name</label>
                            <input type="text" id="form-company" required class="h-10 px-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary transition-all text-sm" placeholder="e.g. Stripe" />
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div class="flex flex-col gap-1.5">
                            <label for="form-location" class="text-xs font-bold uppercase text-secondary">Location</label>
                            <input type="text" id="form-location" required class="h-10 px-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary transition-all text-sm" placeholder="e.g. Hybrid / Remote" />
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label for="form-salary" class="text-xs font-bold uppercase text-secondary">Salary Range</label>
                            <input type="text" id="form-salary" required class="h-10 px-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary transition-all text-sm" placeholder="e.g. $180,000 - $220,000" />
                        </div>
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label for="form-tags" class="text-xs font-bold uppercase text-secondary">Skills / Tags (comma-separated)</label>
                        <input type="text" id="form-tags" class="h-10 px-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary transition-all text-sm" placeholder="e.g. Python, PyTorch, LLMs" />
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label for="form-description" class="text-xs font-bold uppercase text-secondary">Role Description</label>
                        <textarea id="form-description" rows="4" class="p-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary transition-all text-sm resize-none" placeholder="Provide a summary of core requirements and expectations..."></textarea>
                    </div>

                    <div class="pt-4 flex gap-3 justify-end border-t border-outline-variant/10 mt-6">
                        <button type="button" onclick="closeModal()" class="px-5 py-2.5 border border-outline-variant/40 hover:bg-surface-container rounded-lg text-xs uppercase tracking-wider font-bold transition-all">Cancel</button>
                        <button type="submit" class="px-5 py-2.5 bg-primary text-white hover:bg-opacity-90 rounded-lg text-xs uppercase tracking-wider font-bold transition-all">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    )}

    <!-- Footer -->
    <Footer />

    {authenticated && (
        <script is:inline define:vars={{ homepageData, aboutData, faqData, programsData, couponConfigData }}>
            // Tab Switching Logic
            window.switchTab = function(tabName) {
                const panels = document.querySelectorAll('.tab-panel');
                panels.forEach(p => p.classList.add('hidden'));
                
                const panel = document.getElementById(`panel-${tabName}`);
                if (panel) panel.classList.remove('hidden');

                const buttons = document.querySelectorAll('[id^="tab-btn-"]');
                buttons.forEach(btn => {
                    btn.classList.remove('border-primary', 'text-primary');
                    btn.classList.add('border-transparent', 'text-secondary');
                });

                const activeBtn = document.getElementById(`tab-btn-${tabName}`);
                if (activeBtn) {
                    activeBtn.classList.remove('border-transparent', 'text-secondary');
                    activeBtn.classList.add('border-primary', 'text-primary');
                }
            }

            // CMS Page-by-Page Selector Logic
            window.switchCmsPage = function(pageId) {
                const subPanels = document.querySelectorAll('.cms-sub-panel');
                subPanels.forEach(p => p.classList.add('hidden'));
                
                const activePanel = document.getElementById(`cms-sub-${pageId}`);
                if (activePanel) activePanel.classList.remove('hidden');
            }

            // Populate CMS inputs on load
            if (homepageData) {
                document.getElementById('cms-hero-headline').value = homepageData.hero?.headline || '';
                document.getElementById('cms-hero-description').value = homepageData.hero?.description || '';
                document.getElementById('cms-hero-btn-text').value = homepageData.hero?.button_text || '';
                document.getElementById('cms-hero-btn-url').value = homepageData.hero?.button_url || '';
                document.getElementById('cms-trust-bar').value = (homepageData.trust_bar || []).join(', ');
                document.getElementById('cms-about-title').value = homepageData.about?.title || '';
                document.getElementById('cms-about-description').value = homepageData.about?.description || '';
                document.getElementById('cms-pricing-title').value = homepageData.pricing?.title || '';
                document.getElementById('cms-pricing-amount').value = homepageData.pricing?.amount || '';
                document.getElementById('cms-pricing-subtitle').value = homepageData.pricing?.subtitle || '';
            }

            if (aboutData) {
                document.getElementById('cms-about-hero-badge').value = aboutData.hero?.badge || '';
                document.getElementById('cms-about-hero-title').value = aboutData.hero?.title || '';
                document.getElementById('cms-about-hero-desc').value = aboutData.hero?.description || '';
                
                document.getElementById('cms-about-story-title').value = aboutData.story?.title || '';
                document.getElementById('cms-about-story-para').value = aboutData.story?.paragraph || '';
                document.getElementById('cms-about-vision-title').value = aboutData.story?.vision_title || '';
                document.getElementById('cms-about-vision-desc').value = aboutData.story?.vision_desc || '';
                document.getElementById('cms-about-method-title').value = aboutData.story?.method_title || '';
                document.getElementById('cms-about-method-desc').value = aboutData.story?.method_desc || '';
                
                document.getElementById('cms-about-delaware').value = aboutData.registry?.delaware_address || '';
                document.getElementById('cms-about-wyoming').value = aboutData.registry?.wyoming_address || '';
                document.getElementById('cms-about-phone').value = aboutData.registry?.phone || '';
                document.getElementById('cms-about-email').value = aboutData.registry?.email || '';
            }

            if (faqData) {
                document.getElementById('cms-faq-badge').value = faqData.hero?.badge || '';
                document.getElementById('cms-faq-title').value = faqData.hero?.title || '';
                document.getElementById('cms-faq-desc').value = faqData.hero?.description || '';
                
                // Build dynamic FAQ input lines
                const faqContainer = document.getElementById('faq-list-container');
                faqContainer.innerHTML = '';
                faqData.questions.forEach((qItem, idx) => {
                    const row = document.createElement('div');
                    row.className = 'p-4 border border-outline-variant/30 rounded-xl bg-surface-container-low space-y-3';
                    row.innerHTML = `
                        <div class="flex flex-col gap-1">
                            <span class="text-[10px] font-bold text-primary uppercase">Question ${idx + 1}</span>
                            <input type="text" class="faq-input-q h-10 px-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-sm" value="${qItem.q}" />
                        </div>
                        <div class="flex flex-col gap-1">
                            <span class="text-[10px] font-bold text-primary uppercase">Answer ${idx + 1}</span>
                            <textarea class="faq-input-a p-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-sm resize-none" rows="2">${qItem.a}</textarea>
                        </div>
                    `;
                    faqContainer.appendChild(row);
                });
            }

            if (programsData) {
                document.getElementById('cms-ds-meta').value = programsData['data-science-ai']?.metaTitle || '';
                document.getElementById('cms-ds-headline').value = programsData['data-science-ai']?.hero?.headline || '';
                document.getElementById('cms-ds-description').value = programsData['data-science-ai']?.hero?.description || '';

                document.getElementById('cms-cyber-meta').value = programsData['cyber-security']?.metaTitle || '';
                document.getElementById('cms-cyber-headline').value = programsData['cyber-security']?.hero?.headline || '';
                document.getElementById('cms-cyber-description').value = programsData['cyber-security']?.hero?.description || '';

                document.getElementById('cms-devops-meta').value = programsData['devops']?.metaTitle || '';
                document.getElementById('cms-devops-headline').value = programsData['devops']?.hero?.headline || '';
                document.getElementById('cms-devops-description').value = programsData['devops']?.hero?.description || '';
            }

            if (couponConfigData) {
                document.getElementById('cms-coupon-min').value = couponConfigData.minLimit !== undefined ? couponConfigData.minLimit : 10;
                document.getElementById('cms-coupon-max').value = couponConfigData.maxLimit !== undefined ? couponConfigData.maxLimit : 6499;
            }

            // Save Trigger: Homepage
            window.saveHomepage = async function(e) {
                e.preventDefault();
                const headline = document.getElementById('cms-hero-headline').value;
                const description = document.getElementById('cms-hero-description').value;
                const button_text = document.getElementById('cms-hero-btn-text').value;
                const button_url = document.getElementById('cms-hero-btn-url').value;
                const trust_bar = document.getElementById('cms-trust-bar').value.split(',').map(item => item.trim()).filter(Boolean);
                const about_title = document.getElementById('cms-about-title').value;
                const about_description = document.getElementById('cms-about-description').value;
                const pricing_title = document.getElementById('cms-pricing-title').value;
                const pricing_amount = document.getElementById('cms-pricing-amount').value;
                const pricing_subtitle = document.getElementById('cms-pricing-subtitle').value;

                const payload = {
                    hero: { headline, description, button_text, button_url },
                    trust_bar,
                    about: { title: about_title, description: about_description },
                    pricing: { title: pricing_title, amount: pricing_amount, subtitle: pricing_subtitle }
                };

                await sendCmsUpdate('homepage', payload);
            }

            // Save Trigger: About Us
            window.saveAbout = async function(e) {
                e.preventDefault();
                const badge = document.getElementById('cms-about-hero-badge').value;
                const title = document.getElementById('cms-about-hero-title').value;
                const description = document.getElementById('cms-about-hero-desc').value;
                
                const story_title = document.getElementById('cms-about-story-title').value;
                const story_para = document.getElementById('cms-about-story-para').value;
                const vision_title = document.getElementById('cms-about-vision-title').value;
                const vision_desc = document.getElementById('cms-about-vision-desc').value;
                const method_title = document.getElementById('cms-about-method-title').value;
                const method_desc = document.getElementById('cms-about-method-desc').value;
                
                const delaware_address = document.getElementById('cms-about-delaware').value;
                const wyoming_address = document.getElementById('cms-about-wyoming').value;
                const phone = document.getElementById('cms-about-phone').value;
                const email = document.getElementById('cms-about-email').value;

                const payload = {
                    hero: { badge, title, description },
                    story: { title: story_title, paragraph: story_para, vision_title, vision_desc, method_title, method_desc },
                    registry: { legal_title: "Legal Entity Registry", legal_desc: "Sky States is a legally registered corporation in the United States, operating under strict compliance.", presence_title: "Physical Presence", delaware_address, wyoming_address, contact_title: "Institutional Contact", phone, email }
                };

                await sendCmsUpdate('about', payload);
            }

            // Save Trigger: FAQ
            window.saveFaq = async function(e) {
                e.preventDefault();
                const badge = document.getElementById('cms-faq-badge').value;
                const title = document.getElementById('cms-faq-title').value;
                const description = document.getElementById('cms-faq-desc').value;

                const qInputs = document.querySelectorAll('.faq-input-q');
                const aInputs = document.querySelectorAll('.faq-input-a');
                const questions = [];

                qInputs.forEach((input, index) => {
                    questions.push({
                        q: input.value,
                        a: aInputs[index].value
                    });
                });

                const payload = {
                    hero: { badge, title, description },
                    questions
                };

                await sendCmsUpdate('faq', payload);
            }

            // Save Trigger: Programs
            window.savePrograms = async function(e) {
                e.preventDefault();
                
                // Keep the structural content of modules & stats while editing metadata & hero fields
                const updatedPrograms = JSON.parse(JSON.stringify(programsData));

                updatedPrograms['data-science-ai'].metaTitle = document.getElementById('cms-ds-meta').value;
                updatedPrograms['data-science-ai'].hero.headline = document.getElementById('cms-ds-headline').value;
                updatedPrograms['data-science-ai'].hero.description = document.getElementById('cms-ds-description').value;

                updatedPrograms['cyber-security'].metaTitle = document.getElementById('cms-cyber-meta').value;
                updatedPrograms['cyber-security'].hero.headline = document.getElementById('cms-cyber-headline').value;
                updatedPrograms['cyber-security'].hero.description = document.getElementById('cms-cyber-description').value;

                updatedPrograms['devops'].metaTitle = document.getElementById('cms-devops-meta').value;
                updatedPrograms['devops'].hero.headline = document.getElementById('cms-devops-headline').value;
                updatedPrograms['devops'].hero.description = document.getElementById('cms-devops-description').value;

                await sendCmsUpdate('programs', updatedPrograms);
            }

            // Save Trigger: Coupon Limits Configuration
            window.saveCouponConfig = async function(e) {
                e.preventDefault();
                const minLimit = parseInt(document.getElementById('cms-coupon-min').value, 10);
                const maxLimit = parseInt(document.getElementById('cms-coupon-max').value, 10);

                if (minLimit > maxLimit) {
                    alert('Minimum coupon limit cannot exceed the maximum coupon limit.');
                    return;
                }

                await sendCmsUpdate('coupon-config', { minLimit, maxLimit });
            }

            // Generic CMS Submission Helper
            async function sendCmsUpdate(pageId, payload) {
                try {
                    const response = await fetch(`/api/cms?page=${pageId}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    if (response.ok) {
                        alert(`${pageId.toUpperCase()} content changes saved successfully!`);
                        window.location.reload();
                    } else {
                        alert('Failed to save changes. Please try again.');
                    }
                } catch (err) {
                    console.error('CMS Save error:', err);
                    alert('Request failed.');
                }
            }

            // Placements Dialog
            const modal = document.getElementById('job-modal');
            const form = document.getElementById('job-form');
            const modalTitle = document.getElementById('modal-title');
            
            window.openAddModal = function() {
                form.reset();
                document.getElementById('form-job-id').value = '';
                modalTitle.textContent = 'Post New Job Listing';
                modal.classList.remove('hidden');
            }

            window.openEditModal = function(job) {
                modalTitle.textContent = 'Edit Job Listing';
                document.getElementById('form-job-id').value = job.id;
                document.getElementById('form-title').value = job.title;
                document.getElementById('form-company').value = job.company;
                document.getElementById('form-location').value = job.location;
                document.getElementById('form-salary').value = job.salary;
                document.getElementById('form-tags').value = job.tags.join(', ');
                document.getElementById('form-description').value = job.description;
                modal.classList.remove('hidden');
            }

            window.closeModal = function() {
                modal.classList.add('hidden');
            }

            modal?.addEventListener('click', (e) => {
                if (e.target === modal) closeModal();
            });

            window.saveJob = async function(e) {
                e.preventDefault();
                
                const jobId = document.getElementById('form-job-id').value;
                const title = document.getElementById('form-title').value;
                const company = document.getElementById('form-company').value;
                const location = document.getElementById('form-location').value;
                const salary = document.getElementById('form-salary').value;
                const tags = document.getElementById('form-tags').value.split(',').map(t => t.trim()).filter(Boolean);
                const description = document.getElementById('form-description').value;

                const payload = { title, company, location, salary, tags, description };
                
                let method = 'POST';
                if (jobId) {
                    payload.id = jobId;
                    method = 'PUT';
                }

                try {
                    const response = await fetch('/api/jobs', {
                        method: method,
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    if (response.ok) {
                        closeModal();
                        window.location.reload();
                    } else {
                        alert('Failed to save job listing. Please try again.');
                    }
                } catch (error) {
                    console.error('Save error:', error);
                    alert('Save request failed.');
                }
            }

            window.deleteJob = async function(id) {
                if (!confirm('Are you absolutely sure you want to delete this placement listing?')) return;

                try {
                    const response = await fetch('/api/jobs', {
                        method: 'DELETE',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ id })
                    });

                    if (response.ok) {
                        const row = document.getElementById(`row-${id}`);
                        if (row) row.remove();
                    } else {
                        alert('Delete operation failed.');
                    }
                } catch (error) {
                    console.error('Delete error:', error);
                    alert('Request failed.');
                }
            }
        </script>
    )}
</body>
</html>
