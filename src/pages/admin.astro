                document.getElementById('form-story-youtube-url').value = '';
                storyModalTitle.textContent = 'Add New Success Story / Podcast';
                toggleStoryMediaTypeFields('video');
                storyModal.classList.remove('hidden');
            }

            window.openEditStoryModal = function(story) {
                storyModalTitle.textContent = 'Edit Success Story / Podcast';
                document.getElementById('form-story-id').value = story.id;
                document.getElementById('form-story-name').value = story.name;
                document.getElementById('form-story-role').value = story.role;
                document.getElementById('form-story-track').value = story.track;
                document.getElementById('form-story-type').value = story.type;
                document.getElementById('form-story-headline').value = story.headline;
                document.getElementById('form-story-quote').value = story.quote;
                
                if (story.type === 'podcast') {
                    document.getElementById('form-story-youtube-url').value = story.video_url || '';
                    document.getElementById('form-story-video-url').value = '';
                    document.getElementById('form-story-poster').value = '';
                } else {
                    document.getElementById('form-story-video-url').value = story.video_url || '';
                    document.getElementById('form-story-poster').value = story.poster || '';
                    document.getElementById('form-story-youtube-url').value = '';
                }
                
                toggleStoryMediaTypeFields(story.type);
                storyModal.classList.remove('hidden');
            }

            window.closeStoryModal = function() {
                storyModal.classList.add('hidden');
            }

            storyModal?.addEventListener('click', (e) => {
                if (e.target === storyModal) closeStoryModal();
            });

            window.toggleStoryMediaTypeFields = function(type) {
                const videoFields = document.getElementById('story-video-fields');
                const podcastFields = document.getElementById('story-podcast-fields');
                
                if (type === 'podcast') {
                    videoFields.classList.add('hidden');
                    podcastFields.classList.remove('hidden');
                } else {
                    videoFields.classList.remove('hidden');
                    podcastFields.classList.add('hidden');
                }
            }

            window.handleStoryVideoUpload = async function(fileInput) {
                const file = fileInput.files[0];
                if (!file) return;
                
                const formData = new FormData();
                formData.append('file', file);
                formData.append('alt_text', file.name);
                formData.append('title', file.name);
                
                try {
                    const btn = fileInput.nextElementSibling;
                    if (btn) btn.innerText = 'Uploading...';
                    
                    const response = await fetch('/api/media', {
                        method: 'POST',
                        body: formData
                    });
                    
                    if (response.ok) {
                        const res = await response.json();
                        document.getElementById('form-story-video-url').value = res.media.path;
                        alert('Video uploaded successfully!');
                    } else {
                        const err = await response.json();
                        alert('Upload failed: ' + (err.error || 'Unknown error'));
                    }
                } catch (e) {
                    console.error(e);
                    alert('Upload request failed.');
                } finally {
                    fileInput.value = '';
                    const btn = fileInput.nextElementSibling;
                    if (btn) btn.innerHTML = '<span class="material-symbols-outlined text-[14px]">upload</span><span>Upload</span>';
                }
            }

            window.handleStoryPosterUpload = async function(fileInput) {
                const file = fileInput.files[0];
                if (!file) return;
                
                const formData = new FormData();
                formData.append('file', file);
                formData.append('alt_text', file.name);
                formData.append('title', file.name);
                
                try {
                    const btn = fileInput.nextElementSibling;
                    if (btn) btn.innerText = 'Uploading...';
                    
                    const response = await fetch('/api/media', {
                        method: 'POST',
                        body: formData
                    });
                    
                    if (response.ok) {
                        const res = await response.json();
                        document.getElementById('form-story-poster').value = res.media.path;
                        alert('Thumbnail uploaded successfully!');
                    } else {
                        const err = await response.json();
                        alert('Upload failed: ' + (err.error || 'Unknown error'));
                    }
                } catch (e) {
                    console.error(e);
                    alert('Upload request failed.');
                } finally {
                    fileInput.value = '';
                    const btn = fileInput.nextElementSibling;
                    if (btn) btn.innerHTML = '<span class="material-symbols-outlined text-[14px]">upload</span><span>Upload</span>';
                }
            }

            window.saveStory = async function(e) {
                e.preventDefault();
                
                const id = document.getElementById('form-story-id').value;
                const name = document.getElementById('form-story-name').value;
                const role = document.getElementById('form-story-role').value;
                const track = document.getElementById('form-story-track').value;
                const type = document.getElementById('form-story-type').value;
                const headline = document.getElementById('form-story-headline').value;
                const quote = document.getElementById('form-story-quote').value;
                
                let video_url = '';
                let poster = '';
                
                if (type === 'podcast') {
                    video_url = document.getElementById('form-story-youtube-url').value;
                } else {
                    video_url = document.getElementById('form-story-video-url').value;
                    poster = document.getElementById('form-story-poster').value;
                }

                const payload = {
                    name,
                    role,
                    track,
                    type,
                    headline,
                    quote,
                    video_url,
                    poster
                };
                
                let method = 'POST';
                if (id) {
                    payload.id = id;
                    method = 'PUT';
                }

                try {
                    const response = await fetch('/api/stories', {
                        method: method,
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    if (response.ok) {
                        closeStoryModal();
                        window.location.reload();
                    } else {
                        const err = await response.json();
                        alert('Failed to save success story: ' + (err.error || 'Unknown error'));
                    }
                } catch (error) {
                    console.error('Save story error:', error);
                    alert('Save request failed.');
                }
            }

            window.deleteStory = async function(id) {
                if (!confirm('Are you absolutely sure you want to delete this success story?')) return;

                try {
                    const response = await fetch('/api/stories', {
                        method: 'DELETE',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ id })
                    });

                    if (response.ok) {
                        const row = document.getElementById(`story-row-${id}`);
                        if (row) row.remove();
                    } else {
                        alert('Delete operation failed.');
                    }
                } catch (error) {
                    console.error('Delete error:', error);
                    alert('Request failed.');
                }
            }

            window.openUserModal = function(user) {
                const modal = document.getElementById('user-modal');
                const title = document.getElementById('user-modal-title');
                const passwordInput = document.getElementById('form-user-password');
                if (!modal || !title || !passwordInput) return;

                document.getElementById('form-user-id').value = user?.id || '';
                document.getElementById('form-user-username').value = user?.username || '';
                document.getElementById('form-user-role').value = user?.role || 'editor';
                passwordInput.value = '';
                passwordInput.required = !user;

                title.textContent = user ? 'Edit Admin User' : 'Add Admin User';
                modal.classList.remove('hidden');
            }

            window.closeUserModal = function() {
                const modal = document.getElementById('user-modal');
                if (modal) modal.classList.add('hidden');
            }

            window.saveAdminUser = async function(e) {
                e.preventDefault();

                const id = document.getElementById('form-user-id').value;
                const username = document.getElementById('form-user-username').value.trim();
                const password = document.getElementById('form-user-password').value;
                const role = document.getElementById('form-user-role').value;

                const payload = { username, role };
                if (password) payload.password = password;

                try {
                    const response = await fetch('/api/users', {
                        method: id ? 'PUT' : 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(id ? { ...payload, id: Number(id) } : payload),
                    });

                    const data = await response.json();
                    if (!response.ok) {
                        alert(data.error || 'Unable to save user.');
                        return;
                    }

                    closeUserModal();
                    window.location.reload();
                } catch (error) {
                    console.error('Save user error:', error);
                    alert('Request failed.');
                }
            }

            window.deleteAdminUser = async function(id, username) {
                if (!confirm(`Delete admin user "${username}"?`)) return;

                try {
                    const response = await fetch('/api/users', {
                        method: 'DELETE',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ id }),
                    });

                    const data = await response.json();
                    if (!response.ok) {
                        alert(data.error || 'Unable to delete user.');
                        return;
                    }

                    const row = document.getElementById(`user-row-${id}`);
                    if (row) row.remove();
                } catch (error) {
                    console.error('Delete user error:', error);
                    alert('Request failed.');
                }
            }

            window.openCouponModal = function(coupon) {
                const modal = document.getElementById('coupon-modal');
                const title = document.getElementById('coupon-modal-title');
                if (!modal || !title) return;

                document.getElementById('form-coupon-id').value = coupon?.id || '';
                document.getElementById('form-coupon-code').value = coupon?.code || '';
                document.getElementById('form-coupon-discount').value = coupon?.discount_amount ?? '';
                document.getElementById('form-coupon-description').value = coupon?.description || '';
                document.getElementById('form-coupon-max-uses').value = coupon?.max_uses ?? '';
                document.getElementById('form-coupon-expires').value = coupon?.expires_at ? coupon.expires_at.slice(0, 10) : '';
                document.getElementById('form-coupon-active').checked = coupon ? !!coupon.active : true;

                title.textContent = coupon ? 'Edit Coupon' : 'Create Coupon';
                modal.classList.remove('hidden');
            }

            window.closeCouponModal = function() {
                const modal = document.getElementById('coupon-modal');
                if (modal) modal.classList.add('hidden');
            }

            window.saveCoupon = async function(e) {
                e.preventDefault();

                const id = document.getElementById('form-coupon-id').value;
                const payload = {
                    code: document.getElementById('form-coupon-code').value.trim(),
                    discount_amount: Number(document.getElementById('form-coupon-discount').value),
                    description: document.getElementById('form-coupon-description').value.trim(),
                    max_uses: document.getElementById('form-coupon-max-uses').value || null,
                    expires_at: document.getElementById('form-coupon-expires').value || null,
                    active: document.getElementById('form-coupon-active').checked,
                };

                try {
                    const response = await fetch('/api/coupons', {
                        method: id ? 'PUT' : 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(id ? { ...payload, id: Number(id) } : payload),
                    });

                    const data = await response.json();
                    if (!response.ok) {
                        alert(data.error || 'Unable to save coupon.');
                        return;
                    }

                    closeCouponModal();
                    window.location.reload();
                } catch (error) {
                    console.error('Save coupon error:', error);
                    alert('Request failed.');
                }
            }

            window.deleteCoupon = async function(id, code) {
                if (!confirm(`Delete coupon "${code}"?`)) return;

                try {
                    const response = await fetch('/api/coupons', {
                        method: 'DELETE',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ id }),
                    });

                    const data = await response.json();
                    if (!response.ok) {
                        alert(data.error || 'Unable to delete coupon.');
                        return;
                    }

                    const row = document.getElementById(`coupon-row-${id}`);
                    if (row) row.remove();
                } catch (error) {
                    console.error('Delete coupon error:', error);
                    alert('Request failed.');
                }
            }
        </script>
    )}
</body>
</html>
