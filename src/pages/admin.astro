            // Save Trigger: Homepage
            window.saveHomepage = async function(e) {
                e.preventDefault();
                const headline = document.getElementById('cms-hero-headline').value;
                const description = document.getElementById('cms-hero-description').value;
                const button_text = document.getElementById('cms-hero-btn-text').value;
                const button_url = document.getElementById('cms-hero-btn-url').value;
                const consultation_text = document.getElementById('cms-hero-consult-text').value;
                const consultation_url = document.getElementById('cms-hero-consult-url').value;
                const trust_bar = document.getElementById('cms-trust-bar').value.split(',').map(item => item.trim()).filter(Boolean);
                const about_title = document.getElementById('cms-about-title').value;
                const about_description = document.getElementById('cms-about-description').value;

                // Read Why Choose
                const why_choose = [];
                for (let i = 1; i <= 6; i++) {
                    const titleVal = document.getElementById(`cms-why-${i}-title`).value;
                    const descVal = document.getElementById(`cms-why-${i}-desc`).value;
                    why_choose.push({ title: titleVal, description: descVal });
                }

                // Read Programs Section
                const progSectionTitle = document.getElementById('cms-prog-section-title').value;
                const progSectionSubtitle = document.getElementById('cms-prog-section-subtitle').value;
                const programs = [];
                const progIds = ['data-science-ai', 'cyber-security', 'devops'];
                for (let i = 1; i <= 3; i++) {
                    const titleVal = document.getElementById(`cms-prog-${i}-title`).value;
                    const priceVal = document.getElementById(`cms-prog-${i}-price`).value;
                    const highlightsVal = document.getElementById(`cms-prog-${i}-highlights`).value.split(',').map(item => item.trim()).filter(Boolean);
                    const descVal = document.getElementById(`cms-prog-${i}-desc`).value;
                    programs.push({
                        id: progIds[i - 1],
                        title: titleVal,
                        price: priceVal,
                        description: descVal,
                        highlights: highlightsVal
                    });
                }

                // Read Paths Section
                const pathsTitle = document.getElementById('cms-paths-title').value;
                const pathsSubtitle = document.getElementById('cms-paths-subtitle').value;
                const paths = [];
                for (let i = 1; i <= 2; i++) {
                    const titleVal = document.getElementById(`cms-path-${i}-title`).value;
                    const descVal = document.getElementById(`cms-path-${i}-desc`).value;
                    paths.push({ title: titleVal, description: descVal });
                }

                // Read Methodology Section
                const methTitle = document.getElementById('cms-meth-title').value;
                const methSubtitle = document.getElementById('cms-meth-subtitle').value;
                const methDesc = document.getElementById('cms-meth-description').value;
                const steps = [];
                for (let i = 1; i <= 4; i++) {
                    const titleVal = document.getElementById(`cms-meth-${i}-title`).value;
                    const descVal = document.getElementById(`cms-meth-${i}-desc`).value;
                    steps.push({ id: String(i), title: titleVal, description: descVal });
                }

                const pricing_title = document.getElementById('cms-pricing-title').value;
                const pricing_amount = document.getElementById('cms-pricing-amount').value;
                const pricing_subtitle = document.getElementById('cms-pricing-subtitle').value;

                const payload = {
                    hero: { headline, description, button_text, button_url, consultation_text, consultation_url },
                    trust_bar,
                    about: { title: about_title, description: about_description },
                    why_choose,
                    programs_section: { title: progSectionTitle, subtitle: progSectionSubtitle, programs },
                    learning_paths: { title: pathsTitle, subtitle: pathsSubtitle, paths },
                    methodology: { title: methTitle, subtitle: methSubtitle, description: methDesc, steps },
                    pricing: { title: pricing_title, amount: pricing_amount, subtitle: pricing_subtitle }
                };

                await sendCmsUpdate('homepage', payload);
            }

