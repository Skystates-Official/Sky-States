---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Geist:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pricing & Refund Policy | Sky States</title>
    <meta
      name="description"
      content="Review the transparent pricing structure, payment options, and the 14-day satisfaction guarantee refund policy at Sky States."
    />
    <link rel="canonical" href="https://skystates.us/refund-policy" />
  </head>
  <body class="bg-slate-50/50 text-slate-800 font-sans min-h-screen">
    <Header />
    <main class="min-h-screen pt-32 pb-24 px-4 flex justify-center">
      <article
        class="w-full max-w-4xl bg-white rounded-2xl shadow-xl shadow-slate-200/50 border border-slate-200/60 p-8 sm:p-12 md:p-16 space-y-10"
      >
        <!-- Hero/Header Section -->
        <div class="text-center space-y-4 border-b border-slate-100 pb-8">
          <span
            class="inline-block bg-sky-50 border border-sky-100 text-sky-700 px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider"
            >Pricing Transparency</span
          >
          <h1
            class="text-3xl sm:text-4xl font-bold text-[#0f3473] tracking-tight"
          >
            Refund and Returns Policy
          </h1>
          <p class="text-slate-500 text-base max-w-2xl mx-auto">
            At Sky States, we are dedicated to ensuring that our users have a
            positive and enriching experience with our training courses, whether
            they are online or in a classroom setting. We understand that
            circumstances can change, and we want to be as fair and transparent
            as possible with our refund policies. By purchasing a course on the
            Sky States website, you agree to our Privacy Policy, Terms of Use,
            and the refund terms outlined below.
          </p>
        </div>

        <!-- Policy Content -->
        <div class="space-y-10 text-slate-700 leading-relaxed text-base">
          <!-- Section 1 -->
          <div class="space-y-4">
            <h2
              class="text-xl font-bold text-slate-900 flex items-center gap-3"
            >
              <span class="material-symbols-outlined text-[#1b4a9a]"
                >calendar_today</span
              >
              1. 14-Day Refund Eligibility Window
            </h2>
            <p class="text-slate-600 text-justify leading-relaxed">
              We offer a full refund on course fees within the first 14 calendar
              days following your initial payment. The eligibility window is
              strictly calculated from the exact date and time the payment is
              processed, subject to the following conditions:
            </p>
            <div class="space-y-4">
              <div
                class="p-6 rounded-2xl bg-slate-50 border border-slate-200/40"
              >
                <h4
                  class="font-bold text-[#0f3473] text-sm uppercase tracking-wider mb-2"
                >
                  Valid Technical or Quality Grounds
                </h4>
                <p class="text-slate-600 text-sm leading-relaxed">
                  Refund requests will only be considered if you experience
                  verifiable issues with a trainer, class quality, or our core
                  services, and our support team is unable to resolve these
                  issues within a reasonable timeframe.
                </p>
              </div>
              <div
                class="p-6 rounded-2xl bg-slate-50 border border-slate-200/40"
              >
                <h4
                  class="font-bold text-[#0f3473] text-sm uppercase tracking-wider mb-2"
                >
                  Personal Circumstance Exemptions
                </h4>
                <p class="text-slate-600 text-sm leading-relaxed">
                  Refund requests made within the 14-day window due to personal
                  changes—including, but not limited to, changes in your
                  personal schedule, securing employment, or being assigned new
                  academic/work projects—are strictly non-refundable.
                </p>
              </div>
              <div
                class="p-6 rounded-2xl bg-slate-50 border border-slate-200/40"
              >
                <h4
                  class="font-bold text-[#0f3473] text-sm uppercase tracking-wider mb-2"
                >
                  Subjective Opinion & Third-Party Reviews
                </h4>
                <p class="text-slate-600 text-sm leading-relaxed">
                  Refund requests based on third-party reviews and public forums
                  are strictly excluded from eligibility. Because online reviews
                  are highly subjective and vary per individual experience, they
                  do not constitute objective grounds for a refund.
                </p>
              </div>
            </div>
          </div>

          <!-- Section 2 -->
          <div class="space-y-4">
            <h2
              class="text-xl font-bold text-slate-900 flex items-center gap-3"
            >
              <span class="material-symbols-outlined text-[#1b4a9a]"
                >payments</span
              >
              2. Non-Refundable Processing & Payment Fees
            </h2>
            <p class="text-slate-600 text-justify leading-relaxed">
              Depending on your chosen payment method, certain third-party
              processing and convenience fees are strictly non-refundable:
            </p>
            <div class="space-y-4">
              <div class="border-l-4 border-[#1b4a9a] pl-4 py-1">
                <h5 class="font-bold text-slate-800 text-base">
                  Installment & Financing Plans
                </h5>
                <p class="text-slate-600 text-sm mt-1 leading-relaxed">
                  If you utilize a third-party financing partner (such as
                  Afterpay, Klarna, Affirm, Zip, Sezzle, or PayPal Credit), any
                  accrued interest or convenience fees charged by the respective
                  provider cannot be refunded.
                </p>
              </div>
              <div class="border-l-4 border-slate-300 pl-4 py-1">
                <h5 class="font-bold text-slate-800 text-base">
                  Credit & Debit Cards
                </h5>
                <p class="text-slate-600 text-sm mt-1 leading-relaxed">
                  Processing and convenience fees applied by card networks at
                  the time of purchase are non-refundable.
                </p>
              </div>
              <div class="border-l-4 border-slate-300 pl-4 py-1">
                <h5 class="font-bold text-slate-800 text-base">
                  Wire Transfers & Zelle
                </h5>
                <p class="text-slate-600 text-sm mt-1 leading-relaxed">
                  Payments made via direct bank wire transfer or Zelle are
                  exempt from external processing fees. Consequently, 100% of
                  the payment received by Sky States will be refunded if the
                  request is formally approved.
                </p>
              </div>
            </div>
          </div>

          <!-- Section 3 -->
          <div class="space-y-4">
            <h2
              class="text-xl font-bold text-slate-900 flex items-center gap-3"
            >
              <span class="material-symbols-outlined text-[#1b4a9a]">mail</span>
              3. How to Request a Refund & Timeline
            </h2>
            <p class="text-slate-600 text-justify leading-relaxed">
              To formally initiate a refund request within the 14-day
              eligibility window, you must complete the following steps:
            </p>
            <div class="space-y-3 pl-2">
              <div class="flex items-start gap-4">
                <span
                  class="w-6 h-6 rounded-full bg-[#1b4a9a] text-white flex items-center justify-center text-xs font-bold shrink-0 mt-1"
                  >1</span
                >
                <p class="text-slate-600 text-sm leading-relaxed mt-0.5">
                  First, contact your assigned Relationship Manager directly to
                  formally discuss your concerns.
                </p>
              </div>
              <div class="flex items-start gap-4">
                <span
                  class="w-6 h-6 rounded-full bg-[#1b4a9a] text-white flex items-center justify-center text-xs font-bold shrink-0 mt-1"
                  >2</span
                >
                <p class="text-slate-600 text-sm leading-relaxed mt-0.5">
                  Submit a formal, written refund request via email to <a
                    href="mailto:support@skystates.com"
                    class="text-sky-600 hover:underline font-semibold"
                    >support@skystates.com</a
                  >
                </p>
              </div>
            </div>
            <div
              class="bg-sky-50 border border-sky-100 p-6 rounded-2xl flex items-start gap-4"
            >
              <span class="material-symbols-outlined text-[#1b4a9a] text-[32px]"
                >info</span
              >
              <div>
                <h4
                  class="font-bold text-[#0f3473] text-sm uppercase tracking-wider mb-1"
                >
                  Processing Timeline
                </h4>
                <p class="text-slate-600 text-sm leading-relaxed">
                  Once a refund request is officially approved by our billing
                  department, the approved funds will be processed and returned
                  to the original payment method within 10 to 15 business days.
                </p>
              </div>
            </div>
          </div>

          <!-- Section 4 -->
          <div class="space-y-4">
            <h2
              class="text-xl font-bold text-slate-900 flex items-center gap-3"
            >
              <span class="material-symbols-outlined text-[#1b4a9a]">gavel</span
              >
              4. Code of Conduct & Academic Integrity
            </h2>
            <p class="text-slate-600 text-justify leading-relaxed">
              Sky States maintains a zero-tolerance policy regarding disruptive
              behavior and intellectual property infringement. We reserve the
              absolute right to terminate a student's enrollment at any time,
              without a refund, under the following circumstances:
            </p>
            <div class="space-y-4">
              <div
                class="p-6 rounded-2xl bg-slate-50 border border-slate-200/40"
              >
                <h4
                  class="font-bold text-[#0f3473] text-sm uppercase tracking-wider mb-2"
                >
                  Misbehavior
                </h4>
                <p class="text-slate-600 text-sm leading-relaxed">
                  Any form of harassment, disrespect, use of inappropriate
                  language, or misconduct directed toward trainers, staff
                  members, or fellow students.
                </p>
              </div>
              <div
                class="p-6 rounded-2xl bg-slate-50 border border-slate-200/40"
              >
                <h4
                  class="font-bold text-[#0f3473] text-sm uppercase tracking-wider mb-2"
                >
                  Copyright Infringement
                </h4>
                <p class="text-slate-600 text-sm leading-relaxed">
                  Sharing, distributing, copying, or replicating Sky States
                  course content, curriculum, recordings, or proprietary study
                  materials with any external parties for commercial or business
                  purposes. Sky States will pursue formal legal action against
                  any violations.
                </p>
              </div>
            </div>
          </div>

          <!-- Section 5: Contact & Inquiries -->
          <div class="space-y-4 border-t border-slate-100 pt-8">
            <h2
              class="text-xl font-bold text-slate-900 flex items-center gap-3"
            >
              <span class="material-symbols-outlined text-[#1b4a9a]"
                >contact_support</span
              >
              5. Contact & Support
            </h2>
            <p class="text-slate-600 leading-relaxed">
              If you have any questions or need assistance, don't hesitate to
              get in touch with our support team. We are here to help and ensure
              you have the best possible experience.
            </p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-4">
              <div class="flex items-start gap-3">
                <span
                  class="material-symbols-outlined text-[#1b4a9a] text-xl mt-0.5"
                  >mail</span
                >
                <div>
                  <p class="text-xs uppercase font-bold text-slate-500">
                    Email Support
                  </p>
                  <div class="flex flex-col">
                    <a
                      href="mailto:info@skystates.us"
                      class="text-sky-600 font-semibold hover:underline"
                      >info@skystates.us</a
                    >
                    <a
                      href="mailto:support@skystates.us"
                      class="text-sky-600 font-semibold hover:underline"
                      >support@skystates.us</a
                    >
                  </div>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <span
                  class="material-symbols-outlined text-[#1b4a9a] text-xl mt-0.5"
                  >call</span
                >
                <div>
                  <p class="text-xs uppercase font-bold text-slate-500">
                    Call Toll Free
                  </p>
                  <div class="flex flex-col">
                    <a
                      href="tel:+18888102434"
                      class="text-sky-600 font-semibold hover:underline"
                      >(888) 810-2434</a
                    >
                  </div>
                </div>
              </div>

              <div class="flex items-start gap-3 md:col-span-2">
                <span
                  class="material-symbols-outlined text-[#1b4a9a] text-xl mt-0.5"
                  >location_on</span
                >
                <div>
                  <p class="text-xs uppercase font-bold text-slate-500">
                    Office Address
                  </p>
                  <p class="text-sm text-slate-600 mt-0.5">
                    1316 Wall St, Suite 2C, Everett, WA 98201, United States
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Trust banner -->
          <div
            class="bg-slate-50 border border-slate-200/40 p-6 rounded-2xl flex items-start gap-4"
          >
            <span class="material-symbols-outlined text-[#1b4a9a] text-[32px]"
              >verified_user</span
            >
            <div>
              <h4
                class="font-bold text-[#0f3473] text-sm uppercase tracking-wider mb-1"
              >
                Radical Clarity
              </h4>
              <p class="text-slate-600 text-sm leading-relaxed">
                No hidden fees or surprises. Everything is clearly documented to
                guarantee compliance and protect your learning journey.
              </p>
            </div>
          </div>
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
