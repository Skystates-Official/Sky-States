<!-- Detailed Refund Policy Section -->
<section class="max-w-[1280px] mx-auto px-margin-desktop mt-section-gap pb-20">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
    
    <!-- Left & Middle: Detailed Policy Rules -->
    <div class="lg:col-span-2 space-y-12">
      
      <!-- 1. 14-Day Refund Eligibility Window -->
      <div class="bg-surface-container-lowest p-8 md:p-10 rounded-3xl border border-outline-variant/30 ambient-shadow">
        <div class="flex items-center gap-3 mb-6">
          <span class="material-symbols-outlined text-primary text-3xl">calendar_today</span>
          <h3 class="font-headline-md text-headline-md text-on-surface">1. 14-Day Refund Eligibility Window</h3>
        </div>
        
        <p class="text-secondary text-body-md leading-relaxed mb-6">
          We offer a full refund on course fees within the first 14 calendar days following your initial payment. The eligibility window is strictly calculated from the exact date and time the payment is processed, subject to the following conditions:
        </p>

        <div class="space-y-6">
          <div class="p-6 rounded-2xl bg-surface-container-low border border-outline-variant/20">
            <h4 class="font-label-md text-primary uppercase tracking-wider mb-2">Valid Technical or Quality Grounds</h4>
            <p class="text-secondary text-sm leading-relaxed">
              Refund requests will only be considered if you experience verifiable issues with a trainer, class quality, or our core services, and our support team is unable to resolve these issues within a reasonable timeframe.
            </p>
          </div>

          <div class="p-6 rounded-2xl bg-surface-container-low border border-outline-variant/20">
            <h4 class="font-label-md text-primary uppercase tracking-wider mb-2">Personal Circumstance Exemptions</h4>
            <p class="text-secondary text-sm leading-relaxed">
              Refund requests made within the 14-day window due to personal changes—including, but not limited to, changes in your personal schedule, securing employment, or being assigned new academic/work projects—are strictly non-refundable.
            </p>
          </div>

          <div class="p-6 rounded-2xl bg-surface-container-low border border-outline-variant/20">
            <h4 class="font-label-md text-primary uppercase tracking-wider mb-2">Subjective Opinion &amp; Third-Party Reviews</h4>
            <p class="text-secondary text-sm leading-relaxed">
              Refund requests based on third-party reviews and public forums are strictly excluded from eligibility. Because online reviews are highly subjective and vary per individual experience, they do not constitute objective grounds for a refund.
            </p>
          </div>
        </div>
      </div>

      <!-- 2. Non-Refundable Processing & Payment Fees -->
      <div class="bg-surface-container-lowest p-8 md:p-10 rounded-3xl border border-outline-variant/30 ambient-shadow">
        <div class="flex items-center gap-3 mb-6">
          <span class="material-symbols-outlined text-primary text-3xl">payments</span>
          <h3 class="font-headline-md text-headline-md text-on-surface">2. Non-Refundable Processing &amp; Payment Fees</h3>
        </div>

        <p class="text-secondary text-body-md leading-relaxed mb-6">
          Depending on your chosen payment method, certain third-party processing and convenience fees are strictly non-refundable:
        </p>
        
        <div class="space-y-4">
          <div class="border-l-4 border-primary pl-4 py-1">
            <h5 class="font-label-md text-on-surface font-bold">Installment &amp; Financing Plans</h5>
            <p class="text-secondary text-sm mt-1 leading-relaxed">
              If you utilize a third-party financing partner (such as Afterpay, Klarna, Affirm, Zip, Sezzle, or PayPal Credit), any accrued interest or convenience fees charged by the respective provider cannot be refunded.
            </p>
          </div>

          <div class="border-l-4 border-outline pl-4 py-1">
            <h5 class="font-label-md text-on-surface font-bold">Credit &amp; Debit Cards</h5>
            <p class="text-secondary text-sm mt-1 leading-relaxed">
              Processing and convenience fees applied by card networks at the time of purchase are non-refundable.
            </p>
          </div>

          <div class="border-l-4 border-outline pl-4 py-1">
            <h5 class="font-label-md text-on-surface font-bold">Wire Transfers &amp; Zelle</h5>
            <p class="text-secondary text-sm mt-1 leading-relaxed">
              Payments made via direct bank wire transfer or Zelle are exempt from external processing fees. Consequently, 100% of the payment received by Sky States will be refunded if the request is formally approved.
            </p>
          </div>
        </div>
      </div>

      <!-- 3. How to Request a Refund & Processing Timeline -->
      <div class="bg-surface-container-lowest p-8 md:p-10 rounded-3xl border border-outline-variant/30 ambient-shadow">
        <div class="flex items-center gap-3 mb-6">
          <span class="material-symbols-outlined text-primary text-3xl">mail</span>
          <h3 class="font-headline-md text-headline-md text-on-surface">3. How to Request a Refund &amp; Timeline</h3>
        </div>

        <p class="text-secondary text-body-md leading-relaxed mb-6">
          To formally initiate a refund request within the 14-day eligibility window, you must complete the following steps:
        </p>

        <div class="space-y-4 mb-6">
          <div class="flex items-start gap-4">
            <span class="w-6 h-6 rounded-full bg-primary text-white flex items-center justify-center text-xs font-bold shrink-0 mt-1">1</span>
            <p class="text-secondary text-sm leading-relaxed">
              First, contact your assigned Relationship Manager directly to formally discuss your concerns.
            </p>
          </div>
          <div class="flex items-start gap-4">
            <span class="w-6 h-6 rounded-full bg-primary text-white flex items-center justify-center text-xs font-bold shrink-0 mt-1">2</span>
            <p class="text-secondary text-sm leading-relaxed">
              Submit a formal, written refund request via email to <a href="mailto:support@skystates.com" class="text-primary hover:underline font-semibold">support@skystates.com</a>
            </p>
          </div>
        </div>

        <div class="bg-primary-container text-on-primary-container p-6 rounded-2xl flex items-start gap-4">
          <span class="material-symbols-outlined text-[32px]">info</span>
          <div>
            <h4 class="font-label-md font-bold uppercase tracking-wider mb-1">Processing Timeline</h4>
            <p class="text-sm opacity-90 leading-relaxed">
              Once a refund request is officially approved by our billing department, the approved funds will be processed and returned to the original payment method within 10 to 15 business days.
            </p>
          </div>
        </div>
      </div>

      <!-- 4. Code of Conduct & Academic Integrity -->
      <div class="bg-surface-container-lowest p-8 md:p-10 rounded-3xl border border-outline-variant/30 ambient-shadow">
        <div class="flex items-center gap-3 mb-6">
          <span class="material-symbols-outlined text-primary text-3xl">gavel</span>
          <h3 class="font-headline-md text-headline-md text-on-surface">4. Code of Conduct &amp; Academic Integrity</h3>
        </div>

        <p class="text-secondary text-body-md leading-relaxed mb-6">
          Sky States maintains a zero-tolerance policy regarding disruptive behavior and intellectual property infringement. We reserve the absolute right to terminate a student's enrollment at any time, without a refund, under the following circumstances:
        </p>

        <div class="space-y-6">
          <div class="p-6 rounded-2xl bg-surface-container-low border border-outline-variant/20">
            <h4 class="font-label-md text-primary uppercase tracking-wider mb-2">Misbehavior</h4>
            <p class="text-secondary text-sm leading-relaxed">
              Any form of harassment, disrespect, use of inappropriate language, or misconduct directed toward trainers, staff members, or fellow students.
            </p>
          </div>

          <div class="p-6 rounded-2xl bg-surface-container-low border border-outline-variant/20">
            <h4 class="font-label-md text-primary uppercase tracking-wider mb-2">Copyright Infringement</h4>
            <p class="text-secondary text-sm leading-relaxed">
              Sharing, distributing, copying, or replicating Sky States course content, curriculum, recordings, or proprietary study materials with any external parties for commercial or business purposes. Sky States will pursue formal legal action against any violations.
            </p>
          </div>
        </div>
      </div>

    <!-- Right Column: Contacts, Address & Help -->
    <div class="space-y-6 sticky top-24">
      <div class="bg-surface-container-lowest p-8 rounded-3xl border border-outline-variant/30 ambient-shadow space-y-6">
        <div class="flex items-center gap-3">
          <span class="material-symbols-outlined text-primary text-3xl">contact_support</span>
          <h4 class="font-label-lg text-on-surface font-bold uppercase tracking-wider">Contact &amp; Support</h4>
        </div>
        
        <p class="text-secondary text-sm leading-relaxed">
          If you have any questions or need assistance, don't hesitate to get in touch with our support team. We are here to help and ensure you have the best possible experience.
        </p>

        <div class="space-y-4 pt-4 border-t border-outline-variant/20">
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary text-xl mt-0.5">mail</span>
            <div>
              <p class="text-xs uppercase font-bold text-secondary">Email Support</p>
              <div class="flex flex-col">
                <a href="mailto:info@skystates.us" class="text-primary font-semibold hover:underline">info@skystates.us</a>
                <a href="mailto:support@skystates.us" class="text-primary font-semibold hover:underline">support@skystates.us</a>
              </div>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary text-xl mt-0.5">call</span>
            <div>
              <p class="text-xs uppercase font-bold text-secondary">Call Toll Free</p>
              <a href="tel:+18888102434" class="text-primary font-semibold hover:underline">(888) 810-2434</a><br />
              <a href="tel:+18889277072" class="text-primary font-semibold hover:underline">(888) 927-7072</a>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary text-xl mt-0.5">location_on</span>
            <div>
              <p class="text-xs uppercase font-bold text-secondary">Office Address</p>
              <p class="text-sm text-secondary">1316 Wall St, Suite 2C, Everett, WA 98201, United States</p>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Trust Indicator -->
      <div class="bg-secondary-container text-on-secondary-container p-6 rounded-3xl space-y-2">
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-primary">verified_user</span>
          <p class="font-label-md font-bold uppercase tracking-wider text-xs">RADICAL CLARITY</p>
        </div>
        <p class="text-xs opacity-80 leading-relaxed">
          No hidden fees or surprises. Everything is clearly documented to guarantee compliance and protect your learning journey.
        </p>
      </div>
    </div>

  </div>
</section>
</main>
<!-- Footer -->
<Footer />
<script>
        // Micro-interaction for hover effects
        document.querySelectorAll('.ambient-shadow').forEach(card => {
            card.addEventListener('mousemove', e => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                card.style.setProperty('--mouse-x', `${x}px`);
                card.style.setProperty('--mouse-y', `${y}px`);
            });
        });
    </script>
</body></html>