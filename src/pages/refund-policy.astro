---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>

<html lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Pricing &amp; Refund Policy | Sky States</title>
<meta name="description" content="Review the transparent pricing structure, payment options, and the 14-day satisfaction guarantee refund policy at Sky States." />
<link rel="canonical" href="https://skystates.us/refund-policy" />

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>

<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .sky-glass {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }
        .ambient-shadow {
            box-shadow: 0 30px 60px -12px rgba(0, 93, 144, 0.04), 0 18px 36px -18px rgba(0, 0, 0, 0.05);
        }
        .upward-gradient {
            background: linear-gradient(to top, #ffffff 0%, #d3e2ed 100%);
        }
        body {
            background-color: #f9f9f9;
            color: #1a1c1c;
            scroll-behavior: smooth;
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="font-body-md text-on-surface">
<!-- TopAppBar -->
<Header />
<main>
