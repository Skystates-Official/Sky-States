<!-- Detailed Refund Policy Section -->
<section class="max-w-[1280px] mx-auto px-margin-desktop mt-section-gap pb-20">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
    
    <!-- Left & Middle: Detailed Policy Rules -->
    <div class="lg:col-span-2 space-y-12">
      
      <!-- Long-Term Courses -->
      <div class="bg-surface-container-lowest p-8 md:p-10 rounded-3xl border border-outline-variant/30 ambient-shadow">
        <div class="flex items-center gap-3 mb-6">
          <span class="material-symbols-outlined text-primary text-3xl">calendar_today</span>
          <h3 class="font-headline-md text-headline-md text-on-surface">Long-Term Courses <span class="text-sm font-normal text-secondary">(6 Months & Above)</span></h3>
        </div>
        
        <div class="space-y-6">
          <div class="p-6 rounded-2xl bg-surface-container-low border border-outline-variant/20">
            <h4 class="font-label-md text-primary uppercase tracking-wider mb-2">How to Cancel</h4>
            <p class="text-secondary text-body-md leading-relaxed">
              If you need to cancel your enrollment, please notify us in person, by email, by Certified Mail, or through direct communication with Sky States. The cancellation will be effective on the date the notice is postmarked or received.
            </p>
          </div>
          
          <div class="space-y-4">
            <h4 class="font-label-md text-on-surface font-bold uppercase tracking-wider">Refund Structure</h4>
            
            <div class="border-l-4 border-primary pl-4 py-1">
              <h5 class="font-label-md text-on-surface font-bold">Full Refund</h5>
              <p class="text-secondary text-sm mt-1">
                If we do not accept your application or if you cancel within three business days of signing the agreement and making your initial payment, you will receive a full refund.
                <br/><span class="italic text-xs text-primary font-medium mt-1 block">Satisfactory Guarantee: If you don’t find the course satisfactory or for any other reason, you can request a cancellation. Your access to the course will be canceled, and the student will be charged only for the number of classes they have attended.</span>
              </p>
            </div>

            <div class="border-l-4 border-outline pl-4 py-1">
              <h5 class="font-label-md text-on-surface font-bold">Before Classes Begin</h5>
              <p class="text-secondary text-sm mt-1">
                If you cancel after admission but before your first class, you will receive a refund of all money paid except for the registration fee (capped at $99).
              </p>
            </div>

            <div class="border-l-4 border-outline pl-4 py-1">
              <h5 class="font-label-md text-on-surface font-bold">During Drop/Add Period</h5>
              <p class="text-secondary text-sm mt-1">
                If you withdraw during the first week of classes, you will receive a refund of all tuition and fees except for the registration fee.
              </p>
            </div>

            <div class="border-l-4 border-outline pl-4 py-1">
              <h5 class="font-label-md text-on-surface font-bold">After Drop/Add Period</h5>
              <p class="text-secondary text-sm mt-1">
                No refunds will be issued after the first week of classes.
              </p>
            </div>

            <div class="border-l-4 border-outline pl-4 py-1">
              <h5 class="font-label-md text-on-surface font-bold">Withdrawal from Program</h5>
              <p class="text-secondary text-sm mt-1">
                If you withdraw from the program, the above refund structure will apply.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Short-Term Courses -->
      <div class="bg-surface-container-lowest p-8 md:p-10 rounded-3xl border border-outline-variant/30 ambient-shadow">
        <div class="flex items-center gap-3 mb-6">
          <span class="material-symbols-outlined text-primary text-3xl">schedule</span>
          <h3 class="font-headline-md text-headline-md text-on-surface">Short-Term Courses <span class="text-sm font-normal text-secondary">(Less Than 6 Months)</span></h3>
        </div>
        
        <div class="space-y-6">
          <div class="p-6 rounded-2xl bg-surface-container-low border border-outline-variant/20 space-y-4">
            <h4 class="font-label-md text-primary uppercase tracking-wider">Classroom &amp; Instructor-Led Online Training</h4>
            <div>
              <h5 class="font-label-md text-on-surface font-bold">Sky States Cancellations</h5>
              <p class="text-secondary text-sm mt-1">
                We may need to postpone or cancel an event due to insufficient enrollments, instructor illness, or force majeure events (e.g., natural disasters, political instability). If we cancel an event, you will receive a 100% refund.
              </p>
            </div>
            <div>
              <h5 class="font-label-md text-on-surface font-bold">Delegate Cancellations</h5>
              <ul class="list-disc pl-5 text-sm text-secondary space-y-1 mt-1">
                <li><strong>7 Days or More Before Event:</strong> 90% refund of the total paid fee (10% retained as a processing fee).</li>
                <li><strong>Less Than 7 Days Before Event:</strong> No refunds will be provided.</li>
              </ul>
            </div>
          </div>

          <div class="p-6 rounded-2xl bg-surface-container-low border border-outline-variant/20 space-y-4">
            <h4 class="font-label-md text-primary uppercase tracking-wider">Online Training (Self-Paced / Subscription)</h4>
            <div>
              <h5 class="font-label-md text-on-surface font-bold">Delegate Cancellations</h5>
              <ul class="list-disc pl-5 text-sm text-secondary space-y-1 mt-1">
                <li><strong>Within 48 Hours of Subscription:</strong> 95% refund of the total paid fee (5% retained as an administration fee).</li>
                <li><strong>After 48 Hours of Subscription:</strong> No refunds will be issued.</li>
              </ul>
            </div>
          </div>

          <div class="p-6 rounded-2xl bg-surface-container-low border border-outline-variant/20">
            <h4 class="font-label-md text-primary uppercase tracking-wider mb-2">Third-Party Courses</h4>
            <p class="text-secondary text-sm leading-relaxed">
              For courses provided by third parties (e.g., Microsoft Azure Registration, MS SharePoint), we will refund 50% of the total paid fee if cancelled within 48 hours. No refunds will be issued after 48 hours.
            </p>
          </div>
        </div>
      </div>

      <!-- Legal Protection & General Notes -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-surface-container-lowest p-6 rounded-2xl border border-outline-variant/30 ambient-shadow">
          <span class="material-symbols-outlined text-primary text-3xl mb-3">gavel</span>
