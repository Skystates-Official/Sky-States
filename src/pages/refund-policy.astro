  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Geist:wght@400;600;700;800&display=swap" rel="stylesheet"/>

  <link rel="icon" type="image/png" href="/favicon.png" />
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Pricing &amp; Refund Policy | Sky States</title>
<meta name="description" content="Review the transparent pricing structure, payment options, and the 14-day satisfaction guarantee refund policy at Sky States." />
<link rel="canonical" href="https://skystates.us/refund-policy" />





<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .sky-glass {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }
        .ambient-shadow {
            box-shadow: 0 30px 60px -12px rgba(0, 93, 144, 0.04), 0 18px 36px -18px rgba(0, 0, 0, 0.05);
        }
        .upward-gradient {
            background: linear-gradient(to top, #ffffff 0%, #d3e2ed 100%);
        }
        body {
            background-color: #f9f9f9;
            color: #1a1c1c;
            scroll-behavior: smooth;
        }
