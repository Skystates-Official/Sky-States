<ul class="space-y-4 mb-auto">
<li class="flex items-start gap-3">
<span class="material-symbols-outlined text-primary mt-1" style="font-variation-settings: 'FILL' 1;">check_circle</span>
<span class="font-body-md text-body-md">1-on-1 advisor mapping</span>
</li>
<li class="flex items-start gap-3">
<span class="material-symbols-outlined text-primary mt-1" style="font-variation-settings: 'FILL' 1;">check_circle</span>
<span class="font-body-md text-body-md">Curriculum preview</span>
