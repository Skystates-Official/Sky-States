</div>
</div>
</div>
</section>
<!-- Trust Badges Section -->
<section class="py-20 bg-surface-container-low">
<div class="max-w-[1280px] mx-auto px-margin-desktop">
<div class="flex flex-wrap justify-center gap-12 md:gap-24">
<div class="flex flex-col items-center text-center max-w-[200px]">
<div class="w-16 h-16 rounded-full bg-surface-container-lowest shadow-sm flex items-center justify-center mb-4">
<span class="material-symbols-outlined text-primary text-3xl">id_card</span>
</div>
<span class="font-label-md text-label-md text-on-surface">No SSN Required</span>
<p class="font-body-md text-body-md text-on-surface-variant mt-1">Universal Access</p>
</div>
<div class="flex flex-col items-center text-center max-w-[200px]">
<div class="w-16 h-16 rounded-full bg-surface-container-lowest shadow-sm flex items-center justify-center mb-4">
<span class="material-symbols-outlined text-primary text-3xl">currency_exchange</span>
</div>
<span class="font-label-md text-label-md text-on-surface">100% Refundable</span>
