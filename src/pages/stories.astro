---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
// @ts-ignore
import fs from 'fs';
// @ts-ignore
import path from 'path';

export const prerender = false;

const jsonPath = path.resolve('src/data/stories.json');
let stories = [];
try {
  if (fs.existsSync(jsonPath)) {
    stories = JSON.parse(fs.readFileSync(jsonPath, 'utf8'));
  }
} catch (e) {
  console.error("Error loading stories data:", e);
}

// Fallback if database is empty
if (stories.length === 0) {
  stories = [
    {
      id: "story-david-k",
      name: "David K.",
      role: "AWS Solutions Architect (Sky States Graduate)",
      track: "Cyber Security",
      headline: "Industry Career Acceleration",
      quote: "Sky States provided the exact architectural depth and white-glove negotiation coaching needed...",
      type: "video",
      video_url: "/admin/Sky_States_career_acceleration_program_202606270007.mp4",
      poster: "https://lh3.googleusercontent.com/aida/AP1WRLtWc86eqN7wYWoDWBuVQOUYPxBuWgxwZWg5ICi3A91egN4sl-0pumSqVMRURYXGk46SZN5XTx1tVgpCbubOqzHS_94BTv8FWvKx5M8aBcquV7Kolu3JVHXpwP_RjeuaKm3SKW2T_GV9ILPyEOihn-QEV8Vi6wWN5wQHhbQdUQyAJ-eGef3L79_tT8NzUJUzB4f0F75itv3b3Id1h54jLls6rvp43PbHC-xsLvV9FDXTQ8Jx_n97L3u0q-8",
      slug: "industry-career-acceleration-david-k"
    }
  ];
}
---

<!DOCTYPE html>
<html class="light" lang="en">
<head>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Geist:wght@400;600;700;800&display=swap" rel="stylesheet"/>

  <link rel="icon" type="image/png" href="/favicon.png" />
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  
  <title>Success Stories, Video Testimonials & Podcasts | Sky States</title>
  <meta name="description" content="Watch dynamic video reviews, graduate interviews, podcasts, and detailed career transition logs from Sky States alumni." />
  <link rel="canonical" href="https://skystates.us/stories" />

  <style>
    body {
      background-color: #f8fafc;
      color: #0f172a;
      font-family: 'Outfit', 'Inter', sans-serif;
      -webkit-font-smoothing: antialiased;
    }
    .glass-card {
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(226, 232, 240, 0.8);
    }
    .gradient-bg {
      background: radial-gradient(circle at 50% -20%, #e0f2fe 0%, #f8fafc 60%);
    }
  </style>
</head>
<body class="overflow-x-hidden gradient-bg">
  <Header />

  <main class="pt-28 pb-32">
    <section class="max-w-7xl mx-auto px-4 md:px-8 text-center pt-10 pb-12">
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-slate-900 max-w-4xl mx-auto leading-tight">
        Real Transitions. <span class="bg-gradient-to-r from-sky-600 to-blue-700 bg-clip-text text-transparent">Institutional Precision.</span>
      </h1>
      <p class="text-lg md:text-xl text-slate-600 max-w-2xl mx-auto mt-4 leading-relaxed">
        Explore verified video reviews, podcasts, and testimonials from graduates who transitioned into elite tech roles.
      </p>

      <!-- Institutional Metrics -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto mt-12">
        <div class="p-6 bg-white rounded-2xl border border-slate-100 shadow-sm text-center">
          <div class="text-3xl md:text-4xl font-extrabold text-sky-600">$45,000+</div>
          <div class="text-xs text-slate-500 font-semibold uppercase tracking-wider mt-1">Avg Salary Increase</div>
        </div>
        <div class="p-6 bg-white rounded-2xl border border-slate-100 shadow-sm text-center">
          <div class="text-3xl md:text-4xl font-extrabold text-sky-600">96%</div>
          <div class="text-xs text-slate-500 font-semibold uppercase tracking-wider mt-1">Placement Rate</div>
        </div>
        <div class="p-6 bg-white rounded-2xl border border-slate-100 shadow-sm text-center">
          <div class="text-3xl md:text-4xl font-extrabold text-sky-600">4.9/5.0</div>
          <div class="text-xs text-slate-500 font-semibold uppercase tracking-wider mt-1">Trust Rating</div>
        </div>
        <div class="p-6 bg-white rounded-2xl border border-slate-100 shadow-sm text-center">
          <div class="text-3xl md:text-4xl font-extrabold text-sky-600">250+</div>
          <div class="text-xs text-slate-500 font-semibold uppercase tracking-wider mt-1">Hiring Partners</div>
        </div>
      </div>
    </section>

    <!-- Filters Section -->
    <section class="max-w-7xl mx-auto px-4 md:px-8 mb-8 flex justify-center gap-3">
      <button onclick="filterStories('all')" id="filter-btn-all" class="filter-btn px-5 py-2.5 rounded-full text-xs font-bold uppercase tracking-wider bg-primary text-white shadow-sm transition-all cursor-pointer">
        All Media
      </button>
      <button onclick="filterStories('video')" id="filter-btn-video" class="filter-btn px-5 py-2.5 rounded-full text-xs font-bold uppercase tracking-wider bg-white border border-slate-200 text-slate-600 hover:text-primary transition-all cursor-pointer">
        Video Reviews
      </button>
      <button onclick="filterStories('podcast')" id="filter-btn-podcast" class="filter-btn px-5 py-2.5 rounded-full text-xs font-bold uppercase tracking-wider bg-white border border-slate-200 text-slate-600 hover:text-primary transition-all cursor-pointer">
        Podcasts
      </button>
    </section>

    <!-- Stories & Podcasts Grid -->
    <section class="max-w-7xl mx-auto px-4 md:px-8">
      <div id="stories-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {stories.map(story => {
          // If podcast, use a default poster or helper if empty
          const posterImg = story.poster || 'https://images.unsplash.com/photo-1478737270239-2f02b77fc618?auto=format&fit=crop&w=600&q=80';
          
          return (
            <a 
              href={`/stories/${story.slug}`} 
              class="story-card bg-white rounded-[2rem] overflow-hidden border border-slate-200/60 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col group"
              data-type={story.type}
            >
              <div class="aspect-video relative overflow-hidden bg-slate-900 flex items-center justify-center flex-shrink-0">
                <img 
                  src={posterImg} 
                  alt={story.headline} 
                  class="w-full h-full object-cover opacity-80 group-hover:scale-105 transition-transform duration-500" 
                />
                <!-- Type Badge -->
                <span class={`absolute top-4 left-4 px-3 py-1 rounded-md text-[10px] font-bold uppercase tracking-wider text-white ${story.type === 'podcast' ? 'bg-indigo-600' : 'bg-sky-600'}`}>
                  {story.type === 'podcast' ? 'Podcast' : 'Video Review'}
                </span>
                
                <!-- Center Play Indicator -->
                <div class="absolute inset-0 bg-black/20 flex items-center justify-center group-hover:bg-black/35 transition-colors">
                  <div class="w-14 h-14 rounded-full bg-white text-sky-600 flex items-center justify-center shadow-xl group-hover:scale-110 transition-transform duration-300">
                    <span class="material-symbols-outlined text-2xl" style="font-variation-settings: 'FILL' 1;">play_arrow</span>
                  </div>
                </div>
              </div>
              
              <div class="p-6 flex-1 flex flex-col justify-between">
                <div>
                  <span class="text-[10px] text-sky-600 font-bold uppercase tracking-wider">{story.track}</span>
                  <h3 class="font-extrabold text-lg text-slate-900 mt-1.5 group-hover:text-sky-600 transition-colors leading-snug">
                    {story.headline}
                  </h3>
                  <p class="text-slate-600 text-sm mt-3 line-clamp-3 italic">
                    "{story.quote}"
                  </p>
                </div>
                
                <div class="mt-6 pt-4 border-t border-slate-100 flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-sky-50 flex items-center justify-center text-sky-600">
                    <span class="material-symbols-outlined text-sm">person</span>
                  </div>
                  <div>
                    <h4 class="font-bold text-slate-800 text-xs">{story.name}</h4>
                    <p class="text-[10px] text-slate-500">{story.role}</p>
                  </div>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </section>

  </main>

  <Footer />

  <script is:inline>
    function filterStories(type) {
      // Toggle button states
      const buttons = document.querySelectorAll('.filter-btn');
      buttons.forEach(btn => {
        btn.classList.remove('bg-primary', 'text-white', 'shadow-sm');
        btn.classList.add('bg-white', 'border', 'border-slate-200', 'text-slate-600');
      });

      const activeBtn = document.getElementById(`filter-btn-${type}`);
      if (activeBtn) {
        activeBtn.classList.remove('bg-white', 'border', 'border-slate-200', 'text-slate-600');
        activeBtn.classList.add('bg-primary', 'text-white', 'shadow-sm');
      }

      // Filter Cards
      const cards = document.querySelectorAll('.story-card');
      cards.forEach(card => {
        const cardType = card.getAttribute('data-type');
        if (type === 'all' || cardType === type) {
          card.style.display = 'flex';
        } else {
          card.style.display = 'none';
        }
      });
    }
  </script>
</body>
</html>