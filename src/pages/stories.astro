---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import stories from "../data/stories.json";

export const prerender = true;
---

<!doctype html>
<html class="light" lang="en">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Geist:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />

    <title>Success Stories & Alumni Transitions | Sky States</title>
    <meta
      name="description"
      content="Read the inspiring stories of Sky States graduates who successfully transitioned from non-tech fields into DevOps, Cyber Security, and Data Science."
    />
    <link rel="canonical" href="https://skystates.us/stories" />

    <style>
      body {
        background-color: #f8fafc;
        color: #0f172a;
        font-family: "Outfit", "Inter", sans-serif;
        -webkit-font-smoothing: antialiased;
      }
      .gradient-bg {
        background: radial-gradient(circle at 50% -20%, #e0f2fe 0%, #f8fafc 60%);
      }
      .story-card {
        transition:
          opacity 0.3s ease,
          transform 0.3s ease,
          box-shadow 0.3s ease,
          border-color 0.3s ease;
      }
    </style>
  </head>
  <body class="overflow-x-hidden gradient-bg">
    <Header />

    <main class="pt-32 pb-24">
      <!-- Header Section -->
      <section class="max-w-7xl mx-auto px-4 md:px-margin-desktop text-center pt-10 pb-16">
        <span
          class="inline-block bg-sky-50 border border-sky-100 text-sky-700 px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-4"
        >
          SkyStates Success Stories
        </span>
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-[#0f3473] max-w-4xl mx-auto leading-tight">
          Real Transitions. <span class="text-sky-600">Real Careers.</span>
        </h1>
        <p class="text-slate-500 text-base sm:text-lg max-w-2xl mx-auto mt-4 leading-relaxed">
          Read the detailed logs of actual professionals who broke into elite technology roles through our structured
          programs and live mentorship.
        </p>
      </section>

      <!-- Filters Section -->
      <section class="max-w-7xl mx-auto px-4 md:px-margin-desktop mb-12 flex flex-wrap justify-center gap-3">
        <button
          onclick="filterStories('all')"
          id="filter-btn-all"
          class="filter-btn px-5 py-2.5 rounded-full text-xs font-bold uppercase tracking-wider bg-[#1b4a9a] text-white shadow-sm transition-all cursor-pointer border border-[#1b4a9a]"
        >
          All Stories
        </button>
        <button
          onclick="filterStories('Data Science & AI')"
          id="filter-btn-ds"
          class="filter-btn px-5 py-2.5 rounded-full text-xs font-bold uppercase tracking-wider bg-white border border-slate-200 text-slate-600 hover:text-[#1b4a9a] transition-all cursor-pointer"
        >
          Data Science & AI
        </button>
        <button
          onclick="filterStories('Cyber Security')"
          id="filter-btn-cs"
          class="filter-btn px-5 py-2.5 rounded-full text-xs font-bold uppercase tracking-wider bg-white border border-slate-200 text-slate-600 hover:text-[#1b4a9a] transition-all cursor-pointer"
        >
          Cyber Security
        </button>
        <button
          onclick="filterStories('DevOps')"
          id="filter-btn-devops"
          class="filter-btn px-5 py-2.5 rounded-full text-xs font-bold uppercase tracking-wider bg-white border border-slate-200 text-slate-600 hover:text-[#1b4a9a] transition-all cursor-pointer"
        >
          DevOps & Cloud
        </button>
      </section>

      <!-- Stories Grid -->
      <section class="max-w-7xl mx-auto px-4 md:px-margin-desktop">
        <div id="stories-grid" class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
          {
            stories.map((story) => {
              const initials = story.name
                .split(" ")
                .map((n) => n[0])
                .join("");

              let trackClass = "";
              let icon = "";
              if (story.track === "Data Science & AI") {
                trackClass = "bg-violet-50 text-violet-700 border-violet-100/80";
                icon = "database";
              } else if (story.track === "Cyber Security") {
                trackClass = "bg-indigo-50 text-indigo-700 border-indigo-100/80";
                icon = "shield";
              } else {
                trackClass = "bg-sky-50 text-sky-700 border-sky-100/80";
                icon = "terminal";
              }

              return (
                <div
                  class="story-card bg-white rounded-3xl p-8 sm:p-10 border border-slate-200/60 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between"
                  data-track={story.track}
                >
                  <div>
                    <!-- Card Header -->
                    <div class="flex items-center justify-between mb-4">
                      <span
                        class={`inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider border ${trackClass}`}
                      >
                        <span class="material-symbols-outlined text-[12px]">{icon}</span>
                        {story.track === "DevOps" ? "DevOps & Cloud" : story.track}
                      </span>
                      <span class="material-symbols-outlined text-slate-200 text-3xl">format_quote</span>
                    </div>

                    <h3 class="text-xl font-bold text-[#0f3473] tracking-tight leading-snug">
                      {story.headline}
                    </h3>

                    <p class="text-slate-650 text-sm sm:text-base leading-relaxed mt-4 text-justify">
                      {story.paragraph1}
                    </p>

                    <p class="text-slate-500 text-sm leading-relaxed mt-4 text-justify border-l-2 border-sky-100 pl-4 italic">
                      {story.paragraph2}
                    </p>
                  </div>

                  <!-- Card Footer -->
                  <div class="mt-8 pt-6 border-t border-slate-100 flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-sky-50 border border-sky-100 flex items-center justify-center text-sky-700 font-bold text-sm">
                      {initials}
                    </div>
                    <div>
                      <h4 class="font-bold text-slate-800 text-sm">{story.name}</h4>
                      <p class="text-xs text-slate-500 font-medium">Sky States Alumni</p>
                    </div>
                  </div>
                </div>
              );
            })
          }
        </div>
      </section>
    </main>

    <Footer />

    <script is:inline>
      function filterStories(track) {
        // Toggle button states
        const buttons = document.querySelectorAll(".filter-btn");
        buttons.forEach((btn) => {
          btn.classList.remove("bg-[#1b4a9a]", "text-white", "shadow-sm", "border-[#1b4a9a]");
          btn.classList.add("bg-white", "border", "border-slate-200", "text-slate-600", "hover:text-[#1b4a9a]");
        });

        // Update active button state
        let activeBtnId = "filter-btn-all";
        if (track === "Data Science & AI") activeBtnId = "filter-btn-ds";
        else if (track === "Cyber Security") activeBtnId = "filter-btn-cs";
        else if (track === "DevOps") activeBtnId = "filter-btn-devops";

        const activeBtn = document.getElementById(activeBtnId);
        if (activeBtn) {
          activeBtn.classList.remove(
            "bg-white",
            "border",
            "border-slate-200",
            "text-slate-600",
            "hover:text-[#1b4a9a]"
          );
          activeBtn.classList.add("bg-[#1b4a9a]", "text-white", "shadow-sm", "border-[#1b4a9a]");
        }

        // Filter Cards
        const cards = document.querySelectorAll(".story-card");
        cards.forEach((card) => {
          const cardTrack = card.getAttribute("data-track");
          if (track === "all" || cardTrack === track) {
            card.style.display = "flex";
            setTimeout(() => {
              card.style.opacity = "1";
              card.style.transform = "translateY(0)";
            }, 50);
          } else {
            card.style.opacity = "0";
            card.style.transform = "translateY(8px)";
            setTimeout(() => {
              card.style.display = "none";
            }, 300);
          }
        });
      }
    </script>
  </body>
</html>