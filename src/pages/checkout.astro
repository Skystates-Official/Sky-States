---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>

<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Secure Checkout | Sky States</title>
<meta name="description" content="Securely complete your enrollment in the Sky States Career Acceleration Program. Select your track and apply promotional vouchers." />
<link rel="canonical" href="https://skystates.us/checkout" />

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .upward-gradient {
            background: linear-gradient(to top, #ffffff, #d3e2ed);
        }
        .ambient-shadow {
            box-shadow: 0 10px 30px -5px rgba(15, 29, 37, 0.04);
        }
        .form-glow:focus-within {
            box-shadow: 0 0 0 4px rgba(0, 93, 144, 0.1);
        }
    </style>

</head>
<body class="bg-background text-on-background font-body-md min-h-screen">
<!-- TopAppBar -->
<Header />
<main class="max-w-[1280px] mx-auto px-margin-desktop py-12">
<!-- Editorial Header Section -->
<div class="mb-section-gap rounded-xl p-12 upward-gradient flex flex-col gap-2">
<h1 class="text-headline-xl text-primary font-bold">Finalize Your Access</h1>
<p class="text-on-surface-variant max-w-2xl text-body-lg">Begin your journey with Sky States. Secure your introductory session and join a global network of elite scholars and executives.</p>
</div>
<div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter items-start">
<!-- Left Column: Order Summary & Info -->
<div class="lg:col-span-5 flex flex-col gap-8">
<!-- Order Summary Card -->
<section class="bg-surface-container-lowest rounded-xl p-8 ambient-shadow flex flex-col gap-6">
  <h2 class="font-headline-md text-headline-md text-on-surface">Order Summary</h2>
  
  <!-- Dynamic Course Title -->
  <div class="pb-4 border-b border-secondary-container">
    <span class="text-xs font-bold uppercase tracking-wider text-primary">Selected Program</span>
    <h3 class="font-headline-md text-xl text-on-surface mt-1" id="display-course-name">Intro Session</h3>
  </div>

  <!-- Dynamic Tier Selector (Interactive Cards) -->
  <div>
    <span class="block text-xs font-bold uppercase tracking-wider text-secondary mb-3">Select Program Tier</span>
    <div class="grid grid-cols-2 gap-3">
      <!-- Scholar Tier Card -->
      <button type="button" id="btn-tier-scholar" class="flex flex-col items-start p-4 rounded-xl border-2 transition-all duration-300 text-left w-full group relative overflow-hidden" onclick="selectTier('normal')">
        <span class="text-xs font-bold uppercase tracking-wider text-primary">Scholar Tier</span>
        <span class="font-headline-md text-xl font-bold mt-1 text-primary" id="btn-scholar-price">$99</span>
        <span class="text-[10px] text-on-surface-variant mt-1">Live weekend instruction</span>
        <div class="absolute top-1 right-1 opacity-0 group-[.active]:opacity-100 transition-opacity">
          <span class="material-symbols-outlined text-primary text-sm">check_circle</span>
        </div>
      </button>

      <!-- Elite Tier Card -->
      <button type="button" id="btn-tier-elite" class="flex flex-col items-start p-4 rounded-xl border-2 transition-all duration-300 text-left w-full group relative overflow-hidden" onclick="selectTier('1on1')">
        <span class="text-xs font-bold uppercase tracking-wider text-secondary">Elite Tier</span>
        <span class="font-headline-md text-xl font-bold mt-1 text-secondary" id="btn-elite-price">$499</span>
        <span class="text-[10px] text-on-surface-variant mt-1">1-on-1 FAANG Mentor</span>
        <div class="absolute top-1 right-1 opacity-0 group-[.active]:opacity-100 transition-opacity">
          <span class="material-symbols-outlined text-primary text-sm">check_circle</span>
        </div>
      </button>
    </div>
  </div>

  <div class="flex justify-between items-center pt-4 border-t border-secondary-container">
    <div>
      <p class="font-label-md text-label-md text-on-surface" id="display-tier-label">Scholar Tier Program</p>
      <p class="text-xs text-on-surface-variant" id="display-tier-description">Weekend live labs & placement prep</p>
    </div>
    <p class="font-headline-md text-headline-md text-primary" id="display-price-value">$99</p>
  </div>

  <!-- Promo Code Section -->
  <div class="pt-4 border-t border-secondary-container flex flex-col gap-2">
    <label class="text-[10px] font-bold uppercase tracking-wider text-secondary">Apply Promotion Code</label>
    <div class="flex gap-2">
      <input type="text" id="coupon-code-input" placeholder="e.g. SKY150" class="h-10 px-3 border border-outline-variant/30 rounded-lg outline-none focus:border-primary text-sm flex-grow" />
      <button type="button" onclick="applyPromoCode()" class="px-4 bg-primary text-white rounded-lg text-xs uppercase font-bold tracking-wider hover:bg-opacity-90 transition-all cursor-pointer">Apply</button>
    </div>
    <div id="coupon-feedback" class="text-xs font-semibold hidden"></div>
  </div>

  <div class="mt-2 flex justify-between items-center font-bold text-on-surface border-t border-outline-variant/20 pt-4">
    <p>Total Investment</p>
    <p id="display-total-value">$99.00</p>
  </div>
</section>
<!-- Privacy Commitment -->
<section class="bg-secondary-container rounded-xl p-6 flex gap-4 items-start">
<div class="bg-surface-container-lowest p-2 rounded-lg">
<span class="material-symbols-outlined text-primary">shield_person</span>
</div>
<div>
<h3 class="font-label-md text-label-md text-on-secondary-container">No-SSN Privacy Commitment</h3>
<p class="text-sm text-on-surface-variant mt-1">We prioritize your anonymity. No Social Security Number or sensitive identification is required for institutional registry.</p>
</div>
</section>
<!-- What Happens Next -->
<section class="flex flex-col gap-6 p-2">
<h2 class="font-headline-md text-headline-md text-on-surface">What Happens Next</h2>
<ul class="space-y-6">
<li class="flex gap-4">
<span class="h-8 w-8 rounded-full bg-primary text-white flex items-center justify-center shrink-0 font-bold">1</span>
<div>
<p class="font-label-md text-label-md">Instant Portal Access</p>
<p class="text-sm text-on-surface-variant">Your login credentials will be delivered to your inbox immediately after payment.</p>
</div>
</li>
<li class="flex gap-4">
<span class="h-8 w-8 rounded-full bg-primary text-white flex items-center justify-center shrink-0 font-bold">2</span>
<div>
<p class="font-label-md text-label-md">Advisor Assignment</p>
<p class="text-sm text-on-surface-variant">A dedicated academic advisor will be assigned to your profile within 4 business hours.</p>
</div>
</li>
<li class="flex gap-4">
<span class="h-8 w-8 rounded-full bg-primary text-white flex items-center justify-center shrink-0 font-bold">3</span>
<div>
<p class="font-label-md text-label-md">Scheduling Link</p>
<p class="text-sm text-on-surface-variant">Receive a priority calendar link to book your session at your earliest convenience.</p>
</div>
</li>
</ul>
</section>
</div>
<!-- Right Column: Payment Form -->
<div class="lg:col-span-7 sticky top-24">
<div class="bg-surface-container-lowest rounded-xl p-8 md:p-12 ambient-shadow">
<!-- Tabs -->
<div class="flex gap-4 mb-10 border-b border-surface-container-high">
<button class="pb-4 px-2 border-b-2 border-primary text-primary font-label-md text-label-md active:scale-95 transition-transform" onclick="switchTab('cc')">Credit Card</button>
<button class="pb-4 px-2 border-b-2 border-transparent text-on-surface-variant hover:text-primary transition-colors font-label-md text-label-md active:scale-95 transition-transform" onclick="switchTab('emi')">EMI Options</button>
</div>
<!-- Payment Form Content -->
<form class="flex flex-col gap-6" id="payment-form" onsubmit="processPayment(event)">
<div class="flex flex-col gap-2">
<label class="font-label-sm text-label-sm text-on-secondary-fixed-variant" for="card_number">Card Number</label>
<div class="relative group">
<input class="w-full h-12 px-4 rounded-lg border-2 border-secondary-fixed-dim focus:border-primary outline-none transition-all duration-200 form-glow" id="card_number" placeholder="0000 0000 0000 0000" type="text"/>
<div class="absolute right-3 top-1/2 -translate-y-1/2 flex gap-2">
<span class="material-symbols-outlined text-on-surface-variant opacity-40">credit_card</span>
</div>
</div>
</div>
<div class="grid grid-cols-2 gap-gutter">
<div class="flex flex-col gap-2">
<label class="font-label-sm text-label-sm text-on-secondary-fixed-variant" for="expiry">Expiry Date</label>
<input class="w-full h-12 px-4 rounded-lg border-2 border-secondary-fixed-dim focus:border-primary outline-none transition-all duration-200 form-glow" id="expiry" placeholder="MM / YY" type="text"/>
</div>
<div class="flex flex-col gap-2">
<label class="font-label-sm text-label-sm text-on-secondary-fixed-variant" for="cvv">CVV</label>
<input class="w-full h-12 px-4 rounded-lg border-2 border-secondary-fixed-dim focus:border-primary outline-none transition-all duration-200 form-glow" id="cvv" placeholder="•••" type="password"/>
</div>
</div>
<div class="flex flex-col gap-2">
<label class="font-label-sm text-label-sm text-on-secondary-fixed-variant" for="name">Cardholder Name</label>
<input class="w-full h-12 px-4 rounded-lg border-2 border-secondary-fixed-dim focus:border-primary outline-none transition-all duration-200 form-glow" id="name" placeholder="Johnathan Doe" type="text"/>
</div>
<button class="w-full h-14 mt-4 bg-primary text-white rounded-full font-label-md text-label-md upward-gradient text-white border-none shadow-lg hover:shadow-xl active:scale-95 transition-all flex items-center justify-center gap-2 group" type="submit">
<span>Complete Investment</span>
<span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
</button>
<!-- Trust Badges -->
<div class="mt-8 flex flex-wrap items-center justify-center gap-6 opacity-60">
<div class="flex items-center gap-1">
<span class="material-symbols-outlined text-sm">verified_user</span>
<span class="text-xs uppercase tracking-widest font-bold">SSL SECURE</span>
</div>
<div class="flex items-center gap-1">
<span class="material-symbols-outlined text-sm">lock</span>
<span class="text-xs uppercase tracking-widest font-bold">PCI COMPLIANT</span>
</div>
<div class="flex items-center gap-1">
<span class="material-symbols-outlined text-sm">security</span>
<span class="text-xs uppercase tracking-widest font-bold">256-BIT ENCRYPTION</span>
</div>
</div>
</form>
</div>
</div>
</div>
</main>
<!-- Footer -->
<Footer />
    <script is:inline>
        window.switchTab = function(tab) {
            const buttons = document.querySelectorAll('button[onclick^="switchTab"]');
            buttons.forEach(btn => {
                if (btn.getAttribute('onclick').includes(tab)) {
                    btn.classList.add('border-primary', 'text-primary');
                    btn.classList.remove('border-transparent', 'text-on-surface-variant');
                } else {
                    btn.classList.remove('border-primary', 'text-primary');
                    btn.classList.add('border-transparent', 'text-on-surface-variant');
                }
            });
        }

        window.checkoutMode = 'registration';
        window.activeCoupon = null;
        window.selectedTier = 'normal';

        window.updatePricingDisplay = function() {
            const label = document.getElementById('display-tier-label');
            const desc = document.getElementById('display-tier-description');
            const priceEl = document.getElementById('display-price-value');
            const totalEl = document.getElementById('display-total-value');
            const feedbackEl = document.getElementById('coupon-feedback');
            const isFullPayment = window.checkoutMode === 'full';

            let basePrice = 99;
            if (window.selectedTier === 'normal') {
                basePrice = isFullPayment ? 2999 : 99;
                label.textContent = 'Scholar Tier Program';
                desc.textContent = 'Weekend live labs & placement prep';
            } else {
                basePrice = isFullPayment ? 6500 : 499;
                label.textContent = 'Elite Tier (1-on-1)';
                desc.textContent = 'Personal FAANG mentor & 1-on-1 guidance';
            }

            priceEl.textContent = '$' + basePrice.toLocaleString();

            let discount = 0;
            if (window.activeCoupon) {
                const match = window.activeCoupon.code.match(/^SKY(\d+)$/i);
                if (match) {
                    const couponValue = parseInt(match[1], 10);
                    discount = Math.min(couponValue, basePrice);
                }
            }

            const finalTotal = Math.max(0, basePrice - discount);
            totalEl.textContent = '$' + finalTotal.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

            if (feedbackEl) {
                if (window.activeCoupon) {
                    feedbackEl.textContent = `Coupon ${window.activeCoupon.code} applied: -$${discount.toLocaleString()}`;
                    feedbackEl.className = "text-xs font-semibold text-green-600 block";
                } else {
                    feedbackEl.className = "text-xs font-semibold hidden";
                }
            }
        }

        window.selectTier = function(tier) {
            window.selectedTier = tier;
            const btnScholar = document.getElementById('btn-tier-scholar');
            const btnElite = document.getElementById('btn-tier-elite');
            const displayCourse = document.getElementById('display-course-name');

            let courseText = displayCourse.textContent || "";

            if (tier === 'normal') {
                btnScholar.classList.add('border-primary', 'bg-primary/5', 'active');
                btnScholar.classList.remove('border-outline-variant/30', 'opacity-70');
                btnElite.classList.remove('border-primary', 'bg-primary/5', 'active');
                btnElite.classList.add('border-outline-variant/30', 'opacity-70');

                // Strip "Short Term Program" if present
                if (courseText.endsWith(' Short Term Program')) {
                    displayCourse.textContent = courseText.replace(' Short Term Program', '');
                }
            } else {
                btnElite.classList.add('border-primary', 'bg-primary/5', 'active');
                btnElite.classList.remove('border-outline-variant/30', 'opacity-70');
                btnScholar.classList.remove('border-primary', 'bg-primary/5', 'active');
                btnScholar.classList.add('border-outline-variant/30', 'opacity-70');

                // Append "Short Term Program" if not present and it's one of the main courses
                if (courseText && !courseText.endsWith(' Short Term Program') && courseText !== 'Intro Session') {
                    displayCourse.textContent = courseText + ' Short Term Program';
                }
            }

            window.updatePricingDisplay();
        }

        window.applyPromoCode = async function() {
            const input = document.getElementById('coupon-code-input');
            const feedback = document.getElementById('coupon-feedback');
            if (!input || !feedback) return;

            const code = input.value.trim();
            if (!code) {
                feedback.textContent = 'Please enter a coupon code.';
                feedback.className = 'text-xs font-semibold text-red-500 block';
                return;
            }

            const isFullPayment = window.checkoutMode === 'full';
            const basePrice = window.selectedTier === 'normal' 
                ? (isFullPayment ? 2999 : 99) 
                : (isFullPayment ? 6500 : 499);

            try {
                feedback.textContent = 'Validating coupon...';
                feedback.className = 'text-xs font-semibold text-gray-500 block';

                const response = await fetch('/api/validate-coupon', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ code, basePrice })
                });

                const data = await response.json();

                if (response.ok && data.valid) {
                    window.activeCoupon = { code: data.code };
                    window.updatePricingDisplay();
                } else {
                    window.activeCoupon = null;
                    window.updatePricingDisplay();
                    feedback.textContent = data.error || 'Invalid coupon code.';
                    feedback.className = 'text-xs font-semibold text-red-500 block';
                }
            } catch (err) {
                window.activeCoupon = null;
                window.updatePricingDisplay();
                feedback.textContent = 'Connection error. Please try again.';
                feedback.className = 'text-xs font-semibold text-red-500 block';
            }
        }

        // Initialize from URL search parameters
        function initializeCheckout() {
            const params = new URLSearchParams(window.location.search);
            const courseName = params.get('course');
            const type = params.get('type');
            const mode = params.get('mode');

            if (mode === 'full') {
                window.checkoutMode = 'full';
                const sPrice = document.getElementById('btn-scholar-price');
                const ePrice = document.getElementById('btn-elite-price');
                if (sPrice) sPrice.textContent = '$2,999';
                if (ePrice) ePrice.textContent = '$6,500';
            } else {
                window.checkoutMode = 'registration';
                const sPrice = document.getElementById('btn-scholar-price');
                const ePrice = document.getElementById('btn-elite-price');
                if (sPrice) sPrice.textContent = '$99';
                if (ePrice) ePrice.textContent = '$499';
            }

            if (courseName) {
                document.getElementById('display-course-name').textContent = courseName;
            }

            if (type === '1on1' || (courseName && courseName.toLowerCase().includes('short term'))) {
                window.selectTier('1on1');
            } else {
                window.selectTier('normal');
            }
        }

        window.processPayment = function(e) {
            e.preventDefault();
            
            const cardNumber = document.getElementById('card_number').value.trim();
            const expiry = document.getElementById('expiry').value.trim();
            const cvv = document.getElementById('cvv').value.trim();
            const name = document.getElementById('name').value.trim();

            if (!cardNumber || !expiry || !cvv || !name) {
                alert('Please fill out all card payment details.');
                return;
            }

            const totalVal = document.getElementById('display-total-value').textContent;
            const submitBtn = document.querySelector('#payment-form button[type="submit"]');
            const originalBtnContent = submitBtn.innerHTML;

            submitBtn.disabled = true;
            submitBtn.innerHTML = `<span>Processing Securely...</span>`;

            setTimeout(() => {
                alert(`Success! Payment of ${totalVal} has been processed.\nYour transaction ID is TXN-${Math.floor(100000 + Math.random() * 900000)}.`);
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalBtnContent;
                window.location.href = '/';
            }, 1500);
        }

        // Run on load
        initializeCheckout();

        // Card Input Masking & Validations
        const cardNumberInput = document.getElementById('card_number');
        const expiryInput = document.getElementById('expiry');
        const cvvInput = document.getElementById('cvv');
        const nameInput = document.getElementById('name');

        cardNumberInput?.addEventListener('input', (e) => {
            let value = e.target.value.replace(/\D/g, '');
            value = value.substring(0, 16);
            const formatted = value.match(/.{1,4}/g)?.join(' ') || value;
            e.target.value = formatted;
        });

        expiryInput?.addEventListener('input', (e) => {
            let value = e.target.value.replace(/\D/g, '');
            value = value.substring(0, 4);
            if (value.length > 2) {
                e.target.value = value.substring(0, 2) + ' / ' + value.substring(2);
            } else {
                e.target.value = value;
            }
        });

        cvvInput?.addEventListener('input', (e) => {
            let value = e.target.value.replace(/\D/g, '');
            e.target.value = value.substring(0, 4);
        });

        nameInput?.addEventListener('input', (e) => {
            e.target.value = e.target.value.replace(/[^a-zA-Z\s]/g, '');
        });

        // Lightweight atmospheric effect: Move a soft glow based on mouse
        document.addEventListener('mousemove', (e) => {
            const x = e.clientX / window.innerWidth;
            // Subtle shift in gradient for depth
            const gradient = document.querySelector('.upward-gradient');
            if (gradient) {
                gradient.style.background = `linear-gradient(${180 + (x * 10)}deg, #ffffff 0%, #d3e2ed 100%)`;
            }
        });
    </script>
</body></html>