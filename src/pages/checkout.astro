---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { PRICING } from "../lib/pricing.js";

export const prerender = false;

const pricingConfig = {
    registration: PRICING.registration,
    full: PRICING.full,
    offline: PRICING.offline,
};
---

<!doctype html>
<html class="light" lang="en">
    <head>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
            rel="stylesheet"
        />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Geist:wght@400;600;700;800&display=swap"
            rel="stylesheet"
        />

        <link rel="icon" type="image/png" href="/favicon.png" />
        <meta charset="utf-8" />
        <meta content="width=device-width, initial-scale=1.0" name="viewport" />
        <title>Secure Checkout | Sky States</title>
        <meta
            name="description"
            content="Securely complete your enrollment in the Sky States Career Acceleration Program. Select your track and apply promotional vouchers."
        />
        <link rel="canonical" href="https://skystates.us/checkout" />

        <style>
            .material-symbols-outlined {
                font-variation-settings:
                    "FILL" 0,
                    "wght" 400,
                    "GRAD" 0,
                    "opsz" 24;
            }
            .upward-gradient {
                background: linear-gradient(to top, #ffffff, #d3e2ed);
            }
            .ambient-shadow {
                box-shadow: 0 10px 30px -5px rgba(15, 29, 37, 0.04);
            }
            .form-glow:focus-within {
                box-shadow: 0 0 0 4px rgba(0, 93, 144, 0.1);
            }
        </style>
    </head>
    <body class="bg-slate-50/50 text-slate-800 font-sans min-h-screen">
        <!-- TopAppBar -->
        <Header />
        <main
            class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8 pt-24 sm:pt-28 lg:pt-32 pb-12 sm:pb-16"
        >
            <!-- Editorial Header Section -->
            <div
                class="mb-8 sm:mb-12 rounded-2xl sm:rounded-3xl p-6 sm:p-8 lg:p-12 bg-gradient-to-br from-sky-50 to-blue-100/50 border border-sky-100 flex flex-col gap-2 relative overflow-hidden"
            >
                <div
                    class="absolute -right-10 -top-10 w-40 h-40 bg-sky-300/10 blur-3xl rounded-full"
                >
                </div>
                <h1
                    class="text-3xl sm:text-4xl font-extrabold text-slate-900 tracking-tight"
                >
                    Finalize Your Access
                </h1>
                <p
                    class="text-slate-650 max-w-2xl text-sm sm:text-base leading-relaxed"
                >
                    Begin your journey with Sky States. Secure your introductory
                    session and join a global network of elite scholars and
                    executives.
                </p>
            </div>

            <div
                class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8 items-start"
            >
                <!-- Left Column: Order Summary & Info -->
                <div
                    class="lg:col-span-5 flex flex-col gap-6 lg:gap-8 order-2 lg:order-1"
                >
                    <!-- Order Summary Card -->
                    <section
                        class="bg-white rounded-3xl p-6 sm:p-8 border border-slate-200/80 shadow-sm flex flex-col gap-6"
                    >
                        <h2 class="text-xl font-bold text-slate-850">
                            Order Summary
                        </h2>

                        <!-- Dynamic Course Title -->
                        <div class="pb-4 border-b border-slate-100">
                            <span
                                class="text-[10px] font-bold uppercase tracking-wider text-sky-700"
                                >Selected Program</span
                            >
                            <h3
                                class="text-xl font-bold text-slate-900 mt-1"
                                id="display-course-name"
                            >
                                Intro Session
                            </h3>
                        </div>

                        <!-- Dynamic Tier Selector (Interactive Cards) -->
                        <div>
                            <span
                                id="tier-selector-label"
                                class="block text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-3"
                                >Select Program Tier</span
                            >
                            <div
                                class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4"
                                id="tier-buttons-grid"
                            >
                                <!-- Scholar Tier Card -->
                                <button
                                    type="button"
                                    id="btn-tier-scholar"
                                    class="flex flex-col items-start p-4 rounded-2xl border transition-all duration-300 text-left w-full group relative overflow-hidden active border-sky-600 bg-sky-50/20"
                                    onclick="selectTier('normal')"
                                >
                                    <span
                                        class="text-[10px] font-bold uppercase tracking-wider text-sky-700"
                                        >batch classes</span
                                    >
                                    <span
                                        class="text-lg font-black mt-1 text-slate-850"
                                        id="btn-scholar-price">$99</span
                                    >
                                    <span
                                        class="text-[10px] text-slate-400 font-semibold mt-1"
                                        >Live weekend instruction</span
                                    >
                                    <div
                                        class="absolute top-2 right-2 opacity-0 group-[.active]:opacity-100 transition-opacity"
                                    >
                                        <span
                                            class="material-symbols-outlined text-sky-600 text-sm font-bold"
                                            >check_circle</span
                                        >
                                    </div>
                                </button>

                                <!-- Elite Tier Card -->
                                <button
                                    type="button"
                                    id="btn-tier-elite"
                                    class="flex flex-col items-start p-4 rounded-2xl border transition-all duration-300 text-left w-full group relative overflow-hidden border-slate-200/80 opacity-70"
                                    onclick="selectTier('1on1')"
                                >
                                    <span
                                        class="text-[10px] font-bold uppercase tracking-wider text-slate-400"
                                        >personalised classes</span
                                    >
                                    <span
                                        class="text-lg font-black mt-1 text-slate-850"
                                        id="btn-elite-price">$499</span
                                    >
                                    <span
                                        class="text-[10px] text-slate-400 font-semibold mt-1"
                                        >1-on-1 Industry Mentor</span
                                    >
                                    <div
                                        class="absolute top-2 right-2 opacity-0 group-[.active]:opacity-100 transition-opacity"
                                    >
                                        <span
                                            class="material-symbols-outlined text-sky-600 text-sm font-bold"
                                            >check_circle</span
                                        >
                                    </div>
                                </button>
                            </div>
                        </div>

                        <!-- <div
                            class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-1 pt-4 border-t border-slate-100"
                        >
                            <div class="min-w-0">
                                <p
                                    class="font-bold text-slate-850 text-sm"
                                    id="display-tier-label"
                                >
                                    batch classes Program
                                </p>
                                <p
                                    class="text-xs text-slate-400 mt-0.5"
                                    id="display-tier-description"
                                >
                                    Weekend live labs & placement prep
                                </p>
                            </div>
                            <p
                                class="text-xl font-black text-sky-700"
                                id="display-price-value"
                            >
                                $99
                            </p>
                        </div> -->

                        <!-- Promo Code Section (full program only) -->
                        <div
                            id="coupon-section"
                            class="pt-4 border-t border-slate-100 flex flex-col gap-2 hidden"
                        >
                            <label
                                class="text-[10px] font-bold uppercase tracking-wider text-slate-400"
                                >Promotional Code</label
                            >
                            <p class="text-[11px] text-slate-500">
                                Available for full program enrollment only.
                            </p>
                            <div class="flex flex-col sm:flex-row gap-2">
                                <input
                                    type="text"
                                    id="coupon-code-input"
                                    placeholder="e.g. WELCOME150"
                                    class="h-12 px-3.5 border border-slate-200/80 rounded-xl outline-none focus:border-sky-650 focus:ring-2 focus:ring-sky-600/10 text-sm flex-grow transition-all"
                                />
                                <button
                                    type="button"
                                    onclick="applyPromoCode()"
                                    class="h-12 px-5 bg-slate-900 text-white rounded-xl text-xs uppercase font-bold tracking-wider hover:bg-slate-850 transition-all cursor-pointer"
                                    >Apply</button
                                >
                            </div>
                            <div
                                id="coupon-feedback"
                                class="text-xs font-semibold hidden"
                            >
                            </div>
                        </div>
                        <p
                            id="coupon-registration-note"
                            class="pt-4 border-t border-slate-100 text-[11px] text-slate-500 leading-relaxed"
                        >
                            Promotional codes are not available for intro
                            sessions. Enroll in the
                            <a
                                href="/checkout?mode=full"
                                class="text-sky-700 font-semibold hover:underline"
                                >full program</a
                            >
                            to use a coupon.
                        </p>

                        <div
                            class="mt-2 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-1 font-bold text-slate-800 border-t border-slate-100 pt-4"
                        >
                            <p class="text-sm">Total</p>
                            <p
                                class="text-lg font-black text-slate-900"
                                id="display-total-value"
                            >
                                $99.00
                            </p>
                        </div>
                    </section>

                    <!-- Privacy Commitment -->
                    <!-- <section
                        class="bg-sky-50/50 border border-sky-100/50 rounded-3xl p-6 flex gap-4 items-start"
                    >
                        <div
                            class="bg-white p-2 rounded-xl border border-sky-100/60 shadow-sm shrink-0"
                        >
                            <span
                                class="material-symbols-outlined text-sky-600 text-xl"
                                >shield_person</span
                            >
                        </div>
                        <div>
                            <h3 class="font-bold text-sm text-slate-850">
                                No-SSN Privacy Commitment
                            </h3>
                            <p
                                class="text-xs text-slate-500 mt-1 leading-relaxed"
                            >
                                We prioritize your anonymity. No Social Security
                                Number or sensitive identification is required
                                for institutional registry.
                            </p>
                        </div>
                    </section> -->

                    <!-- What Happens Next -->
                    <section class="flex flex-col gap-6 px-1">
                        <h2 class="text-lg font-bold text-slate-850">
                            What Happens Next
                        </h2>
                        <ul class="space-y-4">
                            <li class="flex gap-4 items-start">
                                <span
                                    class="h-7 w-7 rounded-full bg-sky-50 border border-sky-100 text-sky-700 flex items-center justify-center shrink-0 font-bold text-xs"
                                    >1</span
                                >
                                <div>
                                    <p
                                        class="font-bold text-xs sm:text-sm text-slate-800"
                                    >
                                        Instant Portal Access
                                    </p>
                                    <p
                                        class="text-xs text-slate-500 mt-0.5 leading-relaxed"
                                    >
                                        Your login credentials will be delivered
                                        to your inbox immediately after payment.
                                    </p>
                                </div>
                            </li>
                            <li class="flex gap-4 items-start">
                                <span
                                    class="h-7 w-7 rounded-full bg-sky-50 border border-sky-100 text-sky-700 flex items-center justify-center shrink-0 font-bold text-xs"
                                    >2</span
                                >
                                <div>
                                    <p
                                        class="font-bold text-xs sm:text-sm text-slate-800"
                                    >
                                        Advisor Assignment
                                    </p>
                                    <p
                                        class="text-xs text-slate-500 mt-0.5 leading-relaxed"
                                    >
                                        A dedicated academic advisor will be
                                        assigned to your profile within 4
                                        business hours.
                                    </p>
                                </div>
                            </li>
                            <li class="flex gap-4 items-start">
                                <span
                                    class="h-7 w-7 rounded-full bg-sky-50 border border-sky-100 text-sky-700 flex items-center justify-center shrink-0 font-bold text-xs"
                                    >3</span
                                >
                                <div>
                                    <p
                                        class="font-bold text-xs sm:text-sm text-slate-800"
                                    >
                                        Scheduling Link
                                    </p>
                                    <p
                                        class="text-xs text-slate-500 mt-0.5 leading-relaxed"
                                    >
                                        Receive a priority calendar link to book
                                        your session at your earliest
                                        convenience.
                                    </p>
                                </div>
                            </li>
                        </ul>
                    </section>
                </div>

                <!-- Right Column: Checkout -->
                <div
                    class="lg:col-span-7 lg:sticky lg:top-28 order-1 lg:order-2"
                >
                    <div
                        class="bg-white rounded-2xl sm:rounded-3xl p-5 sm:p-8 lg:p-10 border border-slate-200/80 shadow-sm"
                    >
                        <h2 class="text-lg font-bold text-slate-900 mb-1">
                            Complete Enrollment
                        </h2>
                        <p class="text-sm text-slate-500 mb-6">
                            Enter your details below — you'll pay securely on
                            Stripe with cards, wallets, bank transfer, or
                            buy-now-pay-later options.
                        </p>

                        <form class="flex flex-col gap-6" id="payment-form">
                            <div class="flex flex-col gap-2">
                                <label
                                    class="text-[10px] font-bold uppercase tracking-wider text-slate-400"
                                    for="email">Email Address</label
                                >
                                <input
                                    class="w-full h-12 px-4 rounded-xl border border-slate-200/80 focus:border-sky-650 focus:ring-2 focus:ring-sky-600/10 outline-none transition-all duration-200 text-sm"
                                    id="email"
                                    placeholder="you@example.com"
                                    type="email"
                                    required
                                />
                            </div>

                            <div class="flex flex-col gap-2">
                                <label
                                    class="text-[10px] font-bold uppercase tracking-wider text-slate-400"
                                    for="name">Full Name</label
                                >
                                <input
                                    class="w-full h-12 px-4 rounded-xl border border-slate-200/80 focus:border-sky-650 focus:ring-2 focus:ring-sky-600/10 outline-none transition-all duration-200 text-sm"
                                    id="name"
                                    placeholder="Name Enter"
                                    type="text"
                                    required
                                />
                            </div>

                            <div
                                class="rounded-2xl border border-sky-100 bg-sky-50/40 p-5 space-y-4"
                            >
                                <div class="flex gap-3 items-start">
                                    <span
                                        class="material-symbols-outlined text-sky-600 shrink-0"
                                        >lock</span
                                    >
                                    <div
                                        class="text-sm text-slate-600 leading-relaxed"
                                    >
                                        <p
                                            class="font-semibold text-slate-800 mb-1"
                                        >
                                            Secure checkout powered by Stripe
                                        </p>
                                        <p>
                                            On the next page you can pay with
                                            cards, Apple Pay, Google Pay, Link,
                                            ACH bank transfer, and
                                            buy-now-pay-later options such as
                                            Affirm, Klarna, or Afterpay — when
                                            enabled in your region.
                                        </p>
                                    </div>
                                </div>
                                <div>
                                    <p
                                        class="text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-2.5"
                                    >
                                        Accepted payment methods
                                    </p>
                                    <div class="flex flex-wrap gap-2">
                                        <!-- Visa -->
                                        <span
                                            class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-white border border-slate-200 text-[10px] font-bold text-slate-700 shadow-sm hover:border-slate-300 transition-colors"
                                        >
                                            <svg
                                                class="h-3 w-auto"
                                                viewBox="0 0 24 24"
                                                fill="none"
                                                xmlns="http://www.w3.org/2000/svg"
                                            >
                                                <path
                                                    d="M19 6H15.6L12.5 15.3L10.7 7.7C10.2 6.5 9.2 6 8.1 6H4v.5c1.9.5 3.3 1.3 3.8 2.7l3 11.2h3.5L19.5 6H19zM22.5 6H20L17.8 18.5h2.8L22.5 6z"
                                                    fill="#1A1F71"></path>
                                            </svg>
                                            Visa
                                        </span>
                                        <!-- Mastercard -->
                                        <span
                                            class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-white border border-slate-200 text-[10px] font-bold text-slate-700 shadow-sm hover:border-slate-300 transition-colors"
                                        >
                                            <svg
                                                class="h-3.5 w-auto"
                                                viewBox="0 0 24 24"
                                                fill="none"
                                                xmlns="http://www.w3.org/2000/svg"
                                            >
                                                <circle
                                                    cx="8"
                                                    cy="12"
                                                    r="6.5"
                                                    fill="#EB001B"
                                                    fill-opacity="0.9"></circle>
                                                <circle
                                                    cx="16"
                                                    cy="12"
                                                    r="6.5"
                                                    fill="#F79E1B"
                                                    fill-opacity="0.9"></circle>
                                            </svg>
                                            Mastercard
                                        </span>
                                        <!-- Amex -->
                                        <span
                                            class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-white border border-slate-200 text-[10px] font-bold text-slate-700 shadow-sm hover:border-slate-300 transition-colors"
                                        >
                                            <svg
                                                class="h-3.5 w-auto"
                                                viewBox="0 0 24 24"
                                                fill="none"
                                                xmlns="http://www.w3.org/2000/svg"
                                            >
                                                <rect
                                                    width="24"
                                                    height="24"
                                                    rx="4"
                                                    fill="#0070CD"></rect>
                                                <path
                                                    d="M4 17L5.5 13H8.5L10 17H8.5L7.8 15H6.2L5.5 17H4ZM6.5 14L7 12L7.5 14H6.5ZM12 17V13H15V14H13V15.5H14.5V16.5H13V17H12ZM17 17V13H19.5V14H18V15.5H19.5V16.5H18V17H17Z"
                                                    fill="white"
                                                    font-weight="bold"></path>
                                            </svg>
                                            Amex
                                        </span>
                                        <!-- Discover -->
                                        <span
                                            class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-white border border-slate-200 text-[10px] font-bold text-slate-700 shadow-sm hover:border-slate-300 transition-colors"
                                        >
                                            <svg
                                                class="h-3.5 w-auto"
                                                viewBox="0 0 24 24"
                                                fill="none"
                                                xmlns="http://www.w3.org/2000/svg"
                                            >
                                                <path
                                                    d="M2 17h4.5a3.5 3.5 0 000-7H2v7zm1.5-5.5h3a2 2 0 010 4h-3v-4zM9 17h1.5v-7H9v7zm4 0h1.5v-7h-1.5v3.5a1.5 1.5 0 01-3 0v-3.5h-1.5v7h1.5v-3.5a3 3 0 003 0V17zm4.5 0a3.5 3.5 0 000-7H16v7h1.5zm0-5.5a2 2 0 010 4H17.5v-4h0zm4.5.5h-1.5a1 1 0 00-2 0v2a1 1 0 002 0v-2"
                                                    fill="#E65A00"></path>
                                            </svg>
                                            Discover
                                        </span>
                                        <!-- Apple Pay -->
                                        <span
                                            class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-white border border-slate-200 text-[10px] font-bold text-slate-700 shadow-sm hover:border-slate-300 transition-colors"
                                        >
                                            <svg
                                                class="h-3.5 w-auto text-slate-900"
                                                viewBox="0 0 24 24"
                                                fill="currentColor"
                                                xmlns="http://www.w3.org/2000/svg"
                                            >
                                                <path
                                                    d="M17.05 20.28c-.98.95-2.05.98-3.08.4-1.09-.58-2.03-.55-3.14.03-1.04.55-1.99.52-2.93-.38-3.51-3.41-3.01-9.61 1.05-9.61 1.93 0 2.92.93 3.96.93 1.03 0 2.21-.99 4.19-.9 2.08.1 3.58 1.11 4.29 2.45-4.4 2.24-3.69 7.84.51 9.08-.85 1.95-2.35 4.1-4.85 6.0zM14.73 3c.96-1.12 1.62-2.7 1.44-4.28-1.54.06-3.41.97-4.52 2.22-.96 1.08-1.8 2.68-1.56 4.23 1.72.13 3.47-.84 4.64-2.17z"
                                                ></path>
                                            </svg>
                                            Apple Pay
                                        </span>
                                        <!-- Google Pay -->
                                        <span
                                            class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-white border border-slate-200 text-[10px] font-bold text-slate-700 shadow-sm hover:border-slate-300 transition-colors"
                                        >
                                            <svg
                                                class="h-3.5 w-auto"
                                                viewBox="0 0 24 24"
                                                fill="none"
                                                xmlns="http://www.w3.org/2000/svg"
                                            >
                                                <path
                                                    d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                                                    fill="#4285F4"></path>
                                                <path
                                                    d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                                                    fill="#34A853"></path>
                                                <path
                                                    d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                                                    fill="#FBBC05"></path>
                                                <path
                                                    d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                                                    fill="#EA4335"></path>
                                            </svg>
                                            Google Pay
                                        </span>
                                        <!-- Link -->
                                        <span
                                            class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-white border border-slate-200 text-[10px] font-bold text-slate-700 shadow-sm hover:border-slate-300 transition-colors"
                                        >
                                            <span
                                                class="w-2 h-2 rounded-full bg-[#00D4B2] shrink-0"
                                            ></span>
                                            Link
                                        </span>
                                        <!-- Affirm -->
                                        <span
                                            class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-white border border-slate-200 text-[10px] font-bold text-slate-700 shadow-sm hover:border-slate-300 transition-colors"
                                        >
                                            <span
                                                class="w-2 h-2 rounded-full bg-[#4A00E0] shrink-0"
                                            ></span>
                                            Affirm
                                        </span>
                                        <!-- Klarna -->
                                        <span
                                            class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-white border border-slate-200 text-[10px] font-bold text-slate-700 shadow-sm hover:border-slate-300 transition-colors"
                                        >
                                            <span
                                                class="w-2 h-2 rounded-full bg-[#FFB3C7] shrink-0"
                                            ></span>
                                            Klarna
                                        </span>
                                        <!-- Afterpay -->
                                        <span
                                            class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-white border border-slate-200 text-[10px] font-bold text-slate-700 shadow-sm hover:border-slate-300 transition-colors"
                                        >
                                            <span
                                                class="w-2 h-2 rounded-full bg-[#B2FCE4] shrink-0"
                                            ></span>
                                            Afterpay
                                        </span>
                                    </div>
                                </div>
                            </div>

                            <div
                                id="payment-message"
                                class="text-xs font-semibold text-red-500 hidden"
                            >
                            </div>

                            <button
                                class="w-full h-12 bg-gradient-to-r from-sky-600 to-blue-700 text-white rounded-xl text-xs uppercase font-bold tracking-wider shadow-md hover:from-sky-500 hover:to-blue-600 hover:shadow-lg hover:shadow-sky-600/10 active:scale-[0.98] transition-all flex items-center justify-center gap-2 cursor-pointer disabled:opacity-60 disabled:cursor-not-allowed"
                                type="submit"
                                id="submit-payment-btn"
                            >
                                <span>Continue to Secure Checkout</span>
                                <span
                                    class="material-symbols-outlined text-sm font-bold"
                                    >arrow_forward</span
                                >
                            </button>
                        </form>

                        <!-- Trust Badges -->
                        <div
                            class="mt-8 flex flex-wrap items-center justify-center gap-6 opacity-40"
                        >
                            <div class="flex items-center gap-1">
                                <span class="material-symbols-outlined text-sm"
                                    >verified_user</span
                                >
                                <span
                                    class="text-[9px] uppercase tracking-widest font-black text-slate-850"
                                    >SSL SECURE</span
                                >
                            </div>
                            <div class="flex items-center gap-1">
                                <span class="material-symbols-outlined text-sm"
                                    >lock</span
                                >
                                <span
                                    class="text-[9px] uppercase tracking-widest font-black text-slate-850"
                                    >PCI COMPLIANT</span
                                >
                            </div>
                            <div class="flex items-center gap-1">
                                <span class="material-symbols-outlined text-sm"
                                    >security</span
                                >
                                <span
                                    class="text-[9px] uppercase tracking-widest font-black text-slate-850"
                                    >256-BIT ENCRYPTION</span
                                >
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
        <!-- Footer -->
        <Footer />
        <script define:vars={{ pricingConfig }}>
            window.SKY_PRICING = pricingConfig;
        </script>
        <script is:inline>
            const P = window.SKY_PRICING;

            window.checkoutMode = "registration";
            window.activeCoupon = null;
            window.selectedTier = "normal";

            window.getOrderTotal = function () {
                const isFullPayment = window.checkoutMode === "full" || window.checkoutMode === "offline";
                const modeKey = window.checkoutMode;
                const tierKey =
                    window.selectedTier === "1on1" ? "1on1" : "normal";
                let basePrice = P[modeKey][tierKey];
                let discount = 0;
                if (window.activeCoupon && isFullPayment) {
                    discount = window.activeCoupon.discount ?? 0;
                }
                return Math.max(0, basePrice - discount);
            };

            window.updateCouponVisibility = function () {
                const isFull = window.checkoutMode === "full" || window.checkoutMode === "offline";
                const couponSection = document.getElementById("coupon-section");
                const couponNote = document.getElementById(
                    "coupon-registration-note",
                );

                if (couponSection)
                    couponSection.classList.toggle("hidden", !isFull);
                if (couponNote) couponNote.classList.toggle("hidden", isFull);

                if (!isFull) {
                    window.activeCoupon = null;
                    const input = document.getElementById("coupon-code-input");
                    const feedback = document.getElementById("coupon-feedback");
                    if (input) input.value = "";
                    if (feedback)
                        feedback.className = "text-xs font-semibold hidden";
                }
            };

            window.updatePricingDisplay = function () {
                window.updateCouponVisibility();

                const label = document.getElementById("display-tier-label");
                const desc = document.getElementById(
                    "display-tier-description",
                );
                const priceEl = document.getElementById("display-price-value");
                const totalEl = document.getElementById("display-total-value");
                const feedbackEl = document.getElementById("coupon-feedback");
                const isFullPayment = window.checkoutMode === "full" || window.checkoutMode === "offline";
                const modeKey = window.checkoutMode;
                const tierKey =
                    window.selectedTier === "1on1" ? "1on1" : "normal";
                let basePrice = P[modeKey][tierKey];

                if (window.selectedTier === "normal") {
                    if (label) label.textContent = "batch classes Program";
                    if (desc)
                        desc.textContent = "Weekend live labs & placement prep";
                } else {
                    if (label) label.textContent = "personalised classes";
                    if (desc)
                        desc.textContent =
                            "Personal Industry mentor & 1-on-1 guidance";
                }

                if (priceEl)
                    priceEl.textContent = "$" + basePrice.toLocaleString();

                let discount = 0;
                if (window.activeCoupon && isFullPayment) {
                    discount = window.activeCoupon.discount ?? 0;
                }

                const finalTotal = Math.max(0, basePrice - discount);
                if (totalEl) {
                    totalEl.textContent =
                        "$" +
                        finalTotal.toLocaleString("en-US", {
                            minimumFractionDigits: 2,
                            maximumFractionDigits: 2,
                        });
                }

                if (feedbackEl) {
                    if (window.activeCoupon && isFullPayment) {
                        feedbackEl.textContent = `Coupon ${window.activeCoupon.code} applied: -$${discount.toLocaleString()}`;
                        feedbackEl.className =
                            "text-xs font-semibold text-green-600 block";
                    } else {
                        feedbackEl.className = "text-xs font-semibold hidden";
                    }
                }
            };

            window.selectTier = function (tier) {
                if (window.checkoutMode === "offline" && tier === "1on1") {
                    tier = "normal";
                }
                window.selectedTier = tier;
                const btnScholar = document.getElementById("btn-tier-scholar");
                const btnElite = document.getElementById("btn-tier-elite");
                const displayCourse = document.getElementById(
                    "display-course-name",
                );
                if (!btnScholar || !btnElite || !displayCourse) return;

                let courseText = displayCourse.textContent || "";

                if (tier === "normal") {
                    btnScholar.classList.add(
                        "border-sky-600",
                        "bg-sky-50/20",
                        "active",
                    );
                    btnScholar.classList.remove(
                        "border-slate-200/80",
                        "opacity-70",
                    );
                    btnElite.classList.remove(
                        "border-sky-600",
                        "bg-sky-50/20",
                        "active",
                    );
                    btnElite.classList.add("border-slate-200/80", "opacity-70");

                    // Strip "Short Term Program" if present
                    if (courseText.endsWith(" Short Term Program")) {
                        displayCourse.textContent = courseText.replace(
                            " Short Term Program",
                            "",
                        );
                    }
                } else {
                    btnElite.classList.add(
                        "border-sky-600",
                        "bg-sky-50/20",
                        "active",
                    );
                    btnElite.classList.remove(
                        "border-slate-200/80",
                        "opacity-70",
                    );
                    btnScholar.classList.remove(
                        "border-sky-600",
                        "bg-sky-50/20",
                        "active",
                    );
                    btnScholar.classList.add(
                        "border-slate-200/80",
                        "opacity-70",
                    );

                    // Append "Short Term Program" if not present and it's one of the main courses
                    if (
                        courseText &&
                        !courseText.endsWith(" Short Term Program") &&
                        courseText !== "Intro Session"
                    ) {
                        displayCourse.textContent =
                            courseText + " Short Term Program";
                    }
                }

                window.updatePricingDisplay();
            };

            window.applyPromoCode = async function () {
                const input = document.getElementById("coupon-code-input");
                const feedback = document.getElementById("coupon-feedback");
                if (!input || !feedback) return;

                if (window.checkoutMode !== "full") {
                    feedback.textContent =
                        "Promotional codes apply to full program enrollment only.";
                    feedback.className =
                        "text-xs font-semibold text-red-500 block";
                    return;
                }

                const code = input.value.trim();
                if (!code) {
                    feedback.textContent = "Please enter a coupon code.";
                    feedback.className =
                        "text-xs font-semibold text-red-500 block";
                    return;
                }

                const basePrice =
                    P.full[window.selectedTier === "1on1" ? "1on1" : "normal"];

                try {
                    feedback.textContent = "Validating coupon...";
                    feedback.className =
                        "text-xs font-semibold text-gray-500 block";

                    const response = await fetch("/api/validate-coupon", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ code, basePrice, mode: "full" }),
                    });

                    const data = await response.json();

                    if (response.ok && data.valid) {
                        window.activeCoupon = {
                            code: data.code,
                            discount: data.discount,
                        };
                        window.updatePricingDisplay();
                    } else {
                        window.activeCoupon = null;
                        window.updatePricingDisplay();
                        feedback.textContent =
                            data.error || "Invalid coupon code.";
                        feedback.className =
                            "text-xs font-semibold text-red-500 block";
                    }
                } catch (err) {
                    window.activeCoupon = null;
                    window.updatePricingDisplay();
                    feedback.textContent =
                        "Connection error. Please try again.";
                    feedback.className =
                        "text-xs font-semibold text-red-500 block";
                }
            };

            // Initialize from URL search parameters
            function initializeCheckout() {
                const params = new URLSearchParams(window.location.search);
                const courseName = params.get("course");
                const type = params.get("type");
                const mode = params.get("mode");

                if (mode === "offline") {
                    window.checkoutMode = "offline";
                    const sPrice = document.getElementById("btn-scholar-price");
                    const ePrice = document.getElementById("btn-elite-price");
                    if (sPrice)
                        sPrice.textContent =
                            "$" + P.offline.normal.toLocaleString();
                    if (ePrice)
                        ePrice.textContent =
                            "$" + P.offline["1on1"].toLocaleString();

                    // Hide elite tier selection for offline classroom
                    const btnElite = document.getElementById("btn-tier-elite");
                    if (btnElite) btnElite.style.display = "none";
                    const grid = document.getElementById("tier-buttons-grid");
                    if (grid) grid.classList.remove("sm:grid-cols-2");
                    const label = document.getElementById("tier-selector-label");
                    if (label) label.style.display = "none";
                } else if (mode === "full") {
                    window.checkoutMode = "full";
                    const sPrice = document.getElementById("btn-scholar-price");
                    const ePrice = document.getElementById("btn-elite-price");
                    if (sPrice)
                        sPrice.textContent =
                            "$" + P.full.normal.toLocaleString();
                    if (ePrice)
                        ePrice.textContent =
                            "$" + P.full["1on1"].toLocaleString();

                    // Show elite tier selection
                    const btnElite = document.getElementById("btn-tier-elite");
                    if (btnElite) btnElite.style.display = "";
                    const grid = document.getElementById("tier-buttons-grid");
                    if (grid) grid.classList.add("sm:grid-cols-2");
                    const label = document.getElementById("tier-selector-label");
                    if (label) label.style.display = "";
                } else {
                    window.checkoutMode = "registration";
                    const sPrice = document.getElementById("btn-scholar-price");
                    const ePrice = document.getElementById("btn-elite-price");
                    if (sPrice)
                        sPrice.textContent = "$" + P.registration.normal;
                    if (ePrice)
                        ePrice.textContent = "$" + P.registration["1on1"];

                    // Show elite tier selection
                    const btnElite = document.getElementById("btn-tier-elite");
                    if (btnElite) btnElite.style.display = "";
                    const grid = document.getElementById("tier-buttons-grid");
                    if (grid) grid.classList.add("sm:grid-cols-2");
                    const label = document.getElementById("tier-selector-label");
                    if (label) label.style.display = "";
                }

                if (courseName) {
                    const displayCourse = document.getElementById(
                        "display-course-name",
                    );
                    if (displayCourse) displayCourse.textContent = courseName;
                }

                if (mode === "offline") {
                    window.selectTier("normal");
                } else if (
                    type === "1on1" ||
                    (courseName &&
                        courseName.toLowerCase().includes("short term"))
                ) {
                    window.selectTier("1on1");
                } else {
                    window.selectTier("normal");
                }
            }

            initializeCheckout();

            function showPaymentMessage(message, isError = true) {
                const messageEl = document.getElementById("payment-message");
                if (!messageEl) return;
                if (!message) {
                    messageEl.innerHTML = "";
                    messageEl.className = "hidden";
                    return;
                }

                let displayMessage = message;
                if (isError) {
                    const lowercaseMsg = message.toLowerCase();
                    if (
                        lowercaseMsg.includes("stripe_secret_key") ||
                        lowercaseMsg.includes("stripe key") ||
                        lowercaseMsg.includes("not configured") ||
                        lowercaseMsg.includes("database") ||
                        lowercaseMsg.includes("sqlite") ||
                        lowercaseMsg.includes("secretkey")
                    ) {
                        displayMessage =
                            "We are experiencing a payment gateway configuration issue. Please contact support at support@skystates.us to complete your enrollment.";
                    }
                }

                if (isError) {
                    messageEl.innerHTML = `
                        <div class="flex items-start gap-2.5 p-3.5 rounded-xl bg-rose-50 border border-rose-100 text-rose-800 text-xs leading-relaxed font-medium">
                            <span class="material-symbols-outlined text-[16px] text-rose-600 shrink-0 mt-0.5">error</span>
                            <span>${displayMessage}</span>
                        </div>
                    `;
                } else {
                    messageEl.innerHTML = `
                        <div class="flex items-start gap-2.5 p-3.5 rounded-xl bg-emerald-50 border border-emerald-100 text-emerald-800 text-xs leading-relaxed font-medium">
                            <span class="material-symbols-outlined text-[16px] text-emerald-600 shrink-0 mt-0.5">check_circle</span>
                            <span>${displayMessage}</span>
                        </div>
                    `;
                }
                messageEl.className = "block mb-4";
            }

            const checkoutParams = new URLSearchParams(window.location.search);
            if (checkoutParams.get("canceled") === "1") {
                showPaymentMessage(
                    "Checkout was canceled. You can try again when ready.",
                    true,
                );
            }

            function getCheckoutPayload() {
                return {
                    email: (
                        document.getElementById("email")?.value || ""
                    ).trim(),
                    name: (document.getElementById("name")?.value || "").trim(),
                    mode: window.checkoutMode,
                    tier: window.selectedTier,
                    couponCode: window.activeCoupon?.code || "",
                    courseName:
                        document.getElementById("display-course-name")
                            ?.textContent || "Intro Session",
                };
            }

            const paymentForm = document.getElementById("payment-form");
            paymentForm?.addEventListener("submit", async (e) => {
                e.preventDefault();

                const submitBtn = document.getElementById("submit-payment-btn");
                if (!submitBtn) return;
                const originalBtnContent = submitBtn.innerHTML;

                submitBtn.disabled = true;
                submitBtn.innerHTML = "<span>Redirecting to Stripe...</span>";

                try {
                    const payload = getCheckoutPayload();
                    if (!payload.email || !payload.name) {
                        throw new Error(
                            "Please enter your email and full name.",
                        );
                    }

                    const response = await fetch(
                        "/api/payments/create-checkout-session",
                        {
                            method: "POST",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify(payload),
                        },
                    );

                    const data = await response.json();
                    if (!response.ok) {
                        throw new Error(
                            data.error || "Unable to start checkout.",
                        );
                    }

                    if (data.freeCheckout) {
                        const freeResponse = await fetch(
                            "/api/payments/confirm-free",
                            {
                                method: "POST",
                                headers: { "Content-Type": "application/json" },
                                body: JSON.stringify(payload),
                            },
                        );
                        const freeData = await freeResponse.json();
                        if (!freeResponse.ok) {
                            throw new Error(
                                freeData.error ||
                                    "Unable to complete checkout.",
                            );
                        }
                        window.location.href = "/checkout/success?free=1";
                        return;
                    }

                    if (!data.url) {
                        throw new Error(
                            "Stripe checkout URL was not returned.",
                        );
                    }

                    window.location.href = data.url;
                } catch (err) {
                    console.error("Checkout process failed:", err);
                    showPaymentMessage(
                        err.message || "Checkout failed. Please try again.",
                        true,
                    );
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalBtnContent;
                }
            });

            const nameInput = document.getElementById("name");
            nameInput?.addEventListener("input", (e) => {
                const target = e.target;
                if (!target) return;
                target.value = target.value.replace(/[^a-zA-Z\s]/g, "");
            });
        </script>
    </body>
</html>
