---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html class="light" lang="en">
    <head>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
            rel="stylesheet"
        />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Geist:wght@400;600;700;800&display=swap"
            rel="stylesheet"
        />

        <link rel="icon" type="image/png" href="/favicon.png" />
        <meta charset="utf-8" />
        <meta content="width=device-width, initial-scale=1.0" name="viewport" />
        <title>Secure Checkout | Sky States</title>
        <meta
            name="description"
            content="Securely complete your enrollment in the Sky States Career Acceleration Program. Select your track and apply promotional vouchers."
        />
        <link rel="canonical" href="https://skystates.us/checkout" />

        <style>
            .material-symbols-outlined {
                font-variation-settings:
                    "FILL" 0,
                    "wght" 400,
                    "GRAD" 0,
                    "opsz" 24;
            }
            .upward-gradient {
                background: linear-gradient(to top, #ffffff, #d3e2ed);
            }
            .ambient-shadow {
                box-shadow: 0 10px 30px -5px rgba(15, 29, 37, 0.04);
            }
            .form-glow:focus-within {
                box-shadow: 0 0 0 4px rgba(0, 93, 144, 0.1);
            }
        </style>
    </head>
    <body class="bg-slate-50/50 text-slate-800 font-sans min-h-screen">
        <!-- TopAppBar -->
        <Header />
        <main
            class="max-w-[1280px] mx-auto px-4 md:px-margin-desktop pt-28 sm:pt-32 pb-16"
        >
            <!-- Editorial Header Section -->
            <div
                class="mb-12 rounded-3xl p-8 sm:p-12 bg-gradient-to-br from-sky-50 to-blue-100/50 border border-sky-100 flex flex-col gap-2 relative overflow-hidden"
            >
                <div
                    class="absolute -right-10 -top-10 w-40 h-40 bg-sky-300/10 blur-3xl rounded-full"
                >
                </div>
                <h1
                    class="text-3xl sm:text-4xl font-extrabold text-slate-900 tracking-tight"
                >
                    Finalize Your Access
                </h1>
                <p
                    class="text-slate-650 max-w-2xl text-sm sm:text-base leading-relaxed"
                >
                    Begin your journey with Sky States. Secure your introductory
                    session and join a global network of elite scholars and
                    executives.
                </p>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
                <!-- Left Column: Order Summary & Info -->
                <div class="lg:col-span-5 flex flex-col gap-8">
                    <!-- Order Summary Card -->
                    <section
                        class="bg-white rounded-3xl p-6 sm:p-8 border border-slate-200/80 shadow-sm flex flex-col gap-6"
                    >
                        <h2 class="text-xl font-bold text-slate-850">
                            Order Summary
                        </h2>

                        <!-- Dynamic Course Title -->
                        <div class="pb-4 border-b border-slate-100">
                            <span
                                class="text-[10px] font-bold uppercase tracking-wider text-sky-700"
                                >Selected Program</span
                            >
                            <h3
                                class="text-xl font-bold text-slate-900 mt-1"
                                id="display-course-name"
                            >
                                Intro Session
                            </h3>
                        </div>

                        <!-- Dynamic Tier Selector (Interactive Cards) -->
                        <div>
                            <span
                                class="block text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-3"
                                >Select Program Tier</span
                            >
                            <div class="grid grid-cols-2 gap-4">
                                <!-- Scholar Tier Card -->
                                <button
                                    type="button"
                                    id="btn-tier-scholar"
                                    class="flex flex-col items-start p-4 rounded-2xl border transition-all duration-300 text-left w-full group relative overflow-hidden active border-sky-600 bg-sky-50/20"
                                    onclick="selectTier('normal')"
                                >
                                    <span
                                        class="text-[10px] font-bold uppercase tracking-wider text-sky-700"
                                        >Scholar Tier</span
                                    >
                                    <span
                                        class="text-lg font-black mt-1 text-slate-850"
                                        id="btn-scholar-price">$99</span
                                    >
                                    <span
                                        class="text-[10px] text-slate-400 font-semibold mt-1"
                                        >Live weekend instruction</span
                                    >
                                    <div
                                        class="absolute top-2 right-2 opacity-0 group-[.active]:opacity-100 transition-opacity"
                                    >
                                        <span
                                            class="material-symbols-outlined text-sky-600 text-sm font-bold"
                                            >check_circle</span
                                        >
                                    </div>
                                </button>

                                <!-- Elite Tier Card -->
                                <button
                                    type="button"
                                    id="btn-tier-elite"
                                    class="flex flex-col items-start p-4 rounded-2xl border transition-all duration-300 text-left w-full group relative overflow-hidden border-slate-200/80 opacity-70"
                                    onclick="selectTier('1on1')"
                                >
                                    <span
                                        class="text-[10px] font-bold uppercase tracking-wider text-slate-400"
                                        >Elite Tier</span
                                    >
                                    <span
                                        class="text-lg font-black mt-1 text-slate-850"
                                        id="btn-elite-price">$499</span
                                    >
                                    <span
                                        class="text-[10px] text-slate-400 font-semibold mt-1"
                                        >1-on-1 Industry Mentor</span
                                    >
                                    <div
                                        class="absolute top-2 right-2 opacity-0 group-[.active]:opacity-100 transition-opacity"
                                    >
                                        <span
                                            class="material-symbols-outlined text-sky-600 text-sm font-bold"
                                            >check_circle</span
                                        >
                                    </div>
                                </button>
                            </div>
                        </div>

                        <div
                            class="flex justify-between items-center pt-4 border-t border-slate-100"
                        >
                            <div>
                                <p
                                    class="font-bold text-slate-850 text-sm"
                                    id="display-tier-label"
                                >
                                    Scholar Tier Program
                                </p>
                                <p
                                    class="text-xs text-slate-400 mt-0.5"
                                    id="display-tier-description"
                                >
                                    Weekend live labs & placement prep
                                </p>
                            </div>
                            <p
                                class="text-xl font-black text-sky-700"
                                id="display-price-value"
                            >
                                $99
                            </p>
                        </div>

                        <!-- Promo Code Section -->
                        <div
                            class="pt-4 border-t border-slate-100 flex flex-col gap-2"
                        >
                            <label
                                class="text-[10px] font-bold uppercase tracking-wider text-slate-400"
                                >Apply Promotion Code</label
                            >
                            <div class="flex gap-2">
                                <input
                                    type="text"
                                    id="coupon-code-input"
                                    placeholder="e.g. SKY150"
                                    class="h-12 px-3.5 border border-slate-200/80 rounded-xl outline-none focus:border-sky-650 focus:ring-2 focus:ring-sky-600/10 text-sm flex-grow transition-all"
                                />
                                <button
                                    type="button"
                                    onclick="applyPromoCode()"
                                    class="h-12 px-5 bg-slate-900 text-white rounded-xl text-xs uppercase font-bold tracking-wider hover:bg-slate-850 transition-all cursor-pointer"
                                    >Apply</button
                                >
                            </div>
                            <div
                                id="coupon-feedback"
                                class="text-xs font-semibold hidden"
                            >
                            </div>
                        </div>

                        <div
                            class="mt-2 flex justify-between items-center font-bold text-slate-800 border-t border-slate-100 pt-4"
                        >
                            <p class="text-sm">Total Investment</p>
                            <p
                                class="text-lg font-black text-slate-900"
                                id="display-total-value"
                            >
                                $99.00
                            </p>
                        </div>
                    </section>

                    <!-- Privacy Commitment -->
                    <section
                        class="bg-sky-50/50 border border-sky-100/50 rounded-3xl p-6 flex gap-4 items-start"
                    >
                        <div
                            class="bg-white p-2 rounded-xl border border-sky-100/60 shadow-sm shrink-0"
                        >
                            <span
                                class="material-symbols-outlined text-sky-600 text-xl"
                                >shield_person</span
                            >
                        </div>
                        <div>
                            <h3 class="font-bold text-sm text-slate-850">
                                No-SSN Privacy Commitment
                            </h3>
                            <p
                                class="text-xs text-slate-500 mt-1 leading-relaxed"
                            >
                                We prioritize your anonymity. No Social Security
                                Number or sensitive identification is required
                                for institutional registry.
                            </p>
                        </div>
                    </section>

                    <!-- What Happens Next -->
                    <section class="flex flex-col gap-6 px-1">
                        <h2 class="text-lg font-bold text-slate-850">
                            What Happens Next
                        </h2>
                        <ul class="space-y-4">
                            <li class="flex gap-4 items-start">
                                <span
                                    class="h-7 w-7 rounded-full bg-sky-50 border border-sky-100 text-sky-700 flex items-center justify-center shrink-0 font-bold text-xs"
                                    >1</span
                                >
                                <div>
                                    <p
                                        class="font-bold text-xs sm:text-sm text-slate-800"
                                    >
                                        Instant Portal Access
                                    </p>
                                    <p
                                        class="text-xs text-slate-500 mt-0.5 leading-relaxed"
                                    >
                                        Your login credentials will be delivered
                                        to your inbox immediately after payment.
                                    </p>
                                </div>
                            </li>
                            <li class="flex gap-4 items-start">
                                <span
                                    class="h-7 w-7 rounded-full bg-sky-50 border border-sky-100 text-sky-700 flex items-center justify-center shrink-0 font-bold text-xs"
                                    >2</span
                                >
                                <div>
                                    <p
                                        class="font-bold text-xs sm:text-sm text-slate-800"
                                    >
                                        Advisor Assignment
                                    </p>
                                    <p
                                        class="text-xs text-slate-500 mt-0.5 leading-relaxed"
                                    >
                                        A dedicated academic advisor will be
                                        assigned to your profile within 4
                                        business hours.
                                    </p>
                                </div>
                            </li>
                            <li class="flex gap-4 items-start">
                                <span
                                    class="h-7 w-7 rounded-full bg-sky-50 border border-sky-100 text-sky-700 flex items-center justify-center shrink-0 font-bold text-xs"
                                    >3</span
                                >
                                <div>
                                    <p
                                        class="font-bold text-xs sm:text-sm text-slate-800"
                                    >
                                        Scheduling Link
                                    </p>
                                    <p
                                        class="text-xs text-slate-500 mt-0.5 leading-relaxed"
                                    >
                                        Receive a priority calendar link to book
                                        your session at your earliest
                                        convenience.
                                    </p>
                                </div>
                            </li>
                        </ul>
                    </section>
                </div>

                <!-- Right Column: Payment Form -->
                <div class="lg:col-span-7 lg:sticky lg:top-28">
                    <div
                        class="bg-white rounded-3xl p-6 sm:p-10 border border-slate-200/80 shadow-sm"
                    >
                        <!-- Tabs -->
                        <div
                            class="flex gap-2 mb-8 p-1 bg-slate-100/80 rounded-xl border border-slate-200/20"
                        >
                            <button
                                class="w-1/2 py-2.5 rounded-lg text-xs uppercase font-bold tracking-wider transition-all bg-white text-slate-850 shadow-sm"
                                onclick="switchTab('cc')">Credit Card</button
                            >
                            <button
                                class="w-1/2 py-2.5 rounded-lg text-xs uppercase font-bold tracking-wider transition-all text-slate-400"
                                onclick="switchTab('emi')">EMI Options</button
                            >
                        </div>

                        <!-- Payment CC Container -->
                        <div id="payment-cc-container" class="space-y-6">
                            <form class="flex flex-col gap-6" id="payment-form">
                                <div class="flex flex-col gap-2">
                                    <label
                                        class="text-[10px] font-bold uppercase tracking-wider text-slate-400"
                                        for="card_number">Card Number</label
                                    >
                                    <div class="relative group">
                                        <input
                                            class="w-full h-12 px-4 rounded-xl border border-slate-200/80 focus:border-sky-650 focus:ring-2 focus:ring-sky-600/10 outline-none transition-all duration-200 text-sm"
                                            id="card_number"
                                            placeholder="0000 0000 0000 0000"
                                            type="text"
                                        />
                                        <div
                                            class="absolute right-3 top-1/2 -translate-y-1/2 flex items-center"
                                        >
                                            <span
                                                class="material-symbols-outlined text-slate-400 text-lg"
                                                >credit_card</span
                                            >
                                        </div>
                                    </div>
                                </div>

                                <div class="grid grid-cols-2 gap-4">
                                    <div class="flex flex-col gap-2">
                                        <label
                                            class="text-[10px] font-bold uppercase tracking-wider text-slate-400"
                                            for="expiry">Expiry Date</label
                                        >
                                        <input
                                            class="w-full h-12 px-4 rounded-xl border border-slate-200/80 focus:border-sky-650 focus:ring-2 focus:ring-sky-600/10 outline-none transition-all duration-200 text-sm"
                                            id="expiry"
                                            placeholder="MM / YY"
                                            type="text"
                                        />
                                    </div>
                                    <div class="flex flex-col gap-2">
                                        <label
                                            class="text-[10px] font-bold uppercase tracking-wider text-slate-400"
                                            for="cvv">CVV</label
                                        >
                                        <input
                                            class="w-full h-12 px-4 rounded-xl border border-slate-200/80 focus:border-sky-650 focus:ring-2 focus:ring-sky-600/10 outline-none transition-all duration-200 text-sm"
                                            id="cvv"
                                            placeholder="•••"
                                            type="password"
                                        />
                                    </div>
                                </div>

                                <div class="flex flex-col gap-2">
                                    <label
                                        class="text-[10px] font-bold uppercase tracking-wider text-slate-400"
                                        for="name">Cardholder Name</label
                                    >
                                    <input
                                        class="w-full h-12 px-4 rounded-xl border border-slate-200/80 focus:border-sky-650 focus:ring-2 focus:ring-sky-600/10 outline-none transition-all duration-200 text-sm"
                                        id="name"
                                        placeholder="Johnathan Doe"
                                        type="text"
                                    />
                                </div>

                                <button
                                    class="w-full h-12 mt-4 bg-gradient-to-r from-sky-600 to-blue-700 text-white rounded-xl text-xs uppercase font-bold tracking-wider shadow-md hover:from-sky-500 hover:to-blue-600 hover:shadow-lg hover:shadow-sky-600/10 active:scale-[0.98] transition-all flex items-center justify-center gap-2 cursor-pointer"
                                    type="submit"
                                >
                                    <span>Complete Investment</span>
                                    <span
                                        class="material-symbols-outlined text-sm font-bold"
                                        >arrow_forward</span
                                    >
                                </button>
                            </form>
                        </div>

                        <!-- Payment EMI Container -->
                        <div
                            id="payment-emi-container"
                            class="hidden space-y-6"
                        >
                            <div
                                class="p-6 rounded-2xl bg-slate-50 border border-slate-200/60 text-center space-y-3"
                            >
                                <span
                                    class="material-symbols-outlined text-3xl text-sky-600"
                                    >payments</span
                                >
                                <h4 class="font-bold text-slate-800 text-sm">
                                    Flexible Installment Options
                                </h4>
                                <p
                                    class="text-xs text-slate-550 leading-relaxed max-w-sm mx-auto"
                                >
                                    We offer 3, 6, and 12-month low-interest EMI
                                    plans. Speak to our advisor post-enrollment
                                    to activate installments on your profile.
                                </p>
                                <a
                                    href="/contact-us"
                                    class="inline-block px-5 py-2.5 bg-slate-900 hover:bg-slate-850 text-white rounded-xl text-xs uppercase font-bold tracking-wider transition-all"
                                    >Request EMI Plan</a
                                >
                            </div>
                        </div>

                        <!-- Trust Badges -->
                        <div
                            class="mt-8 flex flex-wrap items-center justify-center gap-6 opacity-40"
                        >
                            <div class="flex items-center gap-1">
                                <span class="material-symbols-outlined text-sm"
                                    >verified_user</span
                                >
                                <span
                                    class="text-[9px] uppercase tracking-widest font-black text-slate-850"
                                    >SSL SECURE</span
                                >
                            </div>
                            <div class="flex items-center gap-1">
                                <span class="material-symbols-outlined text-sm"
                                    >lock</span
                                >
                                <span
                                    class="text-[9px] uppercase tracking-widest font-black text-slate-850"
                                    >PCI COMPLIANT</span
                                >
                            </div>
                            <div class="flex items-center gap-1">
                                <span class="material-symbols-outlined text-sm"
                                    >security</span
                                >
                                <span
                                    class="text-[9px] uppercase tracking-widest font-black text-slate-850"
                                    >256-BIT ENCRYPTION</span
                                >
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
        <!-- Footer -->
        <Footer />
        <script is:inline>
            window.switchTab = function (tab) {
                const buttons = document.querySelectorAll(
                    'button[onclick^="switchTab"]',
                );
                buttons.forEach((btn) => {
                    if (btn.getAttribute("onclick").includes(tab)) {
                        btn.classList.add(
                            "bg-white",
                            "text-slate-850",
                            "shadow-sm",
                        );
                        btn.classList.remove("text-slate-400");
                    } else {
                        btn.classList.remove(
                            "bg-white",
                            "text-slate-850",
                            "shadow-sm",
                        );
                        btn.classList.add("text-slate-400");
                    }
                });

                const ccContainer = document.getElementById(
                    "payment-cc-container",
                );
                const emiContainer = document.getElementById(
                    "payment-emi-container",
                );
                if (ccContainer && emiContainer) {
                    if (tab === "cc") {
                        ccContainer.classList.remove("hidden");
                        emiContainer.classList.add("hidden");
                    } else {
                        ccContainer.classList.add("hidden");
                        emiContainer.classList.remove("hidden");
                    }
                }
            };

            window.checkoutMode = "registration";
            window.activeCoupon = null;
            window.selectedTier = "normal";

            window.updatePricingDisplay = function () {
                const label = document.getElementById("display-tier-label");
                const desc = document.getElementById(
                    "display-tier-description",
                );
                const priceEl = document.getElementById("display-price-value");
                const totalEl = document.getElementById("display-total-value");
                const feedbackEl = document.getElementById("coupon-feedback");
                const isFullPayment = window.checkoutMode === "full";

                let basePrice = 99;
                if (window.selectedTier === "normal") {
                    basePrice = isFullPayment ? 3499 : 99;
                    if (label) label.textContent = "Scholar Tier Program";
                    if (desc)
                        desc.textContent = "Weekend live labs & placement prep";
                } else {
                    basePrice = isFullPayment ? 6499 : 499;
                    if (label) label.textContent = "Elite Tier (1-on-1)";
                    if (desc)
                        desc.textContent =
                            "Personal Industry mentor & 1-on-1 guidance";
                }

                if (priceEl)
                    priceEl.textContent = "$" + basePrice.toLocaleString();

                let discount = 0;
                if (window.activeCoupon) {
                    const match = window.activeCoupon.code.match(/^SKY(\d+)$/i);
                    if (match) {
                        const couponValue = parseInt(match[1], 10);
                        discount = Math.min(couponValue, basePrice);
                    }
                }

                const finalTotal = Math.max(0, basePrice - discount);
                if (totalEl)
                    totalEl.textContent =
                        "$" +
                        finalTotal.toLocaleString("en-US", {
                            minimumFractionDigits: 2,
                            maximumFractionDigits: 2,
                        });

                if (feedbackEl) {
                    if (window.activeCoupon) {
                        feedbackEl.textContent = `Coupon ${window.activeCoupon.code} applied: -$${discount.toLocaleString()}`;
                        feedbackEl.className =
                            "text-xs font-semibold text-green-600 block";
                    } else {
                        feedbackEl.className = "text-xs font-semibold hidden";
                    }
                }
            };

            window.selectTier = function (tier) {
                window.selectedTier = tier;
                const btnScholar = document.getElementById("btn-tier-scholar");
                const btnElite = document.getElementById("btn-tier-elite");
                const displayCourse = document.getElementById(
                    "display-course-name",
                );
                if (!btnScholar || !btnElite || !displayCourse) return;

                let courseText = displayCourse.textContent || "";

                if (tier === "normal") {
                    btnScholar.classList.add(
                        "border-sky-600",
                        "bg-sky-50/20",
                        "active",
                    );
                    btnScholar.classList.remove(
                        "border-slate-200/80",
                        "opacity-70",
                    );
                    btnElite.classList.remove(
                        "border-sky-600",
                        "bg-sky-50/20",
                        "active",
                    );
                    btnElite.classList.add("border-slate-200/80", "opacity-70");

                    // Strip "Short Term Program" if present
                    if (courseText.endsWith(" Short Term Program")) {
                        displayCourse.textContent = courseText.replace(
                            " Short Term Program",
                            "",
                        );
                    }
                } else {
                    btnElite.classList.add(
                        "border-sky-600",
                        "bg-sky-50/20",
                        "active",
                    );
                    btnElite.classList.remove(
                        "border-slate-200/80",
                        "opacity-70",
                    );
                    btnScholar.classList.remove(
                        "border-sky-600",
                        "bg-sky-50/20",
                        "active",
                    );
                    btnScholar.classList.add(
                        "border-slate-200/80",
                        "opacity-70",
                    );

                    // Append "Short Term Program" if not present and it's one of the main courses
                    if (
                        courseText &&
                        !courseText.endsWith(" Short Term Program") &&
                        courseText !== "Intro Session"
                    ) {
                        displayCourse.textContent =
                            courseText + " Short Term Program";
                    }
                }

                window.updatePricingDisplay();
            };

            window.applyPromoCode = async function () {
                const input = document.getElementById("coupon-code-input");
                const feedback = document.getElementById("coupon-feedback");
                if (!input || !feedback) return;

                const code = input.value.trim();
                if (!code) {
                    feedback.textContent = "Please enter a coupon code.";
                    feedback.className =
                        "text-xs font-semibold text-red-500 block";
                    return;
                }

                const isFullPayment = window.checkoutMode === "full";
                const basePrice =
                    window.selectedTier === "normal"
                        ? isFullPayment
                            ? 3499
                            : 99
                        : isFullPayment
                          ? 6499
                          : 499;

                try {
                    feedback.textContent = "Validating coupon...";
                    feedback.className =
                        "text-xs font-semibold text-gray-500 block";

                    const response = await fetch("/api/validate-coupon", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ code, basePrice }),
                    });

                    const data = await response.json();

                    if (response.ok && data.valid) {
                        window.activeCoupon = { code: data.code };
                        window.updatePricingDisplay();
                    } else {
                        window.activeCoupon = null;
                        window.updatePricingDisplay();
                        feedback.textContent =
                            data.error || "Invalid coupon code.";
                        feedback.className =
                            "text-xs font-semibold text-red-500 block";
                    }
                } catch (err) {
                    window.activeCoupon = null;
                    window.updatePricingDisplay();
                    feedback.textContent =
                        "Connection error. Please try again.";
                    feedback.className =
                        "text-xs font-semibold text-red-500 block";
                }
            };

            // Initialize from URL search parameters
            function initializeCheckout() {
                const params = new URLSearchParams(window.location.search);
                const courseName = params.get("course");
                const type = params.get("type");
                const mode = params.get("mode");

                if (mode === "full") {
                    window.checkoutMode = "full";
                    const sPrice = document.getElementById("btn-scholar-price");
                    const ePrice = document.getElementById("btn-elite-price");
                    if (sPrice) sPrice.textContent = "$3499";
                    if (ePrice) ePrice.textContent = "$6,499";
                } else {
                    window.checkoutMode = "registration";
                    const sPrice = document.getElementById("btn-scholar-price");
                    const ePrice = document.getElementById("btn-elite-price");
                    if (sPrice) sPrice.textContent = "$99";
                    if (ePrice) ePrice.textContent = "$499";
                }

                if (courseName) {
                    const displayCourse = document.getElementById(
                        "display-course-name",
                    );
                    if (displayCourse) displayCourse.textContent = courseName;
                }

                if (
                    type === "1on1" ||
                    (courseName &&
                        courseName.toLowerCase().includes("short term"))
                ) {
                    window.selectTier("1on1");
                } else {
                    window.selectTier("normal");
                }

                // Sync initial tab style
                window.switchTab("cc");
            }

            // Run on load
            initializeCheckout();

            // Attach submission handler
            const paymentForm = document.getElementById("payment-form");
            paymentForm?.addEventListener("submit", (e) => {
                e.preventDefault();

                const cardNumberInput = document.getElementById("card_number");
                const expiryInput = document.getElementById("expiry");
                const cvvInput = document.getElementById("cvv");
                const nameInput = document.getElementById("name");

                const cardNumber = (cardNumberInput?.value || "").trim();
                const expiry = (expiryInput?.value || "").trim();
                const cvv = (cvvInput?.value || "").trim();
                const name = (nameInput?.value || "").trim();

                if (!cardNumber || !expiry || !cvv || !name) {
                    alert("Please fill out all card payment details.");
                    return;
                }

                const totalVal =
                    document.getElementById("display-total-value")
                        ?.textContent || "$99.00";
                const submitBtn = paymentForm.querySelector(
                    'button[type="submit"]',
                );
                if (!submitBtn) return;
                const originalBtnContent = submitBtn.innerHTML;

                submitBtn.disabled = true;
                submitBtn.innerHTML = `<span>Processing Securely...</span>`;

                setTimeout(() => {
                    alert(
                        `Success! Payment of ${totalVal} has been processed.\nYour transaction ID is TXN-${Math.floor(100000 + Math.random() * 900000)}.`,
                    );
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalBtnContent;
                    window.location.href = "/";
                }, 1500);
            });

            // Card Input Masking & Validations
            const cardNumberInput = document.getElementById("card_number");
            const expiryInput = document.getElementById("expiry");
            const cvvInput = document.getElementById("cvv");
            const nameInput = document.getElementById("name");

            cardNumberInput?.addEventListener("input", (e) => {
                const target = e.target;
                if (!target) return;
                let value = target.value.replace(/\D/g, "");
                value = value.substring(0, 16);
                const formatted = value.match(/.{1,4}/g)?.join(" ") || value;
                target.value = formatted;
            });

            expiryInput?.addEventListener("input", (e) => {
                const target = e.target;
                if (!target) return;
                let value = target.value.replace(/\D/g, "");
                value = value.substring(0, 4);
                if (value.length > 2) {
                    target.value =
                        value.substring(0, 2) + " / " + value.substring(2);
                } else {
                    target.value = value;
                }
            });

            cvvInput?.addEventListener("input", (e) => {
                const target = e.target;
                if (!target) return;
                let value = target.value.replace(/\D/g, "");
                target.value = value.substring(0, 4);
            });

            nameInput?.addEventListener("input", (e) => {
                const target = e.target;
                if (!target) return;
                target.value = target.value.replace(/[^a-zA-Z\s]/g, "");
            });
        </script>
    </body>
</html>
