</div>
<!-- Repeating columns manually for visualization -->
<div class="flex flex-col gap-1"><div class="w-3 h-3 bg-primary rounded-sm"></div><div class="w-3 h-3 bg-surface-container rounded-sm"></div><div class="w-3 h-3 bg-surface-container rounded-sm"></div><div class="w-3 h-3 bg-primary/40 rounded-sm"></div><div class="w-3 h-3 bg-surface-container rounded-sm"></div><div class="w-3 h-3 bg-primary/60 rounded-sm"></div><div class="w-3 h-3 bg-surface-container rounded-sm"></div></div>
<div class="flex flex-col gap-1"><div class="w-3 h-3 bg-surface-container rounded-sm"></div><div class="w-3 h-3 bg-primary/10 rounded-sm"></div><div class="w-3 h-3 bg-surface-container rounded-sm"></div><div class="w-3 h-3 bg-primary/30 rounded-sm"></div><div class="w-3 h-3 bg-surface-container rounded-sm"></div><div class="w-3 h-3 bg-primary/50 rounded-sm"></div><div class="w-3 h-3 bg-surface-container rounded-sm"></div></div>
<div class="flex flex-col gap-1"><div class="w-3 h-3 bg-primary/80 rounded-sm"></div><div class="w-3 h-3 bg-primary/20 rounded-sm"></div><div class="w-3 h-3 bg-surface-container rounded-sm"></div><div class="w-3 h-3 bg-primary/40 rounded-sm"></div><div class="w-3 h-3 bg-surface-container rounded-sm"></div><div class="w-3 h-3 bg-primary/10 rounded-sm"></div><div class="w-3 h-3 bg-primary/60 rounded-sm"></div></div>
<div class="flex flex-col gap-1"><div class="w-3 h-3 bg-surface-container rounded-sm"></div><div class="w-3 h-3 bg-primary/10 rounded-sm"></div><div class="w-3 h-3 bg-surface-container rounded-sm"></div><div class="w-3 h-3 bg-primary/30 rounded-sm"></div><div class="w-3 h-3 bg-surface-container rounded-sm"></div><div class="w-3 h-3 bg-primary/50 rounded-sm"></div><div class="w-3 h-3 bg-surface-container rounded-sm"></div></div>
