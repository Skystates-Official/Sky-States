      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Geist:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />

    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Course",
        name: metaTitle,
        description: description,
        provider: {
          "@type": "EducationalOrganization",
          name: "Sky States",
          sameAs: "https://skystates.us",
