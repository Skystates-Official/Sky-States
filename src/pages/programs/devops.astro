---
import "../../styles/global.css";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import programsData from "../../data/programs.json";

const program = programsData["devops"];
const { metaTitle, hero } = program;
const description =
  hero?.description ||
  "Master DevOps & Cloud Architect competencies with our 6-month intensive training program.";
export const prerender = false;
