            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .sky-gradient-up {
            background: linear-gradient(to top, #ffffff, #d3e2ed);
        }
        .ambient-shadow {
            box-shadow: 0 10px 30px -5px rgba(15, 29, 37, 0.04);
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
        }
    </style>
