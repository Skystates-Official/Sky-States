---
import "../../styles/global.css";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ConsultationModal from "../../components/ConsultationModal.astro";
import { employerLogos } from "../../data/employer-logos.js";

export const prerender = false;
---

<!doctype html>
<html class="scroll-smooth" lang="en">
  <head>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>In-Person Tech Programs & Practical Labs | Sky States</title>
    <meta
      name="description"
      content="Accelerate your technology career with Sky States' offline classroom programs in Seattle (WA). Face-to-face mentoring, 100% lab infrastructure, and alumni placement networks."
    />
    <meta
      name="keywords"
      content="offline data science course, classroom training, data science training, cyber security classroom course, devops offline course, coding bootcamp in-person"
    />
    <link
      rel="canonical"
      href="https://skystates.us/programs/offline-classes"
    />

    <!-- OpenGraph -->
    <meta
      property="og:title"
      content="In-Person Tech Programs & Practical Labs | Sky States"
    />
    <meta
      property="og:description"
      content="Accelerate your career in Seattle with our offline classroom bootcamps. Face-to-face mentorship and dedicated lab infrastructure."
    />
    <meta property="og:image" content="/assets/noida_tech_classroom.png" />
    <meta property="og:type" content="website" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Geist:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />

    <style>
      .material-symbols-outlined {
        font-variation-settings:
          "FILL" 0,
          "wght" 400,
          "GRAD" 0,
          "opsz" 24;
      }
      .sky-gradient-text {
        background: linear-gradient(135deg, #005d90 0%, #0077b6 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .ambient-shadow {
        box-shadow: 0 20px 40px -15px rgba(0, 93, 144, 0.08);
      }
      .glass-card {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(16px);
        border: 1px border-slate-200/50;
      }
      /* Details summary arrow animation */
      details[open] summary span.arrow-icon {
        transform: rotate(180deg);
      }

      /* Infinite Marquee Scroll Right-to-Left */
      @keyframes marquee {
        0% {
          transform: translateX(0);
        }
        100% {
          transform: translateX(-50%);
        }
      }
      .animate-marquee {
        display: flex;
        width: max-content;
        animation: marquee 30s linear infinite;
      }
    </style>
  </head>
  <body class="bg-white text-slate-800 font-sans overflow-x-hidden">
    <Header />

    <!-- Spaced below the navbar to prevent content cutoff -->
    <main class="mt-18 md:mt-12 bg-white">
      <!-- HERO SECTION -->
      <section
        class="relative px-4 md:px-margin-desktop overflow-hidden py-12 md:py-20 bg-white"
      >
        <div
          class="max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-12 gap-12 items-center"
        >
          <!-- Left Content -->
          <div class="z-10 lg:col-span-7 flex flex-col gap-6">
            <h1
              class="text-4xl font-bold text-slate-900 tracking-tight leading-[1.1]"
            >
              Industry-Focused Classroom Training <br />
              <span class="text-sky-300">for Tech Professionalss</span>
            </h1>

            <p
              class="text-base sm:text-base text-slate-500 leading-relaxed max-w-xl"
            >
              Boost your career with the high-technology classroom experience.
              Leverage your career with hands-on labs and receive live weekend
              mentorship from active CTOs. Earn industry-recognized
              certifications with exam vouchers and access targeted placement
              opportunities- No SSN Collection required
            </p>

            <div
              class="grid grid-cols-1 sm:grid-cols-2 gap-4 my-2 test-base font-semibold text-slate-700"
            >
              <div class="flex items-center gap-3">
                <span
                  class="material-symbols-outlined text-sky-600 bg-sky-50 p-1.5 rounded-lg"
                  >workspace_premium</span
                >
                <span>Microsoft DP/SC/AZ-900 Prep</span>
              </div>
              <div class="flex items-center gap-3">
                <span
                  class="material-symbols-outlined text-sky-600 bg-sky-50 p-1.5 rounded-lg"
                  >speed</span
                >
                <span> Gigabit Workstations &amp; Server Labs</span>
              </div>
              <div class="flex items-center gap-3">
                <span
                  class="material-symbols-outlined text-sky-600 bg-sky-50 p-1.5 rounded-lg"
                  >diversity_3</span
                >
                <span>Face-to-Face Code Reviews</span>
              </div>
              <div class="flex items-center gap-3">
                <span
                  class="material-symbols-outlined text-sky-600 bg-sky-50 p-1.5 rounded-lg"
                  >business_center</span
                >
                <span>120+ Partner Placement Drive</span>
              </div>
            </div>

            <div class="flex flex-col sm:flex-row gap-4 mt-2">
              <a
                href="#curriculum-explorer"
                class="group flex items-center justify-center px-8 py-4 rounded-xl bg-gradient-to-r from-sky-600 to-blue-700 text-white test-base font-semibold hover:from-sky-500 hover:to-blue-600 hover:scale-[1.02] shadow-lg shadow-sky-600/15 hover:shadow-sky-600/25 active:scale-[0.98] transition-all duration-200 text-center"
              >
                <span>Explore our Programs </span>
                <span
                  class="material-symbols-outlined text-lg ml-2 font-bold transition-transform duration-200 group-hover:translate-x-1"
                  >arrow_forward</span
                >
              </a>
              <a
                href="#centers"
                class="group flex items-center justify-center px-8 py-4 rounded-xl text-sky-700 bg-sky-50 border border-sky-200/80 hover:bg-sky-50 hover:border-sky-300 hover:scale-[1.02] active:scale-[0.98] transition-all duration-200 font-semibold text-center"
              >
                <span>Visit our Training Centers</span>
              </a>
            </div>
          </div>

          <!-- Right: Premium Classroom Video -->
          <div
            class="relative w-full max-w-2xl mx-auto lg:mx-0 lg:col-span-5 mt-8 lg:mt-0"
          >
            <div
              class="absolute -inset-4 bg-gradient-to-tr from-sky-400/10 to-blue-500/15 blur-3xl opacity-75 rounded-full pointer-events-none"
            >
            </div>

            <div
              class="relative p-1.5 bg-slate-105 rounded-[24px] shadow-xl border border-slate-200 overflow-hidden"
            >
              <video
                autoplay
                loop
                muted
                playsinline
                class="relative rounded-[18px] w-full aspect-video object-cover"
              >
                <source
                  src="/assets/videos/offileline_classes.mp4"
                  type="video/mp4"
                />
                Your browser does not support the video tag.
              </video>
            </div>
          </div>
        </div>
      </section>

      <!-- BRAND TRUST MARQUEE -->
      <section
        class="py-10 bg-white border-y border-slate-200/50 overflow-hidden"
      >
        <div class="max-w-7xl mx-auto px-4 md:px-margin-desktop text-center">
          <p
            class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-6"
          >
            Careers At Leading Tech Companies
          </p>

          <div class="relative w-full overflow-hidden flex items-center">
            <div
              class="flex items-center gap-16 animate-marquee whitespace-nowrap"
            >
              <!-- First Set -->
              <div class="flex items-center gap-16 shrink-0">
                {
                  employerLogos.map((logo) => (
                    <img
                      src={logo.src}
                      alt={logo.name}
                      class="h-8 object-contain opacity-50 grayscale hover:opacity-100 hover:grayscale-0 transition-all duration-300"
                    />
                  ))
                }
              </div>
              <!-- Duplicated Set for Seamless Loop -->
              <div class="flex items-center gap-16 shrink-0" aria-hidden="true">
                {
                  employerLogos.map((logo) => (
                    <img
                      src={logo.src}
                      alt={logo.name}
                      class="h-8 object-contain opacity-50 grayscale hover:opacity-100 hover:grayscale-0 transition-all duration-300"
                    />
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- INTERACTIVE CURRICULUM SELECTOR (IIT DELHI / COURSERA STYLE) -->
      <section
        id="curriculum-explorer"
        class="py-16 md:py-24 px-4 md:px-margin-desktop bg-white"
      >
        <div class="max-w-7xl mx-auto">
          <div class="text-center max-w-3xl mx-auto mb-16 flex flex-col gap-3">
            <h3 class="text-4xl font-bold text-slate-900 tracking-tight">
              Explore our Hands-On Training Programs
            </h3>
            <p
              class="test-base sm:text-base text-slate-500 leading-relaxed max-w-2xl mx-auto"
            >
              Choose the program that fits your career goals. Compare
              curriculum, duration, technology stacks, certifications, and
              placement support.
            </p>
          </div>

          <!-- Interactive Switcher Tab Container -->
          <div class="flex flex-col gap-10">
            <!-- Tabs Headers -->
            <div
              class="flex justify-center border-b border-slate-200 max-w-2xl mx-auto w-full gap-2 sm:gap-6"
            >
              <button
                class="tab-btn pb-4 px-4 test-base sm:text-base font-bold text-sky-600 border-b-2 border-sky-600 transition-all focus:outline-none"
                data-tab="ds-ai"
              >
                Data Science &amp; AI
              </button>
              <button
                class="tab-btn pb-4 px-4 test-base sm:text-base font-medium text-slate-400 border-b-2 border-transparent hover:text-slate-600 transition-all focus:outline-none"
                data-tab="cyber"
              >
                Cyber Security
              </button>
              <button
                class="tab-btn pb-4 px-4 test-base sm:text-base font-medium text-slate-400 border-b-2 border-transparent hover:text-slate-600 transition-all focus:outline-none"
                data-tab="devops"
              >
                DevOps &amp; Cloud
              </button>
            </div>

            <!-- Tabs Content (Full White Panels with Light Slate Borders) -->
            <div class="w-full transition-all">
              <!-- TAB 1: Data Science & AI -->
              <div
                id="tab-ds-ai"
                class="tab-pane grid grid-cols-1 lg:grid-cols-12 gap-12 items-start"
              >
                <!-- Left Column: Video, Details, and Buttons -->
                <div class="lg:col-span-5 flex flex-col gap-6">
                  <!-- Video Frame -->
                  <div
                    class="p-1 bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm"
                  >
                    <img
                      src="/assets/images/DS_and_AI.png"
                      alt="Data Science & AI"
                      class="relative rounded-xl w-full aspect-video object-cover"
                    />
                  </div>

                  <!-- Metadata Details -->
                  <div class="flex flex-col gap-4">
                    <span
                      class="px-2.5 py-1 bg-sky-50 text-sky-700 rounded text-xs font-bold uppercase w-fit tracking-wider"
                      >In-person Class</span
                    >
                    <h4 class="text-2.5xl font-bold text-slate-900">
                      Data Science &amp; AI Architect
                    </h4>
                    <p class="test-base text-slate-500 leading-relaxed">
                      A comprehensive weekend classroom program covering the
                      mathematical foundations of deep learning and
                      petabyte-scale distributed computing.
                    </p>

                    <div
                      class="border-y border-slate-200/60 py-4 grid grid-cols-3 gap-4 text-xs font-bold text-slate-500 uppercase tracking-wide"
                    >
                      <div>
                        <p class="text-slate-400">Duration</p>
                        <p class="text-slate-800 test-base mt-0.5">16 Weeks</p>
                      </div>
                      <div>
                        <p class="text-slate-400">Lectures</p>
                        <p
                          class="text-slate-800 test-base mt-0.5 font-semibold"
                        >
                          In-Person Labs
                        </p>
                      </div>
                      <!-- <div>
                        <p class="text-slate-400">Course Fee</p>
                        <p class="text-sky-700 test-base mt-0.5 font-bold">
                          $9,999
                        </p>
                      </div> -->
                    </div>

                    <div class="space-y-3 mt-2">
                      <h5
                        class="text-xs font-bold uppercase tracking-widest text-slate-450"
                      >
                        Program Highlights:
                      </h5>
                      <div class="space-y-2 test-base text-slate-700">
                        <div class="flex items-center gap-3">
                          <span class="h-2 w-2 bg-sky-500 rounded-full"></span> Python
                          Programming for Data Science
                        </div>
                        <div class="flex items-center gap-3">
                          <span class="h-2 w-2 bg-sky-500 rounded-full"></span> Data
                          Visualization Techniques
                        </div>
                        <div class="flex items-center gap-3">
                          <span class="h-2 w-2 bg-sky-500 rounded-full"></span> Machine
                          Learning Algorithms
                        </div>
                        <div class="flex items-center gap-3">
                          <span class="h-2 w-2 bg-sky-500 rounded-full"></span> Deep
                          Learning Fundamentals
                        </div>
                      </div>
                    </div>
                    <div class="space-y-3 mt-2">
                      <h5
                        class="text-xs font-bold uppercase tracking-widest text-slate-450"
                      >
                        Career Opportunities:
                      </h5>
                      <div class="space-y-2 test-base text-slate-700">
                        <div class="flex items-center gap-3">
                          <span class="h-2 w-2 bg-sky-500 rounded-full"
                          ></span>Data Analyst
                        </div>
                        <div class="flex items-center gap-3">
                          <span class="h-2 w-2 bg-sky-500 rounded-full"></span> Data
                          Scientist
                        </div>
                        <div class="flex items-center gap-3">
                          <span class="h-2 w-2 bg-sky-500 rounded-full"></span> Machine
                          Learning Engineer
                        </div>
                      </div>
                    </div>

                    <div class="flex flex-col sm:flex-row gap-4 mt-4">
                      <button
                        type="button"
                        data-trigger-consultation
                        data-program="Data Science & AI"
                        class="flex-1 px-6 py-3.5 bg-gradient-to-r from-sky-600 to-blue-700 text-white rounded-xl test-base font-semibold hover:from-sky-500 hover:to-blue-600 transition-all text-center shadow-md active:scale-[0.98] cursor-pointer"
                      >
                        Get Started Today
                      </button>
                      <a
                        href="/Data-Science-&-AI.pdf"
                        target="_blank"
                        class="flex-1 px-6 py-3.5 border border-sky-600 text-sky-700 rounded-xl test-base font-semibold hover:bg-sky-50 transition-colors text-center"
                      >
                        Download Curriculum
                      </a>
                    </div>
                  </div>
                </div>

                <!-- Right Column: Program Curriculum Architecture -->
                <div class="lg:col-span-7 space-y-4">
                  <div class="mb-6">
                    <span
                      class="text-xs font-bold text-sky-700 uppercase tracking-widest block"
                      >Syllabus Details</span
                    >
                    <h5 class="text-2xl font-bold text-slate-900 mt-1">
                      Program Curriculum Architecture
                    </h5>
                  </div>

                  <div class="space-y-3.5">
                    <details
                      class="group bg-white border border-slate-200 rounded-xl p-5 transition-all duration-300"
                      open
                    >
                      <summary
                        class="flex justify-between items-center cursor-pointer list-none"
                      >
                        <span
                          class="text-base font-bold text-slate-805 flex items-center gap-4"
                        >
                          <span class="text-sky-600 font-bold text-lg">01</span> Python
                          Core Concepts
                        </span>
                        <span
                          class="material-symbols-outlined text-slate-400 group-open:text-sky-600 group-open:rotate-180 transition-transform arrow-icon"
                          >expand_more</span
                        >
                      </summary>
                      <div
                        class="mt-4 pt-4 border-t border-slate-100 text-slate-650 space-y-3 test-base leading-relaxed"
                      >
                        <p>
                          Develop a foundation in Python by learning the main
                          concepts, containing syntax, variables, data
                          structures, loops, and functions. Attain the coding
                          skills required to develop applications and tasks, and
                          start your journey in data science and artificial
                          intelligence.
                        </p>
                        <div class="flex flex-wrap gap-2 pt-2">
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Python</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Syntax</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Variables</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Data Structures</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Loops</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Functions</span
                          >
                        </div>
                      </div>
                    </details>

                    <details
                      class="group bg-white border border-slate-200 rounded-xl p-5 transition-all duration-300"
                    >
                      <summary
                        class="flex justify-between items-center cursor-pointer list-none"
                      >
                        <span
                          class="text-base font-bold text-slate-805 flex items-center gap-4"
                        >
                          <span class="text-sky-600 font-bold text-lg">02</span> Python
                          Libraries and Exploratory Data Analysis
                        </span>
                        <span
                          class="material-symbols-outlined text-slate-400 group-open:text-sky-600 group-open:rotate-180 transition-transform arrow-icon"
                          >expand_more</span
                        >
                      </summary>
                      <div
                        class="mt-4 pt-4 border-t border-slate-100 text-slate-650 space-y-3 test-base leading-relaxed"
                      >
                        <p>
                          Discover important Python libraries like NumPy,
                          Pandas, Matplotlib, and Seaborn to clean, change,
                          analyze, and visualize data. Learn EDA techniques to
                          find patterns, anomalies and prepare datasets for
                          machine learning and predictive analysis.
                        </p>
                        <div class="flex flex-wrap gap-2 pt-2">
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >NumPy</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Pandas</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Matplotlib</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Seaborn</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >EDA</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Data Visualization</span
                          >
                        </div>
                      </div>
                    </details>

                    <details
                      class="group bg-white border border-slate-200 rounded-xl p-5 transition-all duration-300"
                    >
                      <summary
                        class="flex justify-between items-center cursor-pointer list-none"
                      >
                        <span
                          class="text-base font-bold text-slate-805 flex items-center gap-4"
                        >
                          <span class="text-sky-600 font-bold text-lg">03</span> Mathematics
                          for Data Science
                        </span>
                        <span
                          class="material-symbols-outlined text-slate-400 group-open:text-sky-600 group-open:rotate-180 transition-transform arrow-icon"
                          >expand_more</span
                        >
                      </summary>
                      <div
                        class="mt-4 pt-4 border-t border-slate-100 text-slate-650 space-y-3 test-base leading-relaxed"
                      >
                        <p>
                          Learn the important mathematical and statistical
                          methods used in data science. Understand how to
                          analyze datasets, find patterns, and develop accurate
                          predictive models using quantitative approaches.
                        </p>
                        <div class="flex flex-wrap gap-2 pt-2">
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Probability</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Hypothesis Testing</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Regression Analysis</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Statistics</span
                          >
                        </div>
                      </div>
                    </details>

                    <details
                      class="group bg-white border border-slate-200 rounded-xl p-5 transition-all duration-300"
                    >
                      <summary
                        class="flex justify-between items-center cursor-pointer list-none"
                      >
                        <span
                          class="text-base font-bold text-slate-805 flex items-center gap-4"
                        >
                          <span class="text-sky-600 font-bold text-lg">04</span> Supervised
                          Machine Learning Techniques
                        </span>
                        <span
                          class="material-symbols-outlined text-slate-400 group-open:text-sky-600 group-open:rotate-180 transition-transform arrow-icon"
                          >expand_more</span
                        >
                      </summary>
                      <div
                        class="mt-4 pt-4 border-t border-slate-100 text-slate-650 space-y-3 test-base leading-relaxed"
                      >
                        <p>
                          Develop an understanding of supervised machine
                          learning by working with labeled datasets and widely
                          used algorithms like Linear Regression, Logistic
                          Regression, Decision Trees, Random Forest, Support
                          Vector Machines, and K-Nearest Neighbors. Learn how to
                          generate dependable predictive models and estimate
                          performance utilizing practical datasets.
                        </p>
                        <div class="flex flex-wrap gap-2 pt-2">
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Linear Regression</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Logistic Regression</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Decision Trees</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Random Forest</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >SVM</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >KNN</span
                          >
                        </div>
                      </div>
