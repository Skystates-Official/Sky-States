---
import "../../styles/global.css";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { employerLogos } from "../../data/employer-logos.js";

export const prerender = false;
---

<!doctype html>
<html class="scroll-smooth" lang="en">
  <head>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>In-Person Tech Programs & Practical Labs | Sky States</title>
    <meta
      name="description"
      content="Accelerate your technology career with Sky States' offline classroom programs in Seattle (WA). Face-to-face mentoring, 100% lab infrastructure, and alumni placement networks."
    />
    <meta
      name="keywords"
      content="offline data science course, classroom training, data science training, cyber security classroom course, devops offline course, coding bootcamp in-person"
    />
    <link
      rel="canonical"
      href="https://skystates.us/programs/offline-classes"
    />

    <!-- OpenGraph -->
    <meta
      property="og:title"
      content="In-Person Tech Programs & Practical Labs | Sky States"
    />
    <meta
      property="og:description"
      content="Accelerate your career in Seattle with our offline classroom bootcamps. Face-to-face mentorship and dedicated lab infrastructure."
    />
    <meta property="og:image" content="/assets/noida_tech_classroom.png" />
    <meta property="og:type" content="website" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Geist:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />

    <style>
      .material-symbols-outlined {
        font-variation-settings:
          "FILL" 0,
          "wght" 400,
          "GRAD" 0,
          "opsz" 24;
      }
      .sky-gradient-text {
        background: linear-gradient(135deg, #005d90 0%, #0077b6 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .ambient-shadow {
        box-shadow: 0 20px 40px -15px rgba(0, 93, 144, 0.08);
      }
      .glass-card {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(16px);
        border: 1px border-slate-200/50;
      }
      /* Details summary arrow animation */
      details[open] summary span.arrow-icon {
        transform: rotate(180deg);
      }

      /* Infinite Marquee Scroll Right-to-Left */
      @keyframes marquee {
        0% {
          transform: translateX(0);
        }
        100% {
          transform: translateX(-50%);
        }
      }
      .animate-marquee {
        display: flex;
        width: max-content;
        animation: marquee 30s linear infinite;
      }
    </style>
  </head>
  <body class="bg-white text-slate-800 font-sans overflow-x-hidden">
    <Header />

    <!-- Spaced below the navbar to prevent content cutoff -->
    <main class="mt-18 md:mt-12 bg-white">
      <!-- HERO SECTION -->
      <section
        class="relative px-4 md:px-margin-desktop overflow-hidden py-12 md:py-20 bg-white"
      >
        <div
          class="max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-12 gap-12 items-center"
        >
          <!-- Left Content -->
          <div class="z-10 lg:col-span-7 flex flex-col gap-6">
            <h1
              class="text-4xl font-bold text-slate-900 tracking-tight leading-[1.1]"
            >
              Elite Classroom Training <br />
              <span class="text-sky-300">For Professional Tech Roles</span>
            </h1>

            <p
              class="text-sm sm:text-base text-slate-500 leading-relaxed max-w-xl"
            >
              Accelerate your pivot into high-prestige technology positions.
              Learn in modern physical labs with live weekend guidance from
              active CTOs. No-SSN collection, real certification vouchers, and
              targeted corporate placement pipelines.
            </p>

            <div
              class="grid grid-cols-1 sm:grid-cols-2 gap-4 my-2 text-sm font-semibold text-slate-700"
            >
              <div class="flex items-center gap-3">
                <span
                  class="material-symbols-outlined text-sky-600 bg-sky-50 p-1.5 rounded-lg"
                  >workspace_premium</span
                >
                <span>Microsoft DP/SC/AZ-900 Prep</span>
              </div>
              <div class="flex items-center gap-3">
                <span
                  class="material-symbols-outlined text-sky-600 bg-sky-50 p-1.5 rounded-lg"
                  >speed</span
                >
                <span>Gigabit Workstations &amp; Server Labs</span>
              </div>
              <div class="flex items-center gap-3">
                <span
                  class="material-symbols-outlined text-sky-600 bg-sky-50 p-1.5 rounded-lg"
                  >diversity_3</span
                >
                <span>Face-to-Face Code Reviews</span>
              </div>
              <div class="flex items-center gap-3">
                <span
                  class="material-symbols-outlined text-sky-600 bg-sky-50 p-1.5 rounded-lg"
                  >business_center</span
                >
                <span>120+ Partner Placement Drive</span>
              </div>
            </div>

            <div class="flex flex-col sm:flex-row gap-4 mt-2">
              <a
                href="#curriculum-explorer"
                class="group flex items-center justify-center px-8 py-4 rounded-xl bg-gradient-to-r from-sky-600 to-blue-700 text-white text-sm font-semibold hover:from-sky-500 hover:to-blue-600 hover:scale-[1.02] shadow-lg shadow-sky-600/15 hover:shadow-sky-600/25 active:scale-[0.98] transition-all duration-200 text-center"
              >
                <span>Explore &amp; Enroll Now</span>
                <span
                  class="material-symbols-outlined text-lg ml-2 font-bold transition-transform duration-200 group-hover:translate-x-1"
                  >arrow_forward</span
                >
              </a>
              <a
                href="#centers"
                class="group flex items-center justify-center px-8 py-4 rounded-xl text-sky-700 bg-sky-50 border border-sky-200/80 hover:bg-sky-50 hover:border-sky-300 hover:scale-[1.02] active:scale-[0.98] transition-all duration-200 font-semibold text-center"
              >
                <span>Find Physical Center</span>
              </a>
            </div>
          </div>

          <!-- Right: Premium Classroom Video -->
          <div
            class="relative w-full max-w-2xl mx-auto lg:mx-0 lg:col-span-5 mt-8 lg:mt-0"
          >
            <div
              class="absolute -inset-4 bg-gradient-to-tr from-sky-400/10 to-blue-500/15 blur-3xl opacity-75 rounded-full pointer-events-none"
            >
            </div>

            <div
              class="relative p-1.5 bg-slate-105 rounded-[24px] shadow-xl border border-slate-200 overflow-hidden"
            >
              <video
                autoplay
                loop
                muted
                playsinline
                class="relative rounded-[18px] w-full aspect-video object-cover"
              >
                <source
                  src="/assets/videos/offileline_classes.mp4"
                  type="video/mp4"
                />
                Your browser does not support the video tag.
              </video>
            </div>
          </div>
        </div>
      </section>

      <!-- BRAND TRUST MARQUEE -->
      <section
        class="py-10 bg-white border-y border-slate-200/50 overflow-hidden"
      >
        <div class="max-w-7xl mx-auto px-4 md:px-margin-desktop text-center">
          <p
            class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-6"
          >
            Our Graduates Work At Top Global Technology Firms
          </p>

          <div class="relative w-full overflow-hidden flex items-center">
            <div
              class="flex items-center gap-16 animate-marquee whitespace-nowrap"
            >
              <!-- First Set -->
              <div class="flex items-center gap-16 shrink-0">
                {
                  employerLogos.map((logo) => (
                    <img
                      src={logo.src}
                      alt={logo.name}
                      class="h-8 object-contain opacity-50 grayscale hover:opacity-100 hover:grayscale-0 transition-all duration-300"
                    />
                  ))
                }
              </div>
              <!-- Duplicated Set for Seamless Loop -->
              <div class="flex items-center gap-16 shrink-0" aria-hidden="true">
                {
                  employerLogos.map((logo) => (
                    <img
                      src={logo.src}
                      alt={logo.name}
                      class="h-8 object-contain opacity-50 grayscale hover:opacity-100 hover:grayscale-0 transition-all duration-300"
                    />
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- INTERACTIVE CURRICULUM SELECTOR (IIT DELHI / COURSERA STYLE) -->
      <section
        id="curriculum-explorer"
        class="py-16 md:py-24 px-4 md:px-margin-desktop bg-white"
      >
        <div class="max-w-7xl mx-auto">
          <div class="text-center max-w-3xl mx-auto mb-16 flex flex-col gap-3">
            <h3 class="text-4xl font-bold text-slate-900 tracking-tight">
              Explore Our Offline Programs
            </h3>
            <p
              class="text-sm sm:text-base text-slate-500 leading-relaxed max-w-2xl mx-auto"
            >
              Compare our structured physical classroom programs. Switch tabs to
              preview curricula, duration, stack, and salary goals.
            </p>
          </div>

          <!-- Interactive Switcher Tab Container -->
          <div class="flex flex-col gap-10">
            <!-- Tabs Headers -->
            <div
              class="flex justify-center border-b border-slate-200 max-w-2xl mx-auto w-full gap-2 sm:gap-6"
            >
              <button
                class="tab-btn pb-4 px-4 text-sm sm:text-base font-bold text-sky-600 border-b-2 border-sky-600 transition-all focus:outline-none"
                data-tab="ds-ai"
              >
                Data Science &amp; AI
              </button>
              <button
                class="tab-btn pb-4 px-4 text-sm sm:text-base font-medium text-slate-400 border-b-2 border-transparent hover:text-slate-600 transition-all focus:outline-none"
                data-tab="cyber"
              >
                Cyber Security
              </button>
              <button
                class="tab-btn pb-4 px-4 text-sm sm:text-base font-medium text-slate-400 border-b-2 border-transparent hover:text-slate-600 transition-all focus:outline-none"
                data-tab="devops"
              >
                DevOps &amp; Cloud
              </button>
            </div>

            <!-- Tabs Content (Full White Panels with Light Slate Borders) -->
            <div class="w-full transition-all">
              <!-- TAB 1: Data Science & AI -->
              <div
                id="tab-ds-ai"
                class="tab-pane grid grid-cols-1 lg:grid-cols-12 gap-12 items-start"
              >
                <!-- Left Column: Video, Details, and Buttons -->
                <div class="lg:col-span-5 flex flex-col gap-6">
                  <!-- Video Frame -->
                  <div
                    class="p-1 bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm"
                  >
                    <video
                      autoplay
                      loop
                      muted
                      playsinline
                      class="relative rounded-xl w-full aspect-video object-cover"
                    >
                      <source
                        src="/assets/videos/data%20science%20hero%20section%20video.mp4"
                        type="video/mp4"
                      />
                    </video>
                  </div>

                  <!-- Metadata Details -->
                  <div class="flex flex-col gap-4">
                    <span
                      class="px-2.5 py-1 bg-sky-50 text-sky-700 rounded text-xs font-bold uppercase w-fit tracking-wider"
                      >In-Person Masterclass</span
                    >
                    <h4 class="text-2.5xl font-bold text-slate-900">
                      Data Science &amp; AI Architect
                    </h4>
                    <p class="text-sm text-slate-500 leading-relaxed">
                      A comprehensive, weekends-led physical program mapping
                      mathematical foundations of deep learning to
                      petabyte-scale distributed computing.
                    </p>

                    <div
                      class="border-y border-slate-200/60 py-4 grid grid-cols-3 gap-4 text-xs font-bold text-slate-500 uppercase tracking-wide"
                    >
                      <div>
                        <p class="text-slate-400">Duration</p>
                        <p class="text-slate-800 text-sm mt-0.5">16 Weeks</p>
                      </div>
                      <div>
                        <p class="text-slate-400">Lectures</p>
                        <p class="text-slate-800 text-sm mt-0.5 font-semibold">
                          In-Person Labs
                        </p>
                      </div>
                      <div>
                        <p class="text-slate-400">Tuition Fee</p>
                        <p class="text-sky-700 text-sm mt-0.5 font-bold">
                          $9,999
                        </p>
                      </div>
                    </div>

                    <div class="space-y-3 mt-2">
                      <h5
                        class="text-xs font-bold uppercase tracking-widest text-slate-450"
                      >
                        Core Lab Modules:
                      </h5>
                      <div class="space-y-2 text-sm text-slate-700">
                        <div class="flex items-center gap-3">
                          <span class="h-2 w-2 bg-sky-500 rounded-full"></span> Neural
                          Networks, PyTorch &amp; CUDA implementations
                        </div>
                        <div class="flex items-center gap-3">
                          <span class="h-2 w-2 bg-sky-500 rounded-full"></span> Generative
                          AI, LangChain LLM orchestration, agent building
                        </div>
                        <div class="flex items-center gap-3">
                          <span class="h-2 w-2 bg-sky-500 rounded-full"></span> Distributed
                          computing via Apache Spark &amp; Kafka pipelines
                        </div>
                      </div>
                    </div>

                    <div class="flex flex-col sm:flex-row gap-4 mt-4">
                      <a
                        href="/checkout?course=Data+Science+%26+AI+Offline+Classroom&mode=offline&type=normal"
                        class="flex-1 px-6 py-3.5 bg-gradient-to-r from-sky-600 to-blue-700 text-white rounded-xl text-sm font-semibold hover:from-sky-500 hover:to-blue-600 transition-all text-center shadow-md active:scale-[0.98]"
                      >
                        Enroll in Program
                      </a>
                      <a
                        href="/Data-Science-&-AI.pdf"
                        target="_blank"
                        class="flex-1 px-6 py-3.5 border border-sky-600 text-sky-700 rounded-xl text-sm font-semibold hover:bg-sky-50 transition-colors text-center"
                      >
                        Download Curriculum
                      </a>
                    </div>
                  </div>
                </div>

                <!-- Right Column: Program Curriculum Architecture -->
                <div class="lg:col-span-7 space-y-4">
                  <div class="mb-6">
                    <span
                      class="text-xs font-bold text-sky-700 uppercase tracking-widest block"
                      >Syllabus Details</span
                    >
                    <h5 class="text-2xl font-bold text-slate-900 mt-1">
                      Program Curriculum Architecture
                    </h5>
                  </div>

                  <div class="space-y-3.5">
                    <details
                      class="group bg-white border border-slate-200 rounded-xl p-5 transition-all duration-300"
                      open
                    >
                      <summary
                        class="flex justify-between items-center cursor-pointer list-none"
                      >
                        <span
                          class="text-base font-bold text-slate-805 flex items-center gap-4"
                        >
                          <span class="text-sky-600 font-bold text-lg">01</span> Python
                          Programming
                        </span>
                        <span
                          class="material-symbols-outlined text-slate-400 group-open:text-sky-600 group-open:rotate-180 transition-transform arrow-icon"
                          >expand_more</span
                        >
                      </summary>
                      <div
                        class="mt-4 pt-4 border-t border-slate-100 text-slate-650 space-y-3 text-sm leading-relaxed"
                      >
                        <p>
                          Learn the fundamentals of Python, a versatile and
                          powerful programming language. This module covers
                          essential concepts like syntax, data types, control
                          structures, and functions, laying the foundation for
                          data science and software development.
                        </p>
                        <div class="flex flex-wrap gap-2 pt-2">
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Python</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Syntax</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Functions</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Programming Foundations</span
                          >
                        </div>
                      </div>
                    </details>

                    <details
                      class="group bg-white border border-slate-200 rounded-xl p-5 transition-all duration-300"
                    >
                      <summary
                        class="flex justify-between items-center cursor-pointer list-none"
                      >
                        <span
                          class="text-base font-bold text-slate-805 flex items-center gap-4"
                        >
                          <span class="text-sky-600 font-bold text-lg">02</span> Libraries
                          of Python Programming with EDA
                        </span>
                        <span
                          class="material-symbols-outlined text-slate-400 group-open:text-sky-600 group-open:rotate-180 transition-transform arrow-icon"
                          >expand_more</span
                        >
                      </summary>
                      <div
                        class="mt-4 pt-4 border-t border-slate-100 text-slate-650 space-y-3 text-sm leading-relaxed"
                      >
                        <p>
                          Dive into essential Python libraries like NumPy,
                          Pandas, and Matplotlib. Learn to perform Exploratory
                          Data Analysis (EDA) to uncover insights, visualize
                          trends, and prepare datasets for advanced analytics
                          and modeling.
                        </p>
                        <div class="flex flex-wrap gap-2 pt-2">
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >NumPy</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Pandas</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Matplotlib</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >EDA</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Data Visualization</span
                          >
                        </div>
                      </div>
                    </details>

                    <details
                      class="group bg-white border border-slate-200 rounded-xl p-5 transition-all duration-300"
                    >
                      <summary
                        class="flex justify-between items-center cursor-pointer list-none"
                      >
                        <span
                          class="text-base font-bold text-slate-805 flex items-center gap-4"
                        >
                          <span class="text-sky-600 font-bold text-lg">03</span> Mathematics
                          for Data Science
                        </span>
                        <span
                          class="material-symbols-outlined text-slate-400 group-open:text-sky-600 group-open:rotate-180 transition-transform arrow-icon"
                          >expand_more</span
                        >
                      </summary>
                      <div
                        class="mt-4 pt-4 border-t border-slate-100 text-slate-650 space-y-3 text-sm leading-relaxed"
                      >
                        <p>
                          Master statistical concepts like probability,
                          hypothesis testing, and regression analysis. Learn to
                          interpret data trends, make data-driven decisions, and
                          build a strong foundation for machine learning models.
                        </p>
                        <div class="flex flex-wrap gap-2 pt-2">
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Probability</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Hypothesis Testing</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Regression Analysis</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Statistics</span
                          >
                        </div>
                      </div>
                    </details>

                    <details
                      class="group bg-white border border-slate-200 rounded-xl p-5 transition-all duration-300"
                    >
                      <summary
                        class="flex justify-between items-center cursor-pointer list-none"
                      >
                        <span
                          class="text-base font-bold text-slate-805 flex items-center gap-4"
                        >
                          <span class="text-sky-600 font-bold text-lg">04</span> Machine
                          Learning- Supervised
                        </span>
                        <span
                          class="material-symbols-outlined text-slate-400 group-open:text-sky-600 group-open:rotate-180 transition-transform arrow-icon"
                          >expand_more</span
                        >
                      </summary>
                      <div
                        class="mt-4 pt-4 border-t border-slate-100 text-slate-650 space-y-3 text-sm leading-relaxed"
                      >
                        <p>
                          Learn the fundamentals of supervised learning, where
                          models are trained on labeled data to predict
                          outcomes. Explore key algorithms like linear
                          regression, decision trees, and support vector
                          machines for real-world problem-solving.
                        </p>
                        <div class="flex flex-wrap gap-2 pt-2">
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Supervised Learning</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Linear Regression</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Decision Trees</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >SVM</span
                          >
                        </div>
                      </div>
                    </details>

                    <details
                      class="group bg-white border border-slate-200 rounded-xl p-5 transition-all duration-300"
                    >
                      <summary
                        class="flex justify-between items-center cursor-pointer list-none"
                      >
                        <span
                          class="text-base font-bold text-slate-805 flex items-center gap-4"
                        >
                          <span class="text-sky-600 font-bold text-lg">05</span> Machine
                          Learning- Unsupervised
                        </span>
                        <span
                          class="material-symbols-outlined text-slate-400 group-open:text-sky-600 group-open:rotate-180 transition-transform arrow-icon"
                          >expand_more</span
                        >
                      </summary>
                      <div
                        class="mt-4 pt-4 border-t border-slate-100 text-slate-650 space-y-3 text-sm leading-relaxed"
                      >
                        <p>
                          Dive into unsupervised learning, where models analyze
                          unlabeled data to uncover hidden patterns. Explore
                          clustering, association, and dimensionality reduction
                          techniques like k-means and PCA for data exploration
                          and insights.
                        </p>
                        <div class="flex flex-wrap gap-2 pt-2">
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Unsupervised Learning</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >Clustering</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >PCA</span
                          >
                          <span
                            class="px-2.5 py-1 bg-sky-50 text-sky-705 text-xs font-semibold rounded border border-sky-100/50"
                            >K-Means</span
                          >
                        </div>
                      </div>
                    </details>

                    <details
                      class="group bg-white border border-slate-200 rounded-xl p-5 transition-all duration-300"
