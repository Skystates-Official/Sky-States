<meta property="og:description" content={description} />
<meta property="og:type" content="website" />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Course",
  "name": metaTitle,
  "description": description,
  "provider": {
    "@type": "EducationalOrganization",
    "name": "Sky States",
    "sameAs": "https://skystates.us"
  }
})} />

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>

<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .sky-gradient-up {
            background: linear-gradient(to top, #ffffff, #d3e2ed);
        }
        .ambient-shadow {
            box-shadow: 0 10px 30px -5px rgba(15, 29, 37, 0.04);
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
        }
    </style>

<script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [{
        "@type": "Question",
        "name": "Is the Microsoft exam fee included?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, the Sky States program fee includes one attempt voucher for the Microsoft DP-900: Azure Data Fundamentals certification."
