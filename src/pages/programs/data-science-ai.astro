---
import "../../styles/global.css";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import programsData from "../../data/programs.json";

const program = programsData["data-science-ai"];
const { metaTitle, hero } = program;
const description =
  hero?.description ||
  "Master Data Science & AI Architect competencies with our 6-month intensive training program.";
export const prerender = false;
---

<!doctype html>
<html class="scroll-smooth" lang="en">
  <head>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>{metaTitle}</title>
    <meta name="description" content={description} />
    <link
      rel="canonical"
      href="https://skystates.us/programs/data-science-ai"
    />
    <meta property="og:title" content={metaTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Geist:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />

    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Course",
        name: metaTitle,
        description: description,
        provider: {
          "@type": "EducationalOrganization",
          name: "Sky States",
          sameAs: "https://skystates.us",
        },
      })}
    />

    <style>
      .material-symbols-outlined {
        font-variation-settings:
          "FILL" 0,
          "wght" 400,
          "GRAD" 0,
          "opsz" 24;
      }
      .sky-gradient-up {
        background: linear-gradient(to top, #ffffff, #d3e2ed);
      }
      .ambient-shadow {
        box-shadow: 0 10px 30px -5px rgba(15, 29, 37, 0.04);
      }
      .glass-card {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(12px);
      }
    </style>

    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Is the Microsoft exam fee included?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes, the Sky States program fee includes one attempt voucher for the Microsoft DP-900: Azure Data Fundamentals certification."
            }
          },
          {
            "@type": "Question",
            "name": "What is the refund policy?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "We offer a 100% satisfaction guarantee with a full refund available within the first 14 days of the program start date."
            }
          },
          {
            "@type": "Question",
            "name": "Do I need prior coding experience?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Candidates should have a basic proficiency in Python. We provide a pre-bootcamp 'Python for Data' module for those who need a refresher."
            }
          }
        ]
      }
    </script>
  </head>
  <body class="bg-white text-slate-800 font-sans overflow-x-hidden">
    <!-- TopAppBar -->
    <Header />
    <main class="mt-20">
      <!-- Section 1: Hero -->
      <section
        class="relative px-4 md:px-margin-desktop overflow-hidden py-12 md:py-16 bg-white"
      >
        <div
          class="max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-12 gap-12 items-center"
        >
          <!-- Left content column -->
          <div class="z-10 lg:col-span-7 flex flex-col gap-6">
            <!-- Premium Pill Badge -->
            <div
              class="inline-flex items-center gap-2.5 px-4 py-1.5 bg-sky-50 border border-sky-100 text-sky-700 rounded-full w-fit text-xs font-semibold shadow-sm backdrop-blur-sm"
            >
              <span class="relative flex h-2 w-2">
                <span
                  class="animate-ping absolute inline-flex h-full w-full rounded-full bg-sky-400 opacity-75"
                ></span>
                <span
                  class="relative inline-flex rounded-full h-2 w-2 bg-sky-500"
                ></span>
              </span>
              <span
                class="tracking-wider uppercase font-bold text-[10px] sm:text-xs"
                >Career Acceleration Program</span
              >
            </div>

            <h1
              class="text-4xl font-bold text-slate-900 tracking-tight"
              set:html={hero.headline}
            />
            <p class="text-lg max-w-xl leading-relaxed">
              {hero.description}
            </p>

            <ul
              class="grid grid-cols-1 sm:grid-cols-2 gap-y-3 gap-x-6 text-sm font-medium"
            >
              <li class="flex items-center gap-3">
                <span
                  class="material-symbols-outlined text-sky-600 text-lg flex-shrink-0"
                  >check_circle</span
                >
                <span>6-Month Immersive Track</span>
              </li>
              <li class="flex items-center gap-3">
                <span
                  class="material-symbols-outlined text-sky-600 text-lg flex-shrink-0"
                  >check_circle</span
                >
                <span>Live Virtual Workshops</span>
              </li>
              <li class="flex items-center gap-3">
                <span
                  class="material-symbols-outlined text-sky-600 text-lg flex-shrink-0"
                  >check_circle</span
                >
                <span>Production-Grade Projects</span>
              </li>
              <li class="flex items-center gap-3">
                <span
                  class="material-symbols-outlined text-sky-600 text-lg flex-shrink-0"
                  >check_circle</span
                >
                <span>Microsoft Exam Voucher</span>
              </li>
              <li class="flex items-center gap-3 sm:col-span-2">
                <span
                  class="material-symbols-outlined text-sky-600 text-lg flex-shrink-0"
                  >check_circle</span
                >
                <span>Corporate Referral & Placement Prep</span>
              </li>
            </ul>

            <div class="flex flex-col sm:flex-row gap-4 mt-4">
              <a
                href="#pricing"
                class="group flex items-center justify-center px-8 py-4 rounded-xl bg-gradient-to-r from-sky-600 to-blue-700 text-white text-sm font-semibold hover:from-sky-500 hover:to-blue-600 hover:scale-[1.02] shadow-lg shadow-sky-600/15 hover:shadow-sky-600/25 active:scale-[0.98] transition-all duration-200 text-center"
              >
                <span>Enroll in Program</span>
                <span
                  class="material-symbols-outlined text-lg ml-2 font-bold transition-transform duration-200 group-hover:translate-x-1"
                  >arrow_forward</span
                >
              </a>
              <a
                href="#curriculum"
                class="group flex items-center justify-center px-8 py-4 rounded-xl text-sky-700 bg-sky-50/50 border border-sky-200/80 hover:bg-sky-50 hover:border-sky-300 hover:scale-[1.02] active:scale-[0.98] transition-all duration-200 font-semibold text-center"
              >
                <span>View Curriculum</span>
              </a>
            </div>
          </div>

          <!-- Right Video Mockup Column (col-5) -->
          <div
            class="relative w-full max-w-2xl mx-auto lg:mx-0 lg:col-span-5 mt-12 lg:mt-0"
          >
            <!-- Glowing background ambient light -->
            <div
              class="absolute -inset-4 bg-gradient-to-tr from-sky-400/20 to-blue-500/30 blur-3xl opacity-85 rounded-full pointer-events-none"
            >
            </div>

            <!-- Device frame wrapper -->
            <div
              class="relative p-1.5 bg-gradient-to-b from-slate-100 via-slate-200/60 to-slate-300 rounded-[24px] shadow-2xl border border-slate-200/30 overflow-hidden group"
            >
              <video
                autoplay
                loop
                muted
                playsinline
                class="relative rounded-[18px] w-full aspect-video object-cover transition-transform duration-700 group-hover:scale-[1.005]"
              >
                <source
                  src="/assets/videos/data%20science%20hero%20section%20video.mp4"
                  type="video/mp4"
                />
                Your browser does not support the video tag.
              </video>
            </div>

            <!-- Floating Stats Card (Glassmorphic) -->
            <div
              class="absolute -bottom-6 -left-6 bg-white/90 backdrop-blur-md p-5 rounded-2xl shadow-xl border border-slate-200/60 max-w-[250px] z-20 hover:scale-105 transition-transform duration-300"
            >
              <div class="flex items-center gap-3 mb-2">
                <div
                  class="w-10 h-10 bg-sky-50 rounded-xl flex items-center justify-center text-sky-600"
                >
                  <span class="material-symbols-outlined text-xl"
                    >trending_up</span
                  >
                </div>
                <span class="text-3xl font-black text-slate-900 tracking-tight"
                  >140%</span
                >
              </div>
              <p class="text-[11px] font-semibold text-slate-500 leading-snug">
                Average salary lift reported by Class of 2023 graduates.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Program Quick Info Bar -->
      <section class="py-6 bg-slate-50 border-b border-slate-200/60">
        <div
          class="max-w-7xl mx-auto px-4 md:px-margin-desktop grid grid-cols-1 md:grid-cols-3 gap-6 items-center text-center md:text-left"
        >
          <!-- Column 1: Duration -->
          <div class="flex items-center gap-4 justify-center md:justify-start">
            <div
              class="w-12 h-12 bg-sky-50 rounded-xl flex items-center justify-center text-sky-600 flex-shrink-0 border border-sky-100/50"
            >
              <span class="material-symbols-outlined text-2xl"
                >calendar_today</span
              >
            </div>
            <div>
              <p
                class="text-[16px] text-slate-400 font-bold uppercase tracking-widest mb-0.5"
              >
                Program Duration
              </p>
              <h4 class="text-base font-bold text-slate-800">
                6-Month Live Program
              </h4>
            </div>
          </div>

          <!-- Column 2: Format -->
          <div
            class="flex items-center gap-4 justify-center md:justify-start border-t md:border-t-0 md:border-x border-slate-200/40 py-4 md:py-0 md:px-8"
          >
            <div
              class="w-12 h-12 bg-sky-50 rounded-xl flex items-center justify-center text-sky-600 flex-shrink-0 border border-sky-100/50"
            >
              <span class="material-symbols-outlined text-2xl">menu_book</span>
            </div>
            <div>
              <p
                class="text-[16px] text-slate-400 font-bold uppercase tracking-widest mb-0.5"
              >
                Learning Format
              </p>
              <h4 class="text-base font-bold text-slate-800">
                Online Interactive Bootcamp
              </h4>
            </div>
          </div>

          <!-- Column 3: Applied Practice -->
          <div
            class="flex items-center gap-4 justify-center md:justify-start md:pl-8"
          >
            <div
              class="w-12 h-12 bg-sky-50 rounded-xl flex items-center justify-center text-sky-600 flex-shrink-0 border border-sky-100/50"
            >
              <span class="material-symbols-outlined text-2xl">work</span>
            </div>
            <div>
              <p
                class="text-[16px] text-slate-400 font-bold uppercase tracking-widest mb-0.5"
              >
                Applied Practice
              </p>
              <h4 class="text-base font-bold text-slate-800">
                Real-World Case Studies
              </h4>
            </div>
          </div>
        </div>
      </section>

      <!-- Section: Program Overview & Key Features -->
      <section class="py-20 bg-white border-b border-slate-100">
        <div class="max-w-7xl mx-auto px-4 md:px-margin-desktop">
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
            <!-- Left Column: Overview -->
            <div class="lg:col-span-5 flex flex-col justify-between gap-6">
              <div class="space-y-4">
                <span
                  class="text-sky-700 font-bold uppercase tracking-widest text-xs"
                  >Overview</span
                >
                <h2
                  class="text-3xl sm:text-4xl font-bold text-slate-900 tracking-tight leading-tight"
                >
                  Why Learn Data Science and AI?
                </h2>
                <p class="text-slate-600 text-base leading-relaxed">
                  AI is changing every industry from healthcare to finance.
                  Organizations require experts who can evaluate data, develop
                  models, automate decisions, and utilize AI-driven solutions.
                  <br /><br />
                  If you are beginning your career, changing industry, or advancing
                  your technical skills, this program prepares you with the practical
                  knowledge employers actively look for.
                </p>
              </div>

              <!-- Pricing / Overview Card -->
              <div
                class="bg-slate-50 p-6 rounded-2xl border border-slate-200/80 shadow-sm space-y-4 mt-4"
              >
                <h4 class="font-bold text-sm text-slate-850">
                  Data Science & AI Program Overview
                </h4>
                <p class="text-xs text-slate-500 leading-relaxed">
                  SkyStates is dedicated to providing the best training in Data
                  Science & AI, and we offer a comprehensive 6-month course
                  developed to transform you into a skilled data scientist or AI
                  expert.
                </p>
                <div class="flex items-baseline gap-2 pt-2">
                  <span class="text-3xl font-black text-sky-700">$2,999</span>
                  <span class="text-xs text-slate-400 font-semibold"
                    >/ 6-Month Program / Online Live</span
                  >
                </div>
                <a
                  href="/checkout?course=Data+Science+%26+AI&type=normal&mode=full"
                  class="block w-full py-3 bg-gradient-to-r from-sky-600 to-blue-700 text-white rounded-xl font-bold text-center text-xs uppercase tracking-wider hover:from-sky-500 hover:to-blue-600 active:scale-[0.98] transition-all duration-200 shadow-md shadow-sky-600/10"
                  >Enroll Today</a
                >
              </div>
            </div>

            <!-- Right Column: Key Features -->
            <div class="lg:col-span-7 space-y-6">
              <div>
                <span
                  class="text-sky-700 font-bold uppercase tracking-widest text-xs"
                  >Core Benefits</span
                >
                <h2
                  class="text-3xl font-bold text-slate-900 tracking-tight mt-1"
                >
                  Key Features
                </h2>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <!-- Feature 1 -->
                <div
                  class="flex gap-3.5 items-start p-5 bg-white rounded-2xl border border-slate-100 shadow-sm hover:border-sky-200 hover:-translate-y-0.5 transition-all duration-300 group"
                >
                  <div
                    class="w-8 h-8 rounded-lg bg-sky-50 flex items-center justify-center text-sky-600 group-hover:bg-sky-600 group-hover:text-white transition-colors duration-300 shrink-0"
                  >
                    <span class="material-symbols-outlined text-lg">badge</span>
                  </div>
                  <div class="text-xs text-slate-500 leading-relaxed">
                    <strong class="text-sm font-bold text-slate-800 block mb-1"
                      >Job Assistance</strong
                    >
                    Job assistance through our in-house recruitment agency.
                  </div>
                </div>
                <!-- Feature 2 -->
                <div
                  class="flex gap-3.5 items-start p-5 bg-white rounded-2xl border border-slate-100 shadow-sm hover:border-sky-200 hover:-translate-y-0.5 transition-all duration-300 group"
                >
                  <div
                    class="w-8 h-8 rounded-lg bg-sky-50 flex items-center justify-center text-sky-600 group-hover:bg-sky-600 group-hover:text-white transition-colors duration-300 shrink-0"
                  >
                    <span class="material-symbols-outlined text-lg"
                      >verified</span
                    >
                  </div>
                  <div class="text-xs text-slate-500 leading-relaxed">
                    <strong class="text-sm font-bold text-slate-800 block mb-1"
                      >Sky States Credentials</strong
                    >
                    Industry-advanced Data Scientist and AI certificate from Sky States.
                  </div>
                </div>
                <!-- Feature 3 -->
                <div
                  class="flex gap-3.5 items-start p-5 bg-white rounded-2xl border border-slate-100 shadow-sm hover:border-sky-200 hover:-translate-y-0.5 transition-all duration-300 group"
                >
                  <div
                    class="w-8 h-8 rounded-lg bg-sky-50 flex items-center justify-center text-sky-600 group-hover:bg-sky-600 group-hover:text-white transition-colors duration-300 shrink-0"
                  >
                    <span class="material-symbols-outlined text-lg"
                      >science</span
                    >
                  </div>
                  <div class="text-xs text-slate-500 leading-relaxed">
                    <strong class="text-sm font-bold text-slate-800 block mb-1"
                      >Applied Projects</strong
                    >
                    Applied projects from multiple domains and industry-relevant projects.
                  </div>
                </div>
                <!-- Feature 4 -->
                <div
                  class="flex gap-3.5 items-start p-5 bg-white rounded-2xl border border-slate-100 shadow-sm hover:border-sky-200 hover:-translate-y-0.5 transition-all duration-300 group"
                >
                  <div
                    class="w-8 h-8 rounded-lg bg-sky-50 flex items-center justify-center text-sky-600 group-hover:bg-sky-600 group-hover:text-white transition-colors duration-300 shrink-0"
                  >
                    <span class="material-symbols-outlined text-lg"
                      >trending_up</span
                    >
                  </div>
                  <div class="text-xs text-slate-500 leading-relaxed">
                    <strong class="text-sm font-bold text-slate-800 block mb-1"
                      >Career Pivot</strong
                    >
                    Program made to begin your journey as a Data Scientist.
                  </div>
                </div>
                <!-- Feature 5 -->
                <div
                  class="flex gap-3.5 items-start p-5 bg-white rounded-2xl border border-slate-100 shadow-sm hover:border-sky-200 hover:-translate-y-0.5 transition-all duration-300 group"
                >
                  <div
                    class="w-8 h-8 rounded-lg bg-sky-50 flex items-center justify-center text-sky-600 group-hover:bg-sky-600 group-hover:text-white transition-colors duration-300 shrink-0"
                  >
                    <span class="material-symbols-outlined text-lg">cloud</span>
                  </div>
                  <div class="text-xs text-slate-500 leading-relaxed">
                    <strong class="text-sm font-bold text-slate-800 block mb-1"
                      >Microsoft Advantage</strong
                    >
                    Expert-level training from Microsoft, industry-recognized certificate
                    from Microsoft.
                  </div>
                </div>
                <!-- Feature 6 -->
                <div
                  class="flex gap-3.5 items-start p-5 bg-white rounded-2xl border border-slate-100 shadow-sm hover:border-sky-200 hover:-translate-y-0.5 transition-all duration-300 group"
                >
                  <div
                    class="w-8 h-8 rounded-lg bg-sky-50 flex items-center justify-center text-sky-600 group-hover:bg-sky-600 group-hover:text-white transition-colors duration-300 shrink-0"
                  >
                    <span class="material-symbols-outlined text-lg"
                      >terminal</span
                    >
                  </div>
                  <div class="text-xs text-slate-500 leading-relaxed">
                    <strong class="text-sm font-bold text-slate-800 block mb-1"
                      >Combined Labs</strong
                    >
                    Combined labs for practical learning experience.
                  </div>
                </div>
                <!-- Feature 7 -->
                <div
                  class="flex gap-3.5 items-start p-5 bg-white rounded-2xl border border-slate-100 shadow-sm hover:border-sky-200 hover:-translate-y-0.5 transition-all duration-300 group"
                >
                  <div
                    class="w-8 h-8 rounded-lg bg-sky-50 flex items-center justify-center text-sky-600 group-hover:bg-sky-600 group-hover:text-white transition-colors duration-300 shrink-0"
                  >
                    <span class="material-symbols-outlined text-lg"
                      >live_tv</span
                    >
                  </div>
                  <div class="text-xs text-slate-500 leading-relaxed">
                    <strong class="text-sm font-bold text-slate-800 block mb-1"
                      >Live Classes</strong
                    >
                    Live classes by faculty of industry experts.
                  </div>
                </div>
                <!-- Feature 8 -->
                <div
                  class="flex gap-3.5 items-start p-5 bg-white rounded-2xl border border-slate-100 shadow-sm hover:border-sky-200 hover:-translate-y-0.5 transition-all duration-300 group"
                >
                  <div
                    class="w-8 h-8 rounded-lg bg-sky-50 flex items-center justify-center text-sky-600 group-hover:bg-sky-600 group-hover:text-white transition-colors duration-300 shrink-0"
                  >
                    <span class="material-symbols-outlined text-lg"
                      >menu_book</span
                    >
                  </div>
                  <div class="text-xs text-slate-500 leading-relaxed">
                    <strong class="text-sm font-bold text-slate-800 block mb-1"
                      >LMS Access</strong
                    >
                    Lifetime access to learning resources via our Learning Management
                    System (LMS).
                  </div>
                </div>
                <!-- Feature 9 -->
                <div
                  class="flex gap-3.5 items-start p-5 bg-white rounded-2xl border border-slate-100 shadow-sm hover:border-sky-200 hover:-translate-y-0.5 transition-all duration-300 group"
                >
                  <div
                    class="w-8 h-8 rounded-lg bg-sky-50 flex items-center justify-center text-sky-600 group-hover:bg-sky-600 group-hover:text-white transition-colors duration-300 shrink-0"
                  >
                    <span class="material-symbols-outlined text-lg">groups</span
                    >
                  </div>
                  <div class="text-xs text-slate-500 leading-relaxed">
                    <strong class="text-sm font-bold text-slate-800 block mb-1"
                      >Personalized Batches</strong
                    >
                    Small batches to make sure every student receives attention and
                    instructions.
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Section: Microsoft DP-900 Prep -->
      <section class="py-20 bg-white border-b border-slate-100">
        <div
          class="max-w-7xl mx-auto px-4 md:px-margin-desktop grid grid-cols-1 lg:grid-cols-2 gap-16 items-center"
        >
          <div class="space-y-6">
            <span
              class="text-sky-700 font-bold uppercase tracking-widest text-xs"
              >Core Validator</span
            >
            <h2
              class="text-3xl sm:text-4xl font-bold text-slate-900 tracking-tight leading-tight"
            >
              Data Science and AI Certification Benefits
            </h2>
            <p class="text-slate-600 text-base leading-relaxed">
              At SkyStates, get certified in data science & AI with the
              Microsoft Azure program and get both Data Science AI and Microsoft
              Azure certificates to improve your career chances. Gain access to
              expert classes and an in-house career assistance program.
            </p>

            <div class="space-y-4">
              <div
                class="flex gap-4 p-5 rounded-2xl bg-slate-50 border border-slate-100 shadow-sm hover:shadow-md transition-shadow duration-300"
              >
                <span
                  class="material-symbols-outlined text-sky-600 text-2xl flex-shrink-0"
                  >workspace_premium</span
                >
                <div>
                  <h4 class="font-bold text-slate-800 text-sm mb-1">
                    Official Exam Voucher
                  </h4>
                  <p class="text-xs text-slate-500 leading-relaxed">
                    One attempt fee covered in your program tuition.
                  </p>
                </div>
              </div>
              <div
                class="flex gap-4 p-5 rounded-2xl bg-slate-50 border border-slate-100 shadow-sm hover:shadow-md transition-shadow duration-300"
              >
                <span
                  class="material-symbols-outlined text-sky-600 text-2xl flex-shrink-0"
                  >school</span
                >
                <div>
                  <h4 class="font-bold text-slate-800 text-sm mb-1">
                    Dedicated Bootcamp Module
                  </h4>
                  <p class="text-xs text-slate-500 leading-relaxed">
                    Focus sessions on Azure relational &amp; non-relational data
                    services.
                  </p>
                </div>
              </div>
            </div>
          </div>

          <div
            class="bg-sky-50/50 rounded-3xl p-2 flex items-center justify-center border border-sky-100/50 relative"
          >
            <img
              loading="lazy"
              decoding="async"
              width="640"
              height="453"
              src="https://skystates.us/wp-content/uploads/2025/12/SAMPLE.png"
              class="w-full h-full object-cover relative z-10"
              alt="Microsoft Azure Data Fundamentals Certificate"
            />
          </div>
        </div>
      </section>

