---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { query } from '../db/sqlite.js';

export const prerender = false;

const { slug } = Astro.params;
const cleanSlug = slug || '';

// Fetch page data from SQLite
let page = null;
try {
  page = await query.get("SELECT * FROM pages WHERE slug = ?", [cleanSlug]);
} catch (err) {
  console.error("Database error retrieving page:", err.message);
}

// 404 Fallback if page is not found or is in draft status
if (!page || (page.status !== 'published' && !Astro.cookies.has('admin_session'))) {
  return Astro.redirect('/404');
}

// Parse block configurations
let blocks = [];
try {
  blocks = JSON.parse(page.content_blocks || '[]');
} catch (e) {
  console.error("Error parsing content blocks:", e);
}

const title = page.meta_title || `${page.title} | Sky States`;
const description = page.meta_description || "Institutional excellence in technology.";
const canonicalURL = page.canonical_url || Astro.url.href;
---

<!DOCTYPE html>
<html class="light" lang="en">
<head>
  <link rel="icon" type="image/png" href="/favicon.png" />
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  
  
  
</head>
<body class="bg-background text-on-background font-body-md overflow-x-hidden pt-16">
  <!-- Dynamic Mega Menu Header -->
  <Header />

  <main class="min-h-[60vh] space-y-16 py-12">
    {blocks.map((block) => {
      switch (block.type) {
        case 'hero':
          return (
            <section class="max-w-7xl mx-auto px-4 md:px-margin-desktop py-16 flex flex-col items-center text-center space-y-8">
              {block.data.badge && (
                <span class="px-3 py-1 text-[10px] font-bold uppercase tracking-wider bg-sky-50 text-primary border border-sky-100 rounded-full">
                  {block.data.badge}
                </span>
              )}
              <h1 class="font-headline-xl text-5xl md:text-6xl font-extrabold text-primary leading-tight max-w-4xl" set:html={block.data.headline}>
              </h1>
              <p class="text-secondary font-body-lg text-lg max-w-2xl leading-relaxed">
                {block.data.subtitle}
              </p>
              {block.data.cta_label && (
                <a href={block.data.cta_url || "#"} class="bg-primary text-white hover:bg-opacity-95 px-8 py-3.5 rounded-lg font-bold text-sm uppercase tracking-wider shadow-md transition-all">
                  {block.data.cta_label}
                </a>
              )}
            </section>
          );

        case 'features':
          return (
            <section class="max-w-7xl mx-auto px-4 py-12">
              <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                {(block.data.items || []).map((item) => (
                  <div class="bg-white p-6 rounded-xl border border-outline-variant/20 shadow-sm space-y-3">
                    <div class="w-12 h-12 rounded-lg bg-sky-50 flex items-center justify-center text-primary">
                      <span class="material-symbols-outlined text-2xl">{item.icon || 'star'}</span>
                    </div>
                    <h3 class="text-lg font-bold text-slate-800">{item.title}</h3>
                    <p class="text-sm text-secondary leading-relaxed">{item.description}</p>
                  </div>
                ))}
              </div>
            </section>
          );

        case 'cta':
          return (
            <section class="max-w-5xl mx-auto px-4 py-8">
              <div class="bg-primary text-white p-12 rounded-2xl text-center space-y-6 shadow-xl relative overflow-hidden">
                <h2 class="text-3xl font-extrabold">{block.data.title || 'Ready to Accelerate Your Career?'}</h2>
                <p class="text-white/80 max-w-xl mx-auto text-sm leading-relaxed">
                  {block.data.description || 'Schedule a call or secure your enrollment tier now to start learning.'}
                </p>
                <div class="flex justify-center gap-4">
                  <a href={block.data.btn_url || '/checkout'} class="bg-white text-primary hover:bg-slate-50 px-6 py-3 rounded-lg font-bold text-xs uppercase tracking-wider transition-all">
                    {block.data.btn_label || 'Enroll Now'}
                  </a>
                </div>
              </div>
            </section>
          );

        case 'faq':
          return (
            <section class="max-w-3xl mx-auto px-4 py-12 space-y-6">
              <h2 class="text-2xl font-bold text-center text-slate-800">Frequently Asked Questions</h2>
              <div class="space-y-4">
                {(block.data.items || []).map((item, idx) => (
                  <details class="bg-white rounded-lg border border-outline-variant/20 p-4 group cursor-pointer">
                    <summary class="font-semibold text-slate-700 flex justify-between items-center list-none">
                      <span>{item.q}</span>
                      <span class="material-symbols-outlined transition-transform group-open:rotate-180">expand_more</span>
                    </summary>
                    <p class="text-sm text-secondary mt-3 leading-relaxed border-t border-outline-variant/10 pt-3">
                      {item.a}
                    </p>
                  </details>
                ))}
              </div>
            </section>
          );

        case 'rich_text':
          return (
            <section class="max-w-3xl mx-auto px-4 py-8 prose prose-slate">
              <div set:html={block.data.content}></div>
            </section>
          );

        default:
          return null;
      }
    })}
  </main>

  <Footer />
</body>
</html>
