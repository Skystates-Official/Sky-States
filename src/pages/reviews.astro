---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

export const prerender = false;

// Data structures for clean rendering
const stats = [
    { value: "4.8/5", label: "Overall Rating" },
    { value: "4.9/5", label: "Learner Satisfaction" },
    { value: "5,000+", label: "Successful Learners" },
    { value: "96%", label: "Career Success Rate" },
];

const categoryTabs = [
    { id: "Transitions", name: "Career Transitions" },
    { id: "DevOps", name: "DevOps and Cloud" },
    { id: "CyberSecurity", name: "Cyber Security" },
    { id: "DataScience", name: "Data Science and AI" },
];

const reviewsData = {
    Transitions: [
        {
            name: "Justin Reed",
            role: "Cloud Engineer",
