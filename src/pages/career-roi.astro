<div class="bg-surface p-10 rounded-[32px] text-on-surface">
<h3 class="font-headline-md mb-6 text-center">Interactive ROI Calculator</h3>

<!-- Salary Slider Control -->
<div class="mb-8 p-4 bg-surface-container rounded-2xl border border-outline-variant/30">
  <div class="flex justify-between items-center mb-3">
    <span class="text-secondary font-label-md">Current Annual Salary</span>
    <span class="font-bold text-primary text-xl" id="slider-salary-display">$120,000</span>
