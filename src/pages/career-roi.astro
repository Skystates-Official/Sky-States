---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>

<html class="scroll-smooth" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Salary Guide &amp; Career ROI | Sky States</title>
<meta name="description" content="Analyze technology salaries, calculate career return-on-investment, and explore career trajectory growth models for senior positions." />
<link rel="canonical" href="https://skystates.us/career-roi" />

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&amp;family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            display: inline-block;
            line-height: 1;
            text-transform: none;
            letter-spacing: normal;
            word-wrap: normal;
            white-space: nowrap;
            direction: ltr;
        }
        .upward-gradient {
            background: linear-gradient(to top, #f9f9f9 0%, #cde5ff 100%);
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(205, 229, 255, 0.5);
        }
    </style>

</head>
<body class="bg-background text-on-surface font-body-md overflow-x-hidden">
<!-- TopAppBar -->
