<!-- FAQ Section Deep Dive -->
<section class="py-section-gap px-margin-mobile md:px-margin-desktop bg-surface">
<div class="max-w-3xl mx-auto">
<div class="text-center mb-16">
<h2 class="font-headline-lg text-on-surface mb-4">Frequently Asked Questions</h2>
<p class="font-body-md text-secondary">Transparency regarding our ROI models and data integrity.</p>
</div>
<div class="space-y-4">
<details class="group bg-white rounded-2xl border border-surface-container overflow-hidden" open="">
<summary class="flex justify-between items-center p-6 cursor-pointer hover:bg-surface-container-low transition-colors list-none">
<span class="font-label-md pr-4">How is the $2,999 price point justified against the coaching market?</span>
<span class="material-symbols-outlined group-open:rotate-180 transition-transform">expand_more</span>
</summary>
<div class="p-6 pt-0 text-on-surface-variant leading-relaxed text-sm">
                        Traditional career coaching focuses on resume reviews. Our $2,999 investment includes executive-level negotiation coaching, legal review of offer letters by employment counsel, and access to proprietary salary bands not available to the public. Most clients recover the entire program cost within their first full month's paycheck after a successful pivot.
                    </div>
</details>
<details class="group bg-white rounded-2xl border border-surface-container overflow-hidden">
<summary class="flex justify-between items-center p-6 cursor-pointer hover:bg-surface-container-low transition-colors list-none">
<span class="font-label-md pr-4">Where does your specific salary data come from?</span>
<span class="material-symbols-outlined group-open:rotate-180 transition-transform">expand_more</span>
</summary>
<div class="p-6 pt-0 text-on-surface-variant leading-relaxed text-sm">
                        We synthesize data from three primary streams: 1) Verified U.S. BLS and international equivalent government datasets, 2) LinkedIn Talent Insights premium enterprise data, and 3) Anonymized internal data from over 2,500 successful client placements in 2023-2024.
                    </div>
</details>
<details class="group bg-white rounded-2xl border border-surface-container overflow-hidden">
<summary class="flex justify-between items-center p-6 cursor-pointer hover:bg-surface-container-low transition-colors list-none">
<span class="font-label-md pr-4">Is the ROI figure guaranteed?</span>
<span class="material-symbols-outlined group-open:rotate-180 transition-transform">expand_more</span>
</summary>
<div class="p-6 pt-0 text-on-surface-variant leading-relaxed text-sm">
                        While we cannot legally guarantee specific employment outcomes, our methodology is designed around "asymmetric advantage." If your initial offer does not represent at least a 15% increase over your current market value, we provide a secondary intensive support phase at no additional cost.
                    </div>
</details>
<details class="group bg-white rounded-2xl border border-surface-container overflow-hidden">
<summary class="flex justify-between items-center p-6 cursor-pointer hover:bg-surface-container-low transition-colors list-none">
<span class="font-label-md pr-4">Does the program cover international tax implications for remote roles?</span>
<span class="material-symbols-outlined group-open:rotate-180 transition-transform">expand_more</span>
</summary>
<div class="p-6 pt-0 text-on-surface-variant leading-relaxed text-sm">
                        Yes. Part of our negotiation intelligence includes "Local Market Normalization." We help you understand the true value of an offer by factoring in regional tax brackets and cost-of-living adjustments for global remote opportunities.
                    </div>
</details>
</div>
</div>
</section>
<!-- Disclaimer -->
<section class="pb-section-gap px-margin-mobile">
<div class="max-w-4xl mx-auto text-center opacity-60">
<p class="text-label-sm leading-relaxed">
                Disclaimer: Individual outcomes vary. Salary data is based on industry benchmarks and internal client success history. We do not guarantee specific employment offers or salary figures. Your results will depend on your personal experience, interview performance, and current market conditions.
            </p>
</div>
</section>
</main>
<!-- Footer -->
<Footer />
<script>
    // Visibility observer for scroll animations
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('opacity-100', 'translate-y-0');
                entry.target.classList.remove('opacity-0', 'translate-y-10');
            }
        });
    }, { threshold: 0.1 });

    document.querySelectorAll('section > div').forEach(section => {
        section.classList.add('transition-[opacity,transform]', 'duration-1000', 'opacity-0', 'translate-y-10');
        observer.observe(section);
    });

    // ROI Salary Slider Logic
    const slider = document.getElementById('salary-slider');
    const salaryDisplay = document.getElementById('slider-salary-display');
    const jumpDisplay = document.getElementById('roi-salary-jump');
    const bonusDisplay = document.getElementById('roi-bonus');
    const equityDisplay = document.getElementById('roi-equity');
    const netDisplay = document.getElementById('roi-net-value');
    const ratioDisplay = document.getElementById('roi-ratio');
    const barDisplay = document.getElementById('roi-bar');

    function updateRoi() {
        if (!slider) return;
        const currentSalary = parseInt(slider.value, 10);
        
        const jump = Math.round(currentSalary * 0.35);
        const bonus = Math.round(currentSalary * 0.10);
        const equity = Math.round(currentSalary * 0.20);
        const totalValue = (jump + bonus + equity) - 2999;
        const ratio = (totalValue / 2999).toFixed(1);

        salaryDisplay.textContent = '$' + currentSalary.toLocaleString();
        jumpDisplay.textContent = '+$' + jump.toLocaleString();
        bonusDisplay.textContent = '+$' + bonus.toLocaleString();
        equityDisplay.textContent = '+$' + equity.toLocaleString();
        netDisplay.textContent = '$' + totalValue.toLocaleString();
        ratioDisplay.textContent = ratio + 'x';

        const percentage = Math.min(100, Math.max(10, (totalValue / 150000) * 100));
        barDisplay.style.width = percentage + '%';
    }

    slider?.addEventListener('input', updateRoi);
    updateRoi();
</script>
</body></html>